@page "/share/{Token}"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

@using Dam.Ui.Services
@using Dam.Ui.Components
@using System.Net.Http.Json
@using Microsoft.Extensions.Logging

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ILogger<Share> Logger
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<SharesResource> ShareLoc

<PageTitle>@ShareLoc["SharedContent"] - @CommonLoc["AppName"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">@ShareLoc["LoadingSharedContent"]</MudText>
        </MudStack>
    }
    else if (_requiresPassword)
    {
        <MudPaper Class="pa-6 mx-auto" MaxWidth="400px" Elevation="2">
            <MudStack Spacing="4">
                <MudStack AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h5">@ShareLoc["PasswordRequired"]</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @ShareLoc["PasswordProtected"]
                    </MudText>
                </MudStack>
                
                <MudTextField @bind-Value="_password"
                              Label="@CommonLoc["Label_Password"]"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Immediate="true"
                              OnKeyDown="@OnPasswordKeyDown" />
                
                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                }
                
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="SubmitPassword"
                           Disabled="_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @CommonLoc["Btn_AccessContent"]
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else if (_errorMessage != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            <MudText Typo="Typo.body1">@_errorMessage</MudText>
        </MudAlert>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/">
            @CommonLoc["Btn_GoToHome"]
        </MudButton>
    }
    else if (_sharedAsset != null)
    {
        <!-- Shared Asset View - Two Column Layout -->
        <MudGrid>
            <!-- Preview Area -->
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-4" Elevation="1">
                    @if (_sharedAsset.AssetType == "image")
                    {
                        <MudImage Src="@GetPreviewUrl()"
                                  Alt="@_sharedAsset.Title"
                                  ObjectFit="ObjectFit.Contain"
                                  Style="width: 100%; max-height: 600px;"
                                  Class="rounded" />
                    }
                    else if (_sharedAsset.AssetType == "video")
                    {
                        <video controls poster="@GetPosterUrl()" style="width: 100%; max-height: 600px;">
                            <source src="@GetPreviewUrl()" type="@_sharedAsset.ContentType">
                            @CommonLoc["Text_BrowserNoVideo"]
                        </video>
                    }
                    else if (AssetDisplayHelpers.IsPdfContentType(_sharedAsset.ContentType))
                    {
                        <iframe src="@GetPreviewUrl()" 
                                style="width: 100%; height: 600px; border: none;" 
                                title="@_sharedAsset.Title">
                        </iframe>
                    }
                    else
                    {
                        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Primary" />
                            <MudText Typo="Typo.h6">@_sharedAsset.Title</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @CommonLoc["Text_PreviewNotAvailable"]
                            </MudText>
                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.Download"
                                       Href="@GetDownloadUrl()"
                                       Target="_blank"
                                       Class="mt-2">
                                @CommonLoc["Btn_DownloadToView"]
                            </MudButton>
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>

            <!-- Details Panel -->
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudStack Spacing="3">
                        <!-- Title and Type -->
                        <MudStack>
                            <MudText Typo="Typo.h5">@_sharedAsset.Title</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetAssetTypeColor(_sharedAsset.AssetType)" Style="width: fit-content;">
                                @_sharedAsset.AssetType.ToUpperInvariant()
                            </MudChip>
                        </MudStack>

                        <MudDivider />

                        <!-- Description -->
                        @if (!string.IsNullOrEmpty(_sharedAsset.Description))
                        {
                            <MudStack>
                                <MudText Typo="Typo.subtitle2">@CommonLoc["Label_Description"]</MudText>
                                <MudText Typo="Typo.body2">@_sharedAsset.Description</MudText>
                            </MudStack>
                        }

                        <!-- File Information -->
                        <MudStack>
                            <MudText Typo="Typo.subtitle2">@CommonLoc["Text_FileInformation"]</MudText>
                            <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                <tbody>
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Label_Size"]</MudText></td>
                                        <td><MudText Typo="Typo.body2">@AssetDisplayHelpers.FormatFileSize(_sharedAsset.SizeBytes)</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Label_Type"]</MudText></td>
                                        <td><MudText Typo="Typo.body2">@_sharedAsset.ContentType</MudText></td>
                                    </tr>
                                </tbody>
                            </MudSimpleTable>
                        </MudStack>

                        <!-- Advanced Metadata -->
                        <MudDivider />
                        <MudStack>
                            <MudExpansionPanels Elevation="0" Style="margin: -16px; padding: 0;">
                                <MudExpansionPanel MaxHeight="400"
                                                   Style="background: transparent; padding: 0;"
                                                   Class="pa-0 ma-0">
                                    <TitleContent>
                                        <MudText Typo="Typo.subtitle2" Style="margin-left: -8px;">@CommonLoc["Text_AdvancedMetadata"]</MudText>
                                    </TitleContent>
                                    <ChildContent>
                                        @if (_sharedAsset.MetadataJson.Any())
                                        {
                                            <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                                <tbody>
                                                    @foreach (var kvp in _sharedAsset.MetadataJson.OrderBy(k => k.Key))
                                                    {
                                                        <tr>
                                                            <td><MudText Typo="Typo.body2" Color="Color.Secondary">@AssetDisplayHelpers.FormatMetadataKey(kvp.Key)</MudText></td>
                                                            <td><MudText Typo="Typo.body2">@kvp.Value?.ToString()</MudText></td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </MudSimpleTable>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                @CommonLoc["Text_NoMetadata"]
                                            </MudText>
                                        }
                                    </ChildContent>
                                </MudExpansionPanel>
                            </MudExpansionPanels>
                        </MudStack>

                        <MudDivider />

                        <!-- Download Button -->
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   FullWidth="true"
                                   OnClick="@(() => DownloadAsset(null))">
                            @CommonLoc["Btn_DownloadOriginal"]
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else if (_sharedCollection != null)
    {
        @if (_selectedAsset != null)
        {
            <!-- Selected Asset Detail View - Two Column Layout -->
            <MudButton Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => _selectedAsset = null)"
                       Class="mb-3">
                @CommonLoc["Btn_BackToCollection"]
            </MudButton>

            <MudGrid>
                <!-- Preview Area -->
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-4" Elevation="1">
                        @if (_selectedAsset.AssetType == "image")
                        {
                            <MudImage Src="@GetAssetPreviewUrl(_selectedAsset.Id)"
                                      Alt="@_selectedAsset.Title"
                                      ObjectFit="ObjectFit.Contain"
                                      Style="width: 100%; max-height: 600px;"
                                      Class="rounded" />
                        }
                        else if (_selectedAsset.AssetType == "video")
                        {
                            <video controls poster="@GetAssetPosterUrl(_selectedAsset.Id)" style="width: 100%; max-height: 600px;">
                                <source src="@GetAssetPreviewUrl(_selectedAsset.Id)" type="@_selectedAsset.ContentType">
                                @CommonLoc["Text_BrowserNoVideo"]
                            </video>
                        }
                        else
                        {
                            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Primary" />
                                <MudText Typo="Typo.h6">@_selectedAsset.Title</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @CommonLoc["Text_DocumentPreviewNotAvailable"]
                                </MudText>
                            </MudStack>
                        }
                    </MudPaper>
                </MudItem>

                <!-- Details Panel -->
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudStack Spacing="3">
                            <!-- Title and Type -->
                            <MudStack>
                                <MudText Typo="Typo.h5">@_selectedAsset.Title</MudText>
                                <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetAssetTypeColor(_selectedAsset.AssetType)" Style="width: fit-content;">
                                    @_selectedAsset.AssetType.ToUpperInvariant()
                                </MudChip>
                            </MudStack>

                            <MudDivider />

                            <!-- Description -->
                            @if (!string.IsNullOrEmpty(_selectedAsset.Description))
                            {
                                <MudStack>
                                    <MudText Typo="Typo.subtitle2">@CommonLoc["Label_Description"]</MudText>
                                    <MudText Typo="Typo.body2">@_selectedAsset.Description</MudText>
                                </MudStack>
                            }

                            <!-- File Information -->
                            <MudStack>
                                <MudText Typo="Typo.subtitle2">@CommonLoc["Text_FileInformation"]</MudText>
                                <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                    <tbody>
                                        <tr>
                                            <td><MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Label_Size"]</MudText></td>
                                            <td><MudText Typo="Typo.body2">@AssetDisplayHelpers.FormatFileSize(_selectedAsset.SizeBytes)</MudText></td>
                                        </tr>
                                        <tr>
                                            <td><MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Label_Type"]</MudText></td>
                                            <td><MudText Typo="Typo.body2">@_selectedAsset.ContentType</MudText></td>
                                        </tr>
                                    </tbody>
                                </MudSimpleTable>
                            </MudStack>

                            <!-- Advanced Metadata -->
                            <MudDivider />
                            <MudStack>
                                <MudExpansionPanels Elevation="0" Style="margin: -16px; padding: 0;">
                                    <MudExpansionPanel MaxHeight="400"
                                                       Style="background: transparent; padding: 0;"
                                                       Class="pa-0 ma-0">
                                        <TitleContent>
                                            <MudText Typo="Typo.subtitle2" Style="margin-left: -8px;">@CommonLoc["Text_AdvancedMetadata"]</MudText>
                                        </TitleContent>
                                        <ChildContent>
                                            @if (_selectedAsset.MetadataJson.Any())
                                            {
                                                <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                                    <tbody>
                                                        @foreach (var kvp in _selectedAsset.MetadataJson.OrderBy(k => k.Key))
                                                        {
                                                            <tr>
                                                                <td><MudText Typo="Typo.body2" Color="Color.Secondary">@AssetDisplayHelpers.FormatMetadataKey(kvp.Key)</MudText></td>
                                                                <td><MudText Typo="Typo.body2">@kvp.Value?.ToString()</MudText></td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </MudSimpleTable>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                    @CommonLoc["Text_NoMetadata"]
                                                </MudText>
                                            }
                                        </ChildContent>
                                    </MudExpansionPanel>
                                </MudExpansionPanels>
                            </MudStack>

                            <MudDivider />

                            <!-- Download Button -->
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Download"
                                       FullWidth="true"
                                       OnClick="@(() => DownloadAsset(_selectedAsset.Id))">
                                @CommonLoc["Btn_DownloadOriginal"]
                            </MudButton>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
        else
        {
            <!-- Shared Collection View -->
            <MudPaper Class="pa-4 mb-4" Elevation="1">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack>
                        <MudText Typo="Typo.h5">@_sharedCollection.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @_sharedCollection.Assets.Count assets
                        </MudText>
                    </MudStack>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Download"
                               OnClick="DownloadAllAssets">
                        @CommonLoc["Btn_DownloadAll"]
                    </MudButton>
                </MudStack>
                @if (!string.IsNullOrEmpty(_sharedCollection.Description))
                {
                    <MudText Typo="Typo.body1" Class="mt-2">@_sharedCollection.Description</MudText>
                }
            </MudPaper>

            <MudGrid Spacing="3">
                @if (_sharedCollection.Assets.Count == 0)
                {
                    <MudItem xs="12">
                        <EmptyState Title="@ShareLoc["NoAssetsInCollection"]"
                                    Description="@ShareLoc["EmptyCollectionDesc"]"
                                    Icon="@Icons.Material.Filled.FolderOff" />
                    </MudItem>
                }
                else
                {
                    @foreach (var asset in _sharedCollection.Assets)
                    {
                        <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudCard Elevation="2" Class="cursor-pointer" Style="cursor: pointer;" @onclick="@(() => SelectAsset(asset))">
                            <MudCardMedia Image="@GetCollectionThumbnailUrl(asset)"
                                          Height="160" />
                            <MudCardContent Class="pa-2">
                                <MudText Typo="Typo.body2" Class="text-truncate">@asset.Title</MudText>
                                <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetAssetTypeColor(asset.AssetType)" Variant="Variant.Outlined">
                                    @asset.AssetType
                                </MudChip>
                            </MudCardContent>
                            <MudCardActions Class="pa-2 pt-0" @onclick:stopPropagation="true">
                                <MudButton Variant="Variant.Text"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Download"
                                           OnClick="@(() => DownloadAsset(asset.Id))">
                                    @CommonLoc["Btn_Download"]
                                </MudButton>
                                <MudButton Variant="Variant.Text"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Visibility"
                                           OnClick="@(() => SelectAsset(asset))">
                                    @CommonLoc["Btn_View"]
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                    }
                }
            </MudGrid>
        }
    }
</MudContainer>

@code {
    [Parameter]
    public string Token { get; set; } = "";

    private bool _isLoading = true;
    private bool _requiresPassword = false;
    private bool _isSubmitting = false;
    private string _password = "";
    private string? _error;
    private string? _errorMessage;

    private SharedAssetDto? _sharedAsset;
    private SharedCollectionDto? _sharedCollection;
    private SharedAssetDto? _selectedAsset;

    private IJSObjectReference? _jsModule;

    protected override async Task OnInitializedAsync()
    {
        _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Dam.Ui/js/helpers.js");
        await LoadSharedContent();
    }

    private async Task LoadSharedContent(string? password = null)
    {
        try
        {
            _isLoading = true;
            _error = null;

            var response = await Api.GetSharedContentAsync(Token, password);

            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                // Check if it requires password
                var authContent = await response.Content.ReadFromJsonAsync<PasswordRequiredResponse>();
                if (authContent?.RequiresPassword == true)
                {
                    _requiresPassword = true;
                    _isLoading = false;
                    return;
                }
                _error = ShareLoc["InvalidPassword"];
                _isLoading = false;
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                _errorMessage = response.StatusCode switch
                {
                    System.Net.HttpStatusCode.NotFound => ShareLoc["InvalidOrRemoved"],
                    System.Net.HttpStatusCode.BadRequest => error.Contains("expired") 
                        ? ShareLoc["LinkExpired"] 
                        : error.Contains("revoked") 
                            ? ShareLoc["LinkRevoked"]
                            : ShareLoc["UnableToAccess"],
                    _ => ShareLoc["ErrorLoading"]
                };
                _isLoading = false;
                return;
            }

            // The API returns either SharedAssetDto or SharedCollectionDto
            // We can distinguish by checking if it has "Name" (collection) or "Title" (asset)
            var jsonString = await response.Content.ReadAsStringAsync();
            
            if (jsonString.Contains("\"name\"", StringComparison.OrdinalIgnoreCase) && 
                jsonString.Contains("\"assets\"", StringComparison.OrdinalIgnoreCase))
            {
                // It's a collection
                _sharedCollection = System.Text.Json.JsonSerializer.Deserialize<SharedCollectionDto>(jsonString, 
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                _requiresPassword = false;
            }
            else
            {
                // It's an asset
                _sharedAsset = System.Text.Json.JsonSerializer.Deserialize<SharedAssetDto>(jsonString,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                _requiresPassword = false;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ShareLoc["FailedToLoad"];
            Logger.LogError(ex, "Error loading shared content for token {Token}", Token);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SubmitPassword()
    {
        if (string.IsNullOrEmpty(_password))
        {
            _error = CommonLoc["Validation_EnterPassword"];
            return;
        }

        _isSubmitting = true;
        _error = null;

        await LoadSharedContent(_password);

        if (_requiresPassword)
        {
            _error = ShareLoc["InvalidPassword"];
        }

        _isSubmitting = false;
    }

    private async Task OnPasswordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitPassword();
        }
    }

    private string GetPreviewUrl()
    {
        if (_sharedAsset == null) return "";

        var escapedToken = Uri.EscapeDataString(Token);

        // For PDFs and videos/audio, use the preview endpoint without size
        // so the server returns the original file for inline display / playback.
        if (AssetDisplayHelpers.IsPdfContentType(_sharedAsset.ContentType)
            || _sharedAsset.AssetType == "video"
            || _sharedAsset.AssetType == "audio")
        {
            var url = $"/api/shares/{escapedToken}/preview";
            if (!string.IsNullOrEmpty(_password))
                url += $"?password={Uri.EscapeDataString(_password)}";
            return url;
        }

        // For images / other types, use the rendition URL (medium → thumb → download)
        var previewUrl = _sharedAsset.MediumUrl ?? _sharedAsset.ThumbnailUrl
                         ?? $"/api/shares/{escapedToken}/download";
        return AppendPassword(previewUrl);
    }

    /// <summary>Returns a poster/thumbnail URL for the single shared-asset video element.</summary>
    private string GetPosterUrl()
    {
        if (_sharedAsset == null) return "";
        var url = _sharedAsset.MediumUrl ?? _sharedAsset.ThumbnailUrl ?? "";
        return string.IsNullOrEmpty(url) ? url : AppendPassword(url);
    }

    private string GetAssetPreviewUrl(Guid assetId)
    {
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/preview?assetId={assetId}";
        if (!string.IsNullOrEmpty(_password))
            url += $"&password={Uri.EscapeDataString(_password)}";
        return url;
    }

    /// <summary>Returns a poster/thumbnail URL for a collection-asset video element.</summary>
    private string GetAssetPosterUrl(Guid assetId)
    {
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/preview?assetId={assetId}&size=medium";
        if (!string.IsNullOrEmpty(_password))
            url += $"&password={Uri.EscapeDataString(_password)}";
        return url;
    }

    /// <summary>Appends the share password as a query parameter when present.</summary>
    private string AppendPassword(string url)
    {
        if (string.IsNullOrEmpty(_password)) return url;
        var separator = url.Contains('?') ? '&' : '?';
        return $"{url}{separator}password={Uri.EscapeDataString(_password)}";
    }

    /// <summary>Returns a thumbnail URL for the collection grid card, with password and medium fallback.</summary>
    private string GetCollectionThumbnailUrl(SharedAssetDto asset)
    {
        var url = asset.ThumbnailUrl ?? asset.MediumUrl;
        if (string.IsNullOrEmpty(url))
            return AssetDisplayHelpers.GetPlaceholderForType(asset.AssetType);
        return AppendPassword(url);
    }

    private string GetDownloadUrl()
    {
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/download";
        if (!string.IsNullOrEmpty(_password))
        {
            url += $"?password={Uri.EscapeDataString(_password)}";
        }
        return url;
    }

    private void SelectAsset(SharedAssetDto asset)
    {
        _selectedAsset = asset;
    }

    private async Task DownloadAllAssets()
    {
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/download-all";
        if (!string.IsNullOrEmpty(_password))
            url += $"?password={Uri.EscapeDataString(_password)}";

        if (_jsModule != null)
            await _jsModule.InvokeVoidAsync("downloadViaAnchor", url);
    }

    private async Task DownloadAsset(Guid? assetId)
    {
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/download";
        var queryParams = new List<string>();
        
        if (assetId.HasValue)
            queryParams.Add($"assetId={assetId.Value}");
        if (!string.IsNullOrEmpty(_password))
            queryParams.Add($"password={Uri.EscapeDataString(_password)}");
        
        if (queryParams.Count > 0)
            url += "?" + string.Join("&", queryParams);

        if (_jsModule != null)
            await _jsModule.InvokeVoidAsync("downloadViaAnchor", url);
    }
}
