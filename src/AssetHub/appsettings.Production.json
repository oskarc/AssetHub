{
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "Keycloak": {
    "RequireHttpsMetadata": true,
    "TimeoutSeconds": 30
  },
  "MinIO": {
    "UseSSL": true
  },
  "Email": {
    "UseSsl": true,
    "Enabled": true
  }
}
