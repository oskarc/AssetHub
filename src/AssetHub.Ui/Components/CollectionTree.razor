@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CollectionsResource> CollectionLoc

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!_treeItems.Any())
{
    <EmptyState Title="@CollectionLoc["NoCollectionsYet"]"
                Description="@CollectionLoc["CreateFirstHint"]"
                Icon="@Icons.Material.Filled.Folder" />
}
else
{
    <MudNavMenu>
        @foreach (var item in _treeItems)
        {
            <MudNavLink Icon="@(item.HasChildren ? Icons.Material.Filled.FolderOpen : Icons.Material.Filled.Folder)"
                        Style="@(item.Depth > 0 ? $"margin-left: {item.Depth * 20}px;" : null)"
                        Class="@(SelectedCollectionId == item.Collection.Id ? "mud-nav-link-active" : null)"
                        @onclick="@(() => OnCollectionSelected.InvokeAsync(item.Collection.Id))">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <span>@item.Collection.Name</span>
                        @if (item.Collection.InheritParentAcl)
                        {
                            <MudTooltip Text="@CollectionLoc["Inheriting_RowTag"]">
                                <MudIcon Icon="@Icons.Material.Filled.Link"
                                         Size="Size.Small"
                                         Color="Color.Tertiary" />
                            </MudTooltip>
                        }
                    </MudStack>
                    @if (item.Collection.AssetCount > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@item.Collection.AssetCount</MudChip>
                    }
                </MudStack>
            </MudNavLink>
        }
    </MudNavMenu>
}

@code {
    /// <summary>The ID of the currently selected collection, used to highlight the active item.</summary>
    [Parameter]
    public Guid? SelectedCollectionId { get; set; }

    /// <summary>Fires when the user clicks a collection item.</summary>
    [Parameter]
    public EventCallback<Guid?> OnCollectionSelected { get; set; }

    private sealed record CollectionTreeItem(CollectionResponseDto Collection, int Depth, bool HasChildren);

    private List<CollectionTreeItem> _treeItems = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var all = await Api.GetCollectionsAsync();
            _treeItems = BuildTreeItems(all);
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collections");
        }
        finally
        {
            _loading = false;
        }
    }

    private static List<CollectionTreeItem> BuildTreeItems(List<CollectionResponseDto> all)
    {
        var allIds = new HashSet<Guid>(all.Select(c => c.Id));
        var byParent = all
            .Where(c => c.ParentCollectionId is not null && allIds.Contains(c.ParentCollectionId.Value))
            .GroupBy(c => c.ParentCollectionId!.Value)
            .ToDictionary(g => g.Key, g => g.OrderBy(x => x.Name).ToList());

        // Collections whose parent is absent from the loaded set appear as roots
        // (happens when the user has access to a child but not its parent).
        var roots = all
            .Where(c => c.ParentCollectionId is null || !allIds.Contains(c.ParentCollectionId.Value))
            .OrderBy(c => c.Name)
            .ToList();

        var result = new List<CollectionTreeItem>(all.Count);

        void Walk(CollectionResponseDto c, int depth)
        {
            var hasChildren = byParent.ContainsKey(c.Id);
            result.Add(new CollectionTreeItem(c, depth, hasChildren));
            if (hasChildren)
                foreach (var child in byParent[c.Id])
                    Walk(child, depth + 1);
        }

        foreach (var root in roots)
            Walk(root, 0);

        return result;
    }
}
