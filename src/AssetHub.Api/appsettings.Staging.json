{
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Hangfire": "Warning"
      }
    }
  },
  "Keycloak": {
    "RequireHttpsMetadata": true,
    "TimeoutSeconds": 30
  },
  "MinIO": {
    "UseSSL": true
  },
  "Email": {
    "FromName": "AssetHub (Staging)",
    "Enabled": true
  }
}
