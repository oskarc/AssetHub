@using AssetHub.Application.Dtos
@using AssetHub.Application.Helpers
@using AssetHub.Ui.Services

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AssetsResource> AssetLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.PlaylistAdd" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@AssetLoc["SelectCollectionToAdd"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="dialog-min-width">
            @if (_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="py-4">
                    <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                </MudStack>
            }
            else if (!_availableCollections.Any())
            {
                <MudAlert Severity="Severity.Info">
                    @AssetLoc["NoAdditionalCollections"]
                </MudAlert>
            }
            else
            {
                <MudSelect T="Guid?"
                           @bind-Value="_selectedCollectionId"
                           Label="@CommonLoc["Label_Collection"].Value"
                           Variant="Variant.Outlined"
                           AutoFocus="true"
                           AnchorOrigin="Origin.BottomLeft"
                           TransformOrigin="Origin.TopLeft"
                           FullWidth="true">
                    @foreach (var collection in _availableCollections)
                    {
                        <MudSelectItem T="Guid?" Value="@collection.Id">
                            @collection.Name
                        </MudSelectItem>
                    }
                </MudSelect>
                
                @if (_selectedCollectionId.HasValue)
                {
                    var selected = _availableCollections.FirstOrDefault(c => c.Id == _selectedCollectionId.Value);
                    @if (selected != null && !string.IsNullOrEmpty(selected.Description))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @selected.Description
                        </MudText>
                    }
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CommonLoc["Btn_Cancel"]</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled"
                   OnClick="AddToCollectionAsync"
                   Disabled="@(!_selectedCollectionId.HasValue || _isSubmitting)">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @CommonLoc["Btn_Add"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid AssetId { get; set; }

    [Parameter]
    public List<Guid> ExistingCollectionIds { get; set; } = new();

    private List<CollectionResponseDto> _availableCollections = new();
    private Guid? _selectedCollectionId;
    private bool _isLoading = true;
    private bool _isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableCollectionsAsync();
    }

    private async Task LoadAvailableCollectionsAsync()
    {
        try
        {
            _isLoading = true;
            var allCollections = await Api.GetCollectionsAsync();
            
            // Filter out collections the asset already belongs to
            _availableCollections = allCollections
                .Where(c => !ExistingCollectionIds.Contains(c.Id))
                .OrderBy(c => c.Name, new NaturalSortComparer())
                .ToList();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collections");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AddToCollectionAsync()
    {
        if (!_selectedCollectionId.HasValue) return;

        try
        {
            _isSubmitting = true;
            await Api.AddAssetToCollectionAsync(AssetId, _selectedCollectionId.Value);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "add to collection");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
