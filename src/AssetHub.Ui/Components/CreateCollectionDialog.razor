@using AssetHub.Application.Dtos
@using AssetHub.Ui.Services
@using MudBlazor

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<CollectionsResource> CollectionLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="dialog-title">
            <MudIcon Icon="@Icons.Material.Filled.CreateNewFolder" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@CollectionLoc["CreateCollection"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Class="dialog-intro">
                @CollectionLoc["CreateCollectionDesc"]
            </MudText>

            <MudForm @ref="_form" @bind-IsValid="_isValid">
                <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                    <MudTextField @bind-Value="_name"
                                  Label="@CollectionLoc["CollectionName"]"
                                  Required="true"
                                  RequiredError="@CollectionLoc["Validation_NameRequired"]"
                                  Immediate="true"
                                  Variant="Variant.Outlined"
                                  AutoFocus="true"
                                  Class="mb-2" />

                    <MudTextField @bind-Value="_description"
                                  Label="@CollectionLoc["DescriptionOptional"]"
                                  Lines="3"
                                  Variant="Variant.Outlined" />
                </MudPaper>
            </MudForm>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CommonLoc["Btn_Cancel"]</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled"
                   OnClick="CreateAsync"
                   Disabled="@(!_isValid || _isCreating)">
            @if (_isCreating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @CommonLoc["Btn_Create"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm? _form;
    private string _name = "";
    private string _description = "";
    private bool _isValid;
    private bool _isCreating;

    private void Cancel() => MudDialog.Cancel();

    private async Task CreateAsync()
    {
        if (_form != null)
        {
            await _form.Validate();
            if (!_isValid) return;
        }

        try
        {
            _isCreating = true;

            var dto = new CreateCollectionDto
            {
                Name = _name,
                Description = InputValidation.NormalizeToNull(_description)
            };

            var result = await Api.CreateCollectionAsync(dto);

            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "create collection");
        }
        finally
        {
            _isCreating = false;
        }
    }
}
