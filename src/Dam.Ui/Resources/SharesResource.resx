  <data name="ShareLinkCreated" xml:space="preserve"><value>Share Link Created</value></data>
  <data name="CreatedSuccess" xml:space="preserve"><value>Your share link has been created successfully!</value></data>
  <data name="PasswordProtectedWarning" xml:space="preserve"><value>This link is password protected. Share the password securely with recipients.</value></data>
