{
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  },
  "Keycloak": {
    "RequireHttpsMetadata": false,
    "TimeoutSeconds": 30
  },
  "MinIO": {
    "UseSSL": false,
    "PublicUseSSL": false
  },
  "Email": {
    "SmtpHost": "mailpit",
    "SmtpPort": 1025,
    "UseSsl": false,
    "FromAddress": "noreply@assethub.local",
    "FromName": "AssetHub (Dev)",
    "Enabled": true
  },
  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "http://jaeger:4317",
    "SamplingRatio": 1.0
  }
}
