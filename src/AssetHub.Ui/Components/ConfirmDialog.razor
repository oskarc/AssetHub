@inject IStringLocalizer<CommonResource> CommonLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="@TitleClass">
            <MudIcon Icon="@TitleIcon" Color="@IconColor" />
            <MudText Typo="Typo.h6">@Title</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="dialog-min-width">
            <MudText Typo="Typo.body1" Class="@($"dialog-intro {IntroClass}")">@Message</MudText>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@(CancelText ?? CommonLoc["Btn_Cancel"])</MudButton>
        <MudButton Color="@ConfirmColor" Variant="Variant.Filled" OnClick="Confirm">
            @ConfirmText
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public string TitleIcon { get; set; } = Icons.Material.Filled.Warning;
    [Parameter] public Color IconColor { get; set; } = Color.Warning;
    [Parameter] public string ConfirmText { get; set; } = "Confirm";
    [Parameter] public string? CancelText { get; set; }
    [Parameter] public Color ConfirmColor { get; set; } = Color.Primary;

    private string TitleClass => IconColor switch
    {
        Color.Error => "dialog-title-danger",
        Color.Success => "dialog-title-success",
        _ => "dialog-title"
    };

    private string IntroClass => IconColor switch
    {
        Color.Error => "dialog-intro-danger",
        Color.Success => "dialog-intro-success",
        _ => ""
    };

    private void Cancel() => MudDialog.Cancel();
    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
}
