@using AssetHub.Application.Dtos
@using AssetHub.Ui.Services
@using MudBlazor

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<CollectionsResource> CollectionLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="dialog-title">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@CollectionLoc["EditCollection"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Class="dialog-intro">
                @CollectionLoc["EditCollectionDesc"]
            </MudText>

            <CollectionForm @ref="_collectionForm"
                            Name="@InitialName"
                            Description="@(InitialDescription ?? "")" />

            @* Reparent picker — admin-only (T5-NEST-01 UX follow-up).
               Cycle detection and depth limits are enforced by the API. *@
            @if (_isAdmin)
            {
                <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                    <div class="dialog-section-title">@CollectionLoc["Parent_Section_Header"]</div>
                    <MudAutocomplete T="CollectionResponseDto"
                                     @bind-Value="_selectedParent"
                                     SearchFunc="SearchCollectionsAsync"
                                     ToStringFunc="@(c => c?.Name ?? "")"
                                     Label="@CollectionLoc["Parent_PickerLabel"]"
                                     HelperText="@CollectionLoc["Parent_PickerHelperText"]"
                                     Variant="Variant.Outlined"
                                     Clearable="true"
                                     Dense="true"
                                     ResetValueOnEmptyText="true"
                                     DebounceInterval="300"
                                     MinCharacters="0">
                        <ItemTemplate Context="c">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2">@c.Name</MudText>
                                @if (!string.IsNullOrEmpty(c.Description))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@c.Description</MudText>
                                }
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                </MudPaper>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CommonLoc["Btn_Cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="SaveAsync"
                   Disabled="_isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @CommonLoc["Btn_Save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    [Parameter]
    public Guid CollectionId { get; set; }

    [Parameter]
    public string InitialName { get; set; } = "";

    [Parameter]
    public string? InitialDescription { get; set; }

    /// <summary>The current parent collection ID, passed by the caller so the picker shows the correct initial value.</summary>
    [Parameter]
    public Guid? CurrentParentId { get; set; }

    [System.Diagnostics.CodeAnalysis.SuppressMessage("Style", "S4487",
        Justification = "Read by Razor @ref binding to <CollectionForm @ref=\"_collectionForm\" />")]
    private CollectionForm? _collectionForm;
    private bool _isSaving;

    // Reparent picker state
    private bool _isAdmin;
    private CollectionResponseDto? _selectedParent;
    private List<CollectionResponseDto> _availableCollections = new();

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is not null)
        {
            var state = await AuthStateTask;
            _isAdmin = state.User.IsInRole("admin");
        }

        if (_isAdmin)
        {
            try
            {
                _availableCollections = await Api.GetCollectionsAsync();
                _selectedParent = CurrentParentId.HasValue
                    ? _availableCollections.FirstOrDefault(c => c.Id == CurrentParentId.Value)
                    : null;
            }
            catch (Exception ex)
            {
                Feedback.HandleError(ex, "load collections for reparent");
            }
        }
    }

    private Task<IEnumerable<CollectionResponseDto>> SearchCollectionsAsync(string? query, CancellationToken ct)
    {
        var candidates = _availableCollections.Where(c => c.Id != CollectionId);

        if (!string.IsNullOrWhiteSpace(query))
            candidates = candidates.Where(c => c.Name.Contains(query, StringComparison.OrdinalIgnoreCase));

        return Task.FromResult(candidates.OrderBy(c => c.Name).AsEnumerable());
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        if (_collectionForm is null || !await _collectionForm.ValidateAsync())
            return;

        _isSaving = true;

        var dto = new UpdateCollectionDto
        {
            Name = _collectionForm.Name,
            Description = InputValidation.NormalizeToNull(_collectionForm.Description)
        };
        var nameSuccess = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.UpdateCollectionAsync(CollectionId, dto),
            "update collection");

        if (nameSuccess && _isAdmin && _selectedParent?.Id != CurrentParentId)
        {
            var parentSuccess = await Feedback.ExecuteWithFeedbackAsync(
                () => Api.SetCollectionParentAsync(CollectionId, _selectedParent?.Id),
                "update parent",
                CollectionLoc["Parent_Changed"]);

            if (!parentSuccess)
            {
                _isSaving = false;
                return;
            }
        }

        _isSaving = false;

        if (nameSuccess)
            MudDialog.Close(DialogResult.Ok(true));
    }
}
