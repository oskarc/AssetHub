@using Microsoft.AspNetCore.Localization
@inject IStringLocalizer<CommonResource> CommonLoc
@inject NavigationManager Nav
@inject IJSRuntime JS

<MudMenu Icon="@Icons.Material.Filled.Language"
         Color="Color.Inherit"
         Dense="true"
         AnchorOrigin="Origin.BottomCenter"
         TransformOrigin="Origin.TopCenter">
    <MudMenuItem OnClick="@(() => SetCulture("en"))">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText>English</MudText>
            @if (_currentCulture == "en")
            {
                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary" />
            }
        </MudStack>
    </MudMenuItem>
    <MudMenuItem OnClick="@(() => SetCulture("sv"))">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText>Svenska</MudText>
            @if (_currentCulture == "sv")
            {
                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary" />
            }
        </MudStack>
    </MudMenuItem>
</MudMenu>

@code {
    private string _currentCulture = "en";

    protected override void OnInitialized()
    {
        _currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    }

    private async Task SetCulture(string culture)
    {
        if (culture == _currentCulture) return;
        _currentCulture = culture;

        var cookieValue = CookieRequestCultureProvider.MakeCookieValue(
            new RequestCulture(culture, culture));

        var jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Dam.Ui/js/helpers.js");
        await jsModule.InvokeVoidAsync("setCookie", CookieRequestCultureProvider.DefaultCookieName, cookieValue, 31536000);

        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }
}
