@page "/share/{Token}"
@layout Layout.ShareLayout
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@implements IAsyncDisposable

@using AssetHub.Ui.Services
@using AssetHub.Ui.Components
@using AssetHub.Application
@using System.Net.Http.Json
@using Microsoft.Extensions.Logging

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ILogger<Share> Logger
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<SharesResource> ShareLoc
@inject ISnackbar Snackbar

<PageTitle>@ShareLoc["SharedContent"] - @CommonLoc["AppName"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">@ShareLoc["LoadingSharedContent"]</MudText>
        </MudStack>
    }
    else if (_requiresPassword)
    {
        <MudPaper Class="pa-6 mx-auto" MaxWidth="400px" Elevation="2">
            <MudStack Spacing="4">
                <MudStack AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h5">@ShareLoc["PasswordRequired"]</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @ShareLoc["PasswordProtected"]
                    </MudText>
                </MudStack>
                
                <MudTextField @bind-Value="_password"
                              Label="@CommonLoc["Label_Password"]"
                              Variant="Variant.Outlined"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                              Immediate="true"
                              OnKeyDown="@OnPasswordKeyDown" />
                
                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                }
                
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="SubmitPassword"
                           Disabled="_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @CommonLoc["Btn_AccessContent"]
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else if (_errorMessage != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            <MudText Typo="Typo.body1">@_errorMessage</MudText>
        </MudAlert>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/">
            @CommonLoc["Btn_GoToHome"]
        </MudButton>
    }
    else if (_sharedAsset != null)
    {
        <!-- Shared Asset View -->
        <AssetDetailPanel Asset="_sharedAsset"
                          PreviewUrl="@GetPreviewUrl()"
                          PosterUrl="@GetPosterUrl()"
                          DownloadUrl="@GetDownloadUrl()"
                          OnDownload="@(() => DownloadAsset(null))"
                          MediumDownloadUrl="@GetMediumDownloadUrl(null)"
                          OnDownloadMedium="@(() => DownloadSpecificSize(null, "medium"))"
                          ThumbnailDownloadUrl="@GetThumbnailDownloadUrl(null)"
                          OnDownloadThumbnail="@(() => DownloadSpecificSize(null, "thumb"))"
                          BrowserNoVideoText="@CommonLoc["Text_BrowserNoVideo"]"
                          PreviewNotAvailableText="@CommonLoc["Text_PreviewNotAvailable"]"
                          DownloadToViewText="@CommonLoc["Btn_DownloadToView"]"
                          DescriptionLabel="@CommonLoc["Label_Description"]"
                          CopyrightLabel="@CommonLoc["Label_Copyright"]"
                          FileInformationText="@CommonLoc["Text_FileInformation"]"
                          SizeLabel="@CommonLoc["Label_Size"]"
                          TypeLabel="@CommonLoc["Label_Type"]"
                          MetadataText="@CommonLoc["Text_Metadata"]"
                          DownloadOriginalText="@CommonLoc["Btn_DownloadOriginal"]"
                          DownloadMediumText="@CommonLoc["Btn_DownloadMedium"]"
                          DownloadThumbnailText="@CommonLoc["Btn_DownloadThumbnail"]" />
    }
    else if (_sharedCollection != null)
    {
        @if (_selectedAsset != null)
        {
            <!-- Selected Asset Detail View -->
            <MudButton Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => _selectedAsset = null)"
                       Class="mb-3">
                @CommonLoc["Btn_BackToCollection"]
            </MudButton>

            <AssetDetailPanel Asset="_selectedAsset"
                              PreviewUrl="@GetAssetPreviewUrl(_selectedAsset.Id)"
                              PosterUrl="@GetAssetPosterUrl(_selectedAsset.Id)"
                              DownloadUrl="@GetAssetDownloadUrl(_selectedAsset.Id)"
                              OnDownload="@(() => DownloadAsset(_selectedAsset.Id))"
                              MediumDownloadUrl="@GetMediumDownloadUrl(_selectedAsset.Id)"
                              OnDownloadMedium="@(() => DownloadSpecificSize(_selectedAsset.Id, "medium"))"
                              ThumbnailDownloadUrl="@GetThumbnailDownloadUrl(_selectedAsset.Id)"
                              OnDownloadThumbnail="@(() => DownloadSpecificSize(_selectedAsset.Id, "thumb"))"
                              BrowserNoVideoText="@CommonLoc["Text_BrowserNoVideo"]"
                              PreviewNotAvailableText="@CommonLoc["Text_DocumentPreviewNotAvailable"]"
                              DownloadToViewText="@CommonLoc["Btn_DownloadToView"]"
                              DescriptionLabel="@CommonLoc["Label_Description"]"
                              CopyrightLabel="@CommonLoc["Label_Copyright"]"
                              FileInformationText="@CommonLoc["Text_FileInformation"]"
                              SizeLabel="@CommonLoc["Label_Size"]"
                              TypeLabel="@CommonLoc["Label_Type"]"
                              MetadataText="@CommonLoc["Text_Metadata"]"
                              DownloadOriginalText="@CommonLoc["Btn_DownloadOriginal"]"
                              DownloadMediumText="@CommonLoc["Btn_DownloadMedium"]"
                              DownloadThumbnailText="@CommonLoc["Btn_DownloadThumbnail"]" />
        }
        else
        {
            <!-- Shared Collection View -->
            <MudPaper Class="pa-4 mb-4" Elevation="1">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack>
                        <MudText Typo="Typo.h5">@_sharedCollection.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @string.Format(CommonLoc["Text_CountAssets"].Value, _sharedCollection.Assets.Count)
                        </MudText>
                    </MudStack>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Download"
                               OnClick="DownloadAllAssets"
                               Disabled="_isDownloading">
                        @if (_isDownloading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            @_downloadStatusText
                        }
                        else
                        {
                            @CommonLoc["Btn_DownloadAll"]
                        }
                    </MudButton>
                </MudStack>
                @if (!string.IsNullOrEmpty(_sharedCollection.Description))
                {
                    <MudText Typo="Typo.body1" Class="mt-2">@_sharedCollection.Description</MudText>
                }
            </MudPaper>

            <MudGrid Spacing="3">
                @if (_sharedCollection.Assets.Count == 0)
                {
                    <MudItem xs="12">
                        <EmptyState Title="@ShareLoc["NoAssetsInCollection"]"
                                    Description="@ShareLoc["EmptyCollectionDesc"]"
                                    Icon="@Icons.Material.Filled.FolderOff" />
                    </MudItem>
                }
                else
                {
                    @foreach (var asset in _sharedCollection.Assets)
                    {
                        <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudCard Elevation="2" Class="clickable" @onclick="@(() => SelectAsset(asset))">
                            <MudCardMedia Image="@GetCollectionThumbnailUrl(asset)"
                                          Height="160" />
                            <MudCardContent Class="pa-2">
                                <MudText Typo="Typo.body2" Class="text-truncate">@asset.Title</MudText>
                                <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetAssetTypeColor(asset.AssetType)" Variant="Variant.Outlined">
                                    @CommonLoc[AssetDisplayHelpers.GetAssetTypeKey(asset.AssetType)]
                                </MudChip>
                            </MudCardContent>
                            <MudCardActions Class="pa-2 pt-0" @onclick:stopPropagation="true">
                                <MudButton Variant="Variant.Text"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Download"
                                           OnClick="@(() => DownloadAsset(asset.Id))">
                                    @CommonLoc["Btn_Download"]
                                </MudButton>
                                <MudButton Variant="Variant.Text"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Visibility"
                                           OnClick="@(() => SelectAsset(asset))">
                                    @CommonLoc["Btn_View"]
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                    }
                }
            </MudGrid>
        }
    }
</MudContainer>

@code {
    [Parameter]
    public string Token { get; set; } = "";

    private bool _isLoading = true;
    private bool _requiresPassword = false;
    private bool _isSubmitting = false;
    private bool _isDownloading = false;
    private bool _showPassword = false;
    private string _downloadStatusText = "";
    private string _password = "";
    private string? _accessToken;
    private string? _error;
    private string? _errorMessage;

    private SharedAssetDto? _sharedAsset;
    private SharedCollectionDto? _sharedCollection;
    private SharedAssetDto? _selectedAsset;

    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<Share>? _dotNetRef;
    private bool _jsModuleLoaded = false;
    private bool _initialLoadComplete = false;

    protected override async Task OnInitializedAsync()
    {
        // Don't load content yet - wait for OnAfterRenderAsync to check for stored password
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_jsModuleLoaded)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AssetHub.Ui/js/helpers.js");
            _jsModuleLoaded = true;
            
            // Check if there's a stored password for this share
            var cookieName = $"share_pwd_{Token}";
            var storedPassword = await _jsModule.InvokeAsync<string?>("getCookie", cookieName);
            
            // Now load content with the stored password (if available)
            await LoadSharedContent(storedPassword);
            _initialLoadComplete = true;
            StateHasChanged();
        }
    }

    private async Task LoadSharedContent(string? password = null)
    {
        try
        {
            _isLoading = true;
            _error = null;

            var response = await Api.GetSharedContentAsync(Token, password);

            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                // First check if this is an error response (revoked/expired) vs password required
                string? errorCode = null;
                string? responseBody = await response.Content.ReadAsStringAsync();
                try
                {
                    var errorDto = System.Text.Json.JsonSerializer.Deserialize<AssetHub.Application.Dtos.ApiError>(
                        responseBody, 
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    errorCode = errorDto?.Code;
                }
                catch { /* not an error response */ }

                // Handle revoked/expired shares before password logic
                if (errorCode == Constants.ShareErrorCodes.Revoked)
                {
                    _errorMessage = ShareLoc["LinkRevoked"].Value;
                    _isLoading = false;
                    return;
                }
                if (errorCode == Constants.ShareErrorCodes.Expired)
                {
                    _errorMessage = ShareLoc["LinkExpired"].Value;
                    _isLoading = false;
                    return;
                }

                // Check if it requires password
                PasswordRequiredResponse? authContent = null;
                try
                {
                    authContent = System.Text.Json.JsonSerializer.Deserialize<PasswordRequiredResponse>(
                        responseBody,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                }
                catch { /* not a password required response */ }

                if (authContent?.RequiresPassword == true)
                {
                    _requiresPassword = true;
                    _isLoading = false;
                    
                    // If we tried with a stored password and failed, clear it and show error
                    if (!string.IsNullOrEmpty(password) && _initialLoadComplete)
                    {
                        _error = ShareLoc["InvalidPassword"].Value;
                        _password = password; // Show what was attempted
                        
                        // Clear the invalid stored password
                        if (_jsModule != null)
                        {
                            var cookieName = $"share_pwd_{Token}";
                            await _jsModule.InvokeVoidAsync("setCookie", cookieName, "", 0);
                        }
                    }
                    return;
                }
                _error = ShareLoc["InvalidPassword"].Value;
                _isLoading = false;
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                string? errorCode = null;
                try
                {
                    var errorDto = await response.Content.ReadFromJsonAsync<AssetHub.Application.Dtos.ApiError>();
                    errorCode = errorDto?.Code;
                }
                catch { /* non-JSON body — fall through to generic message */ }

                _errorMessage = errorCode switch
                {
                    Constants.ShareErrorCodes.Expired => ShareLoc["LinkExpired"].Value,
                    Constants.ShareErrorCodes.Revoked => ShareLoc["LinkRevoked"].Value,
                    _ when response.StatusCode == System.Net.HttpStatusCode.NotFound => ShareLoc["InvalidOrRemoved"].Value,
                    _ => ShareLoc["ErrorLoading"].Value
                };
                _isLoading = false;
                return;
            }

            // The API returns either SharedAssetDto or SharedCollectionDto
            // We distinguish by the "type" discriminator property set server-side
            var jsonString = await response.Content.ReadAsStringAsync();
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            using var jsonDoc = System.Text.Json.JsonDocument.Parse(jsonString);
            var scopeType = jsonDoc.RootElement.TryGetProperty("type", out var typeProp) 
                ? typeProp.GetString() 
                : null;

            if (scopeType == Constants.ScopeTypes.Collection)
            {
                _sharedCollection = System.Text.Json.JsonSerializer.Deserialize<SharedCollectionDto>(jsonString, jsonOptions);
                _requiresPassword = false;
            }
            else
            {
                _sharedAsset = System.Text.Json.JsonSerializer.Deserialize<SharedAssetDto>(jsonString, jsonOptions);
                _requiresPassword = false;
            }

            // If password was provided, obtain a short-lived access token for
            // subsequent HTML element URLs (img src, video src, a href) so the
            // actual password never appears in query strings.
            if (!string.IsNullOrEmpty(password))
            {
                var tokenResponse = await Api.GetShareAccessTokenAsync(Token, password);
                if (tokenResponse != null)
                    _accessToken = tokenResponse.AccessToken;
                
                // Store password in cookie for language switches (1 hour expiry)
                if (_jsModule != null)
                {
                    var cookieName = $"share_pwd_{Token}";
                    await _jsModule.InvokeVoidAsync("setCookie", cookieName, password, 3600);
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ShareLoc["FailedToLoad"].Value;
            Logger.LogError(ex, "Error loading shared content for token {Token}", Token);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SubmitPassword()
    {
        if (string.IsNullOrEmpty(_password))
        {
            _error = CommonLoc["Validation_EnterPassword"].Value;
            return;
        }

        _isSubmitting = true;
        _error = null;

        await LoadSharedContent(_password);

        if (_requiresPassword)
        {
            _error = ShareLoc["InvalidPassword"];
            
            // Clear the stored password cookie since it's invalid
            if (_jsModule != null)
            {
                var cookieName = $"share_pwd_{Token}";
                await _jsModule.InvokeVoidAsync("setCookie", cookieName, "", 0);
            }
        }

        _isSubmitting = false;
    }

    private async Task OnPasswordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitPassword();
        }
    }

    private string GetPreviewUrl()
    {
        if (_sharedAsset == null) return "";

        var escapedToken = Uri.EscapeDataString(Token);

        // For PDFs and videos/audio, use the preview endpoint without size
        // so the server returns the original file for inline display / playback.
        if (AssetDisplayHelpers.IsPdfContentType(_sharedAsset.ContentType)
            || _sharedAsset.AssetType == Constants.AssetTypeFilters.Video
            || _sharedAsset.AssetType == "audio")
        {
            var url = $"/api/shares/{escapedToken}/preview";
            if (!string.IsNullOrEmpty(_accessToken))
                url += $"?accessToken={Uri.EscapeDataString(_accessToken)}";
            return url;
        }

        // For images / other types, use the rendition URL (medium → thumb → download)
        var previewUrl = _sharedAsset.MediumUrl ?? _sharedAsset.ThumbnailUrl
                         ?? $"/api/shares/{escapedToken}/download";
        return AppendAccessToken(previewUrl);
    }

    /// <summary>Returns a poster/thumbnail URL for the single shared-asset video element.</summary>
    private string GetPosterUrl()
    {
        if (_sharedAsset == null) return "";
        var url = _sharedAsset.MediumUrl ?? _sharedAsset.ThumbnailUrl ?? "";
        return string.IsNullOrEmpty(url) ? url : AppendAccessToken(url);
    }

    private string GetAssetPreviewUrl(Guid assetId)
    {
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/preview?assetId={assetId}";
        if (!string.IsNullOrEmpty(_accessToken))
            url += $"&accessToken={Uri.EscapeDataString(_accessToken)}";
        return url;
    }

    /// <summary>Returns a poster/thumbnail URL for a collection-asset video element.</summary>
    private string GetAssetPosterUrl(Guid assetId)
    {
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/preview?assetId={assetId}&size=medium";
        if (!string.IsNullOrEmpty(_accessToken))
            url += $"&accessToken={Uri.EscapeDataString(_accessToken)}";
        return url;
    }

    /// <summary>Appends the share access token as a query parameter when present.</summary>
    private string AppendAccessToken(string url)
    {
        if (string.IsNullOrEmpty(_accessToken)) return url;
        var separator = url.Contains('?') ? '&' : '?';
        return $"{url}{separator}accessToken={Uri.EscapeDataString(_accessToken)}";
    }

    /// <summary>Returns a thumbnail URL for the collection grid card, with access token and medium fallback.</summary>
    private string GetCollectionThumbnailUrl(SharedAssetDto asset)
    {
        var url = asset.ThumbnailUrl ?? asset.MediumUrl;
        if (string.IsNullOrEmpty(url))
            return AssetDisplayHelpers.GetPlaceholderForType(asset.AssetType);
        return AppendAccessToken(url);
    }

    private string GetDownloadUrl()
    {
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/download";
        if (!string.IsNullOrEmpty(_accessToken))
            url += $"?accessToken={Uri.EscapeDataString(_accessToken)}";
        return url;
    }

    private string GetAssetDownloadUrl(Guid assetId)
    {
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/download?assetId={assetId}";
        if (!string.IsNullOrEmpty(_accessToken))
            url += $"&accessToken={Uri.EscapeDataString(_accessToken)}";
        return url;
    }

    private void SelectAsset(SharedAssetDto asset)
    {
        _selectedAsset = asset;
    }

    private async Task DownloadAllAssets()
    {
        if (_isDownloading) return;

        _isDownloading = true;
        _downloadStatusText = CommonLoc["Msg_PreparingDownload"].Value;
        StateHasChanged();

        try
        {
            var url = $"/api/shares/{Uri.EscapeDataString(Token)}/download-all";
            if (!string.IsNullOrEmpty(_accessToken))
                url += $"?accessToken={Uri.EscapeDataString(_accessToken)}";

            // The status polling endpoint needs X-Share-Token header
            var headers = new Dictionary<string, string> { { "X-Share-Token", Token } };
            _dotNetRef?.Dispose();
            _dotNetRef = DotNetObjectReference.Create(this);

            if (_jsModule != null)
            {
                var resultJson = await _jsModule.InvokeAsync<string>(
                    "enqueueAndPollZipDownload", url, headers, _dotNetRef);

                var result = System.Text.Json.JsonSerializer.Deserialize<ZipDownloadResult>(resultJson,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (result?.Success != true)
                {
                    _errorMessage = result?.Error ?? CommonLoc["Msg_DownloadFailed"].Value;
                }
            }
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Download-all failed for share token");
            _errorMessage = CommonLoc["Msg_DownloadFailed"].Value;
        }
        finally
        {
            _isDownloading = false;
            _downloadStatusText = "";
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void UpdateZipProgress(string status, string fileName)
    {
        _downloadStatusText = status switch
        {
            "pending" => CommonLoc["Msg_DownloadQueued"].Value,
            "building" => CommonLoc["Msg_BuildingZip"].Value,
            _ => CommonLoc["Msg_PreparingDownload"].Value
        };
        InvokeAsync(StateHasChanged);
    }

    private record ZipDownloadResult(bool Success, string? Error);

    private async Task DownloadAsset(Guid? assetId)
    {
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/download";
        var queryParams = new List<string>();
        
        if (assetId.HasValue)
            queryParams.Add($"assetId={assetId.Value}");
        if (!string.IsNullOrEmpty(_accessToken))
            queryParams.Add($"accessToken={Uri.EscapeDataString(_accessToken)}");
        
        if (queryParams.Count > 0)
            url += "?" + string.Join("&", queryParams);

        if (_jsModule != null)
        {
            var error = await _jsModule.InvokeAsync<string?>("downloadWithErrorCheck", url, null);
            if (!string.IsNullOrEmpty(error))
            {
                Snackbar.Add(error, Severity.Error);
            }
        }
    }

    private async Task DownloadSpecificSize(Guid? assetId, string size)
    {
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/preview?size={size}&download=true";
        if (assetId.HasValue)
            url += $"&assetId={assetId.Value}";
        if (!string.IsNullOrEmpty(_accessToken))
            url += $"&accessToken={Uri.EscapeDataString(_accessToken)}";

        if (_jsModule != null)
        {
            var error = await _jsModule.InvokeAsync<string?>("downloadWithErrorCheck", url, null);
            if (!string.IsNullOrEmpty(error))
            {
                Snackbar.Add(error, Severity.Error);
            }
        }
    }

    private string? GetMediumDownloadUrl(Guid? assetId)
    {
        if (_sharedAsset != null && string.IsNullOrEmpty(_sharedAsset.MediumUrl))
            return null;
        if (_selectedAsset != null && string.IsNullOrEmpty(_selectedAsset.MediumUrl))
            return null;
        
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/preview?size=medium";
        if (assetId.HasValue)
            url += $"&assetId={assetId.Value}";
        if (!string.IsNullOrEmpty(_accessToken))
            url += $"&accessToken={Uri.EscapeDataString(_accessToken)}";
        return url;
    }

    private string? GetThumbnailDownloadUrl(Guid? assetId)
    {
        if (_sharedAsset != null && string.IsNullOrEmpty(_sharedAsset.ThumbnailUrl))
            return null;
        if (_selectedAsset != null && string.IsNullOrEmpty(_selectedAsset.ThumbnailUrl))
            return null;
        
        var url = $"/api/shares/{Uri.EscapeDataString(Token)}/preview?size=thumb";
        if (assetId.HasValue)
            url += $"&assetId={assetId.Value}";
        if (!string.IsNullOrEmpty(_accessToken))
            url += $"&accessToken={Uri.EscapeDataString(_accessToken)}";
        return url;
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        if (_jsModule is not null)
        {
            try { await _jsModule.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
    }
}
