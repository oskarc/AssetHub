@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using Dam.Application
@using Dam.Application.Dtos
@using Dam.Application.Helpers
@using Dam.Ui.Services
@using Dam.Ui.Components
@attribute [Authorize(Policy = "RequireAdmin")]
@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>Admin - AssetHub</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Class="mr-2" />
        Administration
    </MudText>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
        <MudTabPanel Text="Share Management" Icon="@Icons.Material.Filled.Share">
            @ShareManagementTab
        </MudTabPanel>
        <MudTabPanel Text="Collection Access" Icon="@Icons.Material.Filled.FolderShared">
            @CollectionAccessTab
        </MudTabPanel>
        <MudTabPanel Text="User Management" Icon="@Icons.Material.Filled.ManageAccounts">
            @UserManagementTab
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@* ===== SHARE MANAGEMENT TAB ===== *@
@code {
    // Nested component for Share Management
    private RenderFragment ShareManagementTab => __builder =>
    {
        <MudText Typo="Typo.h6" Class="mb-4">All Shared Links</MudText>
        
        @if (_sharesLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_shares == null || !_shares.Any())
        {
            <EmptyState Title="No shares yet"
                        Description="When users create share links for assets or collections, they will appear here for management."
                        Icon="@Icons.Material.Filled.Share" />
        }
        else
        {
            <MudTable Items="@_shares" Hover="true" Dense="true" Striped="true" Filter="ShareFilter" SortLabel="Sort By">
                <ToolBarContent>
                    <MudTextField @bind-Value="_shareSearchString" Placeholder="Search shares..." 
                        Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                        IconSize="Size.Medium" Class="mt-0" Immediate="true" />
                    <MudSpacer />
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Active: @_shares.Count(s => s.Status == "Active")</MudChip>
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">Expired: @_shares.Count(s => s.Status == "Expired")</MudChip>
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Revoked: @_shares.Count(s => s.Status == "Revoked")</MudChip>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.ScopeType)">Type</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.ScopeName)">Target</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.CreatedByUserName)">Created By</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.CreatedAt)">Created</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.ExpiresAt)">Expires</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.LastAccessedAt ?? DateTime.MinValue)">Last Access</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.AccessCount)">Access Count</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.Status)">Status</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@(context.ScopeType == "asset" ? Color.Info : Color.Secondary)">
                            @context.ScopeType
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudTooltip Text="@context.ScopeId.ToString()">
                            @context.ScopeName
                        </MudTooltip>
                        @if (context.HasPassword)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Warning" Class="ml-1" />
                        }
                    </MudTd>
                    <MudTd>@context.CreatedByUserName</MudTd>
                    <MudTd>@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
                    <MudTd>@context.ExpiresAt.ToLocalTime().ToString("g")</MudTd>
                    <MudTd>@(context.LastAccessedAt?.ToLocalTime().ToString("g") ?? "Never")</MudTd>
                    <MudTd><MudChip T="string" Size="Size.Small">@context.AccessCount</MudChip></MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetShareStatusColor(context.Status)">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        @if (context.Status == "Active")
                        {
                            <MudStack Row="true" Spacing="1">
                                @if (context.HasPassword)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Key" Color="Color.Primary" Size="Size.Small"
                                        OnClick="@(() => EditSharePassword(context))" Title="Edit Password" />
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.Block" Color="Color.Error" Size="Size.Small"
                                    OnClick="@(() => RevokeShare(context))" Title="Revoke Share" />
                            </MudStack>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    };
}

@* ===== COLLECTION ACCESS TAB ===== *@
@code {
    private RenderFragment CollectionAccessTab => __builder =>
    {
        <MudText Typo="Typo.h6" Class="mb-4">Collection Access Control</MudText>
        
        @if (_collectionsLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_collections == null || !_collections.Any())
        {
            <EmptyState Title="No collections yet"
                        Description="Create collections from the Assets page to start organizing your media."
                        Icon="@Icons.Material.Filled.Folder" />
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="5">
                    <MudPaper Elevation="2" Class="pa-4 admin-collection-tree">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">Collections</MudText>
                        @foreach (var collection in _collections)
                        {
                            @RenderCollectionTree(collection, 0)
                        }
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="7">
                    <MudPaper Elevation="2" Class="pa-4">
                        @if (_selectedCollection == null)
                        {
                            <EmptyState Title="Select a collection"
                                        Description="Choose a collection from the list to view and manage user access permissions."
                                        Icon="@Icons.Material.Filled.FolderShared" />
                        }
                        else
                        {
                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                Access for: <strong>@_selectedCollection.Name</strong>
                            </MudText>
                            
                            @* Add user form *@
                            <MudGrid Class="mb-4">
                                <MudItem xs="12" sm="5">
                                    <MudTextField @bind-Value="_newAclUserId" Label="User ID" 
                                        Variant="Variant.Outlined" Size="Size.Small" />
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudSelect @bind-Value="_newAclRole" Label="Role" 
                                        Variant="Variant.Outlined" Size="Size.Small">
                                        <MudSelectItem Value="@RoleHierarchy.Roles.Viewer">Viewer</MudSelectItem>
                                        <MudSelectItem Value="@RoleHierarchy.Roles.Contributor">Contributor</MudSelectItem>
                                        <MudSelectItem Value="@RoleHierarchy.Roles.Manager">Manager</MudSelectItem>
                                        <MudSelectItem Value="@RoleHierarchy.Roles.Admin">Admin</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="3">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                        OnClick="AddCollectionAccess" Disabled="@(string.IsNullOrWhiteSpace(_newAclUserId))"
                                        FullWidth="true" Class="mt-1">
                                        Add
                                    </MudButton>
                                </MudItem>
                            </MudGrid>
                            
                            @* Current ACLs *@
                            @if (!_selectedCollection.Acls.Any())
                            {
                                <EmptyState Title="No users have access"
                                            Description="Grant access to users using the form above. They will be able to view or manage assets based on their role."
                                            Icon="@Icons.Material.Filled.PersonAdd" />
                            }
                            else
                            {
                                <MudSimpleTable Dense="true" Hover="true" Striped="true">
                                    <thead>
                                        <tr>
                                            <th>User</th>
                                            <th>Role</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var acl in _selectedCollection.Acls)
                                        {
                                            <tr>
                                                <td>@acl.PrincipalName</td>
                                                <td>
                                                    <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetRoleColor(acl.Role)">
                                                        @acl.Role
                                                    </MudChip>
                                                </td>
                                                <td>
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" 
                                                        Size="Size.Small" OnClick="@(() => RemoveCollectionAccess(acl))" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            }
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    };
}

@* ===== USER MANAGEMENT TAB ===== *@
@code {
    private RenderFragment UserManagementTab => __builder =>
    {
        <MudText Typo="Typo.h6" Class="mb-4">User Management</MudText>
        <MudAlert Severity="Severity.Info" Class="mb-4">
            Manage all users in the Keycloak realm. Click "Manage Access" to grant or revoke collection access for any user.
        </MudAlert>
        
        @if (_allUsersLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_allUsers == null || !_allUsers.Any())
        {
            <EmptyState Title="No users found"
                        Description="No users exist in the Keycloak realm yet. Create a user to get started."
                        Icon="@Icons.Material.Filled.PeopleAlt"
                        ActionText="Create User"
                        ActionIcon="@Icons.Material.Filled.PersonAdd"
                        OnAction="OpenCreateUserDialog" />
        }
        else
        {
            <MudTable Items="@_allUsers" Hover="true" Dense="true" Striped="true" Filter="new Func<KeycloakUserDto,bool>(UserFilter)" SortLabel="Sort By">
                <ToolBarContent>
                    <MudTextField @bind-Value="_userSearchString" Placeholder="Search users..." 
                        Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                        IconSize="Size.Medium" Class="mt-0" Immediate="true" />
                    <MudSpacer />
                    <MudChip T="string" Color="Color.Info" Size="Size.Small">Total: @_allUsers.Count</MudChip>
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">With Access: @_allUsers.Count(u => u.CollectionCount > 0)</MudChip>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               OnClick="OpenCreateUserDialog" Class="ml-2">
                        Create User
                    </MudButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.Username)">Username</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.Email ?? string.Empty)">Email</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.CreatedAt ?? DateTime.MinValue)">Created</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.CollectionCount)">Collections</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.HighestRole ?? string.Empty)">Highest Role</MudTableSortLabel></MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Username</MudTd>
                    <MudTd>@(context.Email ?? "-")</MudTd>
                    <MudTd>@(context.CreatedAt?.ToLocalTime().ToString("g") ?? "-")</MudTd>
                    <MudTd>
                        @if (context.CollectionCount > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.CollectionCount</MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="opacity: 0.6;">None</MudText>
                        }
                    </MudTd>
                    <MudTd>
                        @if (!string.IsNullOrEmpty(context.HighestRole))
                        {
                            <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetRoleColor(context.HighestRole)">
                                @context.HighestRole
                            </MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="opacity: 0.6;">No access</MudText>
                        }
                    </MudTd>
                    <MudTd>
                        <MudButton Size="Size.Small" 
                                   Variant="Variant.Filled" 
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.ManageAccounts"
                                   OnClick="@(() => ManageUserAccess(context))">
                            Manage Access
                        </MudButton>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    };
}

@* ===== CODE-BEHIND ===== *@
@code {
    // Share Management State
    private List<AdminShareDto>? _shares;
    private bool _sharesLoading = true;
    private string _shareSearchString = "";

    // Collection Access State
    private List<CollectionAccessDto>? _collections;
    private bool _collectionsLoading = true;
    private CollectionAccessDto? _selectedCollection;
    private string _newAclUserId = "";
    private string _newAclRole = RoleHierarchy.Roles.Viewer;

    // All Keycloak Users State
    private List<KeycloakUserDto>? _allUsers;
    private bool _allUsersLoading = true;
    private string _userSearchString = "";

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadShares(),
            LoadCollections(),
            LoadAllUsers()
        );
    }

    // ===== SHARE MANAGEMENT =====
    
    private async Task LoadShares()
    {
        try
        {
            _sharesLoading = true;
            _shares = await Api.GetAllSharesAsync();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load shares");
        }
        finally
        {
            _sharesLoading = false;
            StateHasChanged();
        }
    }

    private bool ShareFilter(AdminShareDto share)
    {
        if (string.IsNullOrWhiteSpace(_shareSearchString))
            return true;
        
        return share.ScopeName.Contains(_shareSearchString, StringComparison.OrdinalIgnoreCase)
            || share.CreatedByUserName.Contains(_shareSearchString, StringComparison.OrdinalIgnoreCase)
            || share.Status.Contains(_shareSearchString, StringComparison.OrdinalIgnoreCase);
    }

    private async Task EditSharePassword(AdminShareDto share)
    {
        var parameters = new DialogParameters<SharePasswordDialog>
        {
            { x => x.Share, share }
        };

        var dialog = await DialogService.ShowAsync<SharePasswordDialog>("Edit Share Password", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            // Refresh the shares list to reflect any changes
            await LoadShares();
        }
    }

    private async Task RevokeShare(AdminShareDto share)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Confirm Revoke",
            $"Are you sure you want to revoke the share for \"{share.ScopeName}\"? This action cannot be undone.",
            yesText: "Revoke", cancelText: "Cancel");
        
        if (confirmed != true)
            return;

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.RevokeShareAdminAsync(share.Id),
            "revoke share",
            "Share revoked successfully");
        
        if (success)
        {
            await LoadShares();
        }
    }

    // ===== COLLECTION ACCESS =====
    
    private async Task LoadCollections()
    {
        try
        {
            _collectionsLoading = true;
            var selectedId = _selectedCollection?.Id;
            _collections = await Api.GetCollectionAccessAsync();
            
            // Re-select the previously selected collection to show updated ACLs
            if (selectedId.HasValue)
            {
                _selectedCollection = CollectionTreeHelper.FindById(_collections, selectedId.Value);
            }
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collections");
        }
        finally
        {
            _collectionsLoading = false;
            StateHasChanged();
        }
    }

    private RenderFragment RenderCollectionTree(CollectionAccessDto collection, int depth) => __builder =>
    {
        var isSelected = _selectedCollection?.Id == collection.Id;
        var depthClass = $"admin-tree-item-depth-{Math.Min(depth, 5)}";
        
        <MudButton Variant="@(isSelected ? Variant.Filled : Variant.Text)" 
            Color="@(isSelected ? Color.Primary : Color.Default)"
            OnClick="@(() => SelectCollection(collection))"
            FullWidth="true"
            Class="@($"justify-start mb-1 admin-tree-item {depthClass}")">
            <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Class="mr-2" />
            @collection.Name
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="Color.Default">@collection.Acls.Count</MudChip>
        </MudButton>
        
        @foreach (var child in collection.Children)
        {
            @RenderCollectionTree(child, depth + 1)
        }
    };

    private void SelectCollection(CollectionAccessDto collection)
    {
        _selectedCollection = collection;
        _newAclUserId = "";
        _newAclRole = RoleHierarchy.Roles.Viewer;
    }

    private async Task AddCollectionAccess()
    {
        if (_selectedCollection == null || string.IsNullOrWhiteSpace(_newAclUserId))
            return;

        try
        {
            await Api.AddCollectionAclAsync(_selectedCollection.Id, Constants.PrincipalTypes.User, _newAclUserId, _newAclRole);
            Feedback.ShowSuccess($"Access granted to '{_newAclUserId}'");
            _newAclUserId = "";
            await LoadCollections();
            
            // Re-select the collection to refresh ACLs
            _selectedCollection = CollectionTreeHelper.FindById(_collections, _selectedCollection.Id);
        }
        catch (Exception ex)
        {
            // Check if it's a "user not found" error and show a helpful message
            if (ex.Message.Contains("not found", StringComparison.OrdinalIgnoreCase))
            {
                Feedback.ShowWarning($"User '{_newAclUserId}' does not exist. Please check the username and try again.");
            }
            else
            {
                Feedback.HandleError(ex, "add access");
            }
        }
    }

    private async Task RemoveCollectionAccess(CollectionAclResponseDto acl)
    {
        if (_selectedCollection == null)
            return;

        var confirmed = await DialogService.ShowMessageBox(
            "Confirm Remove Access",
            $"Are you sure you want to remove access for \"{acl.PrincipalId}\" from \"{_selectedCollection.Name}\"?",
            yesText: "Remove", cancelText: "Cancel");
        
        if (confirmed != true)
            return;

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.RemoveCollectionAclAsync(_selectedCollection.Id, acl.PrincipalId, acl.PrincipalType),
            "remove access",
            $"Access removed for {acl.PrincipalId}");
        
        if (success)
        {
            await LoadCollections();
            _selectedCollection = CollectionTreeHelper.FindById(_collections, _selectedCollection.Id);
        }
    }

    // ===== USER MANAGEMENT =====
    
    private async Task LoadAllUsers()
    {
        try
        {
            _allUsersLoading = true;
            _allUsers = await Api.GetKeycloakUsersAsync();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load Keycloak users");
        }
        finally
        {
            _allUsersLoading = false;
            StateHasChanged();
        }
    }

    private bool UserFilter(KeycloakUserDto user)
    {
        if (string.IsNullOrWhiteSpace(_userSearchString))
            return true;
        
        return user.Username.Contains(_userSearchString, StringComparison.OrdinalIgnoreCase)
            || (user.Email?.Contains(_userSearchString, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private async Task ManageUserAccess(KeycloakUserDto user)
    {
        var parameters = new DialogParameters<ManageUserAccessDialog>
        {
            { x => x.UserId, user.Id },
            { x => x.Username, user.Username },
            { x => x.Email, user.Email }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ManageUserAccessDialog>("Manage User Access", parameters, options);
        var result = await dialog.Result;

        // Refresh both user list and collection access to show updated data
        if (result != null && !result.Canceled)
        {
            await Task.WhenAll(LoadAllUsers(), LoadCollections());
        }
    }

    private async Task OpenCreateUserDialog()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<CreateUserDialog>("Create New User", options);
        var result = await dialog.Result;

        // Refresh user list if a user was created
        if (result != null && !result.Canceled)
        {
            await Task.WhenAll(LoadAllUsers(), LoadCollections());
        }
    }
}
