@page "/assets/{AssetId:guid}"
@attribute [Authorize]
@implements IAsyncDisposable

@using AssetHub.Application
@using AssetHub.Application.Dtos
@using AssetHub.Application.Helpers
@using AssetHub.Ui.Components
@using AssetHub.Ui.Services
@using Microsoft.AspNetCore.Authorization

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AssetsResource> AssetLoc
@inject IStringLocalizer<ImageEditorResource> EditorLoc
@inject IStringLocalizer<AdminResource> AdminLoc
@inject LocalizedDisplayService Display

<PageTitle>@(_isLoading ? AssetLoc["LoadingAsset"] : _asset?.Title ?? AssetLoc["AssetNotFound"]) - @CommonLoc["AppName"]</PageTitle>

@if (_isLoading)
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">@AssetLoc["LoadingAsset"]</MudText>
        </MudStack>
    </MudContainer>
}
else if (_asset == null)
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
        <EmptyState Title="@AssetLoc["AssetNotFound"]"
                    Description="@AssetLoc["AssetNotFoundDesc"]"
                    Icon="@Icons.Material.Filled.BrokenImage"
                    ActionText="@CommonLoc["Btn_BackToAssets"]"
                    ActionIcon="@Icons.Material.Filled.ArrowBack"
                    OnAction="@NavigateBackToAssets" />
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
        <!-- Back Button -->
        <MudButton Variant="Variant.Text" 
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@NavigateBackToAssets"
                   Class="mb-3">
            @CommonLoc["Btn_BackToAssets"]
        </MudButton>

        <MudGrid>
            <!-- Preview Area -->
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-4" Elevation="1">
                    <MediaPreview AssetType="@_asset.AssetType"
                                  ContentType="@_asset.ContentType"
                                  Title="@_asset.Title"
                                  PreviewUrl="@GetPreviewUrl()"
                                  PosterUrl="@GetPosterUrl()"
                                  DownloadUrl="@GetDownloadUrl()"
                                  BrowserNoVideoText="@CommonLoc["Text_BrowserNoVideo"]"
                                  PreviewNotAvailableText="@CommonLoc["Text_PreviewNotAvailable"]"
                                  DownloadToViewText="@CommonLoc["Btn_DownloadToView"]" />
                </MudPaper>
            </MudItem>

            <!-- Details Panel -->
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="1">
                    <!-- Title and Status -->
                    <MudStack Spacing="3">
                        <MudStack>
                            <MudText Typo="Typo.h5">@_asset.Title</MudText>
                            <MudStack Row="true" Spacing="1">
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Color="@AssetDisplayHelpers.GetAssetTypeColor(_asset.AssetType)"
                                         Variant="Variant.Outlined"
                                         Icon="@AssetDisplayHelpers.GetAssetIcon(_asset.AssetType)">
                                    @Display.AssetType(_asset.AssetType)
                                </MudChip>
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Color="@AssetDisplayHelpers.GetAssetStatusColor(_asset.Status)"
                                         Icon="@AssetDisplayHelpers.GetAssetStatusIcon(_asset.Status)">
                                    @CommonLoc[AssetDisplayHelpers.GetAssetStatusKey(_asset.Status)]
                                </MudChip>
                            </MudStack>
                        </MudStack>

                        <MudDivider />

                        <!-- Collection Membership (Multi-Collection) -->
                        <MudStack>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.subtitle2">@CommonLoc["Label_Collections"]</MudText>
                                @if (RolePermissions.CanManageCollections(_asset?.UserRole))
                                {
                                    <MudTooltip Text="@AssetLoc["AddToCollection"]">
                                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="OpenAddToCollectionDialogAsync" />
                                    </MudTooltip>
                                }
                            </MudStack>
                            
                            @if (_assetCollections.Any())
                            {
                                <MudStack Spacing="1">
                                    @foreach (var collection in _assetCollections)
                                    {
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudChip T="string" 
                                                     Size="Size.Small" 
                                                     Color="Color.Secondary"
                                                     Icon="@Icons.Material.Filled.Folder"
                                                     OnClick="@(() => Nav.NavigateTo($"/collections?collection={collection.Id}"))"
                                                     Class="clickable">
                                                @collection.Name
                                            </MudChip>
                                            @if (RolePermissions.CanManageCollections(_asset?.UserRole))
                                            {
                                                <MudTooltip Text="@AssetLoc["RemoveFromCollection"]">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                                   Size="Size.Small"
                                                                   Color="Color.Error"
                                                                   OnClick="@(() => RemoveFromCollectionAsync(collection))" />
                                                </MudTooltip>
                                            }
                                        </MudStack>
                                    }
                                </MudStack>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-italic">
                                    @CommonLoc["Text_NotAssignedToCollection"]
                                </MudText>
                            }
                        </MudStack>

                        <!-- Description -->
                        @if (!string.IsNullOrEmpty(_asset.Description))
                        {
                            <MudStack>
                                <MudText Typo="Typo.subtitle2">@CommonLoc["Label_Description"]</MudText>
                                <MudText Typo="Typo.body2">@_asset.Description</MudText>
                            </MudStack>
                        }

                        <!-- Copyright -->
                        @if (!string.IsNullOrEmpty(_asset.Copyright))
                        {
                            <MudStack>
                                <MudText Typo="Typo.subtitle2">@CommonLoc["Label_Copyright"]</MudText>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.Copyright" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2">@_asset.Copyright</MudText>
                                </MudStack>
                            </MudStack>
                        }

                        <!-- File Info -->
                        <MudStack>
                            <MudText Typo="Typo.subtitle2">@CommonLoc["Text_FileInformation"]</MudText>
                            <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                <tbody>
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Label_Size"]</MudText></td>
                                        <td><MudText Typo="Typo.body2">@AssetDisplayHelpers.FormatFileSize(_asset.SizeBytes)</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Label_Type"]</MudText></td>
                                        <td>
                                            <MudTooltip Text="@_asset.ContentType">
                                                <MudText Typo="Typo.body2">@Display.ContentType(_asset.ContentType)</MudText>
                                            </MudTooltip>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Label_Created"]</MudText></td>
                                        <td>
                                            <MudTooltip Text="@_asset.CreatedAt.ToLocalTime().ToString("F")">
                                                <MudText Typo="Typo.body2">@_asset.CreatedAt.ToLocalTime().ToString("g")</MudText>
                                            </MudTooltip>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Label_Updated"]</MudText></td>
                                        <td>
                                            <MudTooltip Text="@_asset.UpdatedAt.ToLocalTime().ToString("F")">
                                                <MudText Typo="Typo.body2">@_asset.UpdatedAt.ToLocalTime().ToString("g")</MudText>
                                            </MudTooltip>
                                        </td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(_asset.Sha256))
                                    {
                                        <tr>
                                            <td><MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Text_SHA256"]</MudText></td>
                                            <td>
                                                <MudTooltip Text="@_asset.Sha256">
                                                    <MudText Typo="Typo.body2" Class="asset-detail-truncate">
                                                        @_asset.Sha256[..Math.Min(16, _asset.Sha256.Length)]...
                                                    </MudText>
                                                </MudTooltip>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudStack>

                        <!-- Tags -->
                        @if (_asset.Tags.Any())
                        {
                            <MudStack>
                                <MudText Typo="Typo.subtitle2">@CommonLoc["Label_Tags"]</MudText>
                                <MudChipSet T="string" ReadOnly="true">
                                    @foreach (var tag in _asset.Tags)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@tag</MudChip>
                                    }
                                </MudChipSet>
                            </MudStack>
                        }

                        @if (_asset.Status == Constants.AssetStatus.Failed)
                        {
                            <MudDivider />
                            <div role="alert" aria-live="assertive">
                                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                                    @AssetLoc["ProcessingFailedMessage"]
                                </MudAlert>
                            </div>
                        }

                        @if (_isPollingProcessing)
                        {
                            <div role="status" aria-live="polite" aria-label="@CommonLoc["Aria_ProcessingInProgress"]">
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" NoIcon="true">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Info" />
                                        <MudText Typo="Typo.body2">@AssetLoc["ProcessingBanner"]</MudText>
                                    </MudStack>
                                </MudAlert>
                            </div>
                        }

                        <!-- Metadata (Expandable) -->
                        @if (_asset.MetadataJson.Where(k => k.Key != "error").Any())
                        {
                            <MudExpansionPanels Elevation="0" Class="share-panel-reset">
                                <MudExpansionPanel MaxHeight="400"
                                                   Class="share-panel-header pa-0 ma-0">
                                    <TitleContent>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudText Typo="Typo.subtitle2">@CommonLoc["Text_Metadata"]</MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                                @_asset.MetadataJson.Count(k => k.Key != "error")
                                            </MudChip>
                                        </MudStack>
                                    </TitleContent>
                                    <ChildContent>
                                        <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                            <tbody>
                                                @foreach (var kvp in _asset.MetadataJson.Where(k => k.Key != "error").OrderBy(k => k.Key))
                                                {
                                                    <tr>
                                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">@AssetDisplayHelpers.FormatMetadataKey(kvp.Key)</MudText></td>
                                                        <td><MudText Typo="Typo.body2">@kvp.Value?.ToString()</MudText></td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </MudSimpleTable>
                                    </ChildContent>
                                </MudExpansionPanel>
                            </MudExpansionPanels>
                        }

                        <DerivativesPanel Derivatives="_derivatives" />

                        <MudDivider />

                        <!-- Actions -->
                        <MudStack Spacing="2">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Download"
                                       FullWidth="true"
                                       Href="@GetDownloadUrl()"
                                       Target="_blank">
                                @CommonLoc["Btn_DownloadOriginal"]
                            </MudButton>

                            @if (!string.IsNullOrEmpty(_asset?.MediumObjectKey))
                            {
                                <MudButton Variant="Variant.Outlined"
                                           StartIcon="@Icons.Material.Filled.Photo"
                                           FullWidth="true"
                                           Href="@($"/api/v1/assets/{AssetId}/medium/download")"
                                           Target="_blank">
                                    @CommonLoc["Btn_DownloadMedium"]
                                </MudButton>
                            }

                            @if (!string.IsNullOrEmpty(_asset?.ThumbObjectKey))
                            {
                                <MudButton Variant="Variant.Outlined"
                                           StartIcon="@Icons.Material.Filled.PhotoSizeSelectSmall"
                                           FullWidth="true"
                                           Href="@($"/api/v1/assets/{AssetId}/thumb/download")"
                                           Target="_blank">
                                    @CommonLoc["Btn_DownloadThumbnail"]
                                </MudButton>
                            }

                            @if (RolePermissions.CanShare(_asset?.UserRole))
                            {
                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.Share"
                                       FullWidth="true"
                                       OnClick="ShareAssetAsync">
                                @CommonLoc["Btn_Share"]
                            </MudButton>
                            }

                            @if (RolePermissions.CanEdit(_asset?.UserRole))
                            {
                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       FullWidth="true"
                                       OnClick="EditAssetAsync">
                                @AssetLoc["EditDetails"]
                            </MudButton>
                            }

                            @if (RolePermissions.CanEdit(_asset?.UserRole)
                                 && _asset?.AssetType == Constants.AssetTypeFilters.Image
                                 && _asset?.Status == Constants.AssetStatus.Ready)
                            {
                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.Tune"
                                       FullWidth="true"
                                       OnClick="@(() => Nav.NavigateTo($"/assets/{AssetId}/edit" + (ReturnUrl != null ? $"?returnUrl={Uri.EscapeDataString(ReturnUrl)}" : "")))">
                                @EditorLoc["Btn_EditImage"]
                            </MudButton>
                            }

                            @if (RolePermissions.CanEdit(_asset?.UserRole)
                                 && _asset is { HasEditDocument: true }
                                 && _asset.AssetType == Constants.AssetTypeFilters.Image
                                 && _asset.Status == Constants.AssetStatus.Ready)
                            {
                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.History"
                                       FullWidth="true"
                                       OnClick="@(() => Nav.NavigateTo($"/assets/{AssetId}/edit?reedit=true" + (ReturnUrl != null ? $"&returnUrl={Uri.EscapeDataString(ReturnUrl)}" : "")))">
                                @EditorLoc["Btn_ReEdit"]
                            </MudButton>
                            }

                            @if (RolePermissions.CanDelete(_asset?.UserRole))
                            {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       FullWidth="true"
                                       OnClick="DeleteAssetAsync">
                                @CommonLoc["Btn_Delete"]
                            </MudButton>
                            }
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
}

@code {
    [Parameter]
    public Guid AssetId { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private AssetResponseDto? _asset;
    private List<AssetCollectionDto> _assetCollections = new();
    private List<AssetDerivativeDto> _derivatives = new();
    private bool _isLoading = true;
    private bool _isPollingProcessing;
    private CancellationTokenSource _cts = new();

    protected override async Task OnParametersSetAsync()
    {
        // Cancel any in-flight request from a previous AssetId
        await _cts.CancelAsync();
        _cts.Dispose();
        _cts = new CancellationTokenSource();
        await LoadAssetAsync();
    }

    private async Task LoadAssetAsync()
    {
        try
        {
            _isLoading = true;
            _asset = await Api.GetAssetAsync(AssetId, _cts.Token);
            await LoadAssetCollectionsAsync();
            await LoadDerivativesAsync();
        }
        catch (OperationCanceledException)
        {
            // Navigation to different asset or disposal — ignore
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load asset");
            _asset = null;
        }
        finally
        {
            _isLoading = false;
        }

        if (_asset?.Status == Constants.AssetStatus.Processing)
        {
            _ = PollUntilProcessedAsync();
        }
    }

    private async Task PollUntilProcessedAsync()
    {
        const int maxAttempts = 40;
        const int pollIntervalMs = 3000;

        _isPollingProcessing = true;

        try
        {
            for (int attempt = 0; attempt < maxAttempts; attempt++)
            {
                await Task.Delay(pollIntervalMs, _cts.Token);

                try
                {
                    var refreshed = await Api.GetAssetAsync(AssetId, _cts.Token);

                    if (refreshed is null || refreshed.Status == Constants.AssetStatus.Failed
                        || refreshed.Status == Constants.AssetStatus.Ready)
                    {
                        _asset = refreshed;
                        _isPollingProcessing = false;
                        await InvokeAsync(StateHasChanged);
                        return;
                    }
                }
                catch (OperationCanceledException) { return; }
                catch { /* polling error — retry next attempt */ }
            }

            // Timeout — stop polling, asset stays in current state
            _isPollingProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
            // Disposed or navigated away
        }
    }

    private async Task LoadAssetCollectionsAsync()
    {
        try
        {
            _assetCollections = await Api.GetAssetCollectionsAsync(AssetId, _cts.Token);
        }
        catch (OperationCanceledException)
        {
            // Cancelled — ignore
        }
        catch (Exception ex)
        {
            _assetCollections = new();
            Feedback.HandleError(ex, "load collections");
        }
    }

    private async Task LoadDerivativesAsync()
    {
        try
        {
            _derivatives = await Api.GetAssetDerivativesAsync(AssetId, _cts.Token);
        }
        catch (OperationCanceledException)
        {
            // Cancelled — ignore
        }
        catch
        {
            _derivatives = new();
        }
    }

    private async Task OpenAddToCollectionDialogAsync()
    {
        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Small, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var parameters = new DialogParameters<AddToCollectionDialog>
        {
            { x => x.AssetId, AssetId },
            { x => x.ExistingCollectionIds, _assetCollections.Select(c => c.Id).ToList() }
        };

        var dialog = await DialogService.ShowAsync<AddToCollectionDialog>(AssetLoc["AddToCollection"], parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled)
        {
            await LoadAssetCollectionsAsync();
            StateHasChanged();
            Feedback.ShowSuccess(CommonLoc["Success_AddedToCollection"].Value);
        }
    }

    private async Task RemoveFromCollectionAsync(AssetCollectionDto collection)
    {
        var message = string.Format(AssetLoc["ConfirmRemoveFromCollection"].Value, collection.Name);

        var confirmed = await DialogService.ShowConfirmAsync(
            AssetLoc["RemoveFromCollection"],
            message,
            CommonLoc["Btn_Remove"],
            Icons.Material.Filled.FolderOff,
            Color.Warning,
            Color.Error);

        if (!confirmed) return;

        try
        {
            await Api.RemoveAssetFromCollectionAsync(AssetId, collection.Id);
            _assetCollections.RemoveAll(c => c.Id == collection.Id);
            StateHasChanged();
            Feedback.ShowSuccess(string.Format(CommonLoc["Success_RemovedFromCollection"].Value, collection.Name));
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "remove from collection");
        }
    }

    private string GetPreviewUrl()
    {
        if (_asset == null) return "";

        // Use medium rendition for images
        if (_asset.AssetType == Constants.AssetTypeFilters.Image && !string.IsNullOrEmpty(_asset.MediumObjectKey))
        {
            return $"/api/v1/assets/{_asset.Id}/medium";
        }

        // Video and PDF use the inline preview endpoint
        if (_asset.AssetType == Constants.AssetTypeFilters.Video ||
            AssetDisplayHelpers.IsPdfContentType(_asset.ContentType))
        {
            return $"/api/v1/assets/{_asset.Id}/preview";
        }

        // Fallback to original
        return $"/api/v1/assets/{_asset.Id}/download";
    }

    private string GetPosterUrl()
    {
        if (_asset == null) return "";
        if (!string.IsNullOrEmpty(_asset.PosterObjectKey))
            return $"/api/v1/assets/{_asset.Id}/poster";
        return "";
    }

    private string GetDownloadUrl()
    {
        return $"/api/v1/assets/{AssetId}/download";
    }

    private async Task ShareAssetAsync()
    {
        if (_asset == null) return;

        await DialogService.ShowShareFlowAsync(
            _asset.Id,
            Constants.ScopeTypes.Asset,
            _asset.Title,
            AssetLoc["CreateShareLink"],
            AssetLoc["ShareLinkCreated"]);
    }

    private async Task EditAssetAsync()
    {
        if (_asset == null) return;

        var parameters = new DialogParameters<EditAssetDialog>
        {
            { x => x.Asset, _asset }
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Small, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<EditAssetDialog>(AssetLoc["EditAssetDetails"], parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is AssetResponseDto updatedAsset)
        {
            _asset = updatedAsset;
            Feedback.ShowSuccess(AssetLoc["AssetUpdatedSuccess"].Value);
            StateHasChanged();
        }
    }

    private async Task DeleteAssetAsync()
    {
        if (_asset == null) return;

        var parameters = new DialogParameters<DeleteAssetDialog>
        {
            { x => x.AssetId, _asset.Id },
            { x => x.AssetTitle, _asset.Title }
        };

        var dialog = await DialogService.ShowAsync<DeleteAssetDialog>(null, parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is string)
        {
            var deletedTitle = _asset.Title;
            var deletedId = _asset.Id;

            var success = await Feedback.ExecuteWithFeedbackAsync(
                () => Api.DeleteAssetAsync(deletedId),
                "delete asset",
                successMessage: null);

            if (success)
            {
                // Soft-delete (T1-LIFE-01). Show an undo snackbar AFTER navigating back so the
                // user lands on the listing where the asset has already disappeared and can
                // hit Undo within 10 s to restore it without browsing the admin Trash tab.
                NavigateBackToAssets();
                Feedback.ShowActionableInfo(
                    string.Format(AdminLoc["Trash_DeleteSnackbar"].Value, deletedTitle),
                    AdminLoc["Trash_DeleteSnackbar_Undo"].Value,
                    async () =>
                    {
                        try { await Api.RestoreFromTrashAsync(deletedId); }
                        catch { Feedback.ShowError(CommonLoc["Error_RestoreFailed"].Value); }
                    });
            }
        }
    }

    private void NavigateBackToAssets()
    {
        var safeUrl = UrlSafetyHelper.SafeReturnUrl(ReturnUrl, "/collections");
        Nav.NavigateTo(safeUrl);
    }

    public ValueTask DisposeAsync()
    {
        _cts.Cancel();
        _cts.Dispose();
        return ValueTask.CompletedTask;
    }
}
