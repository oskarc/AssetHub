@page "/assets/{Id:guid}/edit"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Logging
@attribute [Authorize]
@implements IAsyncDisposable

@using AssetHub.Application.Helpers
@using AssetHub.Ui.Components

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject IStringLocalizer<ImageEditorResource> Loc
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IJSRuntime JS
@inject IUserFeedbackService Feedback
@inject ILogger<ImageEditor> Logger
@inject Microsoft.AspNetCore.Components.Forms.AntiforgeryStateProvider Antiforgery

<PageTitle>@(_isLoading ? Loc["Editor_Loading"] : _asset?.Title ?? Loc["Error_AssetNotFound"]) - @CommonLoc["AppName"]</PageTitle>

@if (_isLoading)
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">@Loc["Editor_Loading"]</MudText>
        </MudStack>
    </MudContainer>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
        <EmptyState Title="@Loc["Error_AssetNotFound"]"
                    Description="@_errorMessage"
                    Icon="@Icons.Material.Filled.BrokenImage"
                    ActionText="@Loc["Btn_BackToAsset"]"
                    ActionIcon="@Icons.Material.Filled.ArrowBack"
                    OnAction="@NavigateBack" />
    </MudContainer>
}
else
{
    <div class="editor-page">
        <MudOverlay Visible="_isSaving" Absolute="true" ZIndex="99999" Class="saving-overlay">
            <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="saving-overlay-content">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                <MudText Typo="Typo.h6" Class="saving-overlay-title">@_savingOverlayText</MudText>
                <MudText Typo="Typo.body2" Class="saving-overlay-hint">@_savingOverlayHint</MudText>
            </MudStack>
        </MudOverlay>

        <EditorToolbar IsCropping="_isCropping"
                       IsSaving="_isSaving"
                       HasUnsavedChanges="_hasUnsavedChanges"
                       CropAspect="_cropAspect"
                       OnNavigateBack="NavigateBack"
                       OnStartCrop="@(() => StartCropAsync(null))"
                       OnApplyCrop="ApplyCropAsync"
                       OnCancelCrop="CancelCropAsync"
                       OnSetCropAspect="SetCropAspectAsync"
                       OnRotate="RotateAsync"
                       OnFlip="FlipAsync"
                       OnResize="OpenResizeDialogAsync"
                       OnAddText="AddTextLayerAsync"
                       OnAddShape="AddShapeAsync"
                       OnAddRedaction="AddRedactionAsync"
                       OnSave="OnToolbarSaveAsync" />

        @* ── Main Content: Layers | Canvas | Inspector ── *@
        <div class="editor-main">
            <EditorLayerPanel Layers="_layers"
                              SelectedLayerId="_selectedLayerId"
                              OnDuplicateSelected="DuplicateSelectedAsync"
                              OnDeleteSelected="DeleteSelectedAsync"
                              OnSelectLayer="SelectLayerAsync"
                              OnToggleLayerVisible="ToggleLayerVisibleAsync"
                              OnToggleLayerLocked="ToggleLayerLockedAsync"
                              OnReorderLayer="OnReorderLayerAsync" />

            @* ── Canvas ── *@
            <div class="editor-canvas-area">
                <div id="@EditorContainerId" class="editor-container"></div>
            </div>

            <EditorInspectorPanel SelectedLayerProps="_selectedLayerProps"
                                  OnUpdateProp="OnInspectorUpdatePropAsync"
                                  OnToggleFontStyle="ToggleFontStyleAsync"
                                  OnCornerRadiusChanged="OnCornerRadiusChangedAsync" />
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "reedit")]
    public bool ReEdit { get; set; }

    private const string EditorContainerId = "image-editor-container";

    private AssetResponseDto? _asset;
    private bool _isLoading = true;
    private string? _errorMessage;
    private bool _hasUnsavedChanges;
    private bool _isSaving;
    // S4487 false positive: bound to <EditorToolbar IsCropping="_isCropping" CropAspect="_cropAspect" />
    // — Sonar's analyser doesn't follow Razor markup back to fields it parameter-binds.
    [System.Diagnostics.CodeAnalysis.SuppressMessage("Major Code Smell", "S4487:Unread \"private\" fields should be removed", Justification = "Read by Razor markup binding to child component parameters.")]
    private bool _isCropping;
    [System.Diagnostics.CodeAnalysis.SuppressMessage("Major Code Smell", "S4487:Unread \"private\" fields should be removed", Justification = "Read by Razor markup binding to child component parameters.")]
    private double? _cropAspect;
    private bool _navigationConfirmed;
    private bool _editorInitStarted;
    private string _savingOverlayText = "";
    private string _savingOverlayHint = "";

    // Layer state
    [System.Diagnostics.CodeAnalysis.SuppressMessage("Major Code Smell", "S4487:Unread \"private\" fields should be removed", Justification = "Read by Razor markup binding to child <EditorLayerPanel Layers=\"_layers\" />.")]
    private List<LayerInfo> _layers = new();
    private string? _selectedLayerId;
    private LayerProps? _selectedLayerProps;

    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<ImageEditor>? _dotNetRef;
    private IDisposable? _locationChangingRegistration;
    private CancellationTokenSource _cts = new();

    protected override async Task OnParametersSetAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
        _cts = new CancellationTokenSource();

        // Dispose the previous JS editor when parameters change (e.g. navigating
        // from one asset's editor to another) so InitEditorAsync re-runs.
        if (_editorInitStarted)
        {
            _editorInitStarted = false;
            if (_jsModule is not null)
            {
                try { await _jsModule.InvokeVoidAsync("dispose"); }
                catch (JSDisconnectedException) { /* circuit gone — JS module is unreachable, nothing to do */ }
            }
        }

        await LoadAssetAsync();
    }

    private async Task LoadAssetAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;

            Logger.LogDebug("Loading asset {AssetId} for image editor", Id);
            _asset = await Api.GetAssetAsync(Id, _cts.Token);

            if (_asset is null)
            {
                Logger.LogWarning("Asset {AssetId} not found", Id);
                _errorMessage = Loc["Error_AssetNotFound"];
                return;
            }

            Logger.LogDebug("Asset {AssetId} loaded: Type={AssetType}, Status={Status}, Size={SizeBytes}",
                Id, _asset.AssetType, _asset.Status, _asset.SizeBytes);

            if (_asset.AssetType != Constants.AssetTypeFilters.Image)
            {
                Logger.LogWarning("Asset {AssetId} is not an image: {AssetType}", Id, _asset.AssetType);
                _errorMessage = Loc["Error_NotAnImage"];
                return;
            }

            if (_asset.Status != Constants.AssetStatus.Ready)
            {
                Logger.LogWarning("Asset {AssetId} is not ready: {Status}", Id, _asset.Status);
                _errorMessage = Loc["Error_NotReady"];
                return;
            }

            if (!RolePermissions.CanEdit(_asset.UserRole))
            {
                Logger.LogWarning("User lacks edit permission for asset {AssetId}, role: {UserRole}", Id, _asset.UserRole);
                _errorMessage = Loc["Error_NoPermission"];
                return;
            }

            const long maxSizeBytes = (long)Constants.Limits.MaxEditorImageSizeMb * 1024 * 1024;
            if (_asset.SizeBytes > maxSizeBytes)
            {
                Logger.LogWarning("Asset {AssetId} too large for editor: {SizeBytes} > {MaxBytes}", Id, _asset.SizeBytes, maxSizeBytes);
                _errorMessage = Loc["Error_TooLarge"];
                return;
            }

            Logger.LogDebug("Asset {AssetId} passed all validation checks for editing", Id);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load asset {AssetId} for image editor", Id);
            _errorMessage = Loc["Error_AssetNotFound"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _locationChangingRegistration = Nav.RegisterLocationChangingHandler(OnLocationChanging);
        }

        if (!_editorInitStarted && _asset is not null && string.IsNullOrEmpty(_errorMessage))
        {
            _editorInitStarted = true;
            await InitEditorAsync();
        }
    }

    private async Task InitEditorAsync()
    {
        try
        {
            Logger.LogDebug("Initializing image editor JS module for asset {AssetId}", Id);

            _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", $"./_content/AssetHub.Ui/js/imageEditor.js?v={BuildInfo.Stamp}");

            _dotNetRef = DotNetObjectReference.Create(this);

            // When re-editing, load the source asset's original image (without baked-in layers)
            // so that restored layers don't appear duplicated on top of the rendered preview.
            var imageUrl = ReEdit && _asset?.SourceAssetId is not null
                ? $"/api/v1/assets/{_asset.SourceAssetId}/preview"
                : $"/api/v1/assets/{Id}/preview";
            var options = new { maxDisplaySize = 2048 };

            Logger.LogDebug("Calling JS init with imageUrl={ImageUrl}, container={ContainerId}", imageUrl, EditorContainerId);

            await _jsModule.InvokeVoidAsync("init",
                EditorContainerId, imageUrl, options, _dotNetRef);

            if (ReEdit && !string.IsNullOrEmpty(_asset?.EditDocument))
            {
                Logger.LogDebug("Loading edit document for asset {AssetId}", Id);
                await _jsModule.InvokeVoidAsync("loadEditDocument", _asset.EditDocument);
            }
        }
        catch (JSDisconnectedException) { /* circuit gone — JS module is unreachable, nothing to do */ }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize image editor for asset {AssetId}", Id);
            _errorMessage = Loc["Error_EditorLoadFailed"];
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnEditorReady()
    {
        Logger.LogDebug("Image editor ready for asset {AssetId}", Id);
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnEditorModified()
    {
        if (!_hasUnsavedChanges)
        {
            _hasUnsavedChanges = true;
            _ = EnableBeforeUnloadAsync();
            InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public void OnEditorError(string message)
    {
        Logger.LogError("Image editor JS error for asset {AssetId}: {ErrorMessage}", Id, message);
        InvokeAsync(() =>
        {
            _errorMessage = Loc["Error_EditorLoadFailed"];
            StateHasChanged();
        });
    }

    [JSInvokable]
    public void OnCropStateChanged(bool isCropping)
    {
        InvokeAsync(() =>
        {
            _isCropping = isCropping;
            StateHasChanged();
        });
    }

    [JSInvokable]
    public void OnSelectionChanged(string? layerId)
    {
        InvokeAsync(async () =>
        {
            _selectedLayerId = layerId;
            await RefreshSelectedLayerPropsAsync();
            StateHasChanged();
        });
    }

    [JSInvokable]
    public void OnLayersChanged(LayerInfo[] layers)
    {
        InvokeAsync(() =>
        {
            _layers = layers?.ToList() ?? new();
            StateHasChanged();
        });
    }

    // ── JS Interop Helpers ──────────────────────────────────────

    private async Task InvokeJsVoidAsync(string identifier, params object?[] args)
    {
        if (_jsModule is null) return;
        try { await _jsModule.InvokeVoidAsync(identifier, args); }
        catch (JSDisconnectedException) { /* circuit gone — JS module is unreachable, nothing to do */ }
    }

    private async Task<T?> InvokeJsAsync<T>(string identifier, params object?[] args)
    {
        if (_jsModule is null) return default;
        try { return await _jsModule.InvokeAsync<T>(identifier, args); }
        catch (JSDisconnectedException) { return default; }
    }

    // ── Crop Methods ───────────────────────────────────────────────

    private async Task StartCropAsync(double? aspect)
    {
        _isCropping = true;
        _cropAspect = aspect;
        StateHasChanged();
        await InvokeJsVoidAsync("startCrop", aspect);
    }

    private async Task SetCropAspectAsync(double? aspect)
    {
        _cropAspect = aspect;
        await InvokeJsVoidAsync("startCrop", aspect);
    }

    private async Task ApplyCropAsync()
    {
        await InvokeJsVoidAsync("applyCrop");
        _isCropping = false;
        _cropAspect = null;
    }

    private async Task CancelCropAsync()
    {
        await InvokeJsVoidAsync("cancelCrop");
        _isCropping = false;
        _cropAspect = null;
    }

    // ── Layer Methods ──────────────────────────────────────────────

    private Task AddTextLayerAsync() => InvokeJsAsync<string>("addText", (object?)null);
    private Task AddShapeAsync(string kind) => InvokeJsAsync<string>("addShape", kind, (object?)null);
    private Task AddRedactionAsync() => InvokeJsAsync<string>("addRedaction");
    private Task DuplicateSelectedAsync() => InvokeJsVoidAsync("duplicateSelected");
    private Task ToggleLayerVisibleAsync(string layerId) => InvokeJsVoidAsync("toggleLayerVisible", layerId);
    private Task ToggleLayerLockedAsync(string layerId) => InvokeJsVoidAsync("toggleLayerLocked", layerId);
    private Task ReorderLayerAsync(string layerId, string direction) => InvokeJsVoidAsync("reorderLayer", layerId, direction);

    private async Task DeleteSelectedAsync()
    {
        await InvokeJsVoidAsync("deleteSelected");
        _selectedLayerId = null;
        _selectedLayerProps = null;
    }

    private async Task SelectLayerAsync(string layerId)
    {
        _selectedLayerId = layerId;
        await InvokeJsVoidAsync("selectLayer", layerId);
        await RefreshSelectedLayerPropsAsync();
    }

    private async Task RefreshSelectedLayerPropsAsync()
    {
        if (_selectedLayerId is null) { _selectedLayerProps = null; return; }
        _selectedLayerProps = await InvokeJsAsync<LayerProps>("getSelectedLayerProps");
    }

    private async Task UpdatePropAsync(string propName, object? value)
    {
        var props = new Dictionary<string, object?> { [propName] = value };
        await InvokeJsVoidAsync("updateSelectedProps", props);
        await RefreshSelectedLayerPropsAsync();
        StateHasChanged();
    }

    private async Task ToggleFontStyleAsync(string style)
    {
        if (_selectedLayerProps is null) return;

        if (style == "bold")
        {
            var newWeight = _selectedLayerProps.FontWeight == "bold" ? "normal" : "bold";
            await UpdatePropAsync("fontWeight", newWeight);
        }
        else if (style == "italic")
        {
            var newStyle = _selectedLayerProps.FontStyle == "italic" ? "normal" : "italic";
            await UpdatePropAsync("fontStyle", newStyle);
        }
    }

    // ── Bridge methods for child component callbacks ──────────────

    private Task OnReorderLayerAsync((string LayerId, string Direction) args) =>
        ReorderLayerAsync(args.LayerId, args.Direction);

    private Task OnInspectorUpdatePropAsync((string PropName, object? Value) args) =>
        UpdatePropAsync(args.PropName, args.Value);

    private async Task OnCornerRadiusChangedAsync(int value)
    {
        await UpdatePropAsync("rx", value);
        await UpdatePropAsync("ry", value);
    }

    private Task RotateAsync(int degrees) => InvokeJsVoidAsync("rotate", degrees);
    private Task FlipAsync(string axis) => InvokeJsVoidAsync("flip", axis);

    private async Task OpenResizeDialogAsync()
    {
        var sizeInfo = await InvokeJsAsync<CanvasSizeInfo>("getCanvasSize");
        if (sizeInfo is null) return;

        var parameters = new DialogParameters<ResizeDialog>
        {
            { x => x.CurrentWidth, sizeInfo.FullResWidth > 0 ? sizeInfo.FullResWidth : sizeInfo.Width },
            { x => x.CurrentHeight, sizeInfo.FullResHeight > 0 ? sizeInfo.FullResHeight : sizeInfo.Height }
        };
        var dlgOptions = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<ResizeDialog>(
            Loc["Btn_Resize"], parameters, dlgOptions);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;
        if (result.Data is not ResizeDialog.ResizeResult resizeData) return;

        await InvokeJsVoidAsync("resize", resizeData.Width, resizeData.Height);
    }

    private Task OnToolbarSaveAsync(EditorToolbar.SaveMethod method) => SaveWithMethodAsync(method);

    private Task SaveWithMethodAsync(EditorToolbar.SaveMethod method) => method switch
    {
        EditorToolbar.SaveMethod.Replace => SaveReplaceFlowAsync(),
        EditorToolbar.SaveMethod.ExportWithPresets => SaveWithPresetsFlowAsync(),
        _ => SaveCopyFlowAsync(),
    };

    private async Task SaveReplaceFlowAsync()
    {
        var confirmed = await DialogService.ShowConfirmAsync(
            Loc["SaveDialog_ConfirmReplaceTitle"],
            Loc["SaveDialog_ConfirmReplaceMessage"],
            Loc["Btn_ReplaceOriginal"],
            Icons.Material.Filled.Warning,
            Color.Warning,
            Color.Error);
        if (!confirmed) return;

        await ShowSavingOverlayAsync();
        await SaveAsReplaceAsync();
    }

    private async Task SaveWithPresetsFlowAsync()
    {
        var isManager = RolePermissions.CanDelete(_asset?.UserRole);
        var presetsParams = new DialogParameters<ExportPresetsDialog>
        {
            { x => x.ShowReplaceToggle, isManager }
        };
        var presetsOptions = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var presetsDialog = await DialogService.ShowAsync<ExportPresetsDialog>(
            Loc["ExportPresets_Title"], presetsParams, presetsOptions);
        var presetsResult = await presetsDialog.Result;

        if (presetsResult is null || presetsResult.Canceled) return;
        if (presetsResult.Data is not ExportPresetsDialog.ExportPresetsResult presetsData) return;

        await ShowSavingOverlayAsync();
        await SaveWithPresetsAsync(presetsData.PresetIds, presetsData.AlsoReplace);
    }

    private async Task SaveCopyFlowAsync()
    {
        var defaultFormat = _asset!.ContentType == "image/png" ? "png" : "jpeg";
        var defaultTitle = _asset.Title + " (edited)";

        Guid? sourceCollectionId = null;
        try
        {
            var assetCollections = await Api.GetAssetCollectionsAsync(Id, _cts.Token);
            sourceCollectionId = assetCollections.FirstOrDefault()?.Id;
        }
        catch { /* Non-critical: copy still works without a default collection */ }

        var copyParams = new DialogParameters<SaveImageCopyDialog>
        {
            { x => x.DefaultTitle, defaultTitle },
            { x => x.DefaultFormat, defaultFormat },
            { x => x.SourceCollectionId, sourceCollectionId }
        };
        var copyOptions = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var copyDialog = await DialogService.ShowAsync<SaveImageCopyDialog>(
            Loc["SaveCopyDialog_Title"], copyParams, copyOptions);
        var copyResult = await copyDialog.Result;

        if (copyResult is null || copyResult.Canceled) return;
        if (copyResult.Data is not SaveImageCopyDialog.SaveCopyResult copyData) return;

        await ShowSavingOverlayAsync();
        await SaveAsCopyAsync(copyData.Title, copyData.CollectionId);
    }

    private async Task ShowSavingOverlayAsync()
    {
        _isSaving = true;
        _savingOverlayText = Loc["Progress_SavingOverlay"];
        _savingOverlayHint = Loc["Progress_SavingOverlayHint"];
        StateHasChanged();
        await Task.Yield();
    }

    /// <summary>
    /// Result from the JS saveEdit fetch call. Defaults make the
    /// "JS interop never returned" path explicit instead of leaving
    /// the properties as default(bool/int) without a written assignment
    /// (S3459); deserialisation overwrites them when the JS call succeeds.
    /// </summary>
    private sealed class JsSaveResult
    {
        public bool Ok { get; set; } = false;
        public int Status { get; set; } = 0;
        public ImageEditResultDto? Body { get; set; }
    }

    private async Task ExecuteSaveAsync(
        string logDescription,
        string fileName,
        string saveMode,
        object? options = null,
        Func<ImageEditResultDto, string>? getNavigateUrl = null,
        Action<ImageEditResultDto>? onBeforeNavigate = null)
    {
        if (_jsModule is null) return;

        try
        {
            // The JS saveEdit function exports the canvas and POSTs it directly
            // to the API via fetch(), bypassing the SignalR circuit entirely.
            // Cookie-authenticated mutations need the antiforgery token (P-12 /
            // A-7); the JS fetch can't read the HttpOnly cookie, so we hand it
            // the request token to embed as X-CSRF-TOKEN.
            Logger.LogInformation("Saving image via JS fetch: {Description} for asset {AssetId}", logDescription, Id);
            var csrfToken = Antiforgery.GetAntiforgeryToken()?.Value ?? string.Empty;
            var result = await _jsModule.InvokeAsync<JsSaveResult?>("saveEdit",
                Id.ToString(), fileName, saveMode, options, csrfToken);

            if (result is null || !result.Ok || result.Body is null)
            {
                var status = result?.Status ?? 0;
                Logger.LogError("JS saveEdit failed for asset {AssetId}: HTTP {StatusCode}", Id, status);
                Feedback.ShowError(status > 0
                    ? $"{Loc["Error_SaveFailed"].Value} ({status})"
                    : Loc["Error_SaveFailed"].Value);
                return;
            }

            _hasUnsavedChanges = false;
            await DisableBeforeUnloadAsync();
            await InvokeJsVoidAsync("clearUnsavedChanges");

            onBeforeNavigate?.Invoke(result.Body);

            _savingOverlayText = Loc["Progress_ProcessingOverlay"];
            _savingOverlayHint = Loc["Progress_ProcessingOverlayHint"];
            StateHasChanged();

            await WaitForProcessingAsync(result.Body.AssetId);

            _navigationConfirmed = true;
            var url = getNavigateUrl?.Invoke(result.Body) ?? "/assets/" + result.Body.AssetId;
            Nav.NavigateTo(url);
        }
        catch (JSDisconnectedException) { /* circuit gone — JS module is unreachable, nothing to do */ }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed {Description} for asset {AssetId}", logDescription, Id);
            Feedback.ShowError(Loc["Error_SaveFailed"].Value);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private Task SaveAsReplaceAsync() => ExecuteSaveAsync(
        "saving image replacement",
        _asset!.Title + ".png",
        "Replace",
        getNavigateUrl: _ =>
        {
            var returnUrl = ReturnUrl is not null ? "?returnUrl=" + Uri.EscapeDataString(ReturnUrl) : "";
            return "/assets/" + Id + returnUrl;
        });

    private Task SaveAsCopyAsync(string title, Guid? collectionId) => ExecuteSaveAsync(
        "saving image copy",
        title + ".png",
        "Copy",
        options: new { title, destinationCollectionId = collectionId?.ToString() });

    private Task SaveWithPresetsAsync(Guid[] presetIds, bool alsoReplace) => ExecuteSaveWithPresetsAsync(presetIds, alsoReplace);

    private async Task ExecuteSaveWithPresetsAsync(Guid[] presetIds, bool alsoReplace)
    {
        if (_jsModule is null) return;

        try
        {
            var fileName = _asset!.Title + ".png";

            // If also replacing, do that first via a separate saveEdit call.
            if (alsoReplace)
            {
                Logger.LogInformation("Replacing original before preset export for asset {AssetId}", Id);
                var csrfToken = Antiforgery.GetAntiforgeryToken()?.Value ?? string.Empty;
                var replaceResult = await _jsModule.InvokeAsync<JsSaveResult?>("saveEdit",
                    Id.ToString(), fileName, "Replace", null, csrfToken);

                if (replaceResult is null || !replaceResult.Ok)
                {
                    Logger.LogError("Failed to replace original for asset {AssetId} during preset export: HTTP {StatusCode}",
                        Id, replaceResult?.Status ?? 0);
                    Feedback.ShowError(Loc["Error_ReplaceFailed"].Value);
                }
            }

            // Now do the CopyWithPresets save.
            await ExecuteSaveAsync(
                "saving image with presets",
                fileName,
                "CopyWithPresets",
                options: new
                {
                    title = _asset.Title,
                    presetIds = presetIds.Select(p => p.ToString()).ToArray()
                },
                onBeforeNavigate: _ =>
                {
                    Feedback.ShowSuccess(string.Format(Loc["ExportPresets_Success"].Value, presetIds.Length));
                });
        }
        catch (JSDisconnectedException) { /* circuit gone — JS module is unreachable, nothing to do */ }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed saving with presets for asset {AssetId}", Id);
            Feedback.ShowError(Loc["Error_SaveFailed"].Value);
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task WaitForProcessingAsync(Guid assetId)
    {
        const int maxAttempts = 30;
        var delayMs = 500;

        for (var attempt = 0; attempt < maxAttempts; attempt++)
        {
            await Task.Delay(delayMs, _cts.Token);

            try
            {
                var asset = await Api.GetAssetAsync(assetId, _cts.Token);
                if (asset is null || asset.Status != Constants.AssetStatus.Processing)
                    return;
            }
            catch (OperationCanceledException) { throw; }
            catch { /* polling error — retry */ }

            // Exponential backoff: 500ms, 1s, 2s, 3s, 3s, ...
            delayMs = Math.Min(delayMs * 2, 3000);
        }
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!_hasUnsavedChanges || _navigationConfirmed) return;

        context.PreventNavigation();

        var confirmed = await DialogService.ShowConfirmAsync(
            CommonLoc["Title_LeavePageConfirm"],
            Loc["Text_UnsavedChanges"],
            CommonLoc["Btn_LeavePage"],
            Icons.Material.Filled.Warning,
            Color.Warning,
            Color.Error);

        if (confirmed)
        {
            _navigationConfirmed = true;
            await _cts.CancelAsync();
            Nav.NavigateTo(context.TargetLocation);
        }
    }

    private void NavigateBack()
    {
        // Do NOT set _navigationConfirmed here — let OnLocationChanging show
        // the unsaved-changes dialog when _hasUnsavedChanges is true.
        var returnUrl = ReturnUrl is not null ? "?returnUrl=" + Uri.EscapeDataString(ReturnUrl) : "";
        Nav.NavigateTo("/assets/" + Id + returnUrl);
    }

    private Task EnableBeforeUnloadAsync() => InvokeJsVoidAsync("enableBeforeUnload");
    private Task DisableBeforeUnloadAsync() => InvokeJsVoidAsync("disableBeforeUnload");



    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
        _locationChangingRegistration?.Dispose();
        await DisableBeforeUnloadAsync();

        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("dispose");
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit gone — JS module is unreachable, nothing to do */ }
        }

        _dotNetRef?.Dispose();
    }
}
