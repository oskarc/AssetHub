# Ignore the contents of certs/ (private keys, dev cert) but keep the
# directory tracked via .gitkeep so CI checkouts have it on disk —
# the Dockerfile's unconditional COPY certs/ otherwise fails with
# "/certs: not found". A bare "certs/" rule excludes the directory
# itself, which would block any !certs/<file> negation below.
certs/*
!certs/.gitkeep
.claude/settings.local.json
Claude-Processing.md
Copilot-Processing.md
scripts/sonar-issues-by-file.txt
scripts/sonar-raw.json
