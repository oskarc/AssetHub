@using AssetHub.Application.Dtos
@using AssetHub.Ui.Services

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AssetsResource> AssetLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="dialog-title">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@AssetLoc["EditAssetDetails"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Class="dialog-intro">
                @AssetLoc["EditAssetDetailsDesc"]
            </MudText>

            <MudForm @ref="_form" @bind-IsValid="_isValid">
                <!-- Basic Info Section -->
                <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                    <div class="dialog-section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                        @CommonLoc["Label_BasicInfo"]
                    </div>
                    <MudTextField @bind-Value="_title"
                                  Label="@CommonLoc["Label_Title"]"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="@AssetLoc["Validation_TitleRequired"]"
                                  Immediate="true"
                                  AutoFocus="true"
                                  Class="mb-2" />

                    <MudTextField @bind-Value="_description"
                                  Label="@AssetLoc["DescriptionOptional"]"
                                  Variant="Variant.Outlined"
                                  Lines="3"
                                  Immediate="true"
                                  Class="mb-2" />

                    <MudTextField @bind-Value="_copyright"
                                  Label="@AssetLoc["CopyrightOptional"]"
                                  Variant="Variant.Outlined"
                                  Lines="3"
                                  Immediate="true" />
                </MudPaper>

                <!-- Tags Section -->
                <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                    <div class="dialog-section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Label" Size="Size.Small" />
                        @CommonLoc["Label_Tags"]
                    </div>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-2">
                        @foreach (var tag in _tags)
                        {
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="Variant.Outlined"
                                     Color="Color.Primary"
                                     OnClose="@(() => RemoveTag(tag))">
                                @tag
                            </MudChip>
                        }
                        @if (_tags.Count == 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@AssetLoc["NoTags"]</MudText>
                        }
                    </MudStack>

                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                        <MudTextField @bind-Value="_newTag"
                                      Label="@CommonLoc["Label_AddTag"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      OnKeyDown="OnTagKeyDown"
                                      Immediate="true"
                                      Class="dialog-flex-fill" />
                        <MudButton Variant="Variant.Outlined"
                                   OnClick="AddTag"
                                   Disabled="@string.IsNullOrWhiteSpace(_newTag)">
                            @CommonLoc["Btn_Add"]
                        </MudButton>
                    </MudStack>
                </MudPaper>

                <!-- Metadata Section -->
                <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                    <div class="dialog-section-title">
                        <MudIcon Icon="@Icons.Material.Filled.DataObject" Size="Size.Small" />
                        @CommonLoc["Text_Metadata"]
                        @if (_metadataFields.Any(f => !f.InitiallyEmpty))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                @_metadataFields.Count(f => !f.InitiallyEmpty) @CommonLoc["Text_Fields"]
                            </MudChip>
                        }
                    </div>

                    @if (_metadataFields.Any(f => !f.InitiallyEmpty))
                    {
                        <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="table-outlined mb-3">
                            <thead>
                                <tr>
                                    <th>@CommonLoc["Label_MetadataKey"]</th>
                                    <th>@CommonLoc["Label_MetadataValue"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var field in _metadataFields.Where(f => !f.InitiallyEmpty))
                                {
                                    <tr>
                                        <td>
                                            <MudText Typo="Typo.body2">@AssetDisplayHelpers.FormatMetadataKey(field.Key)</MudText>
                                        </td>
                                        <td>
                                            <MudTextField @bind-Value="field.Value"
                                                          Variant="Variant.Text"
                                                          Margin="Margin.Dense"
                                                          Immediate="true" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">@CommonLoc["Text_NoMetadata"]</MudText>
                    }

                    @if (_metadataFields.Any(f => f.InitiallyEmpty))
                    {
                        <MudButton Variant="Variant.Text"
                                   Size="Size.Small"
                                   StartIcon="@(_showEmptyFields ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   OnClick="@(() => _showEmptyFields = !_showEmptyFields)"
                                   Class="mb-2">
                            @if (_showEmptyFields)
                            {
                                @CommonLoc["Btn_HideEmptyFields"]
                            }
                            else
                            {
                                @string.Format(CommonLoc["Btn_ShowEmptyFields"].Value, _metadataFields.Count(f => f.InitiallyEmpty))
                            }
                        </MudButton>

                        @if (_showEmptyFields)
                        {
                            <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="table-outlined mb-3">
                                <tbody>
                                    @foreach (var field in _metadataFields.Where(f => f.InitiallyEmpty))
                                    {
                                        <tr>
                                            <td>
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">@AssetDisplayHelpers.FormatMetadataKey(field.Key)</MudText>
                                            </td>
                                            <td>
                                                <MudTextField @bind-Value="field.Value"
                                                              Variant="Variant.Text"
                                                              Margin="Margin.Dense"
                                                              Immediate="true"
                                                              Placeholder="@CommonLoc["Text_EnterValue"]" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    }

                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">@CommonLoc["Text_AddCustomField"]</MudText>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                        <MudTextField @bind-Value="_newMetadataKey"
                                      Label="@CommonLoc["Label_MetadataKey"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      Class="dialog-flex-fill" />
                        <MudTextField @bind-Value="_newMetadataValue"
                                      Label="@CommonLoc["Label_MetadataValue"]"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      Class="dialog-flex-fill" />
                        <MudButton Variant="Variant.Outlined"
                                   OnClick="AddMetadataField"
                                   Disabled="@string.IsNullOrWhiteSpace(_newMetadataKey)">
                            @CommonLoc["Btn_Add"]
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudForm>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CommonLoc["Btn_Cancel"]</MudButton>
        <MudButton OnClick="SaveAsync"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(!_isValid || _isSaving)">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @CommonLoc["Btn_SaveChanges"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public AssetResponseDto Asset { get; set; } = default!;

    private MudForm? _form;
    private string _title = "";
    private string _description = "";
    private string _copyright = "";
    private List<string> _tags = new();
    private string _newTag = "";
    private List<MetadataField> _metadataFields = new();
    private string _newMetadataKey = "";
    private string _newMetadataValue = "";
    private bool _showEmptyFields = false;
    private bool _isValid;
    private bool _isSaving;

    // Standard metadata keys that can be extracted from images
    private static readonly string[] StandardMetadataKeys = new[]
    {
        "artist", "cameraMake", "cameraModel", "dateTaken", "exposureTime",
        "aperture", "iso", "focalLength", "imageWidth", "imageHeight",
        "flash", "software", "gpsLatitude", "gpsLongitude", "credit",
        "caption", "source", "keywords"
    };

    protected override void OnInitialized()
    {
        if (Asset != null)
        {
            _title = Asset.Title;
            _description = Asset.Description ?? "";
            _copyright = Asset.Copyright ?? "";
            _tags = Asset.Tags?.ToList() ?? new();

            // Load existing metadata fields
            if (Asset.MetadataJson != null)
            {
                foreach (var kvp in Asset.MetadataJson.Where(k => k.Key != "error" && k.Key != "metadataExtractionError"))
                {
                    var value = kvp.Value?.ToString() ?? "";
                    _metadataFields.Add(new MetadataField
                    {
                        Key = kvp.Key,
                        Value = value,
                        InitiallyEmpty = string.IsNullOrWhiteSpace(value)
                    });
                }
            }

            // Add empty standard fields that don't exist yet
            foreach (var key in StandardMetadataKeys.Where(key =>
                !_metadataFields.Any(f => f.Key.Equals(key, StringComparison.OrdinalIgnoreCase))))
            {
                _metadataFields.Add(new MetadataField { Key = key, Value = "", InitiallyEmpty = true });
            }

            // Sort: fields with values first, then empty fields
            _metadataFields = _metadataFields
                .OrderByDescending(f => !string.IsNullOrWhiteSpace(f.Value))
                .ThenBy(f => f.Key)
                .ToList();
        }
    }

    private void AddTag()
    {
        var tag = _newTag.Trim();
        if (!string.IsNullOrWhiteSpace(tag) && !_tags.Contains(tag, StringComparer.OrdinalIgnoreCase))
        {
            _tags.Add(tag);
            _newTag = "";
        }
    }

    private void RemoveTag(string tag)
    {
        _tags.Remove(tag);
    }

    private void OnTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTag();
        }
    }

    private void AddMetadataField()
    {
        var key = _newMetadataKey.Trim();
        if (!string.IsNullOrWhiteSpace(key) && !_metadataFields.Any(f => f.Key.Equals(key, StringComparison.OrdinalIgnoreCase)))
        {
            _metadataFields.Insert(0, new MetadataField { Key = key, Value = _newMetadataValue.Trim() });
            _newMetadataKey = "";
            _newMetadataValue = "";
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        if (_form != null)
        {
            await _form.Validate();
            if (!_isValid) return;
        }

        _isSaving = true;

        var metadata = new Dictionary<string, object>();
        foreach (var field in _metadataFields)
        {
            var value = field.Value?.Trim();
            if (!string.IsNullOrWhiteSpace(value))
                metadata[field.Key] = value;
        }
        var dto = new UpdateAssetDto
        {
            Title = _title,
            Description = InputValidation.NormalizeToNull(_description),
            Copyright = InputValidation.NormalizeToNull(_copyright),
            Tags = _tags,
            MetadataJson = metadata
        };
        var (success, updatedAsset) = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.UpdateAssetAsync(Asset.Id, dto),
            "update asset");
        _isSaving = false;

        if (success)
            MudDialog.Close(DialogResult.Ok(updatedAsset));
    }

    private sealed class MetadataField
    {
        public string Key { get; set; } = "";
        public string Value { get; set; } = "";
        public bool InitiallyEmpty { get; set; }
    }
}
