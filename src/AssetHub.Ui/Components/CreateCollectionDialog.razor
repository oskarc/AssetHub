@using AssetHub.Application.Dtos
@using AssetHub.Ui.Services
@using MudBlazor

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<CollectionsResource> CollectionLoc

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.CreateNewFolder" Class="mr-2" />
            @CollectionLoc["CreateCollection"]
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_name"
                          Label="@CollectionLoc["CollectionName"]"
                          Required="true"
                          RequiredError="@CollectionLoc["Validation_NameRequired"]"
                          Immediate="true"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField @bind-Value="_description"
                          Label="@CollectionLoc["DescriptionOptional"]"
                          Lines="3"
                          Variant="Variant.Outlined" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CommonLoc["Btn_Cancel"]</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled"
                   OnClick="CreateAsync"
                   Disabled="@(!_isValid || _isCreating)">
            @if (_isCreating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @CommonLoc["Btn_Create"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm? _form;
    private string _name = "";
    private string _description = "";
    private bool _isValid;
    private bool _isCreating;

    private void Cancel() => MudDialog.Cancel();

    private async Task CreateAsync()
    {
        if (_form != null)
        {
            await _form.Validate();
            if (!_isValid) return;
        }

        try
        {
            _isCreating = true;

            var dto = new CreateCollectionDto
            {
                Name = _name,
                Description = string.IsNullOrWhiteSpace(_description) ? null : _description
            };

            var result = await Api.CreateCollectionAsync(dto);

            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "create collection");
        }
        finally
        {
            _isCreating = false;
        }
    }
}
