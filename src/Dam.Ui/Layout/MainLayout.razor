@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IJSRuntime JS
@inject IHttpContextAccessor HttpContextAccessor

<MudThemeProvider Theme="@_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Menu"
                               Color="Color.Inherit"
                               Edge="Edge.Start"
                               OnClick="@((e) => DrawerToggle())" />
            </Authorized>
        </AuthorizeView>

        <MudText Typo="Typo.h5" Class="ml-3">@CommonLoc["AppName"]</MudText>

        <MudSpacer />

        <!-- Auth: show user + login/logout -->
        <AuthorizeView>
            <Authorized Context="auth">
                <MudText Class="mr-2" Typo="Typo.body2">
                    @DisplayName(auth.User)
                </MudText>

                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomCenter">
                    <MudMenuItem Icon="@Icons.Material.Filled.Lock" OnClick="@ChangePassword">
                        @CommonLoc["Btn_ChangePassword"]
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="@Logout">
                        @CommonLoc["Btn_SignOut"]
                    </MudMenuItem>
                </MudMenu>
            </Authorized>

            <NotAuthorized>
                <MudButton Variant="Variant.Filled"
                           Size="Size.Small"
                           OnClick="@Login"
                           Class="mr-2">
                    @CommonLoc["Btn_SignIn"]
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>

        <LanguageSwitcher />

        <MudIconButton Icon="@(DarkLightModeButtonIcon)"
                       Color="Color.Inherit"
                       OnClick="@DarkModeToggle" />
    </MudAppBar>

    <AuthorizeView>
        <Authorized>
            <MudDrawer id="nav-drawer" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
                <NavMenu />
            </MudDrawer>
        </Authorized>
    </AuthorizeView>

    <MudMainContent Class="pt-16 pa-4">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    @CommonLoc["Error_UnhandledError"]
    <a href="." class="reload">@CommonLoc["Error_Reload"]</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private MudTheme? _theme = null;
    private IJSObjectReference? _jsModule;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        // Read dark mode preference from cookie so SSR renders the correct theme
        // (avoids flash when page reloads, e.g. on language switch)
        var cookies = HttpContextAccessor.HttpContext?.Request.Cookies;
        if (cookies != null && cookies.TryGetValue("darkMode", out var dm))
        {
            _isDarkMode = !string.Equals(dm, "false", StringComparison.OrdinalIgnoreCase);
        }

        _theme = new()
        {
            PaletteLight = _lightPalette,
            PaletteDark = _darkPalette,
            LayoutProperties = new LayoutProperties()
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Dam.Ui/js/helpers.js");
            var stored = await _jsModule.InvokeAsync<string?>("getLocalStorage", "darkMode");
            if (stored != null)
            {
                _isDarkMode = stored == "true";
                // Sync cookie with localStorage value so next SSR uses correct theme
                await _jsModule.InvokeVoidAsync("setCookie", "darkMode", stored, 31536000);
                StateHasChanged();
            }
        }
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private async Task DarkModeToggle()
    {
        _isDarkMode = !_isDarkMode;
        if (_jsModule != null)
        {
            var val = _isDarkMode.ToString().ToLowerInvariant();
            await _jsModule.InvokeVoidAsync("setLocalStorage", "darkMode", val);
            await _jsModule.InvokeVoidAsync("setCookie", "darkMode", val, 31536000);
        }
    }

    private void Login()
    {
        // forceLoad = true so we do a full navigation and the OIDC middleware takes over
        Nav.NavigateTo("/auth/login", forceLoad: true);
    }

    private void ChangePassword()
    {
        Nav.NavigateTo("/auth/change-password", forceLoad: true);
    }

    private void Logout()
    {
        Nav.NavigateTo("/auth/logout", forceLoad: true);
    }

    private static string DisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        var name = user.Identity?.Name;

        if (!string.IsNullOrWhiteSpace(name))
            return name;

        return user.FindFirst("preferred_username")?.Value
            ?? user.FindFirst("email")?.Value
            ?? "Signed In";
    }

    private readonly PaletteLight _lightPalette = new()
    {
        Black = "#110e2d",
        Primary = "#5171a5",
        Secondary = "#607d8b",
        AppbarText = "#424242",
        AppbarBackground = "rgba(255,255,255,0.8)",
        DrawerBackground = "#ffffff",
        GrayLight = "#e8e8e8",
        GrayLighter = "#f9f9f9",
    };

    private readonly PaletteDark _darkPalette = new()
    {
        Primary = "#6b8cae",
        Secondary = "#78909c",
        Surface = "#1e1e2d",
        Background = "#1a1a27",
        BackgroundGray = "#151521",
        AppbarText = "#92929f",
        AppbarBackground = "rgba(26,26,39,0.8)",
        DrawerBackground = "#1a1a27",
        ActionDefault = "#74718e",
        ActionDisabled = "#9999994d",
        ActionDisabledBackground = "#605f6d4d",
        TextPrimary = "#b2b0bf",
        TextSecondary = "#92929f",
        TextDisabled = "#ffffff33",
        DrawerIcon = "#92929f",
        DrawerText = "#92929f",
        GrayLight = "#2a2833",
        GrayLighter = "#1e1e2d",
        Info = "#4a86ff",
        Success = "#3dcb6c",
        Warning = "#ffb545",
        Error = "#ff3f5f",
        LinesDefault = "#33323e",
        TableLines = "#33323e",
        Divider = "#292838",
        OverlayLight = "#1e1e2d80",
    };

    public string DarkLightModeButtonIcon => _isDarkMode switch
    {
        true => Icons.Material.Rounded.AutoMode,
        false => Icons.Material.Outlined.DarkMode,
    };
}