  <data name="Dialog_Field_ExpiresInDays" xml:space="preserve"><value>Löper ut om (dagar)</value></data>
  <data name="Dialog_Submit" xml:space="preserve"><value>Skicka inbjudan</value></data>
  <data name="Dialog_Cancel" xml:space="preserve"><value>Avbryt</value></data>

