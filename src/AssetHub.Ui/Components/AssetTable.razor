@using AssetHub.Application
@using AssetHub.Application.Dtos
@using AssetHub.Ui.Services

@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AssetsResource> AssetLoc

<MudTable Items="@Items" Hover="true" Dense="true" Elevation="2" Breakpoint="Breakpoint.Sm">
    <HeaderContent>
        @if (SelectionMode)
        {
            <MudTh Class="col-w-42"></MudTh>
        }
        <MudTh></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssetResponseDto, object>(x => x.Title)">@AssetLoc["Column_Title"]</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssetResponseDto, object>(x => x.AssetType)">@CommonLoc["Label_Type"]</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssetResponseDto, object>(x => x.SizeBytes)">@AssetLoc["Column_Size"]</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="new Func<AssetResponseDto, object>(x => x.CreatedAt)">@AssetLoc["Column_Created"]</MudTableSortLabel></MudTh>
        @if (!SelectionMode)
        {
            <MudTh Class="col-text-right">@AssetLoc["Column_Actions"]</MudTh>
        }
    </HeaderContent>
    <RowTemplate>
        @if (SelectionMode)
        {
            <MudTd @onclick:stopPropagation="true">
                <MudCheckBox T="bool"
                             Value="@SelectedAssetIds.Contains(context.Id)"
                             ValueChanged="@(v => OnToggleSelection.InvokeAsync((context.Id, v)))"
                             Size="Size.Small"
                             Color="Color.Primary"
                             Class="checkbox-compact" />
            </MudTd>
        }
        <MudTd DataLabel="" Class="col-icon">
            <MudAvatar Rounded="true" Size="Size.Medium" Class="clickable" @onclick="() => OnRowClick(context)">
                <MudImage Src="@AssetDisplayHelpers.GetThumbnailUrl(context.Id, context.ThumbObjectKey, context.AssetType, context.PosterObjectKey)"
                          Alt="@context.Title"
                          ObjectFit="ObjectFit.Cover"
                          Width="40" Height="40"
                          loading="lazy" />
            </MudAvatar>
        </MudTd>
        <MudTd DataLabel="@AssetLoc["Column_Title"]">
            <MudLink OnClick="@(() => OnRowClick(context))" Underline="Underline.Hover">
                @context.Title
            </MudLink>
        </MudTd>
        <MudTd DataLabel="@CommonLoc["Label_Type"]">
            <MudChip T="string" Size="Size.Small"
                     Color="@AssetDisplayHelpers.GetAssetTypeColor(context.AssetType)"
                     Variant="Variant.Outlined">
                @CommonLoc[AssetDisplayHelpers.GetAssetTypeKey(context.AssetType)]
            </MudChip>
        </MudTd>
        <MudTd DataLabel="@AssetLoc["Column_Size"]">
            @AssetDisplayHelpers.FormatFileSize(context.SizeBytes)
        </MudTd>
        <MudTd DataLabel="@AssetLoc["Column_Created"]">
            <MudTooltip Text="@context.CreatedAt.ToLocalTime().ToString("F")">
                <span>@context.CreatedAt.ToLocalTime().ToString("g")</span>
            </MudTooltip>
        </MudTd>
        <MudTd DataLabel="@AssetLoc["Column_Actions"]" Class="col-text-right">
            @if (!SelectionMode)
            {
            @if (CanShare)
            {
                <MudTooltip Text="@CommonLoc["Btn_Share"]">
                    <MudIconButton Icon="@Icons.Material.Filled.Share"
                                   Size="Size.Small"
                                   OnClick="@(() => OnShare.InvokeAsync(context))" />
                </MudTooltip>
            }
            @if (CanDelete)
            {
                <MudTooltip Text="@CommonLoc["Btn_Delete"]">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="@(() => OnDelete.InvokeAsync(context))" />
                </MudTooltip>
            }
            }
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    [Parameter, EditorRequired]
    public List<AssetResponseDto> Items { get; set; } = new();

    [Parameter]
    public bool SelectionMode { get; set; }

    [Parameter]
    public HashSet<Guid> SelectedAssetIds { get; set; } = new();

    [Parameter]
    public string UserRole { get; set; } = RoleHierarchy.Roles.Viewer;

    [Parameter]
    public EventCallback<AssetResponseDto> OnAssetClick { get; set; }

    [Parameter]
    public EventCallback<(Guid Id, bool Selected)> OnToggleSelection { get; set; }

    [Parameter]
    public EventCallback<AssetResponseDto> OnShare { get; set; }

    [Parameter]
    public EventCallback<AssetResponseDto> OnDelete { get; set; }

    private bool CanShare => RolePermissions.CanShare(UserRole);
    private bool CanDelete => RolePermissions.CanDelete(UserRole);

    private async Task OnRowClick(AssetResponseDto asset)
    {
        if (SelectionMode)
        {
            await OnToggleSelection.InvokeAsync((asset.Id, !SelectedAssetIds.Contains(asset.Id)));
            return;
        }
        await OnAssetClick.InvokeAsync(asset);
    }
}
