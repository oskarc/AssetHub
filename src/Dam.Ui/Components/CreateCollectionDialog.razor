@using Dam.Application.Dtos
@using Dam.Ui.Services
@using MudBlazor

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.CreateNewFolder" Class="mr-2" />
            Create Collection
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_name"
                          Label="Collection Name"
                          Required="true"
                          RequiredError="Name is required"
                          Variant="Variant.Outlined"
                          Class="mb-3" />

            <MudTextField @bind-Value="_description"
                          Label="Description (optional)"
                          Lines="3"
                          Variant="Variant.Outlined" />

            @if (ParentId.HasValue)
            {
                <MudAlert Severity="Severity.Info" Class="mt-3" Dense="true">
                    This will be created as a sub-collection.
                </MudAlert>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled"
                   OnClick="CreateAsync"
                   Disabled="@(!_isValid || _isCreating)">
            @if (_isCreating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid? ParentId { get; set; }

    private MudForm? _form;
    private string _name = "";
    private string _description = "";
    private bool _isValid;
    private bool _isCreating;

    private void Cancel() => MudDialog.Cancel();

    private async Task CreateAsync()
    {
        if (_form != null)
        {
            await _form.Validate();
            if (!_isValid) return;
        }

        try
        {
            _isCreating = true;

            var dto = new CreateCollectionDto
            {
                Name = _name,
                Description = string.IsNullOrWhiteSpace(_description) ? null : _description,
                ParentId = ParentId
            };

            CollectionResponseDto result;
            if (ParentId.HasValue)
            {
                result = await Api.CreateSubCollectionAsync(ParentId.Value, dto);
            }
            else
            {
                result = await Api.CreateCollectionAsync(dto);
            }

            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "create collection");
        }
        finally
        {
            _isCreating = false;
        }
    }
}
