@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using AssetHub.Application
@using AssetHub.Application.Dtos
@using AssetHub.Ui.Services
@using AssetHub.Ui.Components
@attribute [Authorize(Policy = "RequireAdmin")]
@inject NavigationManager Navigation
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AdminResource> AdminLoc

<PageTitle>@AdminLoc["PageTitle"] - @CommonLoc["AppName"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Class="mr-2" />
        @AdminLoc["PageTitle"]
    </MudText>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6"
             ActivePanelIndex="@_activeTabIndex" ActivePanelIndexChanged="OnActiveTabChanged">
        <MudTabPanel Text="@AdminLoc["Tab_ShareManagement"]" Icon="@Icons.Material.Filled.Share">
            <AdminSharesTab />
        </MudTabPanel>
        <MudTabPanel Text="@AdminLoc["Tab_CollectionAccess"]" Icon="@Icons.Material.Filled.FolderShared">
            <AdminCollectionAccessTab @ref="_collectionsTab" />
        </MudTabPanel>
        <MudTabPanel Text="@AdminLoc["Tab_UserManagement"]" Icon="@Icons.Material.Filled.ManageAccounts">
            <AdminUsersTab OnChanged="OnUsersChanged" />
        </MudTabPanel>
        <MudTabPanel Text="@AdminLoc["Tab_ExportPresets"]" Icon="@Icons.Material.Filled.Tune">
            <AdminExportPresetsTab />
        </MudTabPanel>
        <MudTabPanel Text="@AdminLoc["Tab_MetadataSchemas"]" Icon="@Icons.Material.Filled.Schema">
            <AdminMetadataSchemasTab />
        </MudTabPanel>
        <MudTabPanel Text="@AdminLoc["Tab_Taxonomies"]" Icon="@Icons.Material.Filled.AccountTree">
            <AdminTaxonomiesTab />
        </MudTabPanel>
        <MudTabPanel Text="@AdminLoc["Tab_AuditLog"]" Icon="@Icons.Material.Filled.History">
            <AdminAuditTab />
        </MudTabPanel>
        <MudTabPanel Text="@AdminLoc["Tab_Migrations"]" Icon="@Icons.Material.Filled.CloudUpload">
            <AdminMigrationsTab />
        </MudTabPanel>
        <MudTabPanel Text="@AdminLoc["Tab_Trash"]" Icon="@Icons.Material.Filled.Delete">
            <AdminTrashTab />
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private int _activeTabIndex;
    private AdminCollectionAccessTab? _collectionsTab;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("tab", out var tabValue)
            && int.TryParse(tabValue, out var tab) && tab >= 0 && tab <= 8)
            _activeTabIndex = tab;
    }

    private void OnActiveTabChanged(int index)
    {
        _activeTabIndex = index;
        var baseUri = Navigation.Uri.Split('?')[0];
        Navigation.NavigateTo($"{baseUri}?tab={index}", replace: true);
    }

    private async Task OnUsersChanged()
    {
        if (_collectionsTab != null)
            await _collectionsTab.RefreshAsync();
    }
}
