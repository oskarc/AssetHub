@using MudBlazor
@using AssetHub.Application
@using AssetHub.Application.Dtos
@using AssetHub.Application.Helpers
@using AssetHub.Ui.Services

@inject NavigationManager Nav
@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AdminResource> AdminLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="dialog-title">
            <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@AdminLoc["ManageUserAccess"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Class="dialog-intro">
                @AdminLoc["ManageUserAccessDesc"]
            </MudText>

            <!-- User Info Header -->
            <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudAvatar Color="Color.Primary" Size="Size.Large">
                        @(string.IsNullOrEmpty(FirstName) ? Username[..1].ToUpper() : FirstName[..1].ToUpper())
                    </MudAvatar>
                    <MudStack Spacing="0">
                        @if (!string.IsNullOrEmpty(FirstName) || !string.IsNullOrEmpty(LastName))
                        {
                            <MudText Typo="Typo.subtitle1"><strong>@FirstName @LastName</strong></MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@Username</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.subtitle1"><strong>@Username</strong></MudText>
                        }
                        @if (!string.IsNullOrEmpty(Email))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Email</MudText>
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>

            <!-- Reset Password -->
            <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="0">
                        <div class="dialog-section-title" style="margin-bottom:0;padding-bottom:6px;border-bottom:none">
                            <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Small" />
                            @AdminLoc["ResetPassword"]
                        </div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @AdminLoc["ResetPasswordDesc"]
                        </MudText>
                    </MudStack>
                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Email"
                               OnClick="SendPasswordResetEmail"
                               Disabled="@_resettingPassword">
                        @if (_resettingPassword)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <text>@CommonLoc["Text_Sending"]</text>
                        }
                        else
                        {
                            <text>@CommonLoc["Btn_ResetPassword"]</text>
                        }
                    </MudButton>
                </MudStack>
                @if (_passwordResetSuccess)
                {
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">
                        @AdminLoc["PasswordResetEmailSent"]
                    </MudAlert>
                }
            </MudPaper>

            <!-- Add New Collection Access -->
            @if (!IsSystemAdmin)
            {
            <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                <div class="dialog-section-title">
                    @AdminLoc["AddCollectionAccess"]
                </div>
                <MudStack Spacing="2">
                    <MudSelect T="Guid?"
                               @bind-Value="_selectedCollectionId"
                               Label="@CommonLoc["Label_Collection"]"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Disabled="@(_availableCollections.Count == 0)">
                        @foreach (var collection in _availableCollections)
                        {
                            <MudSelectItem T="Guid?" Value="@collection.Id">@collection.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                        <MudSelect T="string"
                                   @bind-Value="_selectedRole"
                                   Label="@CommonLoc["Label_Role"]"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Class="dialog-flex-fill">
                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Viewer">@CommonLoc["Role_Viewer"]</MudSelectItem>
                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Contributor">@CommonLoc["Role_Contributor"]</MudSelectItem>
                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Manager">@CommonLoc["Role_Manager"]</MudSelectItem>
                        </MudSelect>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddCollectionAccess"
                                   Disabled="@(!_selectedCollectionId.HasValue || _isAdding)">
                            @CommonLoc["Btn_Add"]
                        </MudButton>
                    </MudStack>
                </MudStack>
                @if (_availableCollections.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        @AdminLoc["UserHasAllAccess"]
                    </MudAlert>
                }
            </MudPaper>
            } @* end !IsSystemAdmin *@

            @if (IsSystemAdmin)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    @AdminLoc["AdminImplicitAccess"]
                </MudAlert>
            }

            <!-- Current Collections List -->
            @if (!IsSystemAdmin && _userCollections.Count > 0)
            {
                <MudSimpleTable Dense="true" Hover="true" Striped="true" Elevation="0" Class="table-outlined">
                    <thead>
                        <tr>
                            <th>@CommonLoc["Label_Collection"]</th>
                            <th>@CommonLoc["Label_Role"]</th>
                            <th class="dialog-actions-col-sm">@CommonLoc["Label_Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var collection in _userCollections.OrderBy(c => c.CollectionName, new NaturalSortComparer()))
                        {
                            <tr>
                                <td>
                                    <MudLink Href="@($"/collections?collection={collection.CollectionId}")"
                                             Color="Color.Primary"
                                             Underline="Underline.Hover"
                                             Target="_blank">
                                        @collection.CollectionName
                                    </MudLink>
                                </td>
                                <td>
                                    @if (_editingCollectionId == collection.CollectionId)
                                    {
                                        <MudSelect T="string"
                                                   @bind-Value="_editingRole"
                                                   Variant="Variant.Outlined"
                                                   Dense="true"
                                                   Margin="Margin.Dense"
                                                   Class="dialog-role-select">
                                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Viewer">@CommonLoc["Role_Viewer"]</MudSelectItem>
                                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Contributor">@CommonLoc["Role_Contributor"]</MudSelectItem>
                                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Manager">@CommonLoc["Role_Manager"]</MudSelectItem>
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetRoleColor(collection.Role)" Variant="Variant.Outlined">
                                            @CommonLoc[AssetDisplayHelpers.GetRoleKey(collection.Role)]
                                        </MudChip>
                                    }
                                </td>
                                <td>
                                    @if (_editingCollectionId == collection.CollectionId)
                                    {
                                        <MudStack Row="true" Spacing="1">
                                            <MudTooltip Text="@CommonLoc["Btn_Save"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Save"
                                                               Size="Size.Small"
                                                               Color="Color.Success"
                                                               OnClick="SaveRoleEdit" />
                                            </MudTooltip>
                                            <MudTooltip Text="@CommonLoc["Btn_Cancel"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                                               Size="Size.Small"
                                                               Color="Color.Default"
                                                               OnClick="CancelRoleEdit" />
                                            </MudTooltip>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudStack Row="true" Spacing="1">
                                            <MudTooltip Text="@AdminLoc["ChangeRole"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small"
                                                               Color="Color.Primary"
                                                               OnClick="@(() => StartRoleEdit(collection))"
                                                               Disabled="@(_revokingCollections.Count > 0)" />
                                            </MudTooltip>
                                            <MudTooltip Text="@AdminLoc["RevokeAccess"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.RemoveCircle"
                                                               Size="Size.Small"
                                                               Color="Color.Error"
                                                               OnClick="@(() => RevokeAccess(collection))"
                                                               Disabled="@(_revokingCollections.Contains(collection.CollectionId))" />
                                            </MudTooltip>
                                        </MudStack>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">@CommonLoc["Btn_Close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string UserId { get; set; } = default!;

    [Parameter]
    public string Username { get; set; } = default!;

    [Parameter]
    public string? Email { get; set; }

    [Parameter]
    public string? FirstName { get; set; }

    [Parameter]
    public string? LastName { get; set; }

    [Parameter]
    public bool IsSystemAdmin { get; set; }

    private List<UserCollectionAccessDto> _userCollections = new();
    private List<CollectionAccessDto> _allCollections = new();
    private List<CollectionAccessDto> _availableCollections = new();
    private Guid? _selectedCollectionId;
    private string _selectedRole = RoleHierarchy.Roles.Viewer;
    private bool _isAdding = false;
    private HashSet<Guid> _revokingCollections = new();

    private Guid? _editingCollectionId;
    private string _editingRole = "";

    // Reset Password State
    private bool _resettingPassword = false;
    private bool _passwordResetSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserCollections();
        await LoadAllCollections();
        UpdateAvailableCollections();
    }

    private async Task LoadUserCollections()
    {
        try
        {
            var users = await Api.GetUsersAsync();
            var user = users.FirstOrDefault(u => u.UserId == UserId);
            _userCollections = user?.Collections.ToList() ?? new List<UserCollectionAccessDto>();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load user collections");
        }
    }

    private async Task LoadAllCollections()
    {
        try
        {
            var hierarchicalCollections = await Api.GetCollectionAccessAsync();
            // Flatten the hierarchy to make all collections available
            _allCollections = CollectionTreeHelper.FlattenAll(hierarchicalCollections).ToList();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collections");
        }
    }

    private void UpdateAvailableCollections()
    {
        var userCollectionIds = _userCollections.Select(c => c.CollectionId).ToHashSet();
        _availableCollections = _allCollections
            .Where(c => !userCollectionIds.Contains(c.Id))
            .ToList();
    }

    private async Task AddCollectionAccess()
    {
        if (!_selectedCollectionId.HasValue) return;

        _isAdding = true;
        StateHasChanged();

        try
        {
            await Api.AddCollectionAclAsync(_selectedCollectionId.Value, Constants.PrincipalTypes.User, UserId, _selectedRole);
            Feedback.ShowSuccess(CommonLoc["Success_CollectionAccessAdded"].Value);

            // Reload user collections to confirm the change persisted
            await LoadUserCollections();

            // Reset and update available collections
            _selectedCollectionId = null;
            _selectedRole = RoleHierarchy.Roles.Viewer;
            UpdateAvailableCollections();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "add collection access");
        }
        finally
        {
            _isAdding = false;
            StateHasChanged();
        }
    }

    private void StartRoleEdit(UserCollectionAccessDto collection)
    {
        _editingCollectionId = collection.CollectionId;
        _editingRole = collection.Role;
    }

    private async Task SaveRoleEdit()
    {
        if (!_editingCollectionId.HasValue) return;

        try
        {
            await Api.UpdateCollectionAclAsync(_editingCollectionId.Value, Constants.PrincipalTypes.User, UserId, _editingRole);

            // Reload user collections to confirm the change persisted
            await LoadUserCollections();

            Feedback.ShowSuccess(CommonLoc["Success_RoleUpdated"].Value);

            _editingCollectionId = null;
            _editingRole = "";
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "update role");
        }
    }

    private void CancelRoleEdit()
    {
        _editingCollectionId = null;
        _editingRole = "";
    }

    private async Task RevokeAccess(UserCollectionAccessDto collection)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, CommonLoc["Confirm_Revoke"] },
            { x => x.Message, string.Format(AdminLoc["ConfirmRevokeAccess"], collection.CollectionName) },
            { x => x.TitleIcon, Icons.Material.Filled.RemoveCircle },
            { x => x.IconColor, Color.Warning },
            { x => x.ConfirmText, CommonLoc["Btn_Revoke"] },
            { x => x.ConfirmColor, Color.Error }
        };
        var confirmDialog = await DialogService.ShowAsync<ConfirmDialog>(null, parameters);
        var confirmResult = await confirmDialog.Result;

        if (confirmResult == null || confirmResult.Canceled)
            return;

        _revokingCollections.Add(collection.CollectionId);
        StateHasChanged();

        try
        {
            await Api.RemoveCollectionAclAsync(collection.CollectionId, UserId, Constants.PrincipalTypes.User);
            Feedback.ShowSuccess(string.Format(CommonLoc["Success_RevokedAccessTo"].Value, collection.CollectionName));

            // Reload user collections to confirm the change persisted
            await LoadUserCollections();

            // Update available collections
            UpdateAvailableCollections();

            // Force UI refresh before removing from tracking
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "revoke access");
        }
        finally
        {
            _revokingCollections.Remove(collection.CollectionId);
            StateHasChanged();
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));

    private async Task SendPasswordResetEmail()
    {
        _resettingPassword = true;
        _passwordResetSuccess = false;
        StateHasChanged();

        try
        {
            await Api.SendPasswordResetEmailAsync(UserId);
            _passwordResetSuccess = true;
            Feedback.ShowSuccess(AdminLoc["PasswordResetSuccess"]);
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "send password reset email");
        }
        finally
        {
            _resettingPassword = false;
            StateHasChanged();
        }
    }
}
