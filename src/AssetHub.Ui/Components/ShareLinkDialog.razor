@using MudBlazor
@using AssetHub.Ui.Services

@inject IUserFeedbackService Feedback
@inject IClipboardService Clipboard
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<SharesResource> ShareLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="dialog-title-success">
            <MudIcon Icon="@Icons.Material.Filled.Share" Color="Color.Success" />
            <MudText Typo="Typo.h6">@ShareLoc["ShareLinkCreated"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Class="dialog-intro dialog-intro-success">
                @ShareLoc["CreatedSuccess"]
            </MudText>

            @* Share Link Section *@
            <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                <div class="dialog-section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" />
                    @ShareLoc["ShareUrl"]
                </div>
                <MudTextField Value="@ShareUrl"
                              Label="@ShareLoc["ShareURL"]"
                              ReadOnly="true"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                              OnAdornmentClick="CopyUrlToClipboard" />

                @if (ExpiresAt.HasValue)
                {
                    <MudTooltip Text="@ExpiresAt.Value.ToLocalTime().ToString("F")">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                            @CommonLoc["Label_Expires"]: @ExpiresAt.Value.ToLocalTime().ToString("g")
                        </MudText>
                    </MudTooltip>
                }
            </MudPaper>

            @if (!string.IsNullOrEmpty(Password))
            {
                @* Password Section *@
                <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                    <div class="dialog-section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                        @CommonLoc["Label_Password"]
                    </div>
                    <MudTextField Value="@Password"
                                  Label="@CommonLoc["Label_Password"]"
                                  ReadOnly="true"
                                  Variant="Variant.Outlined"
                                  InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="TogglePasswordVisibility" />

                    <MudButton Size="Size.Small"
                               Variant="Variant.Text"
                               StartIcon="@Icons.Material.Filled.ContentCopy"
                               OnClick="CopyPasswordToClipboard"
                               Class="mt-2">
                        @CommonLoc["Btn_CopyPassword"]
                    </MudButton>
                </MudPaper>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">@CommonLoc["Btn_Close"]</MudButton>
        @if (!string.IsNullOrEmpty(Password))
        {
            <MudButton Color="Color.Primary" 
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.ContentCopy"
                       OnClick="CopyAllToClipboard">
                @CommonLoc["Btn_CopyAll"]
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string ShareUrl { get; set; } = "";

    [Parameter]
    public string Password { get; set; } = "";

    [Parameter]
    public DateTime? ExpiresAt { get; set; }

    private bool _showPassword = false;

    private void Close() => MudDialog.Close();

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private async Task CopyUrlToClipboard()
    {
        if (await Clipboard.CopyTextAsync(ShareUrl))
        {
            Feedback.ShowSuccess(CommonLoc["Success_LinkCopied"].Value);
        }
        else
        {
            Feedback.ShowWarning(CommonLoc["Warning_CopyFailed"].Value);
        }
    }

    private async Task CopyPasswordToClipboard()
    {
        if (await Clipboard.CopyTextAsync(Password))
        {
            Feedback.ShowSuccess(CommonLoc["Success_PasswordCopied"].Value);
        }
        else
        {
            Feedback.ShowWarning(CommonLoc["Warning_CopyFailed"].Value);
        }
    }

    private async Task CopyAllToClipboard()
    {
        var text = string.Format(ShareLoc["Text_CopyAllTemplate"].Value, ShareUrl, Password);
        if (await Clipboard.CopyTextAsync(text))
        {
            Feedback.ShowSuccess(CommonLoc["Success_LinkAndPasswordCopied"].Value);
        }
        else
        {
            Feedback.ShowWarning(CommonLoc["Warning_CopyFailed"].Value);
        }
    }
}
