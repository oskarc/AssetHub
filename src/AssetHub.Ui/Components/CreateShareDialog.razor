@using MudBlazor
@using AssetHub.Application
@using AssetHub.Application.Helpers
@using AssetHub.Ui.Services
@using System.ComponentModel.DataAnnotations

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<SharesResource> ShareLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Share" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@ShareLoc["CreateShareLink"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @string.Format(ShareLoc["CreateShareDesc"].Value, ContentName)
            </MudText>

            @* Password Section *@
            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                <MudText Typo="Typo.subtitle2" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Class="mr-1" />
                    @CommonLoc["Label_Password"]
                </MudText>
                <MudTextField @bind-Value="_password"
                              Label="@CommonLoc["Label_Password"]"
                              Variant="Variant.Outlined"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="TogglePasswordVisibility"
                              Validation="@((string p) => !string.IsNullOrEmpty(p) && p.Length < Constants.Limits.MinSharePasswordLength ? string.Format(CommonLoc["Validation_PasswordMinLength"].Value, Constants.Limits.MinSharePasswordLength) : null)"
                              HelperText="@ShareLoc["PasswordHelperText"]"
                              Class="mb-2" />
                <MudButton Size="Size.Small"
                           Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="GenerateNewPassword">
                    @CommonLoc["Btn_GenerateNew"]
                </MudButton>
            </MudPaper>

            @* Expiration Section *@
            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                <MudText Typo="Typo.subtitle2" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                    @ShareLoc["Expiration"]
                </MudText>
                <MudSelect T="int" @bind-Value="_expirationDays" Variant="Variant.Outlined" Label="@ShareLoc["ExpiresIn"]">
                    <MudSelectItem Value="1">@CommonLoc["Expiry_1Day"]</MudSelectItem>
                    <MudSelectItem Value="7">@CommonLoc["Expiry_7Days"]</MudSelectItem>
                    <MudSelectItem Value="14">@CommonLoc["Expiry_14Days"]</MudSelectItem>
                    <MudSelectItem Value="30">@CommonLoc["Expiry_30Days"]</MudSelectItem>
                    <MudSelectItem Value="90">@CommonLoc["Expiry_90Days"]</MudSelectItem>
                </MudSelect>
            </MudPaper>

            @* Email Notification Section *@
            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                <MudText Typo="Typo.subtitle2" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Class="mr-1" />
                    @ShareLoc["NotifyEmail"]
                </MudText>

                <MudTextField @bind-Value="_emailInput"
                              Label="@ShareLoc["AddEmailLabel"]"
                              Variant="Variant.Outlined"
                              Placeholder="@ShareLoc["AddEmailPlaceholder"]"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Add"
                              OnAdornmentClick="AddEmail"
                              OnKeyDown="OnEmailKeyDown"
                              Error="@(!string.IsNullOrEmpty(_emailError))"
                              ErrorText="@_emailError" />

                @if (_emails.Any())
                {
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-2">
                        @foreach (var email in _emails)
                        {
                            <MudChip T="string"
                                     Color="Color.Primary"
                                     Variant="Variant.Outlined"
                                     Size="Size.Small"
                                     OnClose="@(() => RemoveEmail(email))">
                                @email
                            </MudChip>
                        }
                    </MudStack>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                        @string.Format(ShareLoc["EmailsWillReceive"].Value, _emails.Count)
                    </MudText>
                }
            </MudPaper>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CommonLoc["Btn_Cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Share"
                   OnClick="CreateShare"
                   Disabled="_isCreating">
            @if (_isCreating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @ShareLoc["CreateShare"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>
    /// The ID of the asset or collection to share.
    /// </summary>
    [Parameter]
    public Guid ScopeId { get; set; }

    /// <summary>
    /// "asset" or "collection"
    /// </summary>
    [Parameter]
    public string ScopeType { get; set; } = Constants.ScopeTypes.Asset;

    /// <summary>
    /// Display name of the content being shared.
    /// </summary>
    [Parameter]
    public string ContentName { get; set; } = "";

    private string _password = "";
    private bool _showPassword = false;
    private int _expirationDays = 7;
    private string _emailInput = "";
    private string _emailError = "";
    private List<string> _emails = new();
    private bool _isCreating = false;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(ContentName))
            ContentName = CommonLoc["Text_ThisCollection"].Value;
        _password = PasswordGenerator.Generate(12);
    }

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private void GenerateNewPassword()
    {
        _password = PasswordGenerator.Generate(12);
    }

    private void OnEmailKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddEmail();
        }
    }

    private void AddEmail()
    {
        _emailError = "";

        if (string.IsNullOrWhiteSpace(_emailInput))
            return;

        var email = _emailInput.Trim().ToLowerInvariant();

        // Basic email validation
        if (!new EmailAddressAttribute().IsValid(email))
        {
            _emailError = CommonLoc["Validation_InvalidEmail"].Value;
            return;
        }

        if (_emails.Contains(email))
        {
            _emailError = CommonLoc["Validation_DuplicateEmail"].Value;
            return;
        }

        _emails.Add(email);
        _emailInput = "";
    }

    private void RemoveEmail(string email)
    {
        _emails.Remove(email);
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task CreateShare()
    {
        if (string.IsNullOrWhiteSpace(_password))
        {
            Feedback.ShowError(CommonLoc["Validation_PasswordRequired"].Value);
            return;
        }

        _isCreating = true;
        try
        {
            var expiresAt = DateTime.UtcNow.AddDays(_expirationDays);
            var emailList = _emails.Any() ? _emails : null;

            var share = await Api.CreateShareAsync(
                ScopeId,
                ScopeType,
                expiresAt,
                _password,
                emailList
            );

            // Return the share result so the caller can show the success dialog
            MudDialog.Close(DialogResult.Ok(share));
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "create share");
        }
        finally
        {
            _isCreating = false;
        }
    }
}
