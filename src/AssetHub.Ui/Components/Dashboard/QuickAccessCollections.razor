@using AssetHub.Application.Helpers
@inject IStringLocalizer<CommonResource> Loc
@inject LocalizedDisplayService Display

<MudPaper Elevation="1" Class="pa-5 content-card">
    <div class="section-header">
        <MudText Typo="Typo.h6">@Loc["Dashboard_QuickAccess"]</MudText>
        @if (!Loading)
        {
            <MudButton Variant="Variant.Text" Color="Color.Primary"
                       Href="/collections"
                       EndIcon="@Icons.Material.Filled.ArrowForward">
                @Loc["Dashboard_ViewAll"]
            </MudButton>
        }
    </div>

    @if (Loading)
    {
        <MudGrid>
            @for (var i = 0; i < 4; i++)
            {
                <MudItem xs="6" sm="4" md="3">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="100px" Class="rounded" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (Collections.Count == 0)
    {
        <EmptyState Title="@Loc["Dashboard_NoCollections"]"
                    Icon="@Icons.Material.Filled.FolderOpen"
                    Class="py-4" />
    }
    else
    {
        <MudGrid>
            @foreach (var collection in Collections)
            {
                <MudItem xs="6" sm="4" md="3">
                    <MudCard Class="cursor-pointer" @onclick="async () => await OnCollectionClicked.InvokeAsync(collection.Id)">
                        <MudCardContent>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" />
                                <MudText Typo="Typo.subtitle1" Class="text-truncate">@collection.Name</MudText>
                            </div>
                            <MudText Typo="Typo.caption" Class="mt-1" Color="Color.Secondary">
                                @Loc["Dashboard_Updated"] @Display.TimeAgo(collection.UpdatedAt)
                            </MudText>
                            <div class="d-flex align-center gap-2 mt-2">
                                <MudChip T="string" Size="Size.Small"
                                         Color="@AssetDisplayHelpers.GetRoleColor(collection.UserRole)">
                                    @Display.Role(collection.UserRole)
                                </MudChip>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @collection.AssetCount @Loc["Dashboard_Assets"]
                                </MudText>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudPaper>

@code {
    [Parameter] public List<CollectionResponseDto> Collections { get; set; } = [];
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback<Guid> OnCollectionClicked { get; set; }
}
