@using MudBlazor
@using AssetHub.Application.Helpers
@using AssetHub.Ui.Services
@using AssetHub.Application.Dtos

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<SharesResource> ShareLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="dialog-title">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@ShareLoc["SharePassword"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Class="dialog-intro">
                @string.Format(ShareLoc["ManagePasswordDesc"].Value, GetLocalizedScopeType(Share.ScopeType), Share.ScopeName)
            </MudText>

            @if (Share.HasPassword && string.IsNullOrEmpty(InitialPassword))
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    @ShareLoc["CurrentPasswordNotAvailable"]
                </MudAlert>
            }

            <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                <div class="dialog-section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                    @CommonLoc["Label_Password"]
                </div>
                <MudTextField @bind-Value="_password"
                              Label="@_passwordLabel"
                              Variant="Variant.Outlined"
                              AutoFocus="true"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="TogglePasswordVisibility"
                              Validation="@((string p) => !string.IsNullOrEmpty(p) && p.Length < Constants.Limits.MinSharePasswordLength ? string.Format(CommonLoc["Validation_PasswordMinLength"].Value, Constants.Limits.MinSharePasswordLength) : null)"
                              HelperText="@_helperText"
                              Class="mb-2" />
                <MudButton Size="Size.Small"
                           Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="GenerateNewPassword">
                    @CommonLoc["Btn_GenerateNew"]
                </MudButton>
            </MudPaper>

            <MudAlert Severity="Severity.Info" Dense="true">
                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" />
                @ShareLoc["PasswordUpdateWarning"]
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CommonLoc["Btn_Cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SavePassword"
                   Disabled="_isSaving || string.IsNullOrWhiteSpace(_password) || _password.Length < Constants.Limits.MinSharePasswordLength">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @ShareLoc["UpdatePassword"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public AdminShareDto Share { get; set; } = default!;

    [Parameter]
    public string InitialPassword { get; set; } = string.Empty;

    private string _password = "";
    private bool _showPassword = false;
    private bool _isSaving = false;

    private string _passwordLabel => !string.IsNullOrEmpty(InitialPassword) 
        ? CommonLoc["Label_CurrentPassword"].Value 
        : CommonLoc["Label_NewPassword"].Value;

    private string _helperText => !string.IsNullOrEmpty(InitialPassword)
        ? ShareLoc["CurrentPasswordHelperText"].Value
        : ShareLoc["NewPasswordHelper"].Value;

    protected override void OnInitialized()
    {
        // Only pre-fill if InitialPassword was provided (e.g., from previous save)
        // Otherwise leave empty - user can type their own or click Generate New
        _password = InitialPassword;
    }

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private void GenerateNewPassword()
    {
        _password = PasswordGenerator.Generate(12);
    }

    private string GetLocalizedScopeType(string scopeType) =>
        AssetDisplayHelpers.GetLocalizedScopeType(scopeType, CommonLoc);

    private void Cancel() => MudDialog.Cancel();

    private async Task SavePassword()
    {
        if (string.IsNullOrWhiteSpace(_password))
        {
            Feedback.ShowError(CommonLoc["Validation_PasswordEmpty"].Value);
            return;
        }

        _isSaving = true;
        try
        {
            await Api.UpdateSharePasswordAsync(Share.Id, _password);
            Feedback.ShowSuccess(CommonLoc["Success_PasswordUpdated"].Value);
            // Return the plaintext password to the caller so it can be displayed
            MudDialog.Close(DialogResult.Ok(_password));
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "update password");
        }
        finally
        {
            _isSaving = false;
        }
    }
}
