@using AssetHub.Application.Dtos
@using AssetHub.Ui.Services
@using MudBlazor

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<CollectionsResource> CollectionLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="dialog-title">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@CollectionLoc["EditCollection"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Class="dialog-intro">
                @CollectionLoc["EditCollectionDesc"]
            </MudText>

            <CollectionForm @ref="_collectionForm"
                            Name="@InitialName"
                            Description="@(InitialDescription ?? "")" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CommonLoc["Btn_Cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="SaveAsync"
                   Disabled="_isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @CommonLoc["Btn_Save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid CollectionId { get; set; }

    [Parameter]
    public string InitialName { get; set; } = "";

    [Parameter]
    public string? InitialDescription { get; set; }

    private CollectionForm? _collectionForm;
    private bool _isSaving;

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        if (_collectionForm == null || !await _collectionForm.ValidateAsync())
            return;

        _isSaving = true;
        var dto = new UpdateCollectionDto
        {
            Name = _collectionForm.Name,
            Description = InputValidation.NormalizeToNull(_collectionForm.Description)
        };
        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.UpdateCollectionAsync(CollectionId, dto),
            "update collection");
        _isSaving = false;

        if (success)
            MudDialog.Close(DialogResult.Ok(true));
    }
}
