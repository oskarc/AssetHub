{
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Error",
        "Hangfire": "Error"
      }
    }
  },
  "Keycloak": {
    "Authority": "https://keycloak.assethub.local:8443/realms/media",
    "ClientId": "test-client",
    "ClientSecret": "test-secret",
    "AdminUsername": "test-admin",
    "AdminPassword": "test-password",
    "RequireHttpsMetadata": true,
    "TimeoutSeconds": 5
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "AccessKey": "test-access-key",
    "SecretKey": "test-secret-key",
    "BucketName": "test-bucket",
    "UseSSL": false
  },
  "App": {
    "BaseUrl": "https://localhost"
  },
  "Redis": {
    "ConnectionString": ""
  },
  "Email": {
    "Enabled": false,
    "SmtpHost": "localhost",
    "SmtpPort": 25,
    "FromAddress": "test@test.com",
    "FromName": "AssetHub Test"
  },
  "ClamAV": {
    "Enabled": false
  },
  "Database": {
    "AutoMigrate": false
  }
}
