@page "/all-assets"
@attribute [Authorize(Policy = "RequireAdmin")]
@implements IAsyncDisposable

@using AssetHub.Application
@using AssetHub.Application.Dtos
@using AssetHub.Ui.Components
@using AssetHub.Ui.Services
@using Microsoft.AspNetCore.Authorization

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AssetsResource> AssetLoc
@inject LocalStorageService LocalStorage

<PageTitle>@AssetLoc["AllAssetsTitle"] - @CommonLoc["AppName"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
    <!-- Header -->
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudStack>
            <MudText Typo="Typo.h4">@AssetLoc["AllAssetsTitle"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @AssetLoc["BrowseAllAssets"]
            </MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
            @if (_selectionMode)
            {
                @if (_selectedAssetIds.Count > 0)
                {
                    <MudButton Variant="Variant.Filled"
                               Size="Size.Small"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Checklist"
                               OnClick="OpenBulkDeleteAsync">
                        @string.Format(AssetLoc["BulkAssetActionsBtn"], _selectedAssetIds.Count)
                    </MudButton>
                }
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           StartIcon="@(_allAssetsSelected ? Icons.Material.Filled.Deselect : Icons.Material.Filled.SelectAll)"
                           OnClick="ToggleSelectAllAssets">
                    @(_allAssetsSelected ? CommonLoc["Btn_DeselectAll"] : CommonLoc["Btn_SelectAll"])
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Close"
                           OnClick="ExitSelectionMode">
                    @AssetLoc["CancelAssetSelection"]
                </MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.CheckBox"
                           OnClick="EnterSelectionMode">
                    @AssetLoc["SelectManyAssets"]
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Upload"
                           OnClick="@(() => _showUpload = !_showUpload)">
                    @CommonLoc["Btn_Upload"]
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="RefreshAsync">
                    @CommonLoc["Btn_Refresh"]
                </MudButton>
            }
        </MudStack>
    </MudStack>

    <!-- Upload Area -->
    @if (_showUpload)
    {
        <MudPaper Class="pa-3 mb-4" Elevation="0" Outlined="true">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudSelect T="Guid?"
                               @bind-Value="_uploadCollectionId"
                               Label="@AssetLoc["UploadToCollection"]"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Style="max-width: 300px;">
                        <MudSelectItem T="Guid?" Value="@((Guid?)null)">@AssetLoc["NoCollection"]</MudSelectItem>
                        @foreach (var collection in _collections)
                        {
                            <MudSelectItem T="Guid?" Value="@collection.Id">@collection.Name</MudSelectItem>
                        }
                    </MudSelect>
                    @if (!_uploadCollectionId.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning">
                            @AssetLoc["UploadNoCollectionWarning"]
                        </MudText>
                    }
                </MudStack>
                <AssetUpload CollectionId="@_uploadCollectionId" OnUploadComplete="@OnUploadComplete" RequireCollection="false" />
            </MudStack>
        </MudPaper>
    }

    <!-- Search and Filter -->
    <MudPaper Class="pa-3 mb-4" Elevation="0" Outlined="true">
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudTextField @bind-Value="_searchQuery"
                              Placeholder="@AssetLoc["SearchAllPlaceholder"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              DebounceInterval="500"
                              OnDebounceIntervalElapsed="SearchAsync" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="Guid?"
                           Value="_filterCollectionId"
                           Label="@CommonLoc["Label_Collection"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           ValueChanged="@OnCollectionFilterChanged">
                    <MudSelectItem T="Guid?" Value="@((Guid?)null)">@CommonLoc["Filter_AllCollections"]</MudSelectItem>
                    @foreach (var collection in _collections)
                    {
                        <MudSelectItem T="Guid?" Value="@collection.Id">@collection.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="string"
                           Value="_filterType"
                           Label="@CommonLoc["Label_Type"]"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           ValueChanged="@OnFilterChanged">
                    <MudSelectItem Value="@((string?)null)">@CommonLoc["Filter_AllTypes"]</MudSelectItem>
                    <MudSelectItem Value="@(Constants.AssetTypeFilters.Image)">@CommonLoc["Filter_Images"]</MudSelectItem>
                    <MudSelectItem Value="@(Constants.AssetTypeFilters.Video)">@CommonLoc["Filter_Videos"]</MudSelectItem>
                    <MudSelectItem Value="@(Constants.AssetTypeFilters.Document)">@CommonLoc["Filter_Documents"]</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Class="mt-1">
                    <MudIconButton Icon="@Icons.Material.Filled.GridView"
                                   Color="@(_viewMode == Constants.ViewModes.Grid ? Color.Primary : Color.Default)"
                                   OnClick="@(() => SetViewModeAsync(Constants.ViewModes.Grid))"
                                   aria-label="@CommonLoc["Aria_GridView"]" />
                    <MudIconButton Icon="@Icons.Material.Filled.ViewList"
                                   Color="@(_viewMode == Constants.ViewModes.List ? Color.Primary : Color.Default)"
                                   OnClick="@(() => SetViewModeAsync(Constants.ViewModes.List))"
                                   aria-label="@CommonLoc["Aria_ListView"]" />
                </MudButtonGroup>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- Stats -->
    @if (!_isLoading && _total > 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            @string.Format(AssetLoc["ShowingOfAssets"], _assets.Count, _total)
        </MudText>
    }

    <!-- Asset Grid -->
    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">@AssetLoc["LoadingAssets"]</MudText>
        </MudStack>
    }
    else if (_assets.Count == 0)
    {
        @if (!string.IsNullOrWhiteSpace(_searchQuery) || !string.IsNullOrWhiteSpace(_filterType) || _filterCollectionId.HasValue)
        {
            <EmptyState Title="@AssetLoc["NoMatchingAssets"]"
                        Description="@AssetLoc["NoMatchingAssetsDesc"]"
                        Icon="@Icons.Material.Filled.SearchOff" />
        }
        else
        {
            <EmptyState Title="@AssetLoc["NoAssetsYet"]"
                        Description="@AssetLoc["NoAssetsUploadHint"]"
                        Icon="@Icons.Material.Filled.PhotoLibrary" />
        }
    }
    else
    {
        @if (_viewMode == Constants.ViewModes.Grid)
        {
            <MudGrid Spacing="3">
                @foreach (var asset in _assets)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                        <MudCard Class="@GetCardClass(asset.Id)" Elevation="2">
                            <div @onclick="() => OnCardClick(asset)" class="clickable">
                                @if (_selectionMode)
                                {
                                    <MudCheckBox T="bool" Class="asset-select-checkbox"
                                                 Value="@_selectedAssetIds.Contains(asset.Id)"
                                                 ValueChanged="@(val => ToggleSelection(asset.Id, val))" />
                                }
                                <MudCardMedia Image="@AssetDisplayHelpers.GetThumbnailUrl(asset.Id, asset.ThumbObjectKey, asset.AssetType, asset.PosterObjectKey)" 
                                              Height="160" 
                                              Class="asset-thumbnail" />
                                <MudCardContent Class="pa-2">
                                    <MudText Typo="Typo.body2" Class="text-truncate">
                                        @asset.Title
                                    </MudText>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <MudChip T="string" 
                                                 Size="Size.Small" 
                                                 Color="@AssetDisplayHelpers.GetAssetTypeColor(asset.AssetType)"
                                                 Variant="Variant.Outlined">
                                            @CommonLoc[AssetDisplayHelpers.GetAssetTypeKey(asset.AssetType)]
                                        </MudChip>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @AssetDisplayHelpers.FormatFileSize(asset.SizeBytes)
                                        </MudText>
                                    </MudStack>
                                </MudCardContent>
                            </div>
                            <MudCardActions Class="pa-2 pt-0">
                                @if (CanShare(asset))
                                {
                                    <MudTooltip Text="@CommonLoc["Btn_Share"]">
                                        <MudIconButton Icon="@Icons.Material.Filled.Share" 
                                                       Size="Size.Small" 
                                                       OnClick="@(async () => await ShareAsset(asset))" />
                                    </MudTooltip>
                                }
                                <MudSpacer />
                                @if (CanDelete(asset))
                                {
                                    <MudTooltip Text="@CommonLoc["Btn_Delete"]">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                       Size="Size.Small" 
                                                       Color="Color.Error"
                                                       OnClick="@(async () => await DeleteAsset(asset))" />
                                    </MudTooltip>
                                }
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
        else
        {
            <MudTable Items="@_assets" Hover="true" Dense="true" Striped="true" Elevation="2" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    @if (_selectionMode)
                    {
                        <MudTh Style="width: 50px;"></MudTh>
                    }
                    <MudTh></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetResponseDto, object>(x => x.Title)">@AssetLoc["Column_Title"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetResponseDto, object>(x => x.AssetType)">@CommonLoc["Label_Type"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssetResponseDto, object>(x => x.SizeBytes)">@AssetLoc["Column_Size"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="new Func<AssetResponseDto, object>(x => x.CreatedAt)">@AssetLoc["Column_Created"]</MudTableSortLabel></MudTh>
                    <MudTh Class="col-text-right">@AssetLoc["Column_Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @if (_selectionMode)
                    {
                        <MudTd>
                            <MudCheckBox T="bool"
                                         Value="@_selectedAssetIds.Contains(context.Id)"
                                         ValueChanged="@(val => ToggleSelection(context.Id, val))" />
                        </MudTd>
                    }
                    <MudTd DataLabel="" Class="col-icon">
                        <MudAvatar Rounded="true" Size="Size.Medium" Class="clickable" @onclick="() => ViewAsset(context.Id)">
                            <MudImage Src="@AssetDisplayHelpers.GetThumbnailUrl(context.Id, context.ThumbObjectKey, context.AssetType, context.PosterObjectKey)" 
                                      Alt="@context.Title"
                                      ObjectFit="ObjectFit.Cover"
                                      Width="40" Height="40" />
                        </MudAvatar>
                    </MudTd>
                    <MudTd DataLabel="@AssetLoc["Column_Title"]">
                        <MudLink OnClick="@(() => ViewAsset(context.Id))" Underline="Underline.Hover">
                            @context.Title
                        </MudLink>
                    </MudTd>
                    <MudTd DataLabel="@CommonLoc["Label_Type"]">
                        <MudChip T="string" Size="Size.Small"
                                 Color="@AssetDisplayHelpers.GetAssetTypeColor(context.AssetType)"
                                 Variant="Variant.Outlined">
                            @CommonLoc[AssetDisplayHelpers.GetAssetTypeKey(context.AssetType)]
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="@AssetLoc["Column_Size"]">
                        @AssetDisplayHelpers.FormatFileSize(context.SizeBytes)
                    </MudTd>
                    <MudTd DataLabel="@AssetLoc["Column_Created"]">
                        <MudTooltip Text="@context.CreatedAt.ToLocalTime().ToString("F")">
                            <span>@context.CreatedAt.ToLocalTime().ToString("g")</span>
                        </MudTooltip>
                    </MudTd>
                    <MudTd DataLabel="@AssetLoc["Column_Actions"]" Class="col-text-right">
                        @if (CanShare(context))
                        {
                            <MudTooltip Text="@CommonLoc["Btn_Share"]">
                                <MudIconButton Icon="@Icons.Material.Filled.Share"
                                               Size="Size.Small"
                                               OnClick="@(async () => await ShareAsset(context))" />
                            </MudTooltip>
                        }
                        @if (CanDelete(context))
                        {
                            <MudTooltip Text="@CommonLoc["Btn_Delete"]">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(async () => await DeleteAsset(context))" />
                            </MudTooltip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }

        @if (_total > _assets.Count)
        {
            <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
                <MudButton Variant="Variant.Outlined" OnClick="LoadMoreAsync" Disabled="_isLoadingMore">
                    @if (_isLoadingMore)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @string.Format(AssetLoc["LoadMoreRemaining"], _total - _assets.Count)
                </MudButton>
            </MudStack>
        }
    }
</MudContainer>

@code {
    private List<AssetResponseDto> _assets = new();
    private List<CollectionResponseDto> _collections = new();
    private int _total = 0;
    private int _skip = 0;
    private const int _take = 24;
    private bool _isLoading = true;
    private bool _isLoadingMore = false;

    private string _searchQuery = "";
    private string? _filterType;
    private Guid? _filterCollectionId;
    private Guid? _uploadCollectionId;
    private string _viewMode = Constants.ViewModes.Grid;
    private bool _showUpload = false;

    private const string ViewModeStorageKey = "viewMode_allAssets";

    // Bulk selection state
    private bool _selectionMode;
    private HashSet<Guid> _selectedAssetIds = new();
    private CancellationTokenSource _cts = new();
    
    // Role-based UI visibility using centralized permissions
    private bool CanShare(AssetResponseDto asset) => RolePermissions.CanShare(asset.UserRole);
    private bool CanDelete(AssetResponseDto asset) => RolePermissions.CanDelete(asset.UserRole);

    protected override async Task OnInitializedAsync()
    {
        await LoadCollectionsAsync();
        await LoadAssetsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var stored = await LocalStorage.GetAsync(ViewModeStorageKey);
            if (!string.IsNullOrEmpty(stored))
            {
                _viewMode = stored;
                StateHasChanged();
            }
        }
    }

    private async Task SetViewModeAsync(string mode)
    {
        _viewMode = mode;
        await LocalStorage.SetAsync(ViewModeStorageKey, mode);
    }

    private async Task LoadCollectionsAsync()
    {
        try
        {
            _collections = await Api.GetCollectionsAsync(_cts.Token);
        }
        catch (OperationCanceledException)
        {
            // Disposed — ignore
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collections");
        }
    }

    private async Task LoadAssetsAsync()
    {
        try
        {
            _isLoading = true;
            StateHasChanged();

            var response = await Api.GetAllAssetsAsync(
                _searchQuery,
                _filterType,
                _filterCollectionId,
                Constants.SortBy.CreatedDesc,
                _skip,
                _take,
                _cts.Token);
            
            _assets.AddRange(response.Items);
            _total = response.Total;
        }
        catch (OperationCanceledException)
        {
            // Disposed — ignore
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load assets");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMoreAsync()
    {
        _isLoadingMore = true;
        _skip = _assets.Count;
        
        try
        {
            var response = await Api.GetAllAssetsAsync(
                _searchQuery,
                _filterType,
                _filterCollectionId,
                Constants.SortBy.CreatedDesc,
                _skip,
                _take,
                _cts.Token);
            
            _assets.AddRange(response.Items);
            _total = response.Total;
        }
        catch (OperationCanceledException)
        {
            // Disposed — ignore
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load more assets");
        }
        finally
        {
            _isLoadingMore = false;
        }
    }

    private async Task RefreshAsync()
    {
        _skip = 0;
        _assets.Clear();
        await LoadAssetsAsync();
    }

    private async Task OnUploadComplete()
    {
        _showUpload = false;
        await RefreshAsync();
    }

    private async Task SearchAsync()
    {
        _skip = 0;
        _assets.Clear();
        await LoadAssetsAsync();
    }

    private async Task OnFilterChanged(string? value)
    {
        _filterType = value;
        await SearchAsync();
    }

    private async Task OnCollectionFilterChanged(Guid? value)
    {
        _filterCollectionId = value;
        await SearchAsync();
    }

    private void ViewAsset(Guid id)
    {
        var currentUrl = Nav.ToBaseRelativePath(Nav.Uri);
        Nav.NavigateTo($"/assets/{id}?returnUrl=/{Uri.EscapeDataString(currentUrl)}");
    }

    private void GoToCollection(Guid? collectionId)
    {
        if (collectionId.HasValue)
        {
            Nav.NavigateTo($"/collections?collection={collectionId.Value}");
        }
    }

    private async Task ShareAsset(AssetResponseDto asset)
    {
        var createParams = new DialogParameters<CreateShareDialog>
        {
            { x => x.ScopeId, asset.Id },
            { x => x.ScopeType, Constants.ScopeTypes.Asset },
            { x => x.ContentName, asset.Title }
        };

        var createResult = await DialogService.ShowAsync<CreateShareDialog>(AssetLoc["CreateShareLink"], createParams);
        var result = await createResult.Result;

        if (result != null && !result.Canceled && result.Data is ShareResponseDto share)
        {
            var successParams = new DialogParameters<ShareLinkDialog>
            {
                { x => x.ShareUrl, share.ShareUrl },
                { x => x.Password, share.Password ?? "" },
                { x => x.ExpiresAt, share.ExpiresAt }
            };

            await DialogService.ShowAsync<ShareLinkDialog>(AssetLoc["ShareLinkCreated"], successParams);
        }
    }

    private async Task DeleteAsset(AssetResponseDto asset)
    {
        var confirmParams = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, AssetLoc["ConfirmDelete"] },
            { x => x.Message, string.Format(AssetLoc["ConfirmDeleteAsset"], asset.Title) },
            { x => x.TitleIcon, Icons.Material.Filled.Delete },
            { x => x.IconColor, Color.Error },
            { x => x.ConfirmText, CommonLoc["Btn_Delete"] },
            { x => x.ConfirmColor, Color.Error }
        };
        var confirmDialog = await DialogService.ShowAsync<ConfirmDialog>(null, confirmParams);
        var confirmResult = await confirmDialog.Result;

        if (confirmResult != null && !confirmResult.Canceled)
        {
            var success = await Feedback.ExecuteWithFeedbackAsync(
                () => Api.DeleteAssetAsync(asset.Id),
                "delete asset",
                AssetLoc["AssetDeletedSuccess"]);
            
            if (success)
            {
                _assets.Remove(asset);
                _total--;
            }
        }
    }

    // ── Bulk Selection ───────────────────────────────────────────

    private bool _allAssetsSelected => _assets.Count > 0 && _assets.All(a => _selectedAssetIds.Contains(a.Id));

    private void EnterSelectionMode()
    {
        _selectionMode = true;
        _selectedAssetIds.Clear();
    }

    private void ExitSelectionMode()
    {
        _selectionMode = false;
        _selectedAssetIds.Clear();
    }

    private void ToggleSelectAllAssets()
    {
        if (_allAssetsSelected)
            _selectedAssetIds.Clear();
        else
            _selectedAssetIds = new HashSet<Guid>(_assets.Select(a => a.Id));
    }

    private void ToggleSelection(Guid id, bool selected)
    {
        if (selected)
            _selectedAssetIds.Add(id);
        else
            _selectedAssetIds.Remove(id);
    }

    private void OnCardClick(AssetResponseDto asset)
    {
        if (_selectionMode)
        {
            ToggleSelection(asset.Id, !_selectedAssetIds.Contains(asset.Id));
            return;
        }
        ViewAsset(asset.Id);
    }

    private string GetCardClass(Guid id) =>
        _selectedAssetIds.Contains(id)
            ? "asset-card mud-border-primary"
            : "asset-card";

    private async Task OpenBulkDeleteAsync()
    {
        if (_selectedAssetIds.Count == 0) return;

        var selectedAssets = _assets.Where(a => _selectedAssetIds.Contains(a.Id)).ToList();
        if (selectedAssets.Count == 0) return;

        var parameters = new DialogParameters<BulkAssetActionsDialog>
        {
            { x => x.SelectedAssets, selectedAssets },
            { x => x.CollectionId, null }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<BulkAssetActionsDialog>(
            AssetLoc["BulkAssetActions"], parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            _selectionMode = false;
            _selectedAssetIds.Clear();
            await RefreshAsync();
        }
    }

    public ValueTask DisposeAsync()
    {
        _cts.Cancel();
        _cts.Dispose();
        return ValueTask.CompletedTask;
    }
}
