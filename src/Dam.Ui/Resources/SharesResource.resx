  <data name="LinkExpired" xml:space="preserve"><value>This share link has expired.</value></data>
  <data name="LinkRevoked" xml:space="preserve"><value>This share link has been revoked.</value></data>
  <data name="UnableToAccess" xml:space="preserve"><value>Unable to access shared content.</value></data>
  <data name="ErrorLoading" xml:space="preserve"><value>An error occurred while loading the shared content.</value></data>
  <data name="FailedToLoad" xml:space="preserve"><value>Failed to load shared content. Please try again later.</value></data>
