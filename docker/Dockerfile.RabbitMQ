FROM rabbitmq:4-management-alpine@sha256:b618738ea52cb6d0073ee9f0412ede133411ecacd7afa40f17be748a6d9a9ee1

# Patch known HIGH CVEs in Alpine base packages until upstream image is rebuilt:
# - CVE-2026-22184: zlib buffer overflow (fixed in 1.3.2-r0)
# - CVE-2026-28390: OpenSSL NULL-ptr DoS in CMS (fixed in 3.5.6-r0)
# - CVE-2026-40200: musl stack-based code execution (fixed in 1.2.5-r23)
USER root
RUN apk upgrade --no-cache zlib libcrypto3 libssl3 musl musl-utils
USER rabbitmq
