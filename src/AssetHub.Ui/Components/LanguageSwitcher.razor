@using Microsoft.AspNetCore.Localization
@implements IAsyncDisposable
@inject IStringLocalizer<CommonResource> CommonLoc
@inject NavigationManager Nav
@inject IJSRuntime JS

<MudMenu Icon="@Icons.Material.Filled.Language"
         Color="Color.Inherit"
         Dense="true"
         Label="@_currentCulture.ToUpperInvariant()"
         AnchorOrigin="Origin.BottomCenter"
         TransformOrigin="Origin.TopCenter">
    <MudMenuItem OnClick="@(() => SetCulture("en"))">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText>English</MudText>
            @if (_currentCulture == "en")
            {
                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary" />
            }
        </MudStack>
    </MudMenuItem>
    <MudMenuItem OnClick="@(() => SetCulture("sv"))">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText>Svenska</MudText>
            @if (_currentCulture == "sv")
            {
                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary" />
            }
        </MudStack>
    </MudMenuItem>
</MudMenu>

@code {
    private string _currentCulture = "en";
    private IJSObjectReference? _jsModule;

    protected override void OnInitialized()
    {
        _currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    }

    private async Task SetCulture(string culture)
    {
        if (culture == _currentCulture) return;
        _currentCulture = culture;

        var cookieValue = CookieRequestCultureProvider.MakeCookieValue(
            new RequestCulture(culture, culture));

        _jsModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AssetHub.Ui/js/helpers.js");
        await _jsModule.InvokeVoidAsync("setCookie", CookieRequestCultureProvider.DefaultCookieName, cookieValue, 31536000);

        // Reload the current page. Derive a base-relative path so navigation is guaranteed
        // same-origin even if Nav.Uri has somehow been influenced — closes the open-redirect
        // taint path Sonar flags on the raw Nav.Uri → NavigateTo flow.
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        Nav.NavigateTo(relative, forceLoad: true);
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            try { await _jsModule.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
    }
}
