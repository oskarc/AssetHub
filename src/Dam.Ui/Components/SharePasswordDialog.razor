@using MudBlazor
@using Dam.Ui.Services
@using Dam.Application.Dtos

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Class="mr-2" Color="Color.Primary" />
            Share Password
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Manage the password for this shared @Share.ScopeType: <strong>@Share.ScopeName</strong>
            </MudText>

            <MudDivider />

            <MudTextField @bind-Value="_password"
                          Label="New Password"
                          Variant="Variant.Outlined"
                          InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="TogglePasswordVisibility"
                          HelperText="Enter a new password for this share." />

            <MudStack Row="true" Spacing="2">
                <MudButton Size="Size.Small"
                           Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="GenerateNewPassword">
                    Generate New
                </MudButton>
            </MudStack>

            <MudAlert Severity="Severity.Info" Dense="true">
                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" />
                Updating the password will require all users to use the new password to access the share.
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SavePassword"
                   Disabled="_isSaving || string.IsNullOrWhiteSpace(_password)">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Update Password
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public AdminShareDto Share { get; set; } = default!;

    private string _password = "";
    private bool _showPassword = true;
    private bool _isSaving = false;

    protected override void OnInitialized()
    {
        _password = GeneratePassword();
    }

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private void GenerateNewPassword()
    {
        _password = GeneratePassword();
    }

    private static string GeneratePassword(int length = 12)
    {
        const string upperCase = "ABCDEFGHJKLMNPQRSTUVWXYZ";
        const string lowerCase = "abcdefghjkmnpqrstuvwxyz";
        const string digits = "23456789";
        const string special = "!@#$%&*";
        const string allChars = upperCase + lowerCase + digits + special;

        var random = new Random();
        var password = new char[length];

        password[0] = upperCase[random.Next(upperCase.Length)];
        password[1] = lowerCase[random.Next(lowerCase.Length)];
        password[2] = digits[random.Next(digits.Length)];
        password[3] = special[random.Next(special.Length)];

        for (int i = 4; i < length; i++)
        {
            password[i] = allChars[random.Next(allChars.Length)];
        }

        return new string(password.OrderBy(_ => random.Next()).ToArray());
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SavePassword()
    {
        if (string.IsNullOrWhiteSpace(_password))
        {
            Feedback.ShowError("Password cannot be empty.");
            return;
        }

        _isSaving = true;
        try
        {
            await Api.UpdateSharePasswordAsync(Share.Id, _password);
            Feedback.ShowSuccess("Password updated successfully!");
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "update password");
        }
        finally
        {
            _isSaving = false;
        }
    }
}
