@using AssetHub.Application.Dtos
@using AssetHub.Ui.Services
@using MudBlazor

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<CollectionsResource> CollectionLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="dialog-title">
            <MudIcon Icon="@Icons.Material.Filled.CreateNewFolder" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@CollectionLoc["CreateCollection"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Class="dialog-intro">
                @CollectionLoc["CreateCollectionDesc"]
            </MudText>

            <CollectionForm @ref="_collectionForm" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CommonLoc["Btn_Cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="CreateAsync"
                   Disabled="_isCreating">
            @if (_isCreating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @CommonLoc["Btn_Create"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private CollectionForm? _collectionForm;
    private bool _isCreating;

    private void Cancel() => MudDialog.Cancel();

    private async Task CreateAsync()
    {
        if (_collectionForm == null || !await _collectionForm.ValidateAsync())
            return;

        _isCreating = true;
        var dto = new CreateCollectionDto
        {
            Name = _collectionForm.Name,
            Description = InputValidation.NormalizeToNull(_collectionForm.Description)
        };
        var (success, result) = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.CreateCollectionAsync(dto),
            "create collection");
        _isCreating = false;

        if (success)
            MudDialog.Close(DialogResult.Ok(result));
    }
}
