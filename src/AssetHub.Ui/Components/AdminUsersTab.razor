@using AssetHub.Application.Helpers
@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AdminResource> AdminLoc
@inject ISnackbar Snackbar
@inject LocalStorageService LocalStorage

<MudTable T="KeycloakUserDto" ServerData="LoadServerData" @ref="_table"
          Hover="true" Dense="true" Striped="true">
    <NoRecordsContent>
        @if (_totalAll == 0)
        {
            <EmptyState Title="@AdminLoc["NoUsersFound"]"
                        Description="@AdminLoc["NoUsersFoundDesc"]"
                        Icon="@Icons.Material.Filled.PeopleAlt"
                        ActionText="@CommonLoc["Btn_CreateUser"]"
                        ActionIcon="@Icons.Material.Filled.PersonAdd"
                        OnAction="OpenCreateUserDialog" />
        }
        else
        {
            <EmptyState Title="@AdminLoc["NoMatchingUsers"]"
                        Description="@AdminLoc["NoMatchingUsersDesc"]"
                        Icon="@Icons.Material.Filled.SearchOff" />
        }
    </NoRecordsContent>
    <ToolBarContent>
        <MudTextField @bind-Value="_userSearchString" Placeholder="@AdminLoc["SearchUsersPlaceholder"]"
            Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
            IconSize="Size.Medium" Class="mt-0" Immediate="true" DebounceInterval="500"
            @bind-Value:after="OnSearchChanged" T="string" />
        <MudSpacer />
        <MudChip T="string" Color="@(_activeCategory == null ? Color.Info : Color.Default)"
                 Variant="Variant.Outlined" Size="Size.Small"
                 OnClick="@(() => SetCategory(null))" Class="chip-clickable">
            @AdminLoc["Total"]: @_totalAll
        </MudChip>
        <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
        <MudChip T="string" Color="@(_activeCategory == "withaccess" ? Color.Success : Color.Default)"
                 Size="Size.Small" OnClick="@(() => SetCategory("withaccess"))" Class="chip-clickable">
            @AdminLoc["WithAccess"]: @_withAccessCount
        </MudChip>
        <MudChip T="string" Color="@(_activeCategory == "admin" ? Color.Primary : Color.Default)"
                 Size="Size.Small" OnClick="@(() => SetCategory("admin"))" Class="chip-clickable">
            @AdminLoc["Admins"]: @_adminCount
        </MudChip>
        <MudChip T="string" Color="@(_activeCategory == "noaccess" ? Color.Warning : Color.Default)"
                 Size="Size.Small" OnClick="@(() => SetCategory("noaccess"))" Class="chip-clickable">
            @AdminLoc["NoAssignedAccess"]: @_noAccessCount
        </MudChip>
        <MudTooltip Text="@AdminLoc["SyncUsersTooltip"]">
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Sync"
                       OnClick="SyncDeletedUsers" Class="ml-2"
                       Disabled="@_isSyncing">
                @if (_isSyncing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                }
                @AdminLoc["Btn_SyncUsers"]
            </MudButton>
        </MudTooltip>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="OpenCreateUserDialog" Class="ml-2">
            @CommonLoc["Btn_CreateUser"]
        </MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="KeycloakUserDto" SortLabel="username">@AdminLoc["Header_Username"]</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="KeycloakUserDto" SortLabel="email">@AdminLoc["Header_Email"]</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="KeycloakUserDto" SortLabel="createdat">@AdminLoc["Header_Created"]</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="KeycloakUserDto" SortLabel="collectioncount">@CommonLoc["Label_Collections"]</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="KeycloakUserDto" SortLabel="highestrole">@AdminLoc["Header_HighestRole"]</MudTableSortLabel></MudTh>
        <MudTh>@CommonLoc["Label_Actions"]</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Username</MudTd>
        <MudTd>@(context.Email ?? "-")</MudTd>
        <MudTd>
            @if (context.CreatedAt.HasValue)
            {
                <MudTooltip Text="@context.CreatedAt.Value.ToLocalTime().ToString("F")">
                    <MudText Typo="Typo.body2">@context.CreatedAt.Value.ToLocalTime().ToString("g")</MudText>
                </MudTooltip>
            }
            else
            {
                <MudText Typo="Typo.body2">—</MudText>
            }
        </MudTd>
        <MudTd>
            @if (context.IsSystemAdmin)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                         Icon="@Icons.Material.Filled.AdminPanelSettings">
                    @CommonLoc["Text_AllCollections"]
                </MudChip>
            }
            else if (context.CollectionCount > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.CollectionCount</MudChip>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Text_None"]</MudText>
            }
        </MudTd>
        <MudTd>
            @if (context.IsSystemAdmin)
            {
                <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetRoleColor(RoleHierarchy.Roles.Admin)" Variant="Variant.Filled">
                    @CommonLoc[AssetDisplayHelpers.GetRoleKey(RoleHierarchy.Roles.Admin)]
                </MudChip>
            }
            else if (!string.IsNullOrEmpty(context.HighestRole))
            {
                <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetRoleColor(context.HighestRole)">
                    @CommonLoc[AssetDisplayHelpers.GetRoleKey(context.HighestRole)]
                </MudChip>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Text_NoAccess"]</MudText>
            }
        </MudTd>
        <MudTd>
            <MudStack Row="true" Spacing="1">
                <MudTooltip Text="@CommonLoc["Btn_ManageAccess"]">
                    <MudIconButton Icon="@Icons.Material.Filled.ManageAccounts"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   OnClick="@(() => ManageUserAccess(context))" />
                </MudTooltip>
                <MudTooltip Text="@AdminLoc["DeleteUser"]">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => DeleteUser(context))" />
                </MudTooltip>
            </MudStack>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    /// <summary>
    /// Fires after any action that also changes collection ACL data (create/delete/manage access/sync),
    /// so the parent can tell the collections tab to refresh.
    /// </summary>
    [Parameter] public EventCallback OnChanged { get; set; }

    private MudTable<KeycloakUserDto>? _table;
    private string _userSearchString = "";
    private bool _isSyncing;
    private string? _activeCategory;
    private int _totalAll;
    private int _withAccessCount;
    private int _adminCount;
    private int _noAccessCount;

    private const string StorageKeyCategory = "adminUsers_category";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = await LocalStorage.GetAsync(StorageKeyCategory);
            if (!string.IsNullOrEmpty(saved))
            {
                _activeCategory = saved;
                if (_table != null) await _table.ReloadServerData();
            }
        }
    }

    public async Task RefreshAsync()
    {
        if (_table != null) await _table.ReloadServerData();
    }

    private async Task<TableData<KeycloakUserDto>> LoadServerData(TableState state, CancellationToken ct)
    {
        try
        {
            var sortBy = state.SortLabel;
            var sortDesc = state.SortDirection == SortDirection.Descending;
            var skip = state.Page * state.PageSize;

            var response = await Api.GetKeycloakUsersPaginatedAsync(
                _userSearchString, _activeCategory, sortBy, sortDesc, skip, state.PageSize, ct);

            _totalAll = response.TotalAll;
            _withAccessCount = response.WithAccessCount;
            _adminCount = response.AdminCount;
            _noAccessCount = response.NoAccessCount;

            return new TableData<KeycloakUserDto>
            {
                TotalItems = response.TotalFiltered,
                Items = response.Users
            };
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load Keycloak users");
            return new TableData<KeycloakUserDto> { TotalItems = 0, Items = [] };
        }
    }

    private async Task OnSearchChanged()
    {
        if (_table != null) await _table.ReloadServerData();
    }

    private async Task SetCategory(string? category)
    {
        _activeCategory = _activeCategory == category ? null : category;
        await LocalStorage.SetAsync(StorageKeyCategory, _activeCategory ?? "");
        if (_table != null) await _table.ReloadServerData();
    }

    private async Task ManageUserAccess(KeycloakUserDto user)
    {
        var parameters = new DialogParameters<ManageUserAccessDialog>
        {
            { x => x.UserId, user.Id },
            { x => x.Username, user.Username },
            { x => x.Email, user.Email },
            { x => x.FirstName, user.FirstName },
            { x => x.LastName, user.LastName },
            { x => x.IsSystemAdmin, user.IsSystemAdmin }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ManageUserAccessDialog>(AdminLoc["ManageUserAccess"], parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            if (_table != null) await _table.ReloadServerData();
            await OnChanged.InvokeAsync();
        }
    }

    private async Task OpenCreateUserDialog()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<CreateUserDialog>(AdminLoc["CreateNewUser"], options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            if (_table != null) await _table.ReloadServerData();
            await OnChanged.InvokeAsync();
        }
    }

    private async Task DeleteUser(KeycloakUserDto user)
    {
        var confirmed = await DialogService.ShowConfirmAsync(
            AdminLoc["DeleteUser"],
            string.Format(AdminLoc["ConfirmDeleteUser"], user.Username),
            CommonLoc["Btn_Delete"],
            Icons.Material.Filled.PersonRemove,
            Color.Error,
            Color.Error);

        if (!confirmed)
            return;

        var (success, _) = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.DeleteUserAsync(user.Id),
            "delete user",
            string.Format(AdminLoc["UserDeletedSuccess"], user.Username));

        if (success)
        {
            if (_table != null) await _table.ReloadServerData();
            await OnChanged.InvokeAsync();
        }
    }

    private async Task SyncDeletedUsers()
    {
        try
        {
            _isSyncing = true;
            StateHasChanged();

            var preview = await Api.SyncDeletedUsersAsync(dryRun: true);

            if (preview.DeletedUsers == 0)
            {
                Snackbar.Add(AdminLoc["SyncNoGhostUsers"], Severity.Success);
                return;
            }

            var message = string.Format(AdminLoc["SyncConfirm"], preview.DeletedUsers, preview.AclsRemoved, preview.SharesRevoked);

            var confirmed = await DialogService.ShowConfirmAsync(
                AdminLoc["Btn_SyncUsers"],
                message,
                CommonLoc["Btn_Confirm"],
                Icons.Material.Filled.Sync,
                Color.Warning,
                Color.Primary);

            if (!confirmed)
                return;

            var result = await Api.SyncDeletedUsersAsync(dryRun: false);

            Snackbar.Add(string.Format(AdminLoc["SyncCompleted"], result.DeletedUsers, result.AclsRemoved, result.SharesRevoked), Severity.Success);

            if (_table != null) await _table.ReloadServerData();
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "sync users");
        }
        finally
        {
            _isSyncing = false;
            StateHasChanged();
        }
    }
}
