@using AssetHub.Application
@using AssetHub.Application.Dtos
@using AssetHub.Application.Helpers
@using AssetHub.Ui.Services

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AssetsResource> AssetLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="dialog-title-danger">
            <MudIcon Icon="@Icons.Material.Filled.DeleteSweep" Color="Color.Error" />
            <MudText Typo="Typo.h6">@AssetLoc["BulkAssetActions"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Class="dialog-intro dialog-intro-danger">
                @string.Format(AssetLoc["BulkAssetActionsDesc"], SelectedAssets.Count)
            </MudText>

            @if (CollectionId.HasValue)
            {
                <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                    <MudSwitch T="bool" @bind-Value="_permanentDelete" Color="Color.Error"
                               Label="@AssetLoc["BulkAssetPermanentDeleteSwitch"]" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                        @(_permanentDelete ? AssetLoc["BulkAssetPermanentDeleteOn"] : AssetLoc["BulkAssetPermanentDeleteOff"])
                    </MudText>
                </MudPaper>
            }

            <MudSimpleTable Dense="true" Hover="true" Striped="true" Elevation="0" Class="table-outlined">
                <thead>
                    <tr>
                        <th>@AssetLoc["Column_Title"]</th>
                        <th class="col-w-100">@CommonLoc["Label_Type"]</th>
                        <th class="col-w-100 col-text-right">@AssetLoc["Column_Size"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var asset in SelectedAssets)
                    {
                        <tr>
                            <td>@asset.Title</td>
                            <td>
                                <MudText Typo="Typo.body2">
                                    @CommonLoc[AssetDisplayHelpers.GetAssetTypeKey(asset.AssetType)]
                                </MudText>
                            </td>
                            <td class="col-text-right">@AssetDisplayHelpers.FormatFileSize(asset.SizeBytes)</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Disabled="_isProcessing">@CommonLoc["Btn_Close"]</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.DeleteForever"
                   OnClick="BulkDeleteAsync"
                   Disabled="_isProcessing">
            @if (_isProcessing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @string.Format(AssetLoc["BulkAssetDeleteConfirmBtn"], SelectedAssets.Count)
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public List<AssetResponseDto> SelectedAssets { get; set; } = new();
    [Parameter] public Guid? CollectionId { get; set; }

    private bool _isProcessing;
    private bool _permanentDelete;

    private async Task BulkDeleteAsync()
    {
        var confirmMessage = _permanentDelete || !CollectionId.HasValue
            ? string.Format(AssetLoc["BulkAssetDeleteFinalConfirm"], SelectedAssets.Count)
            : string.Format(AssetLoc["BulkAssetRemoveFinalConfirm"], SelectedAssets.Count);

        var confirmParams = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, AssetLoc["BulkAssetDeleteTitle"] },
            { x => x.Message, confirmMessage },
            { x => x.TitleIcon, Icons.Material.Filled.DeleteForever },
            { x => x.IconColor, Color.Error },
            { x => x.ConfirmText, CommonLoc["Btn_Delete"] },
            { x => x.ConfirmColor, Color.Error }
        };
        var confirmDialog = await DialogService.ShowAsync<ConfirmDialog>(null, confirmParams);
        var confirmResult = await confirmDialog.Result;

        if (confirmResult == null || confirmResult.Canceled) return;

        _isProcessing = true;
        StateHasChanged();

        try
        {
            var ids = SelectedAssets.Select(a => a.Id).ToList();
            Guid? fromCollectionId = _permanentDelete ? null : CollectionId;

            var result = await Api.BulkDeleteAssetsAsync(ids, fromCollectionId);

            if (result.Failed > 0)
                Feedback.ShowWarning(string.Format(AssetLoc["BulkAssetDeletePartial"], result.Deleted, result.Failed));
            else
                Feedback.ShowSuccess(string.Format(AssetLoc["BulkAssetDeleteSuccess"], result.Deleted));

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "bulk delete assets");
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private void Close() => MudDialog.Cancel();
}
