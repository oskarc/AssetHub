@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using Dam.Application
@using Dam.Application.Dtos
@using Dam.Application.Helpers
@using Dam.Ui.Services
@using Dam.Ui.Components
@attribute [Authorize(Policy = "RequireAdmin")]
@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AdminResource> AdminLoc
@inject ISnackbar Snackbar

<PageTitle>@AdminLoc["PageTitle"] - @CommonLoc["AppName"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Class="mr-2" />
        @AdminLoc["PageTitle"]
    </MudText>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
        <MudTabPanel Text="@AdminLoc["Tab_ShareManagement"]" Icon="@Icons.Material.Filled.Share">
            @ShareManagementTab
        </MudTabPanel>
        <MudTabPanel Text="@AdminLoc["Tab_CollectionAccess"]" Icon="@Icons.Material.Filled.FolderShared">
            @CollectionAccessTab
        </MudTabPanel>
        <MudTabPanel Text="@AdminLoc["Tab_UserManagement"]" Icon="@Icons.Material.Filled.ManageAccounts">
            @UserManagementTab
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@* ===== SHARE MANAGEMENT TAB ===== *@
@code {
    // Nested component for Share Management
    private RenderFragment ShareManagementTab => __builder =>
    {
        <MudText Typo="Typo.h6" Class="mb-4">@AdminLoc["AllSharedLinks"]</MudText>
        
        @if (_sharesLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_shares == null || !_shares.Any())
        {
            <EmptyState Title="@AdminLoc["NoSharesYet"]"
                        Description="@AdminLoc["NoSharesDesc"]"
                        Icon="@Icons.Material.Filled.Share" />
        }
        else
        {
            <MudTable Items="@_shares" Hover="true" Dense="true" Striped="true" Filter="ShareFilter" SortLabel="Sort By">
                <ToolBarContent>
                    <MudTextField @bind-Value="_shareSearchString" Placeholder="@AdminLoc["SearchSharesPlaceholder"]" 
                        Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                        IconSize="Size.Medium" Class="mt-0" Immediate="true" />
                    <MudSpacer />
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">@AdminLoc["Active"]: @_shares.Count(s => s.Status == "Active")</MudChip>
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">@AdminLoc["Expired"]: @_shares.Count(s => s.Status == "Expired")</MudChip>
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">@AdminLoc["Revoked"]: @_shares.Count(s => s.Status == "Revoked")</MudChip>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.ScopeType)">@CommonLoc["Label_Type"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.ScopeName)">@AdminLoc["Header_Target"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.CreatedByUserName)">@AdminLoc["Header_CreatedBy"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.CreatedAt)">@CommonLoc["Label_Created"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.ExpiresAt)">@CommonLoc["Label_Expires"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.LastAccessedAt ?? DateTime.MinValue)">@AdminLoc["Header_LastAccess"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.AccessCount)">@AdminLoc["Header_AccessCount"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.Status)">@CommonLoc["Label_Status"]</MudTableSortLabel></MudTh>
                    <MudTh>@CommonLoc["Label_Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@(context.ScopeType == "asset" ? Color.Info : Color.Default)" Variant="Variant.Outlined">
                            @context.ScopeType
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudTooltip Text="@context.ScopeId.ToString()">
                            @context.ScopeName
                        </MudTooltip>
                        @if (context.HasPassword)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Warning" Class="ml-1" />
                        }
                    </MudTd>
                    <MudTd>@context.CreatedByUserName</MudTd>
                    <MudTd>@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
                    <MudTd>@context.ExpiresAt.ToLocalTime().ToString("g")</MudTd>
                    <MudTd>@(context.LastAccessedAt?.ToLocalTime().ToString("g") ?? @CommonLoc["Text_Never"])</MudTd>
                    <MudTd><MudChip T="string" Size="Size.Small">@context.AccessCount</MudChip></MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetShareStatusColor(context.Status)">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        @if (context.Status == "Active")
                        {
                            <MudStack Row="true" Spacing="1">
                                <MudTooltip Text="@AdminLoc["ShowShareInfo"]">
                                    <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Size="Size.Small"
                                        OnClick="@(() => ShowShareInfo(context))" />
                                </MudTooltip>
                                @if (context.HasPassword)
                                {
                                    <MudTooltip Text="@AdminLoc["EditPassword"]">
                                        <MudIconButton Icon="@Icons.Material.Filled.Key" Color="Color.Primary" Size="Size.Small"
                                            OnClick="@(() => EditSharePassword(context))" />
                                    </MudTooltip>
                                }
                                <MudTooltip Text="@AdminLoc["RevokeShare"]">
                                    <MudIconButton Icon="@Icons.Material.Filled.Block" Color="Color.Error" Size="Size.Small"
                                        OnClick="@(() => RevokeShare(context))" />
                                </MudTooltip>
                            </MudStack>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    };
}

@* ===== COLLECTION ACCESS TAB ===== *@
@code {
    private RenderFragment CollectionAccessTab => __builder =>
    {
        <MudText Typo="Typo.h6" Class="mb-4">@AdminLoc["CollectionAccessControl"]</MudText>
        
        @if (_collectionsLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_collections == null || !_collections.Any())
        {
            <EmptyState Title="@AdminLoc["NoCollectionsYet"]"
                        Description="@AdminLoc["NoCollectionsDesc"]"
                        Icon="@Icons.Material.Filled.Folder" />
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="5">
                    <MudPaper Elevation="2" Class="pa-4 admin-collection-tree">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">@CommonLoc["Label_Collections"]</MudText>
                        @foreach (var collection in _collections)
                        {
                            @RenderCollectionTree(collection, 0)
                        }
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="7">
                    <MudPaper Elevation="2" Class="pa-4">
                        @if (_selectedCollection == null)
                        {
                            <EmptyState Title="@AdminLoc["SelectACollection"]"
                                        Description="@AdminLoc["SelectACollectionDesc"]"
                                        Icon="@Icons.Material.Filled.FolderShared" />
                        }
                        else
                        {
                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                @AdminLoc["AccessFor"] <strong>@_selectedCollection.Name</strong>
                            </MudText>
                            
                            @* Add user form *@
                            <MudGrid Class="mb-4">
                                <MudItem xs="12" sm="5">
                                    <MudAutocomplete T="KeycloakUserDto"
                                                     @bind-Value="_newAclUser"
                                                     SearchFunc="SearchUsersForAcl"
                                                     ToStringFunc="@(u => u?.Username ?? "")"
                                                     Label="@AdminLoc["SearchUsersPlaceholder"]"
                                                     Variant="Variant.Outlined"
                                                     Margin="Margin.Dense"
                                                     ResetValueOnEmptyText="true"
                                                     DebounceInterval="200"
                                                     MinCharacters="0"
                                                     MaxItems="20">
                                        <ItemTemplate Context="user">
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2">@user.Username</MudText>
                                                @if (!string.IsNullOrEmpty(user.Email))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@user.Email</MudText>
                                                }
                                            </MudStack>
                                        </ItemTemplate>
                                    </MudAutocomplete>
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudSelect @bind-Value="_newAclRole" Label="@CommonLoc["Label_Role"]" 
                                        Variant="Variant.Outlined" Margin="Margin.Dense">
                                        <MudSelectItem Value="@RoleHierarchy.Roles.Viewer">@CommonLoc["Role_Viewer"]</MudSelectItem>
                                        <MudSelectItem Value="@RoleHierarchy.Roles.Contributor">@CommonLoc["Role_Contributor"]</MudSelectItem>
                                        <MudSelectItem Value="@RoleHierarchy.Roles.Manager">@CommonLoc["Role_Manager"]</MudSelectItem>
                                        <MudSelectItem Value="@RoleHierarchy.Roles.Admin">@CommonLoc["Role_Admin"]</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="3">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                        OnClick="AddCollectionAccess" Disabled="@(_newAclUser == null)"
                                        FullWidth="true" Class="mt-1">
                                        @CommonLoc["Btn_Add"]
                                    </MudButton>
                                </MudItem>
                            </MudGrid>
                            
                            @* Current ACLs *@
                            @if (!_selectedCollection.Acls.Any())
                            {
                                <EmptyState Title="@AdminLoc["NoUsersHaveAccess"]"
                                            Description="@AdminLoc["NoUsersHaveAccessDesc"]"
                                            Icon="@Icons.Material.Filled.PersonAdd" />
                            }
                            else
                            {
                                <MudSimpleTable Dense="true" Hover="true" Striped="true">
                                    <thead>
                                        <tr>
                                            <th>@CommonLoc["Label_User"]</th>
                                            <th>@CommonLoc["Label_Role"]</th>
                                            <th>@CommonLoc["Label_Actions"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var acl in _selectedCollection.Acls)
                                        {
                                            <tr>
                                                <td>
                                                    <MudStack Spacing="0">
                                                        <MudText Typo="Typo.body2">@acl.PrincipalName</MudText>
                                                        @if (!string.IsNullOrEmpty(acl.PrincipalEmail))
                                                        {
                                                            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@acl.PrincipalEmail</MudText>
                                                        }
                                                    </MudStack>
                                                </td>
                                                <td>
                                                    <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetRoleColor(acl.Role)">
                                                        @acl.Role
                                                    </MudChip>
                                                </td>
                                                <td>
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" 
                                                        Size="Size.Small" OnClick="@(() => RemoveCollectionAccess(acl))" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            }
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    };
}

@* ===== USER MANAGEMENT TAB ===== *@
@code {
    private RenderFragment UserManagementTab => __builder =>
    {
        <MudText Typo="Typo.h6" Class="mb-4">@AdminLoc["UserManagement"]</MudText>
        
        @if (_allUsersLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_allUsers == null || !_allUsers.Any())
        {
            <EmptyState Title="@AdminLoc["NoUsersFound"]"
                        Description="@AdminLoc["NoUsersFoundDesc"]"
                        Icon="@Icons.Material.Filled.PeopleAlt"
                        ActionText="@CommonLoc["Btn_CreateUser"]"
                        ActionIcon="@Icons.Material.Filled.PersonAdd"
                        OnAction="OpenCreateUserDialog" />
        }
        else
        {
            <MudTable Items="@_allUsers" Hover="true" Dense="true" Striped="true" Filter="new Func<KeycloakUserDto,bool>(UserFilter)" SortLabel="Sort By">
                <ToolBarContent>
                    <MudTextField @bind-Value="_userSearchString" Placeholder="@AdminLoc["SearchUsersPlaceholder"]" 
                        Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                        IconSize="Size.Medium" Class="mt-0" Immediate="true" />
                    <MudSpacer />
                    <MudChip T="string" Color="Color.Info" Size="Size.Small">@AdminLoc["Total"]: @_allUsers.Count</MudChip>
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">@AdminLoc["WithAccess"]: @_allUsers.Count(u => u.CollectionCount > 0)</MudChip>
                    <MudTooltip Text="@AdminLoc["SyncUsersTooltip"]">
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Sync"
                                   OnClick="SyncDeletedUsers" Class="ml-2"
                                   Disabled="@_isSyncing">
                            @if (_isSyncing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                            }
                            @AdminLoc["Btn_SyncUsers"]
                        </MudButton>
                    </MudTooltip>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               OnClick="OpenCreateUserDialog" Class="ml-2">
                        @CommonLoc["Btn_CreateUser"]
                    </MudButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.Username)">@AdminLoc["Header_Username"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.Email ?? string.Empty)">@AdminLoc["Header_Email"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.CreatedAt ?? DateTime.MinValue)">@AdminLoc["Header_Created"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.CollectionCount)">@CommonLoc["Label_Collections"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.HighestRole ?? string.Empty)">@AdminLoc["Header_HighestRole"]</MudTableSortLabel></MudTh>
                    <MudTh>@CommonLoc["Label_Actions"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Username</MudTd>
                    <MudTd>@(context.Email ?? "-")</MudTd>
                    <MudTd>@(context.CreatedAt?.ToLocalTime().ToString("g") ?? "-")</MudTd>
                    <MudTd>
                        @if (context.CollectionCount > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.CollectionCount</MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="opacity: 0.6;">@CommonLoc["Text_None"]</MudText>
                        }
                    </MudTd>
                    <MudTd>
                        @if (!string.IsNullOrEmpty(context.HighestRole))
                        {
                            <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetRoleColor(context.HighestRole)">
                                @context.HighestRole
                            </MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="opacity: 0.6;">@CommonLoc["Text_NoAccess"]</MudText>
                        }
                    </MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="1">
                            <MudTooltip Text="@CommonLoc["Btn_ManageAccess"]">
                                <MudIconButton Icon="@Icons.Material.Filled.ManageAccounts"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="@(() => ManageUserAccess(context))" />
                            </MudTooltip>
                            <MudTooltip Text="@AdminLoc["DeleteUser"]">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                               Color="Color.Error" 
                                               Size="Size.Small"
                                               OnClick="@(() => DeleteUser(context))" />
                            </MudTooltip>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        }
    };
}

@* ===== CODE-BEHIND ===== *@
@code {
    // Share Management State
    private List<AdminShareDto>? _shares;
    private bool _sharesLoading = true;
    private string _shareSearchString = "";

    // Collection Access State
    private List<CollectionAccessDto>? _collections;
    private bool _collectionsLoading = true;
    private CollectionAccessDto? _selectedCollection;
    private KeycloakUserDto? _newAclUser;
    private string _newAclRole = RoleHierarchy.Roles.Viewer;

    // All Keycloak Users State
    private List<KeycloakUserDto>? _allUsers;
    private bool _allUsersLoading = true;
    private string _userSearchString = "";
    private bool _isSyncing = false;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadShares(),
            LoadCollections(),
            LoadAllUsers()
        );
    }

    // ===== SHARE MANAGEMENT =====
    
    private async Task LoadShares()
    {
        try
        {
            _sharesLoading = true;
            _shares = await Api.GetAllSharesAsync();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load shares");
        }
        finally
        {
            _sharesLoading = false;
            StateHasChanged();
        }
    }

    private bool ShareFilter(AdminShareDto share)
    {
        if (string.IsNullOrWhiteSpace(_shareSearchString))
            return true;
        
        return share.ScopeName.Contains(_shareSearchString, StringComparison.OrdinalIgnoreCase)
            || share.CreatedByUserName.Contains(_shareSearchString, StringComparison.OrdinalIgnoreCase)
            || share.Status.Contains(_shareSearchString, StringComparison.OrdinalIgnoreCase);
    }

    private async Task EditSharePassword(AdminShareDto share)
    {
        var parameters = new DialogParameters<SharePasswordDialog>
        {
            { x => x.Share, share }
        };

        var dialog = await DialogService.ShowAsync<SharePasswordDialog>(AdminLoc["EditSharePassword"], parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            // Refresh the shares list to reflect any changes
            await LoadShares();
        }
    }

    private async Task RevokeShare(AdminShareDto share)
    {
        var confirmed = await DialogService.ShowMessageBox(
            CommonLoc["Confirm_Revoke"],
            string.Format(AdminLoc["ConfirmRevokeShare"], share.ScopeName),
            yesText: CommonLoc["Btn_Revoke"], cancelText: CommonLoc["Btn_Cancel"]);
        
        if (confirmed != true)
            return;

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.RevokeShareAdminAsync(share.Id),
            "revoke share",
            AdminLoc["ShareRevokedSuccess"]);
        
        if (success)
        {
            await LoadShares();
        }
    }

    // ===== COLLECTION ACCESS =====
    
    private async Task LoadCollections()
    {
        try
        {
            _collectionsLoading = true;
            var selectedId = _selectedCollection?.Id;
            _collections = await Api.GetCollectionAccessAsync();
            
            // Re-select the previously selected collection to show updated ACLs
            if (selectedId.HasValue)
            {
                _selectedCollection = CollectionTreeHelper.FindById(_collections, selectedId.Value);
            }
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collections");
        }
        finally
        {
            _collectionsLoading = false;
            StateHasChanged();
        }
    }

    private RenderFragment RenderCollectionTree(CollectionAccessDto collection, int depth) => __builder =>
    {
        var isSelected = _selectedCollection?.Id == collection.Id;
        var depthClass = $"admin-tree-item-depth-{Math.Min(depth, 5)}";
        
        <MudButton Variant="@(isSelected ? Variant.Filled : Variant.Text)" 
            Color="@(isSelected ? Color.Primary : Color.Default)"
            OnClick="@(() => SelectCollection(collection))"
            FullWidth="true"
            Class="@($"justify-start mb-1 admin-tree-item {depthClass}")">
            <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Class="mr-2" />
            @collection.Name
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="Color.Default">@collection.Acls.Count</MudChip>
        </MudButton>
        
        @foreach (var child in collection.Children)
        {
            @RenderCollectionTree(child, depth + 1)
        }
    };

    private void SelectCollection(CollectionAccessDto collection)
    {
        _selectedCollection = collection;
        _newAclUser = null;
        _newAclRole = RoleHierarchy.Roles.Viewer;
    }

    private Task<IEnumerable<KeycloakUserDto>> SearchUsersForAcl(string? value, CancellationToken ct)
    {
        var users = _allUsers ?? new List<KeycloakUserDto>();
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(users.AsEnumerable());

        var filtered = users.Where(u =>
            u.Username.Contains(value, StringComparison.OrdinalIgnoreCase)
            || (u.Email?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false)
            || (u.FirstName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false)
            || (u.LastName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false));

        return Task.FromResult(filtered);
    }

    private async Task AddCollectionAccess()
    {
        if (_selectedCollection == null || _newAclUser == null)
            return;

        var userId = _newAclUser.Id;
        var username = _newAclUser.Username;

        try
        {
            await Api.AddCollectionAclAsync(_selectedCollection.Id, Constants.PrincipalTypes.User, userId, _newAclRole);
            Feedback.ShowSuccess(string.Format(CommonLoc["Success_AccessGranted"], username));
            _newAclUser = null;
            await LoadCollections();
            
            // Re-select the collection to refresh ACLs
            _selectedCollection = CollectionTreeHelper.FindById(_collections, _selectedCollection.Id);
        }
        catch (Exception ex)
        {
            // Check if it's a "user not found" error and show a helpful message
            if (ex.Message.Contains("not found", StringComparison.OrdinalIgnoreCase))
            {
                Feedback.ShowWarning(string.Format(CommonLoc["Warning_UserNotFound"], username));
            }
            else
            {
                Feedback.HandleError(ex, "add access");
            }
        }
    }

    private async Task RemoveCollectionAccess(CollectionAclResponseDto acl)
    {
        if (_selectedCollection == null)
            return;

        var confirmed = await DialogService.ShowMessageBox(
            CommonLoc["Confirm_RemoveAccess"],
            string.Format(AdminLoc["ConfirmRemoveAccess"], acl.PrincipalId, _selectedCollection.Name),
            yesText: CommonLoc["Btn_Remove"], cancelText: CommonLoc["Btn_Cancel"]);
        
        if (confirmed != true)
            return;

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.RemoveCollectionAclAsync(_selectedCollection.Id, acl.PrincipalId, acl.PrincipalType),
            "remove access",
            string.Format(CommonLoc["Success_AccessRemoved"], acl.PrincipalId));
        
        if (success)
        {
            await LoadCollections();
            _selectedCollection = CollectionTreeHelper.FindById(_collections, _selectedCollection.Id);
        }
    }

    // ===== USER MANAGEMENT =====
    
    private async Task LoadAllUsers()
    {
        try
        {
            _allUsersLoading = true;
            _allUsers = await Api.GetKeycloakUsersAsync();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load Keycloak users");
        }
        finally
        {
            _allUsersLoading = false;
            StateHasChanged();
        }
    }

    private bool UserFilter(KeycloakUserDto user)
    {
        if (string.IsNullOrWhiteSpace(_userSearchString))
            return true;
        
        return user.Username.Contains(_userSearchString, StringComparison.OrdinalIgnoreCase)
            || (user.Email?.Contains(_userSearchString, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private async Task ManageUserAccess(KeycloakUserDto user)
    {
        var parameters = new DialogParameters<ManageUserAccessDialog>
        {
            { x => x.UserId, user.Id },
            { x => x.Username, user.Username },
            { x => x.Email, user.Email },
            { x => x.FirstName, user.FirstName },
            { x => x.LastName, user.LastName }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ManageUserAccessDialog>(AdminLoc["ManageUserAccess"], parameters, options);
        var result = await dialog.Result;

        // Refresh both user list and collection access to show updated data
        if (result != null && !result.Canceled)
        {
            await Task.WhenAll(LoadAllUsers(), LoadCollections());
        }
    }

    private async Task OpenCreateUserDialog()
    {
