@using AssetHub.Application
@using AssetHub.Application.Dtos
@using AssetHub.Ui.Services

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AssetsResource> AssetLoc
@inject IStringLocalizer<AdminResource> AdminLoc

@if (_isLoading)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">@AssetLoc["LoadingAssets"]</MudText>
    </MudStack>
}
else if (_assets.Count == 0)
{
    <EmptyState Title="@AssetLoc["NoAssetsYet"]"
                Description="@AssetLoc["NoAssetsGridHint"]"
                Icon="@Icons.Material.Filled.PhotoLibrary" />
}
else
{
    @if (ViewMode == Constants.ViewModes.Grid)
    {
    <MudGrid Spacing="3">
        <AssetCardGrid Items="@_assets"
                       SelectionMode="@SelectionMode"
                       SelectedAssetIds="@SelectedAssetIds"
                       UserRole="@UserRole"
                       OnAssetClick="@OnAssetClicked"
                       OnToggleSelection="@OnToggleAssetSelection"
                       OnShare="@ShareAsset"
                       OnDelete="@DeleteAsset" />
    </MudGrid>
    }
    else
    {
        <AssetTable Items="@_assets"
                    SelectionMode="@SelectionMode"
                    SelectedAssetIds="@SelectedAssetIds"
                    UserRole="@UserRole"
                    OnAssetClick="@OnAssetClicked"
                    OnToggleSelection="@OnToggleAssetSelection"
                    OnShare="@ShareAsset"
                    OnDelete="@DeleteAsset" />
    }

    @if (_total > _assets.Count)
    {
        <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
            <MudButton Variant="Variant.Outlined" OnClick="LoadMoreAsync">
                @CommonLoc["Btn_LoadMore"] @string.Format(CommonLoc["Text_Remaining"].Value, _total - _assets.Count)
            </MudButton>
        </MudStack>
    }
}

@code {
    [Parameter]
    public Guid? CollectionId { get; set; }

    [Parameter]
    public string? SearchQuery { get; set; }

    [Parameter]
    public string? FilterType { get; set; }

    private const string SortBy = Constants.SortBy.CreatedDesc;

    [Parameter]
    public string ViewMode { get; set; } = Constants.ViewModes.Grid;

    [Parameter]
    public string UserRole { get; set; } = RoleHierarchy.Roles.Viewer;

    [Parameter]
    public EventCallback<AssetResponseDto> OnAssetSelected { get; set; }

    [Parameter]
    public EventCallback OnAssetsChanged { get; set; }

    [Parameter]
    public bool SelectionMode { get; set; }

    [Parameter]
    public HashSet<Guid> SelectedAssetIds { get; set; } = new();

    [Parameter]
    public EventCallback<HashSet<Guid>> SelectedAssetIdsChanged { get; set; }

    private readonly List<AssetResponseDto> _assets = new();
    private int _total = 0;
    private int _skip = 0;
    private const int _take = 24;
    private bool _isLoading = true;
    private Guid? _loadedCollectionId;
    private string? _loadedFilterType;
    private string _loadedSearchQuery = "";

    protected override async Task OnParametersSetAsync()
    {
        if (CollectionId.HasValue)
        {
            var collectionChanged = _loadedCollectionId != CollectionId.Value;
            var filterChanged = _loadedFilterType != FilterType
                             || _loadedSearchQuery != (SearchQuery ?? "");

            if (collectionChanged || filterChanged)
            {
                _loadedCollectionId = CollectionId.Value;
                _loadedFilterType = FilterType;
                _loadedSearchQuery = SearchQuery ?? "";
                _skip = 0;
                _assets.Clear();
                await LoadAssetsAsync();
            }
        }
        else
        {
            _loadedCollectionId = null;
            _assets.Clear();
            _total = 0;
            _isLoading = false;
        }
    }

    private async Task LoadAssetsAsync()
    {
        if (!CollectionId.HasValue) return;

        try
        {
            _isLoading = true;
            var response = await Api.GetAssetsAsync(
                CollectionId.Value,
                SearchQuery,
                FilterType,
                SortBy,
                _skip,
                _take);
            _assets.AddRange(response.Items);
            _total = response.Total;
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load assets");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMoreAsync()
    {
        _skip = _assets.Count;
        await LoadAssetsAsync();
    }

    public async Task RefreshAsync()
    {
        _skip = 0;
        _assets.Clear();
        await LoadAssetsAsync();
    }

    // ── Event handlers for sub-components ────────────────────────────────

    private void OnAssetClicked(AssetResponseDto asset)
    {
        ViewAsset(asset.Id);
    }

    private async Task OnToggleAssetSelection((Guid Id, bool Selected) args)
    {
        if (args.Selected)
            SelectedAssetIds.Add(args.Id);
        else
            SelectedAssetIds.Remove(args.Id);
        await SelectedAssetIdsChanged.InvokeAsync(SelectedAssetIds);
    }

    // ── Navigation ───────────────────────────────────────────────────────

    private void ViewAsset(Guid id)
    {
        if (CollectionId.HasValue)
        {
            Nav.NavigateTo($"/assets/{id}?returnUrl=/collections%3Fcollection%3D{CollectionId.Value}");
        }
        else
        {
            Nav.NavigateTo($"/assets/{id}");
        }
    }

    // ── Asset actions ────────────────────────────────────────────────────

    private async Task ShareAsset(AssetResponseDto asset)
    {
        var share = await DialogService.ShowShareFlowAsync(
            asset.Id,
            Constants.ScopeTypes.Asset,
            asset.Title,
            AssetLoc["CreateShareLink"],
            AssetLoc["ShareLinkCreated"]);

        if (share != null)
        {
            await OnAssetsChanged.InvokeAsync();
        }
    }

    private async Task DeleteAsset(AssetResponseDto asset)
    {
        var dialog = await DialogService.ShowAsync<DeleteAssetDialog>(
            null,
            new DialogParameters<DeleteAssetDialog>
            {
                { x => x.AssetId, asset.Id },
                { x => x.AssetTitle, asset.Title },
                { x => x.FromCollectionId, CollectionId }
            });

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not string action) return;

        var success = action == DeleteAssetDialog.ActionRemove && CollectionId.HasValue
            ? await RemoveFromCollectionAsync(asset)
            : await SoftDeleteAsync(asset);

        if (success)
        {
            _assets.Remove(asset);
            _total--;
            await OnAssetsChanged.InvokeAsync();
        }
    }

    private Task<bool> RemoveFromCollectionAsync(AssetResponseDto asset)
        => Feedback.ExecuteWithFeedbackAsync(
            () => Api.DeleteAssetAsync(asset.Id, CollectionId),
            "remove asset from collection",
            AssetLoc["AssetRemovedSuccess"]);

    private async Task<bool> SoftDeleteAsync(AssetResponseDto asset)
    {
        // Full delete is now soft (T1-LIFE-01) — show an undo snackbar so users can recover
        // within the 10 s window without bouncing through the admin Trash tab.
        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.DeleteAssetAsync(asset.Id),
            "delete asset",
            successMessage: null);
        if (!success) return false;

        var deletedAsset = asset;
        Feedback.ShowActionableInfo(
            string.Format(AdminLoc["Trash_DeleteSnackbar"].Value, deletedAsset.Title),
            AdminLoc["Trash_DeleteSnackbar_Undo"].Value,
            () => UndoSoftDeleteAsync(deletedAsset));
        return true;
    }

    private async Task UndoSoftDeleteAsync(AssetResponseDto deletedAsset)
    {
        try
        {
            await Api.RestoreFromTrashAsync(deletedAsset.Id);
            _assets.Insert(0, deletedAsset);
            _total++;
            await OnAssetsChanged.InvokeAsync();
            StateHasChanged();
        }
        catch
        {
            Feedback.ShowError(CommonLoc["Error_RestoreFailed"].Value);
        }
    }

    // ── Public helpers for parent access ─────────────────────────────────

    public List<AssetResponseDto> GetSelectedAssets() =>
        _assets.Where(a => SelectedAssetIds.Contains(a.Id)).ToList();

    public List<Guid> GetAllAssetIds() =>
        _assets.Select(a => a.Id).ToList();
}
