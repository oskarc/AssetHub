@using AssetHub.Application.Helpers

@inject IStringLocalizer<AssetsResource> AssetLoc
@inject IStringLocalizer<CollectionsResource> CollectionLoc
@inject IStringLocalizer<CommonResource> CommonLoc

<MudText Typo="Typo.h6" Class="mb-1">@AssetLoc["SelectCollection"]</MudText>
<MudText Typo="Typo.body2" Class="mb-3" Color="Color.Secondary">@AssetLoc["SelectCollectionDesc"]</MudText>

<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
    <MudTextField Value="@SearchString"
                  ValueChanged="@SearchStringChanged"
                  Placeholder="@AssetLoc["SearchCollectionsPlaceholder"]"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true"
                  Class="flex-1"
                  T="string" />
    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
        <MudIconButton Icon="@Icons.Material.Filled.GridView"
                       Color="@(ViewMode == Constants.ViewModes.Grid ? Color.Primary : Color.Default)"
                       OnClick="@(() => ViewModeChanged.InvokeAsync(Constants.ViewModes.Grid))"
                       aria-label="@CommonLoc["Aria_GridView"]" />
        <MudIconButton Icon="@Icons.Material.Filled.ViewList"
                       Color="@(ViewMode == Constants.ViewModes.List ? Color.Primary : Color.Default)"
                       OnClick="@(() => ViewModeChanged.InvokeAsync(Constants.ViewModes.List))"
                       aria-label="@CommonLoc["Aria_ListView"]" />
    </MudButtonGroup>
</MudStack>

@if (Loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (AllCollections == null || !FilteredCollections.Any())
{
    <EmptyState Title="@AssetLoc["NoCollectionsFound"]"
                Icon="@Icons.Material.Filled.FolderOff" />
}
else if (ViewMode == Constants.ViewModes.Grid)
{
    <MudGrid>
        @foreach (var collection in FilteredCollections)
        {
            <MudItem xs="6" sm="4" md="3" lg="2">
                <MudCard Class="@GetCollectionCardClass(collection.Id)" @onclick="() => OnCollectionCardClick(collection)">
                    <MudCardContent>
                        <div class="d-flex align-center gap-2 collection-card-header">
                            @if (SelectionMode)
                            {
                                <MudCheckBox T="bool"
                                             Value="@SelectedCollectionIds.Contains(collection.Id)"
                                             ValueChanged="@(v => ToggleCollectionSelection(collection.Id, v))"
                                             Size="Size.Small"
                                             Color="Color.Primary"
                                             Class="checkbox-compact-card"
                                             @onclick:stopPropagation="true" />
                            }
                            <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" Class="flex-shrink-0" />
                            <MudTooltip Text="@collection.Name" Class="tooltip-flex">
                                <MudText Typo="Typo.subtitle2" Class="collection-name-truncate">@collection.Name</MudText>
                            </MudTooltip>
                        </div>
                        <div class="d-flex align-center gap-1 mt-2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@CollectionLoc["YourRole"]:</MudText>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@AssetDisplayHelpers.GetRoleColor(collection.UserRole)">
                                @CommonLoc[AssetDisplayHelpers.GetRoleKey(collection.UserRole)]
                            </MudChip>
                        </div>
                        <div class="mt-1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@string.Format(CommonLoc["Text_CountAssets"], collection.AssetCount)</MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}
else
{
    <MudTable Items="@FilteredCollections" Dense="true" Hover="true" Striped="true" Elevation="0"
              Breakpoint="Breakpoint.Sm" OnRowClick="@OnCollectionRowClick" T="CollectionResponseDto"
              RowClass="cursor-pointer" Class="table-outlined">
        <HeaderContent>
            @if (SelectionMode)
            {
                <MudTh Class="col-w-42"></MudTh>
            }
            <MudTh><MudTableSortLabel SortBy="new Func<CollectionResponseDto, object>(x => x.Name)">@CollectionLoc["CollectionName"]</MudTableSortLabel></MudTh>
            <MudTh Class="col-w-200"><MudTableSortLabel SortBy="new Func<CollectionResponseDto, object>(x => x.Description ?? string.Empty)">@CollectionLoc["Description"]</MudTableSortLabel></MudTh>
            <MudTh Class="col-w-120"><MudTableSortLabel SortBy="new Func<CollectionResponseDto, object>(x => x.UserRole)">@CollectionLoc["YourRole"]</MudTableSortLabel></MudTh>
            <MudTh Class="col-w-100"><MudTableSortLabel SortBy="new Func<CollectionResponseDto, object>(x => x.AssetCount)">@CommonLoc["Text_CountAssetsHeader"]</MudTableSortLabel></MudTh>
        </HeaderContent>
        <RowTemplate>
            @if (SelectionMode)
            {
                <MudTd @onclick:stopPropagation="true">
                    <MudCheckBox T="bool"
                                 Value="@SelectedCollectionIds.Contains(context.Id)"
                                 ValueChanged="@(v => ToggleCollectionSelection(context.Id, v))"
                                 Size="Size.Small"
                                 Color="Color.Primary"
                                 Class="checkbox-compact" />
                </MudTd>
            }
            <MudTd DataLabel="@CollectionLoc["CollectionName"]">
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" Size="Size.Small" />
                    <MudText Typo="Typo.body2">@context.Name</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="@CollectionLoc["Description"]">
                @if (!string.IsNullOrWhiteSpace(context.Description))
                {
                    <MudTooltip Text="@context.Description">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@Truncate(context.Description, 20)</MudText>
                    </MudTooltip>
                }
            </MudTd>
            <MudTd DataLabel="@CollectionLoc["YourRole"]">
                <MudChip T="string" Size="Size.Small"
                         Color="@AssetDisplayHelpers.GetRoleColor(context.UserRole)">
                    @CommonLoc[AssetDisplayHelpers.GetRoleKey(context.UserRole)]
                </MudChip>
            </MudTd>
            <MudTd DataLabel="@CommonLoc["Text_CountAssetsHeader"]" Class="col-text-right">@context.AssetCount</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter] public List<CollectionResponseDto>? AllCollections { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string SearchString { get; set; } = "";
    [Parameter] public EventCallback<string> SearchStringChanged { get; set; }
    [Parameter] public string ViewMode { get; set; } = Constants.ViewModes.Grid;
    [Parameter] public EventCallback<string> ViewModeChanged { get; set; }
    [Parameter] public bool SelectionMode { get; set; }
    [Parameter] public HashSet<Guid> SelectedCollectionIds { get; set; } = new();
    [Parameter] public EventCallback<Guid?> OnCollectionSelected { get; set; }

    private IEnumerable<CollectionResponseDto> FilteredCollections =>
        (AllCollections ?? Enumerable.Empty<CollectionResponseDto>())
        .Where(c => string.IsNullOrWhiteSpace(SearchString)
            || c.Name.Contains(SearchString, StringComparison.OrdinalIgnoreCase)
            || (c.Description?.Contains(SearchString, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(c => c.Name, new NaturalSortComparer());

    private void ToggleCollectionSelection(Guid id, bool selected)
    {
        if (selected)
            SelectedCollectionIds.Add(id);
        else
            SelectedCollectionIds.Remove(id);
    }

    private string GetCollectionCardClass(Guid id) =>
        SelectedCollectionIds.Contains(id)
            ? "cursor-pointer collection-card mud-border-primary"
            : "cursor-pointer collection-card";

    private async Task OnCollectionCardClick(CollectionResponseDto collection)
    {
        if (SelectionMode)
        {
            ToggleCollectionSelection(collection.Id, !SelectedCollectionIds.Contains(collection.Id));
            return;
        }
        await OnCollectionSelected.InvokeAsync(collection.Id);
    }

    private async Task OnCollectionRowClick(TableRowClickEventArgs<CollectionResponseDto> args)
    {
        if (args.Item is not null)
            await OnCollectionCardClick(args.Item);
    }

    private static string Truncate(string value, int maxLength) =>
        value.Length > maxLength ? value[..maxLength] + "…" : value;
}
