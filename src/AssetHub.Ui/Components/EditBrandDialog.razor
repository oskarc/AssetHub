@using AssetHub.Application.Dtos
@using AssetHub.Ui.Resources
@using AssetHub.Ui.Services
@using MudBlazor

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<BrandsResource> Loc

@*
    Edit dialog for an existing brand. Same form shape as CreateBrandDialog;
    only field changes that differ from the seed value land on the PATCH —
    UpdateBrandDto's properties are all nullable so unset fields are no-ops
    server-side. Opened from the row-level edit button on AdminBrandsTab.
*@
<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.Palette" />
            <MudText Typo="Typo.h6">@Loc["Dialog_Edit_Title"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 480px;">
            <MudTextField @bind-Value="_name"
                          Label="@Loc["Dialog_Field_Name"]"
                          Required="true"
                          MaxLength="200"
                          Variant="Variant.Outlined" />

            <MudStack Row="true" Spacing="2">
                <MudTextField @bind-Value="_primary"
                              Label="@Loc["Dialog_Field_PrimaryColor"]"
                              Variant="Variant.Outlined"
                              MaxLength="16"
                              Validation="@(new Func<string, IEnumerable<string>>(ValidateHex))"
                              Style="flex: 1;" />
                <MudTextField @bind-Value="_secondary"
                              Label="@Loc["Dialog_Field_SecondaryColor"]"
                              Variant="Variant.Outlined"
                              MaxLength="16"
                              Validation="@(new Func<string, IEnumerable<string>>(ValidateHex))"
                              Style="flex: 1;" />
            </MudStack>

            <MudSwitch T="bool" @bind-Value="_isDefault"
                       Label="@Loc["Dialog_Field_IsDefault"]"
                       Color="Color.Primary" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@Loc["Dialog_Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@_submitting"
                   OnClick="SubmitAsync">
            @Loc["Dialog_Save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>The brand to edit. Required parameter — caller passes the row's DTO.</summary>
    [Parameter, EditorRequired] public BrandResponseDto Brand { get; set; } = null!;

    private string _name = string.Empty;
    private string _primary = "#1976D2";
    private string _secondary = "#424242";
    private bool _isDefault;
    private bool _submitting;

    // Snapshot the original values so SubmitAsync can build a diff-only PATCH —
    // unchanged fields stay null on the wire (no-op server-side per UpdateBrandDto).
    private string _origName = string.Empty;
    private string _origPrimary = string.Empty;
    private string _origSecondary = string.Empty;
    private bool _origIsDefault;

    private static readonly System.Text.RegularExpressions.Regex HexRegex =
        new(@"^#([0-9A-Fa-f]{3}|[0-9A-Fa-f]{6})$",
            System.Text.RegularExpressions.RegexOptions.Compiled,
            TimeSpan.FromSeconds(1));

    protected override void OnInitialized()
    {
        _name = _origName = Brand.Name;
        _primary = _origPrimary = Brand.PrimaryColor;
        _secondary = _origSecondary = Brand.SecondaryColor;
        _isDefault = _origIsDefault = Brand.IsDefault;
    }

    private static IEnumerable<string> ValidateHex(string value)
    {
        if (string.IsNullOrWhiteSpace(value)) yield break;
        if (!HexRegex.IsMatch(value)) yield return "Must be a hex literal like #1976D2.";
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;
        _submitting = true;
        try
        {
            var dto = new UpdateBrandDto
            {
                // Only send fields that actually changed — keeps the audit
                // event's "changed_fields" list honest.
                Name = !string.Equals(_name.Trim(), _origName, StringComparison.Ordinal) ? _name.Trim() : null,
                PrimaryColor = !string.Equals(_primary, _origPrimary, StringComparison.OrdinalIgnoreCase) ? _primary : null,
                SecondaryColor = !string.Equals(_secondary, _origSecondary, StringComparison.OrdinalIgnoreCase) ? _secondary : null,
                IsDefault = _isDefault != _origIsDefault ? _isDefault : null
            };
            var updated = await Api.UpdateBrandAsync(Brand.Id, dto);
            MudDialog.Close(DialogResult.Ok(updated));
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "update brand");
        }
        finally
        {
            _submitting = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
