@using AssetHub.Ui.Resources
@using AssetHub.Ui.Services
@using MudBlazor
@using Microsoft.JSInterop

@inject IJSRuntime JS
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<WebhooksResource> Loc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Warning" />
            <MudText Typo="Typo.h6" id="webhook-secret-title">@Loc["SecretShown_Title"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 480px;">
            <MudAlert Severity="Severity.Warning" Dense="true">
                @Loc["SecretShown_Desc"]
            </MudAlert>
            <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="background: var(--mud-palette-background-grey);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.body2"
                             Style="font-family: 'Courier New', monospace; word-break: break-all; flex: 1;">
                        @Secret
                    </MudText>
                    <MudIconButton Size="Size.Small"
                                   Icon="@Icons.Material.Outlined.ContentCopy"
                                   OnClick="CopyAsync"
                                   aria-label="@Loc["SecretShown_CopyAck"]" />
                </MudStack>
            </MudPaper>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">
            @Loc["SecretShown_Close"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter, EditorRequired] public string Secret { get; set; } = string.Empty;

    private async Task CopyAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Secret);
            Feedback.ShowSuccess(Loc["SecretShown_CopyAck"].Value);
        }
        catch
        {
            // Some browsers / iframes block clipboard.writeText silently —
            // the secret is still visible in the textbox, so this is a UX
            // nicety, not a critical path.
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
