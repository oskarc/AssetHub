@using Dam.Application.Dtos
@using Dam.Ui.Services

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body1">Select a collection to add this asset to:</MudText>
            
            @if (_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="py-4">
                    <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                </MudStack>
            }
            else if (!_availableCollections.Any())
            {
                <MudAlert Severity="Severity.Info">
                    No additional collections available. This asset is already in all collections you have access to.
                </MudAlert>
            }
            else
            {
                <MudSelect T="Guid?" 
                           @bind-Value="_selectedCollectionId"
                           Label="Collection"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter">
                    @foreach (var collection in _availableCollections)
                    {
                        <MudSelectItem Value="@((Guid?)collection.Id)">
                            @collection.Name
                            @if (!string.IsNullOrEmpty(collection.Description))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">
                                    - @collection.Description
                                </MudText>
                            }
                        </MudSelectItem>
                    }
                </MudSelect>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled"
                   OnClick="AddToCollectionAsync"
                   Disabled="@(!_selectedCollectionId.HasValue || _isSubmitting)">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Add
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid AssetId { get; set; }

    [Parameter]
    public List<Guid> ExistingCollectionIds { get; set; } = new();

    private List<CollectionResponseDto> _availableCollections = new();
    private Guid? _selectedCollectionId;
    private bool _isLoading = true;
    private bool _isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableCollectionsAsync();
    }

    private async Task LoadAvailableCollectionsAsync()
    {
        try
        {
            _isLoading = true;
            var allCollections = await Api.GetCollectionsAsync();
            
            // Filter out collections the asset already belongs to
            _availableCollections = allCollections
                .Where(c => !ExistingCollectionIds.Contains(c.Id))
                .OrderBy(c => c.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collections");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AddToCollectionAsync()
    {
        if (!_selectedCollectionId.HasValue) return;

        try
        {
            _isSubmitting = true;
            await Api.AddAssetToCollectionAsync(AssetId, _selectedCollectionId.Value);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "add to collection");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
