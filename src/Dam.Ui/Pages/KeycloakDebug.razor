@page "/debug/keycloak"

@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

@using System.Text
@using System.Text.Json
@using Dam.Application

@inject IConfiguration Config
@inject IHostEnvironment Env
@inject IHttpContextAccessor HttpContextAccessor

<MudText Typo="Typo.h4">Keycloak Debug</MudText>

@if (!_isAllowed)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled">
        Debug page is only available from localhost/private network.
        <br />
        Environment: @_environmentName
    </MudAlert>
}
else
{
    <MudPaper Class="pa-4" Elevation="1">
        <MudText Typo="Typo.subtitle2">Environment</MudText>
        <MudText>ASPNETCORE_ENVIRONMENT: @_environmentName</MudText>
        <MudText>Remote IP: @_remoteIp</MudText>
        <MudText>Host: @_host</MudText>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle2">Keycloak</MudText>
        <MudText>Authority: @_authority</MudText>
        <MudText>Token: @_tokenUrl</MudText>
        <MudText>UserInfo: @_userinfoUrl</MudText>

        <MudDivider Class="my-3" />

        <MudStack Spacing="2">
            <MudTextField @bind-Value="_username" Label="Username" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined" InputType="InputType.Password" />
            <MudTextField @bind-Value="_scope" Label="Scope" Variant="Variant.Outlined" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ProbeAsync" Disabled="@_busy">
                @(_busy ? "Probing…" : "Probe token + userinfo")
            </MudButton>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Error">@_error</MudAlert>
            }

            @if (!string.IsNullOrWhiteSpace(_resultJson))
            {
                <MudText Typo="Typo.subtitle2">Result</MudText>
                <MudTextField Value="@_resultJson" Lines="18" ReadOnly="true" Variant="Variant.Outlined" />
            }
        </MudStack>
    </MudPaper>
}

@code {
    private bool _isAllowed;
    private string _environmentName = "";
    private string _remoteIp = "";
    private string _host = "";

    private string _authority = "";
    private string _tokenUrl = "";
    private string _userinfoUrl = "";

    private string _username = "testuser";
    private string _password = "testuser123";
    private string _scope = "openid profile email";

    private bool _busy;
    private string? _error;
    private string? _resultJson;

    protected override void OnInitialized()
    {
        _environmentName = Env.EnvironmentName;

        var http = HttpContextAccessor.HttpContext;
        _remoteIp = http?.Connection.RemoteIpAddress?.ToString() ?? "<null>";
        _host = http?.Request.Host.Value ?? "<null>";

        _isAllowed = http is not null && DebugGuard.IsLocalDebugRequest(http);

        _authority = Config["Keycloak:Authority"] ?? "http://keycloak:8080/realms/media";
        _tokenUrl = _authority.TrimEnd('/') + "/protocol/openid-connect/token";
        _userinfoUrl = _authority.TrimEnd('/') + "/protocol/openid-connect/userinfo";
    }

    private async Task ProbeAsync()
    {
        _busy = true;
        _error = null;
        _resultJson = null;

        try
        {
            if (!_isAllowed)
            {
                _error = "Not allowed from this client.";
                return;
            }

            var clientId = Config["Keycloak:ClientId"] ?? "assethub-app";
            var clientSecret = Config["Keycloak:ClientSecret"];
            if (string.IsNullOrWhiteSpace(clientSecret))
            {
                _error = "Missing Keycloak:ClientSecret";
                return;
            }

            using var httpClient = new HttpClient();

            var tokenForm = new Dictionary<string, string>
            {
                ["grant_type"] = "password",
                ["client_id"] = clientId,
                ["client_secret"] = clientSecret,
                ["username"] = _username,
                ["password"] = _password,
                ["scope"] = string.IsNullOrWhiteSpace(_scope) ? "openid profile email" : _scope
            };

            using var tokenResp = await httpClient.PostAsync(_tokenUrl, new FormUrlEncodedContent(tokenForm));
            var tokenBody = await tokenResp.Content.ReadAsStringAsync();

            string? accessToken = null;
            if (tokenResp.IsSuccessStatusCode)
            {
                using var doc = JsonDocument.Parse(tokenBody);
                if (doc.RootElement.TryGetProperty("access_token", out var at))
                    accessToken = at.GetString();
            }

            object? userinfoObj = null;
            if (!string.IsNullOrWhiteSpace(accessToken))
            {
                using var userReq = new HttpRequestMessage(HttpMethod.Get, _userinfoUrl);
                userReq.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", accessToken);
                using var userResp = await httpClient.SendAsync(userReq);
                var userBody = await userResp.Content.ReadAsStringAsync();

                userinfoObj = new
                {
                    endpoint = _userinfoUrl,
                    status = (int)userResp.StatusCode,
                    www_authenticate = userResp.Headers.WwwAuthenticate.Count > 0
                        ? string.Join(", ", userResp.Headers.WwwAuthenticate)
                        : null,
                    body = userBody
                };
            }

            var result = new
            {
                token = new
                {
                    endpoint = _tokenUrl,
                    status = (int)tokenResp.StatusCode,
                    access_token_len = accessToken?.Length ?? 0,
                    body = tokenResp.IsSuccessStatusCode ? null : tokenBody
                },
                userinfo = userinfoObj
            };

            _resultJson = JsonSerializer.Serialize(result, new JsonSerializerOptions { WriteIndented = true });
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
