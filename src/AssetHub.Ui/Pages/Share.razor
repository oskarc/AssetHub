@page "/share/{Token}"
@layout Layout.ShareLayout
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@implements IAsyncDisposable

@using AssetHub.Ui.Services
@using AssetHub.Ui.Components
@using AssetHub.Application
@using AssetHub.Application.Dtos
@using System.Net.Http.Json
@using Microsoft.Extensions.Logging

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ILogger<Share> Logger
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<SharesResource> ShareLoc
@inject ISnackbar Snackbar
@inject LocalizedDisplayService Display

<PageTitle>@ShareLoc["SharedContent"] - @CommonLoc["AppName"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="@($"py-8 {(_brand is null ? string.Empty : "ah-branded-share")}")">
    <BrandHeader Brand="@_brand" />
    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">@ShareLoc["LoadingSharedContent"]</MudText>
        </MudStack>
    }
    else if (_requiresPassword)
    {
        <MudPaper Class="pa-6 mx-auto" MaxWidth="400px" Elevation="2">
            <MudStack Spacing="4">
                <MudStack AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h5">@ShareLoc["PasswordRequired"]</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @ShareLoc["PasswordProtected"]
                    </MudText>
                </MudStack>
                
                <MudTextField @bind-Value="_password"
                              Label="@CommonLoc["Label_Password"]"
                              Variant="Variant.Outlined"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              AdornmentAriaLabel="@CommonLoc["Aria_TogglePasswordVisibility"]"
                              OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                              Immediate="true"
                              OnKeyDown="@OnPasswordKeyDown" />
                
                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                }
                
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="SubmitPassword"
                           Disabled="_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @CommonLoc["Btn_AccessContent"]
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else if (_errorMessage != null)
    {
        <EmptyState Title="@_errorMessage"
                    Description="@_errorDescription"
                    Icon="@_errorIcon" />
    }
    else if (_sharedAsset != null)
    {
        <!-- Shared Asset View -->
        <AssetDetailPanel Asset="_sharedAsset"
                          PreviewUrl="@GetPreviewUrl()"
                          PosterUrl="@GetPosterUrl()"
                          DownloadUrl="@GetDownloadUrl()"
                          OnDownload="@(() => DownloadAsset(null))"
                          MediumDownloadUrl="@GetMediumDownloadUrl(null)"
                          OnDownloadMedium="@(() => DownloadSpecificSize(null, "medium"))"
                          ThumbnailDownloadUrl="@GetThumbnailDownloadUrl(null)"
                          OnDownloadThumbnail="@(() => DownloadSpecificSize(null, "thumb"))"
                          BrowserNoVideoText="@CommonLoc["Text_BrowserNoVideo"]"
                          PreviewNotAvailableText="@CommonLoc["Text_PreviewNotAvailable"]"
                          DownloadToViewText="@CommonLoc["Btn_DownloadToView"]"
                          DescriptionLabel="@CommonLoc["Label_Description"]"
                          CopyrightLabel="@CommonLoc["Label_Copyright"]"
                          FileInformationText="@CommonLoc["Text_FileInformation"]"
                          SizeLabel="@CommonLoc["Label_Size"]"
                          TypeLabel="@CommonLoc["Label_Type"]"
                          MetadataText="@CommonLoc["Text_Metadata"]"
                          DownloadOriginalText="@CommonLoc["Btn_DownloadOriginal"]"
                          DownloadMediumText="@CommonLoc["Btn_DownloadMedium"]"
                          DownloadThumbnailText="@CommonLoc["Btn_DownloadThumbnail"]"
                          AssetTypeDisplay="@Display.AssetType(_sharedAsset.AssetType)"
                          ContentTypeDisplay="@Display.ContentType(_sharedAsset.ContentType)" />
    }
    else if (_sharedCollection != null)
    {
        <SharedCollectionView Collection="_sharedCollection" Token="@Token" AccessToken="@_accessToken" />
    }
</MudContainer>

@code {
    [Parameter]
    public string Token { get; set; } = "";

    private bool _isLoading = true;
    private bool _requiresPassword = false;
    private bool _isSubmitting = false;
    private bool _showPassword = false;
    private string _password = "";
    private string? _accessToken;
    private string? _error;
    private string? _errorMessage;
    private string _errorDescription = "";
    private string _errorIcon = Icons.Material.Filled.Error;

    private void SetError(string message, string description, string icon)
    {
        _errorMessage = message;
        _errorDescription = description;
        _errorIcon = icon;
    }

    private SharedAssetDto? _sharedAsset;
    private SharedCollectionDto? _sharedCollection;
    private BrandResponseDto? _brand;

    private IJSObjectReference? _jsModule;
    private bool _jsModuleLoaded = false;
    private bool _initialLoadComplete = false;

    protected override async Task OnInitializedAsync()
    {
        // Don't load content yet - wait for OnAfterRenderAsync to check for stored password
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_jsModuleLoaded)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AssetHub.Ui/js/helpers.js");
            _jsModuleLoaded = true;
            
            // Check if there's a stored password for this share
            var cookieName = $"share_pwd_{Token}";
            var storedPassword = await _jsModule.InvokeAsync<string?>("getCookie", cookieName);
            
            // Now load content with the stored password (if available)
            await LoadSharedContent(storedPassword);
            _initialLoadComplete = true;
            StateHasChanged();
        }
    }

    private async Task LoadSharedContent(string? password = null)
    {
        try
        {
            _isLoading = true;
            _error = null;

            ISharedContentDto content;
            try
            {
                content = await Api.GetSharedContentAsync(Token, password);
            }
            catch (ApiException ex)
            {
                switch (ex.ErrorCode)
                {
                    case "PASSWORD_REQUIRED":
                        _requiresPassword = true;
                        _isLoading = false;

                        // If we tried with a stored password and failed, clear it and show error
                        if (!string.IsNullOrEmpty(password) && _initialLoadComplete)
                        {
                            _error = ShareLoc["InvalidPassword"].Value;
                            _password = password; // Show what was attempted

                            // Clear the invalid stored password
                            if (_jsModule != null)
                            {
                                var cookieName = $"share_pwd_{Token}";
                                await _jsModule.InvokeVoidAsync("setCookie", cookieName, "", 0);
                            }
                        }
                        return;
                    case Constants.ShareErrorCodes.Revoked:
                        SetError(ShareLoc["LinkRevoked"].Value, ShareLoc["LinkRevokedDesc"].Value, Icons.Material.Filled.LinkOff);
                        _isLoading = false;
                        return;
                    case Constants.ShareErrorCodes.Expired:
                        SetError(ShareLoc["LinkExpired"].Value, ShareLoc["LinkExpiredDesc"].Value, Icons.Material.Filled.TimerOff);
                        _isLoading = false;
                        return;
                    default:
                        if (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                        {
                            // Invalid password (different from PASSWORD_REQUIRED above).
                            _requiresPassword = true;
                            _error = ShareLoc["InvalidPassword"].Value;
                        }
                        else if (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
                        {
                            SetError(ShareLoc["InvalidOrRemoved"].Value, ShareLoc["InvalidOrRemovedDesc"].Value, Icons.Material.Filled.LinkOff);
                        }
                        else
                        {
                            SetError(ShareLoc["ErrorLoading"].Value, ShareLoc["ErrorLoadingDesc"].Value, Icons.Material.Filled.ErrorOutline);
                        }
                        _isLoading = false;
                        return;
                }
            }

            // Success — dispatch on concrete content type.
            if (content is SharedCollectionDto col)
            {
                _sharedCollection = col;
                _brand = col.Brand;
                _requiresPassword = false;
            }
            else if (content is SharedAssetDto ass)
            {
                _sharedAsset = ass;
                _brand = ass.Brand;
                _requiresPassword = false;
            }

            // If password was provided, obtain a short-lived access token for
            // subsequent HTML element URLs (img src, video src, a href) so the
            // actual password never appears in query strings.
            if (!string.IsNullOrEmpty(password))
            {
                var tokenResponse = await Api.GetShareAccessTokenAsync(Token, password);
                if (tokenResponse != null)
                    _accessToken = tokenResponse.AccessToken;
                
                // Store password in cookie for language switches (1 hour expiry)
                if (_jsModule != null)
                {
                    var cookieName = $"share_pwd_{Token}";
                    await _jsModule.InvokeVoidAsync("setCookie", cookieName, password, 3600);
                }
            }
        }
        catch (Exception ex)
        {
            SetError(ShareLoc["FailedToLoad"].Value, ShareLoc["ErrorLoadingDesc"].Value, Icons.Material.Filled.CloudOff);
            Logger.LogError(ex, "Error loading shared content for token {Token}", Token);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SubmitPassword()
    {
        if (string.IsNullOrEmpty(_password))
        {
            _error = CommonLoc["Validation_EnterPassword"].Value;
            return;
        }

        _isSubmitting = true;
        _error = null;

        await LoadSharedContent(_password);

        if (_requiresPassword)
        {
            _error = ShareLoc["InvalidPassword"];
            
            // Clear the stored password cookie since it's invalid
            if (_jsModule != null)
            {
                var cookieName = $"share_pwd_{Token}";
                await _jsModule.InvokeVoidAsync("setCookie", cookieName, "", 0);
            }
        }

        _isSubmitting = false;
    }

    private async Task OnPasswordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitPassword();
        }
    }

    private string GetPreviewUrl()
    {
        if (_sharedAsset == null) return "";

        var escapedToken = Uri.EscapeDataString(Token);

        // For PDFs and videos/audio, use the preview endpoint without size
        // so the server returns the original file for inline display / playback.
        if (AssetDisplayHelpers.IsPdfContentType(_sharedAsset.ContentType)
            || _sharedAsset.AssetType == Constants.AssetTypeFilters.Video
            || _sharedAsset.AssetType == Constants.AssetTypeFilters.Audio)
        {
            var url = $"/api/v1/shares/{escapedToken}/preview";
            if (!string.IsNullOrEmpty(_accessToken))
                url += $"?accessToken={Uri.EscapeDataString(_accessToken)}";
            return url;
        }

        // For images / other types, use the rendition URL (medium → thumb → download)
        var previewUrl = _sharedAsset.MediumUrl ?? _sharedAsset.ThumbnailUrl
                         ?? $"/api/v1/shares/{escapedToken}/download";
        return AppendAccessToken(previewUrl);
    }

    /// <summary>Returns a poster/thumbnail URL for the single shared-asset video element.</summary>
    private string GetPosterUrl()
    {
        if (_sharedAsset == null) return "";
        var url = _sharedAsset.MediumUrl ?? _sharedAsset.ThumbnailUrl ?? "";
        return string.IsNullOrEmpty(url) ? url : AppendAccessToken(url);
    }

    /// <summary>Appends the share access token as a query parameter when present.</summary>
    private string AppendAccessToken(string url)
    {
        if (string.IsNullOrEmpty(_accessToken)) return url;
        var separator = url.Contains('?') ? '&' : '?';
        return $"{url}{separator}accessToken={Uri.EscapeDataString(_accessToken)}";
    }

    private string GetDownloadUrl()
    {
        var url = $"/api/v1/shares/{Uri.EscapeDataString(Token)}/download";
        if (!string.IsNullOrEmpty(_accessToken))
            url += $"?accessToken={Uri.EscapeDataString(_accessToken)}";
        return url;
    }

    private async Task DownloadAsset(Guid? assetId)
    {
        var url = $"/api/v1/shares/{Uri.EscapeDataString(Token)}/download";
        var queryParams = new List<string>();
        
        if (assetId.HasValue)
            queryParams.Add($"assetId={assetId.Value}");
        if (!string.IsNullOrEmpty(_accessToken))
            queryParams.Add($"accessToken={Uri.EscapeDataString(_accessToken)}");
        
        if (queryParams.Count > 0)
            url += "?" + string.Join("&", queryParams);

        if (_jsModule != null)
        {
            var error = await _jsModule.InvokeAsync<string?>("downloadWithErrorCheck", url, null);
            if (!string.IsNullOrEmpty(error))
            {
                Snackbar.Add(error, Severity.Error);
            }
        }
    }

    private async Task DownloadSpecificSize(Guid? assetId, string size)
    {
        var url = $"/api/v1/shares/{Uri.EscapeDataString(Token)}/preview?size={size}&download=true";
        if (assetId.HasValue)
            url += $"&assetId={assetId.Value}";
        if (!string.IsNullOrEmpty(_accessToken))
            url += $"&accessToken={Uri.EscapeDataString(_accessToken)}";

        if (_jsModule != null)
        {
            var error = await _jsModule.InvokeAsync<string?>("downloadWithErrorCheck", url, null);
            if (!string.IsNullOrEmpty(error))
            {
                Snackbar.Add(error, Severity.Error);
            }
        }
    }

    private string? GetMediumDownloadUrl(Guid? assetId)
    {
        if (_sharedAsset != null && string.IsNullOrEmpty(_sharedAsset.MediumUrl))
            return null;
        
        var url = $"/api/v1/shares/{Uri.EscapeDataString(Token)}/preview?size=medium";
        if (assetId.HasValue)
            url += $"&assetId={assetId.Value}";
        if (!string.IsNullOrEmpty(_accessToken))
            url += $"&accessToken={Uri.EscapeDataString(_accessToken)}";
        return url;
    }

    private string? GetThumbnailDownloadUrl(Guid? assetId)
    {
        if (_sharedAsset != null && string.IsNullOrEmpty(_sharedAsset.ThumbnailUrl))
            return null;
        
        var url = $"/api/v1/shares/{Uri.EscapeDataString(Token)}/preview?size=thumb";
        if (assetId.HasValue)
            url += $"&assetId={assetId.Value}";
        if (!string.IsNullOrEmpty(_accessToken))
            url += $"&accessToken={Uri.EscapeDataString(_accessToken)}";
        return url;
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            try { await _jsModule.DisposeAsync(); }
            catch (JSDisconnectedException) { /* circuit gone — JS module is unreachable */ }
        }
    }
}
