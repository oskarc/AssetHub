@using AssetHub.Application.Dtos
@using AssetHub.Application.Helpers
@using AssetHub.Ui.Services

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<CollectionsResource> CollectionLoc

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_collections.Count == 0)
{
    <EmptyState Title="@CollectionLoc["NoCollectionsYet"]"
                Description="@CollectionLoc["CreateFirstHint"]"
                Icon="@Icons.Material.Filled.CreateNewFolder"
                Class="py-4" />
}
else
{
    <MudNavMenu Dense="true">
        @foreach (var collection in _collections)
        {
            <div class="d-flex align-center collection-item">
                <MudNavLink Icon="@Icons.Material.Filled.Folder"
                            IconColor="@(SelectedCollectionId == collection.Id ? Color.Primary : Color.Default)"
                            OnClick="@(() => SelectCollection(collection))"
                            Class="@(SelectedCollectionId == collection.Id ? "mud-nav-link-active flex-grow-1" : "flex-grow-1")">
                    @collection.Name
                    @if (collection.AssetCount > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Class="ml-auto" Variant="Variant.Text">
                            @collection.AssetCount
                        </MudChip>
                    }
                </MudNavLink>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true" AnchorOrigin="Origin.BottomRight">
                    @if (RolePermissions.CanEditCollection(collection.UserRole))
                    {
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => EditCollection(collection))">
                            @CollectionLoc["Rename"]
                        </MudMenuItem>
                    }
                    @if (RolePermissions.CanDelete(collection.UserRole))
                    {
                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="@(() => DeleteCollection(collection))" IconColor="Color.Error">
                            @CommonLoc["Btn_Delete"]
                        </MudMenuItem>
                    }
                </MudMenu>
            </div>
        }
    </MudNavMenu>
}

@code {
    [Parameter]
    public EventCallback<Guid?> OnCollectionSelected { get; set; }

    [Parameter]
    public Guid? SelectedCollectionId { get; set; }

    private List<CollectionResponseDto> _collections = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadCollectionsAsync();
    }

    private async Task LoadCollectionsAsync()
    {
        try
        {
            _isLoading = true;
            _collections = await Api.GetCollectionsAsync();
            _collections = _collections.OrderBy(c => c.Name, new NaturalSortComparer()).ToList();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collections");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SelectCollection(CollectionResponseDto collection)
    {
        await OnCollectionSelected.InvokeAsync(collection.Id);
    }

    private async Task EditCollection(CollectionResponseDto collection)
    {
        var parameters = new DialogParameters<EditCollectionDialog>
        {
            { x => x.CollectionId, collection.Id },
            { x => x.InitialName, collection.Name },
            { x => x.InitialDescription, collection.Description }
        };

        var dialog = await DialogService.ShowAsync<EditCollectionDialog>(CollectionLoc["EditCollection"], parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadCollectionsAsync();
            Feedback.ShowSuccess(CollectionLoc["UpdatedSuccess"].Value);
        }
    }

    private async Task DeleteCollection(CollectionResponseDto collection)
    {
        var assetWarning = collection.AssetCount > 0 
            ? string.Format(CollectionLoc["AssetCountWarning"].Value, collection.AssetCount) 
            : "";

        var result = await DialogService.ShowMessageBox(
            CollectionLoc["DeleteCollection"].Value,
            string.Format(CollectionLoc["ConfirmDeleteCollection"].Value, collection.Name, assetWarning),
            yesText: CommonLoc["Btn_Delete"].Value,
            cancelText: CommonLoc["Btn_Cancel"].Value);

        if (result == true)
        {
            var success = await Feedback.ExecuteWithFeedbackAsync(
                () => Api.DeleteCollectionAsync(collection.Id),
                "delete collection",
                CollectionLoc["DeletedSuccess"].Value);
            
            if (success)
            {
                _collections.Remove(collection);
                
                // If we deleted the selected collection, clear selection
                if (SelectedCollectionId == collection.Id)
                {
                    await OnCollectionSelected.InvokeAsync(null);
                }
            }
        }
    }

    public async Task RefreshAsync()
    {
        _collections.Clear();
        await LoadCollectionsAsync();
    }
}
