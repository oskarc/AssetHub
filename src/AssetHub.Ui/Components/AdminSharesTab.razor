@using AssetHub.Application
@using AssetHub.Application.Helpers
@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AdminResource> AdminLoc
@inject LocalStorageService LocalStorage
@inject LocalizedDisplayService Display

@if (_sharesLoading && _shares == null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_shares == null || (!_shares.Any() && _totalCount == 0))
{
    <EmptyState Title="@AdminLoc["NoSharesYet"]"
                Description="@AdminLoc["NoSharesDesc"]"
                Icon="@Icons.Material.Filled.Share" />
}
else
{
    <MudTable Items="@_shares" Hover="true" Dense="true" Striped="true" Filter="ShareFilter" SortLabel="@CommonLoc["Label_SortBy"]">
        <NoRecordsContent>
            <EmptyState Title="@AdminLoc["NoMatchingShares"]"
                        Description="@AdminLoc["NoMatchingSharesDesc"]"
                        Icon="@Icons.Material.Filled.SearchOff" />
        </NoRecordsContent>
        <ToolBarContent>
            <MudTextField @bind-Value="_shareSearchString" Placeholder="@AdminLoc["SearchSharesPlaceholder"]"
                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                IconSize="Size.Medium" Class="mt-0" Immediate="true" DebounceInterval="500" />
            <MudSpacer />
            <MudChip T="string" Color="@(_showActive ? Color.Success : Color.Default)" Size="Size.Small" OnClick="ToggleActive" Class="chip-clickable">@AdminLoc["Active"]: @_shares.Count(s => s.Status == Constants.ShareStatus.Active)</MudChip>
            <MudChip T="string" Color="@(_showExpired ? Color.Warning : Color.Default)" Size="Size.Small" OnClick="ToggleExpired" Class="chip-clickable">@AdminLoc["Expired"]: @_shares.Count(s => s.Status == Constants.ShareStatus.Expired)</MudChip>
            <MudChip T="string" Color="@(_showRevoked ? Color.Error : Color.Default)" Size="Size.Small" OnClick="ToggleRevoked" Class="chip-clickable">@AdminLoc["Revoked"]: @_shares.Count(s => s.Status == Constants.ShareStatus.Revoked)</MudChip>
            <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
            <MudChip T="string" Color="@(_showAssets ? Color.Info : Color.Default)" Size="Size.Small" OnClick="ToggleAssets" Class="chip-clickable">@CommonLoc["ScopeType_Asset"]: @_shares.Count(s => s.ScopeType == Constants.ScopeTypes.Asset)</MudChip>
            <MudChip T="string" Color="@(_showCollections ? Color.Tertiary : Color.Default)" Size="Size.Small" OnClick="ToggleCollections" Class="chip-clickable">@CommonLoc["ScopeType_Collection"]: @_shares.Count(s => s.ScopeType == Constants.ScopeTypes.Collection)</MudChip>
            <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
            <MudTooltip Text="@AdminLoc["DeleteAllExpired"]">
                <MudIconButton Icon="@Icons.Material.Filled.EventBusy" Color="Color.Warning" Size="Size.Small"
                    OnClick="BulkDeleteExpired" Disabled="@(_sharesLoading || _shares.Count(s => s.Status == Constants.ShareStatus.Expired) == 0)" />
            </MudTooltip>
            <MudTooltip Text="@AdminLoc["DeleteAllRevoked"]">
                <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" Color="Color.Error" Size="Size.Small"
                    OnClick="BulkDeleteRevoked" Disabled="@(_sharesLoading || _shares.Count(s => s.Status == Constants.ShareStatus.Revoked) == 0)" />
            </MudTooltip>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.ScopeType)">@CommonLoc["Label_Type"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.ScopeName)">@AdminLoc["Header_Target"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.CreatedByUserName)">@AdminLoc["Header_CreatedBy"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.CreatedAt)">@CommonLoc["Label_Created"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.ExpiresAt)">@CommonLoc["Label_Expires"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.LastAccessedAt ?? DateTime.MinValue)">@AdminLoc["Header_LastAccess"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.AccessCount)">@AdminLoc["Header_AccessCount"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AdminShareDto, object>(x => x.Status)">@CommonLoc["Label_Status"]</MudTableSortLabel></MudTh>
            <MudTh>@CommonLoc["Label_Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@(context.ScopeType == Constants.ScopeTypes.Asset ? Color.Info : Color.Default)" Variant="Variant.Outlined">
                    @Display.ScopeType(context.ScopeType)
                </MudChip>
            </MudTd>
            <MudTd>
                <MudTooltip Text="@context.ScopeId.ToString()">
                    <MudText Typo="Typo.body2" Class="text-truncate-200">
                        @context.ScopeName
                    </MudText>
                </MudTooltip>
                @if (context.HasPassword)
                {
                    <MudTooltip Text="@CommonLoc["Dashboard_PasswordProtected"]">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Warning" Class="ml-1" />
                    </MudTooltip>
                }
            </MudTd>
            <MudTd>@context.CreatedByUserName</MudTd>
            <MudTd>
                <MudTooltip Text="@context.CreatedAt.ToLocalTime().ToString("F")">
                    <MudText Typo="Typo.body2">@context.CreatedAt.ToLocalTime().ToString("g")</MudText>
                </MudTooltip>
            </MudTd>
            <MudTd>
                <MudTooltip Text="@context.ExpiresAt.ToLocalTime().ToString("F")">
                    <MudText Typo="Typo.body2">@context.ExpiresAt.ToLocalTime().ToString("g")</MudText>
                </MudTooltip>
            </MudTd>
            <MudTd>
                @if (context.LastAccessedAt.HasValue)
                {
                    <MudTooltip Text="@context.LastAccessedAt.Value.ToLocalTime().ToString("F")">
                        <MudText Typo="Typo.body2">@context.LastAccessedAt.Value.ToLocalTime().ToString("g")</MudText>
                    </MudTooltip>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Text_Never"]</MudText>
                }
            </MudTd>
            <MudTd><MudText Typo="Typo.body2">@context.AccessCount</MudText></MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetShareStatusColor(context.Status)">
                    @AdminLoc[AssetDisplayHelpers.GetShareStatusKey(context.Status)]
                </MudChip>
            </MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="1">
                    <MudTooltip Text="@AdminLoc["ShowShareInfo"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Primary" Size="Size.Small"
                            OnClick="@(() => ShowShareInfo(context))" />
                    </MudTooltip>
                    @if (context.Status == Constants.ShareStatus.Active)
                    {
                        <MudTooltip Text="@AdminLoc["RevokeShare"]">
                            <MudIconButton Icon="@Icons.Material.Filled.Block" Color="Color.Warning" Size="Size.Small"
                                OnClick="@(() => RevokeShare(context))" />
                        </MudTooltip>
                    }
                    else
                    {
                        <MudTooltip Text="@AdminLoc["DeleteShare"]">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                OnClick="@(() => DeleteShare(context))" />
                        </MudTooltip>
                    }
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudPaper Elevation="0" Class="d-flex justify-center align-center pa-3 gap-3">
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @CommonLoc["Showing"] @_shares.Count @CommonLoc["OfTotal"] @_totalCount
        </MudText>
        @if (_hasMore)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                OnClick="LoadMoreAsync" Disabled="@_sharesLoading">
                @if (_sharesLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @AdminLoc["LoadMore"]
            </MudButton>
        }
    </MudPaper>
}

@code {
    private const int PageSize = Constants.Limits.DefaultAdminPageSize;

    private List<AdminShareDto>? _shares;
    private bool _sharesLoading = true;
    private string _shareSearchString = "";
    private int _totalCount;
    private bool _hasMore;
    private bool _showActive = true;
    private bool _showExpired = true;
    private bool _showRevoked = true;
    private bool _showAssets = true;
    private bool _showCollections = true;

    private const string StorageKeyActive = "adminShares_showActive";
    private const string StorageKeyExpired = "adminShares_showExpired";
    private const string StorageKeyRevoked = "adminShares_showRevoked";
    private const string StorageKeyAssets = "adminShares_showAssets";
    private const string StorageKeyCollections = "adminShares_showCollections";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(reset: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _showActive = await LocalStorage.GetBoolAsync(StorageKeyActive, true);
            _showExpired = await LocalStorage.GetBoolAsync(StorageKeyExpired, true);
            _showRevoked = await LocalStorage.GetBoolAsync(StorageKeyRevoked, true);
            _showAssets = await LocalStorage.GetBoolAsync(StorageKeyAssets, true);
            _showCollections = await LocalStorage.GetBoolAsync(StorageKeyCollections, true);
            
            StateHasChanged();
        }
    }

    public async Task RefreshAsync()
    {
        await LoadAsync(reset: true);
        StateHasChanged();
    }

    private async Task LoadAsync(bool reset = false)
    {
        try
        {
            _sharesLoading = true;

            if (reset)
                _shares = null;

            var skip = _shares?.Count ?? 0;
            var response = await Api.GetAllSharesAsync(skip: skip, take: PageSize);
            _totalCount = response.Total;

            if (reset || _shares == null)
                _shares = response.Items;
            else
                _shares.AddRange(response.Items);

            _hasMore = _shares.Count < _totalCount;
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load shares");
        }
        finally
        {
            _sharesLoading = false;
        }
    }

    private async Task LoadMoreAsync()
    {
        await LoadAsync(reset: false);
    }

    private bool ShareFilter(AdminShareDto share)
    {
        // Status filter
        var statusMatch = share.Status switch
        {
            Constants.ShareStatus.Active => _showActive,
            Constants.ShareStatus.Expired => _showExpired,
            Constants.ShareStatus.Revoked => _showRevoked,
            _ => true
        };
        if (!statusMatch) return false;

        // Scope type filter
        var scopeMatch = share.ScopeType switch
        {
            Constants.ScopeTypes.Asset => _showAssets,
            Constants.ScopeTypes.Collection => _showCollections,
            _ => true
        };
        if (!scopeMatch) return false;

        if (string.IsNullOrWhiteSpace(_shareSearchString))
            return true;

        return share.ScopeName.Contains(_shareSearchString, StringComparison.OrdinalIgnoreCase)
            || share.CreatedByUserName.Contains(_shareSearchString, StringComparison.OrdinalIgnoreCase)
            || share.Status.Contains(_shareSearchString, StringComparison.OrdinalIgnoreCase);
    }

    private async Task RevokeShare(AdminShareDto share)
    {
        var confirmed = await DialogService.ShowConfirmAsync(
            CommonLoc["Confirm_Revoke"],
            string.Format(AdminLoc["ConfirmRevokeShare"], share.ScopeName),
            CommonLoc["Btn_Revoke"],
            Icons.Material.Filled.LinkOff,
            Color.Warning,
            Color.Error);

        if (!confirmed)
            return;

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.RevokeShareAdminAsync(share.Id),
            "revoke share",
            AdminLoc["ShareRevokedSuccess"]);

        if (success)
        {
            await LoadAsync(reset: true);
        }
    }

    private async Task ShowShareInfo(AdminShareDto share)
    {
        var parameters = new DialogParameters<ShareInfoDialog>
        {
            { x => x.Share, share },
            { x => x.ShareUrl, string.Empty },
            { x => x.SharePassword, string.Empty }
        };

        var dialog = await DialogService.ShowAsync<ShareInfoDialog>(AdminLoc["ShowShareInfo"], parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadAsync(reset: true);
        }
    }

    private async Task ToggleActive()
    {
        _showActive = !_showActive;
        await SaveFilterState(StorageKeyActive, _showActive);
    }

    private async Task ToggleExpired()
    {
        _showExpired = !_showExpired;
        await SaveFilterState(StorageKeyExpired, _showExpired);
    }

    private async Task ToggleRevoked()
    {
        _showRevoked = !_showRevoked;
        await SaveFilterState(StorageKeyRevoked, _showRevoked);
    }

    private async Task ToggleAssets()
    {
        _showAssets = !_showAssets;
        await SaveFilterState(StorageKeyAssets, _showAssets);
    }

    private async Task ToggleCollections()
    {
        _showCollections = !_showCollections;
        await SaveFilterState(StorageKeyCollections, _showCollections);
    }

    private async Task SaveFilterState(string key, bool value)
    {
        await LocalStorage.SetBoolAsync(key, value);
    }

    private async Task DeleteShare(AdminShareDto share)
    {
        var confirmed = await DialogService.ShowConfirmAsync(
            AdminLoc["DeleteShare"],
            string.Format(AdminLoc["ConfirmDeleteShare"], share.ScopeName),
            CommonLoc["Btn_Delete"],
            Icons.Material.Filled.Delete,
            Color.Error,
            Color.Error);

        if (!confirmed)
            return;

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.DeleteShareAdminAsync(share.Id),
            "delete share",
            AdminLoc["ShareDeletedSuccess"]);

        if (success)
        {
            await LoadAsync(reset: true);
        }
    }

    private async Task BulkDeleteExpired()
    {
        var count = _shares?.Count(s => s.Status == Constants.ShareStatus.Expired) ?? 0;

        var confirmed = await DialogService.ShowConfirmAsync(
            AdminLoc["DeleteAllExpired"],
            string.Format(AdminLoc["ConfirmDeleteAllExpired"], count),
            CommonLoc["Btn_Delete"],
            Icons.Material.Filled.EventBusy,
            Color.Error,
            Color.Error);

        if (!confirmed)
            return;

        var (success, deleted) = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.BulkDeleteSharesByStatusAsync(Constants.ShareStatus.Expired),
            "delete expired shares",
            string.Format(AdminLoc["BulkSharesDeletedSuccess"], count));

        if (success)
        {
            await LoadAsync(reset: true);
        }
    }

    private async Task BulkDeleteRevoked()
    {
        var count = _shares?.Count(s => s.Status == Constants.ShareStatus.Revoked) ?? 0;

        var confirmed = await DialogService.ShowConfirmAsync(
            AdminLoc["DeleteAllRevoked"],
            string.Format(AdminLoc["ConfirmDeleteAllRevoked"], count),
            CommonLoc["Btn_Delete"],
            Icons.Material.Filled.DeleteSweep,
            Color.Error,
            Color.Error);

        if (!confirmed)
            return;

        var (success, deleted) = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.BulkDeleteSharesByStatusAsync(Constants.ShareStatus.Revoked),
            "delete revoked shares",
            string.Format(AdminLoc["BulkSharesDeletedSuccess"], count));

        if (success)
        {
            await LoadAsync(reset: true);
        }
    }
}
