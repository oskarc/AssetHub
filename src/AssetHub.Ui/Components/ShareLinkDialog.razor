@using MudBlazor
@using AssetHub.Ui.Services

@inject IUserFeedbackService Feedback
@inject IJSRuntime JS
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<SharesResource> ShareLoc

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Share" Class="mr-2" Color="Color.Success" />
            @ShareLoc["ShareLinkCreated"]
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Success" Dense="true">
                @ShareLoc["CreatedSuccess"]
            </MudAlert>

            <MudTextField Value="@ShareUrl"
                          Label="@ShareLoc["ShareURL"]"
                          ReadOnly="true"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                          OnAdornmentClick="CopyUrlToClipboard" />

            @if (!string.IsNullOrEmpty(Password))
            {
            <MudTextField Value="@Password"
                          Label="@CommonLoc["Label_Password"]"
                          ReadOnly="true"
                          Variant="Variant.Outlined"
                          InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="TogglePasswordVisibility" />

            <MudStack Row="true" Spacing="2">
                <MudButton Size="Size.Small"
                           Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="CopyPasswordToClipboard">
                    @CommonLoc["Btn_CopyPassword"]
                </MudButton>
                <MudButton Size="Size.Small"
                           Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.ContentCopy"
                           OnClick="CopyAllToClipboard">
                    @CommonLoc["Btn_CopyAll"]
                </MudButton>
            </MudStack>
            }

            @if (ExpiresAt.HasValue)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                    @CommonLoc["Label_Expires"]: @ExpiresAt.Value.ToLocalTime().ToString("f")
                </MudText>
            }

            @if (!string.IsNullOrEmpty(Password))
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Class="mr-1" />
                    @ShareLoc["PasswordProtectedWarning"]
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">@CommonLoc["Btn_Close"]</MudButton>
        @if (!string.IsNullOrEmpty(Password))
        {
            <MudButton Color="Color.Primary" 
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.ContentCopy"
                       OnClick="CopyAllToClipboard">
                @CommonLoc["Btn_CopyAll"]
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string ShareUrl { get; set; } = "";

    [Parameter]
    public string Password { get; set; } = "";

    [Parameter]
    public DateTime? ExpiresAt { get; set; }

    private bool _showPassword = false;

    private void Close() => MudDialog.Close();

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private async Task CopyUrlToClipboard()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", ShareUrl);
            Feedback.ShowSuccess(CommonLoc["Success_LinkCopied"].Value);
        }
        catch
        {
            Feedback.ShowWarning(CommonLoc["Warning_CopyFailed"].Value);
        }
    }

    private async Task CopyPasswordToClipboard()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Password);
            Feedback.ShowSuccess(CommonLoc["Success_PasswordCopied"].Value);
        }
        catch
        {
            Feedback.ShowWarning(CommonLoc["Warning_CopyFailed"].Value);
        }
    }

    private async Task CopyAllToClipboard()
    {
        try
        {
            var text = string.Format(ShareLoc["Text_CopyAllTemplate"].Value, ShareUrl, Password);
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            Feedback.ShowSuccess(CommonLoc["Success_LinkAndPasswordCopied"].Value);
        }
        catch
        {
            Feedback.ShowWarning(CommonLoc["Warning_CopyFailed"].Value);
        }
    }
}
