@inherits LayoutComponentBase
@implements IDisposable
@using AssetHub.Ui.Components
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject IStringLocalizer<CommonResource> CommonLoc
@inject ThemeService Theme
@inject IHttpContextAccessor HttpContextAccessor

<MudThemeProvider Theme="@_theme" IsDarkMode="Theme.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<a href="#main-content" class="skip-link">@CommonLoc["Link_SkipToContent"]</a>

<MudLayout>
    <MudAppBar Elevation="0" Class="appbar-border">
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Menu"
                               Color="Color.Inherit"
                               Edge="Edge.Start"
                               aria-label="@CommonLoc["Aria_ToggleNavigation"]"
                               OnClick="@((e) => DrawerToggle())" />
            </Authorized>
        </AuthorizeView>

        <MudText Typo="Typo.h6" Class="ml-3 appbar-title">@CommonLoc["AppName"]</MudText>

        <MudSpacer />

        <!-- Auth: show user + login/logout -->
        <AuthorizeView>
            <Authorized Context="auth">
                <SavedSearchesMenu />

                <MudText Class="mr-2" Typo="Typo.body2">
                    @DisplayName(auth.User)
                </MudText>

                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomCenter" aria-label="@CommonLoc["Aria_AccountMenu"]">
                    <MudMenuItem Icon="@Icons.Material.Filled.Lock" OnClick="@ChangePassword">
                        @CommonLoc["Btn_ChangePassword"]
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="@Logout">
                        @CommonLoc["Btn_SignOut"]
                    </MudMenuItem>
                </MudMenu>
            </Authorized>

            <NotAuthorized>
                <MudButton Variant="Variant.Filled"
                           Size="Size.Small"
                           OnClick="@Login"
                           Class="mr-2">
                    @CommonLoc["Btn_SignIn"]
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>

        <LanguageSwitcher />

        <MudIconButton Icon="@(DarkLightModeButtonIcon)"
                       Color="Color.Inherit"
                       aria-label="@CommonLoc["Aria_ToggleDarkMode"]"
                       OnClick="@DarkModeToggle" />
    </MudAppBar>

    <AuthorizeView>
        <Authorized>
            <MudDrawer id="nav-drawer" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Breakpoint="Breakpoint.Md"
                       Class="drawer-border">
                <nav aria-label="@CommonLoc["Aria_MainNavigation"]">
                    <NavMenu />
                </nav>
            </MudDrawer>
        </Authorized>
    </AuthorizeView>

    <MudMainContent Class="pt-16 px-5 py-6" id="main-content" role="main">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    @CommonLoc["Error_UnhandledError"]
    <a href="." class="reload">@CommonLoc["Error_Reload"]</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private MudTheme? _theme = null;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        Theme.InitializeFromCookies(HttpContextAccessor);
        Theme.OnChange += StateHasChanged;

        _theme = new()
        {
            PaletteLight = _lightPalette,
            PaletteDark = _darkPalette,
            LayoutProperties = new LayoutProperties(),
            Typography = new Typography()
            {
                Default = new DefaultTypography
                {
                    FontFamily = ["'Inter'", "Roboto", "Helvetica", "Arial", "sans-serif"],
                    LetterSpacing = "normal",
                },
                H1 = new H1Typography
                {
                    FontWeight = "700",
                    LetterSpacing = "-.02em",
                    LineHeight = "1.2",
                },
                H2 = new H2Typography
                {
                    FontWeight = "700",
                    LetterSpacing = "-.015em",
                    LineHeight = "1.25",
                },
                H3 = new H3Typography
                {
                    FontWeight = "600",
                    LetterSpacing = "-.01em",
                    LineHeight = "1.3",
                },
                H4 = new H4Typography
                {
                    FontWeight = "600",
                    LetterSpacing = "-.01em",
                    LineHeight = "1.35",
                },
                H5 = new H5Typography
                {
                    FontWeight = "600",
                    LetterSpacing = "-.005em",
                    LineHeight = "1.4",
                },
                H6 = new H6Typography
                {
                    FontWeight = "600",
                    LetterSpacing = "0",
                    LineHeight = "1.45",
                },
                Subtitle1 = new Subtitle1Typography
                {
                    FontWeight = "500",
                    LetterSpacing = ".005em",
                },
                Body1 = new Body1Typography
                {
                    LineHeight = "1.65",
                    LetterSpacing = ".01em",
                },
                Body2 = new Body2Typography
                {
                    LineHeight = "1.6",
                    LetterSpacing = ".01em",
                },
                Caption = new CaptionTypography
                {
                    LetterSpacing = ".02em",
                    LineHeight = "1.5",
                },
            }
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (await Theme.InitializeFromLocalStorageAsync())
                StateHasChanged();
        }
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private async Task DarkModeToggle()
    {
        await Theme.ToggleAsync();
    }

    private void Login()
    {
        // forceLoad = true so we do a full navigation and the OIDC middleware takes over
        Nav.NavigateTo("/auth/login", forceLoad: true);
    }

    private void ChangePassword()
    {
        Nav.NavigateTo("/auth/change-password", forceLoad: true);
    }

    private void Logout()
    {
        Nav.NavigateTo("/auth/logout", forceLoad: true);
    }

    private string DisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        var name = user.Identity?.Name;

        if (!string.IsNullOrWhiteSpace(name))
            return name;

        return user.FindFirst("preferred_username")?.Value
            ?? user.FindFirst("email")?.Value
            ?? CommonLoc["Text_SignedIn"].Value;
    }

    private readonly PaletteLight _lightPalette = new()
    {
        Black = "#110e2d",
        Primary = "#4a6fa5",
        PrimaryDarken = "#3b5a87",
        PrimaryLighten = "#6b8ebf",
        Secondary = "#607d8b",
        Tertiary = "#7e57c2",
        Info = "#2196f3",
        Success = "#43a047",
        Warning = "#fb8c00",
        Error = "#e53935",
        AppbarText = "#37474f",
        AppbarBackground = "#ffffff",
        DrawerBackground = "#fafbfc",
        DrawerText = "#37474f",
        DrawerIcon = "#607d8b",
        Background = "#f5f6f8",
        Surface = "#ffffff",
        GrayLight = "#e8eaed",
        GrayLighter = "#f5f6f8",
        TextPrimary = "#1a2332",
        TextSecondary = "#5f6b7a",
        LinesDefault = "#dfe3e8",
        TableLines = "#e8eaed",
        Divider = "#e8eaed",
    };

    private readonly PaletteDark _darkPalette = new()
    {
        Primary = "#7ba3d4",
        PrimaryDarken = "#5a85b8",
        PrimaryLighten = "#9bbde6",
        Secondary = "#8eaab5",
        Tertiary = "#b39ddb",
        Surface = "#1e2030",
        Background = "#171923",
        BackgroundGray = "#13141f",
        AppbarText = "#a0a4b8",
        AppbarBackground = "#1a1c2e",
        DrawerBackground = "#1a1c2e",
        DrawerText = "#a0a4b8",
        DrawerIcon = "#8a8ea0",
        ActionDefault = "#7b7f96",
        ActionDisabled = "#9999994d",
        ActionDisabledBackground = "#605f6d4d",
        TextPrimary = "#d0d1dc",
        TextSecondary = "#9496a8",
        TextDisabled = "#ffffff33",
        GrayLight = "#282a3a",
        GrayLighter = "#1e2030",
        Info = "#5c9aff",
        Success = "#4caf50",
        Warning = "#ffca28",
        Error = "#ef5350",
        LinesDefault = "#2d2f42",
        TableLines = "#2d2f42",
        Divider = "#252738",
        OverlayLight = "#1e203080",
    };

    public string DarkLightModeButtonIcon => Theme.IsDarkMode switch
    {
        true => Icons.Material.Rounded.LightMode,
        false => Icons.Material.Outlined.DarkMode,
    };

    public void Dispose()
    {
        Theme.OnChange -= StateHasChanged;
    }
}