@page "/assets"
@attribute [Authorize]

@using Dam.Application.Dtos
@using Dam.Ui.Components
@using Dam.Ui.Services
@using Microsoft.AspNetCore.Authorization

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AssetsResource> AssetLoc

<PageTitle>@AssetLoc["PageTitle"] - @CommonLoc["AppName"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
    <MudGrid>
        <!-- Left Sidebar: Collection Tree -->
        <MudItem xs="12" md="3" lg="2">
            <MudPaper Class="pa-3" Elevation="1">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.h6">@CommonLoc["Label_Collections"]</MudText>
                    <MudStack Row="true" Spacing="1">
                        @if (_selectedCollectionId.HasValue)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                           Size="Size.Small"
                                           OnClick="DeselectCollection"
                                           title="@CommonLoc["Btn_Close"]" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.CreateNewFolder" 
                                       Size="Size.Small"
                                       OnClick="CreateCollectionAsync"
                                       title="@AssetLoc["CreateCollection"]" />
                    </MudStack>
                </MudStack>
                
                <CollectionTree @ref="_collectionTree" 
                                OnCollectionSelected="OnCollectionSelected"
                                SelectedCollectionId="_selectedCollectionId" />
            </MudPaper>
        </MudItem>

        <!-- Main Content -->
        <MudItem xs="12" md="9" lg="10">
            <!-- Header with breadcrumb and actions -->
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudBreadcrumbs Items="_breadcrumbs" Class="pa-0">
                    <ItemTemplate Context="item">
                        <MudLink Href="@item.Href" Color="Color.Primary">@item.Text</MudLink>
                    </ItemTemplate>
                </MudBreadcrumbs>

                @if (_selectedCollectionId.HasValue)
                {
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick="DownloadAllAsync">
                            @CommonLoc["Btn_DownloadAll"]
                        </MudButton>
                        @if (CanShare)
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Share"
                                       OnClick="ShareCollectionAsync">
                                @AssetLoc["ShareCollection"]
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="RefreshAsync">
                            @CommonLoc["Btn_Refresh"]
                        </MudButton>
                    </MudStack>
                }
            </MudStack>

            @if (!_selectedCollectionId.HasValue)
            {
                <EmptyState Title="@AssetLoc["SelectCollection"]"
                            Description="@AssetLoc["SelectCollectionDesc"]"
                            Icon="@Icons.Material.Filled.FolderOpen" />
            }
            else
            {
                <!-- Upload Area (Contributors and above can upload) -->
                @if (CanUpload)
                {
                    <AssetUpload CollectionId="@_selectedCollectionId" 
                                 OnUploadComplete="@OnUploadComplete" />
                }

                <!-- Search and Filter -->
                <MudPaper Class="pa-3 my-3" Elevation="0" Outlined="true">
                    <MudGrid>
                        <MudItem xs="12" sm="6" md="4">
                            <MudTextField @bind-Value="_searchQuery"
                                          Placeholder="@AssetLoc["SearchPlaceholder"]"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          Immediate="true"
                                          DebounceInterval="500"
                                          OnDebounceIntervalElapsed="SearchAsync" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudSelect @bind-Value="_filterType"
                                       Label="@CommonLoc["Label_Type"]"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense">
                                <MudSelectItem Value="@((string?)null)">@CommonLoc["Filter_AllTypes"]</MudSelectItem>
                                <MudSelectItem Value="@("image")">@CommonLoc["Filter_Images"]</MudSelectItem>
                                <MudSelectItem Value="@("video")">@CommonLoc["Filter_Videos"]</MudSelectItem>
                                <MudSelectItem Value="@("document")">@CommonLoc["Filter_Documents"]</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudSelect @bind-Value="_sortBy"
                                       Label="@CommonLoc["Label_SortBy"]"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense">
                                <MudSelectItem Value="@("created_desc")">@CommonLoc["Sort_NewestFirst"]</MudSelectItem>
                                <MudSelectItem Value="@("created_asc")">@CommonLoc["Sort_OldestFirst"]</MudSelectItem>
                                <MudSelectItem Value="@("title_asc")">@CommonLoc["Sort_TitleAZ"]</MudSelectItem>
                                <MudSelectItem Value="@("size_desc")">@CommonLoc["Sort_LargestFirst"]</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="2">
                            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Class="mt-1">
                                <MudIconButton Icon="@Icons.Material.Filled.GridView" 
                                               Color="@(_viewMode == "grid" ? Color.Primary : Color.Default)"
                                               OnClick="@(() => _viewMode = "grid")" />
                                <MudIconButton Icon="@Icons.Material.Filled.ViewList"
                                               Color="@(_viewMode == "list" ? Color.Primary : Color.Default)"
                                               OnClick="@(() => _viewMode = "list")" />
                            </MudButtonGroup>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <!-- Asset Grid -->
                <AssetGrid @ref="_assetGrid"
                           CollectionId="@_selectedCollectionId"
                           SearchQuery="@_searchQuery"
                           FilterType="@_filterType"
                           SortBy="@_sortBy"
                           UserRole="@(_selectedCollection?.UserRole ?? "viewer")"
                           OnAssetsChanged="@OnAssetsChanged" />
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "collection")]
    public Guid? CollectionQueryParam { get; set; }

    private CollectionTree? _collectionTree;
    private AssetGrid? _assetGrid;

    private Guid? _selectedCollectionId;
    private CollectionResponseDto? _selectedCollection;
    private List<BreadcrumbItem> _breadcrumbs = new() { new("Home", "/assets") };

    private string _searchQuery = "";
    private string? _filterType;
    private string _sortBy = "created_desc";
    private string _viewMode = "grid";
    
    // Role-based UI visibility using centralized permissions
    private string CurrentUserRole => _selectedCollection?.UserRole ?? "viewer";
    private bool CanUpload => RolePermissions.CanUpload(CurrentUserRole);
    private bool CanShare => RolePermissions.CanShare(CurrentUserRole);

    protected override async Task OnInitializedAsync()
    {
        if (CollectionQueryParam.HasValue)
        {
            await OnCollectionSelected(CollectionQueryParam.Value);
        }
    }

    private async Task OnCollectionSelected(Guid? collectionId)
    {
        _selectedCollectionId = collectionId;

        if (collectionId.HasValue)
        {
            try
            {
                _selectedCollection = await Api.GetCollectionAsync(collectionId.Value);
                UpdateBreadcrumbs();
            }
            catch (Exception ex)
            {
                Feedback.HandleError(ex, "load collection");
            }
        }
        else
        {
            _selectedCollection = null;
            _breadcrumbs = new() { new("Home", "/assets") };
        }
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new() { new("Home", "/assets") };
        if (_selectedCollection != null)
        {
            _breadcrumbs.Add(new(_selectedCollection.Name, $"/assets?collection={_selectedCollection.Id}"));
        }
    }

    private async Task DeselectCollection()
    {
        await OnCollectionSelected(null);
    }

    private async Task CreateCollectionAsync()
    {
        // Always create top-level collections - users can create sub-collections from the tree context menu
        var parameters = new DialogParameters<CreateCollectionDialog>
        {
            { x => x.ParentId, (Guid?)null }
        };

        var dialog = await DialogService.ShowAsync<CreateCollectionDialog>(AssetLoc["CreateCollection"], parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            if (_collectionTree != null)
            {
                await _collectionTree.RefreshAsync();
            }
            Feedback.ShowSuccess(AssetLoc["CollectionCreatedSuccess"]);
        }
    }

    private async Task ShareCollectionAsync()
    {
        if (!_selectedCollectionId.HasValue) return;

        var contentName = _selectedCollection?.Name ?? "this collection";

        var createParams = new DialogParameters<CreateShareDialog>
        {
            { x => x.ScopeId, _selectedCollectionId.Value },
            { x => x.ScopeType, "collection" },
            { x => x.ContentName, contentName }
        };

        var createResult = await DialogService.ShowAsync<CreateShareDialog>(AssetLoc["CreateShareLink"], createParams);
        var result = await createResult.Result;

        if (result != null && !result.Canceled && result.Data is ShareResponseDto share)
        {
            var successParams = new DialogParameters<ShareLinkDialog>
            {
                { x => x.ShareUrl, share.ShareUrl },
                { x => x.Password, share.Password ?? "" },
                { x => x.ExpiresAt, share.ExpiresAt }
            };

            await DialogService.ShowAsync<ShareLinkDialog>(AssetLoc["ShareLinkCreated"], successParams);
        }
    }

    private async Task RefreshAsync()
    {
        if (_assetGrid != null)
        {
            await _assetGrid.RefreshAsync();
        }
    }

    private async Task DownloadAllAsync()
    {
        if (!_selectedCollectionId.HasValue) return;

        var url = $"/api/collections/{_selectedCollectionId.Value}/download-all";
        
        var jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Dam.Ui/js/helpers.js");
        await jsModule.InvokeVoidAsync("downloadViaAnchor", url);
    }

    private async Task OnUploadComplete()
    {
        await RefreshAsync();
    }

    private async Task OnAssetsChanged()
    {
        // Update collection tree counts if needed
        if (_collectionTree != null)
        {
            await _collectionTree.RefreshAsync();
        }
    }

    private async Task SearchAsync()
    {
        // In a real implementation, this would filter the asset grid
        // For now, just refresh
        await RefreshAsync();
    }
}
