@page "/collections"
@page "/assets"
@attribute [Authorize]
@implements IAsyncDisposable

@using AssetHub.Application.Dtos
@using AssetHub.Application.Helpers
@using AssetHub.Ui.Components
@using AssetHub.Ui.Services
@using Microsoft.AspNetCore.Authorization

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AssetsResource> AssetLoc
@inject IStringLocalizer<CollectionsResource> CollectionLoc
@inject LocalStorageService LocalStorage

<PageTitle>@AssetLoc["PageTitle"] - @CommonLoc["AppName"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
        <!-- Header with breadcrumb and actions -->
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudBreadcrumbs Items="_breadcrumbs" Class="pa-0">
                <ItemTemplate Context="item">
                    <MudLink OnClick="@(() => OnBreadcrumbClick(item))" Color="Color.Primary" Style="cursor: pointer;">@item.Text</MudLink>
                </ItemTemplate>
            </MudBreadcrumbs>

            @if (_selectedCollectionId.HasValue)
            {
                <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                    @if (_assetSelectionMode)
                    {
                        @if (_selectedAssetIds.Count > 0)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Checklist"
                                       OnClick="OpenBulkAssetActionsAsync">
                                @string.Format(AssetLoc["BulkAssetActionsBtn"], _selectedAssetIds.Count)
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="ExitAssetSelectionMode">
                            @AssetLoc["CancelAssetSelection"]
                        </MudButton>
                    }
                    else
                    {
                    @if (CanDelete)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CheckBox"
                                   OnClick="EnterAssetSelectionMode">
                            @AssetLoc["SelectManyAssets"]
                        </MudButton>
                    }
                <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Download"
                               OnClick="DownloadAllAsync"
                               Disabled="_isDownloading">
                        @if (_isDownloading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            @_downloadStatusText
                        }
                        else
                        {
                            @CommonLoc["Btn_DownloadAll"]
                        }
                    </MudButton>
                    @if (CanShare)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Share"
                                   OnClick="ShareCollectionAsync">
                            @AssetLoc["ShareCollection"]
                        </MudButton>
                    }
                    @if (CanManageAccess)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Security"
                                   OnClick="ManageAccessAsync">
                            @AssetLoc["ManageAccess"]
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="RefreshAsync">
                        @CommonLoc["Btn_Refresh"]
                    </MudButton>
                    }
                </MudStack>
            }
            else
            {
                <MudStack Row="true" Spacing="2">
                    @if (_selectionMode)
                    {
                        @if (_selectedCollectionIds.Count > 0)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Checklist"
                                       OnClick="OpenBulkActionsAsync">
                                @string.Format(CollectionLoc["BulkActionsBtn"], _selectedCollectionIds.Count)
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="ExitSelectionMode">
                            @CollectionLoc["CancelSelection"]
                        </MudButton>
                    }
                    else
                    {
                        <AuthorizeView Policy="RequireAdmin" Context="selectManyCtx">
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.CheckBox"
                                       OnClick="EnterSelectionMode">
                                @CollectionLoc["SelectMany"]
                            </MudButton>
                        </AuthorizeView>
                    }
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.CreateNewFolder"
                               OnClick="CreateCollectionAsync">
                        @AssetLoc["CreateCollection"]
                    </MudButton>
                </MudStack>
            }
        </MudStack>

        @if (!_selectedCollectionId.HasValue)
        {
            <MudText Typo="Typo.h6" Class="mb-1">@AssetLoc["SelectCollection"]</MudText>
            <MudText Typo="Typo.body2" Class="mb-3" Style="opacity: 0.7;">@AssetLoc["SelectCollectionDesc"]</MudText>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
                <MudTextField @bind-Value="_collectionSearchString"
                              Placeholder="@AssetLoc["SearchCollectionsPlaceholder"]"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              Style="flex: 1;" />
                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                    <MudIconButton Icon="@Icons.Material.Filled.GridView"
                                   Color="@(_collectionViewMode == Constants.ViewModes.Grid ? Color.Primary : Color.Default)"
                                   OnClick="@(() => SetCollectionViewModeAsync(Constants.ViewModes.Grid))" />
                    <MudIconButton Icon="@Icons.Material.Filled.ViewList"
                                   Color="@(_collectionViewMode == Constants.ViewModes.List ? Color.Primary : Color.Default)"
                                   OnClick="@(() => SetCollectionViewModeAsync(Constants.ViewModes.List))" />
                </MudButtonGroup>
            </MudStack>

            @if (_allCollectionsLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else if (_allCollections == null || !FilteredCollections.Any())
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    @AssetLoc["NoCollectionsFound"]
                </MudAlert>
            }
            else if (_collectionViewMode == Constants.ViewModes.Grid)
            {
                <MudGrid>
                    @foreach (var collection in FilteredCollections)
                    {
                        <MudItem xs="6" sm="4" md="3" lg="2">
                            <MudCard Class="@GetCollectionCardClass(collection.Id)" @onclick="() => OnCollectionCardClick(collection)">
                                <MudCardContent>
                                    <div class="d-flex align-center gap-2 collection-card-header">
                                        @if (_selectionMode)
                                        {
                                            <MudCheckBox T="bool"
                                                         Value="@_selectedCollectionIds.Contains(collection.Id)"
                                                         ValueChanged="@(v => ToggleCollectionSelection(collection.Id, v))"
                                                         Size="Size.Small"
                                                         Color="Color.Primary"
                                                         Style="margin: -8px -4px -8px -8px; flex-shrink: 0;"
                                                         @onclick:stopPropagation="true" />
                                        }
                                        <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" Style="flex-shrink: 0;" />
                                        <MudTooltip Text="@collection.Name" Style="min-width: 0; flex: 1;">
                                            <MudText Typo="Typo.subtitle2" Class="collection-name-truncate">@collection.Name</MudText>
                                        </MudTooltip>
                                    </div>
                                    <div class="d-flex align-center gap-1 mt-2">
                                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">@CollectionLoc["YourRole"]:</MudText>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@AssetDisplayHelpers.GetRoleColor(collection.UserRole)">
                                            @CommonLoc[AssetDisplayHelpers.GetRoleKey(collection.UserRole)]
                                        </MudChip>
                                    </div>
                                    <div class="mt-1">
                                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">@string.Format(CommonLoc["Text_CountAssets"], collection.AssetCount)</MudText>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                <MudTable Items="@FilteredCollections" Dense="true" Hover="true" Striped="true" Elevation="0"
                          Breakpoint="Breakpoint.Sm" OnRowClick="@OnCollectionRowClick" T="CollectionResponseDto"
                          RowClass="cursor-pointer" Class="table-outlined">
                    <HeaderContent>
                        @if (_selectionMode)
                        {
                            <MudTh Style="width: 42px;"></MudTh>
                        }
                        <MudTh><MudTableSortLabel SortBy="new Func<CollectionResponseDto, object>(x => x.Name)">@CollectionLoc["CollectionName"]</MudTableSortLabel></MudTh>
                        <MudTh Style="width: 200px;"><MudTableSortLabel SortBy="new Func<CollectionResponseDto, object>(x => x.Description ?? string.Empty)">@CollectionLoc["Description"]</MudTableSortLabel></MudTh>
                        <MudTh Style="width: 120px;"><MudTableSortLabel SortBy="new Func<CollectionResponseDto, object>(x => x.UserRole)">@CollectionLoc["YourRole"]</MudTableSortLabel></MudTh>
                        <MudTh Style="width: 100px;"><MudTableSortLabel SortBy="new Func<CollectionResponseDto, object>(x => x.AssetCount)">@CommonLoc["Text_CountAssetsHeader"]</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        @if (_selectionMode)
                        {
                            <MudTd @onclick:stopPropagation="true">
                                <MudCheckBox T="bool"
                                             Value="@_selectedCollectionIds.Contains(context.Id)"
                                             ValueChanged="@(v => ToggleCollectionSelection(context.Id, v))"
                                             Size="Size.Small"
                                             Color="Color.Primary"
                                             Style="margin: -4px;" />
                            </MudTd>
                        }
                        <MudTd DataLabel="@CollectionLoc["CollectionName"]">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" Size="Size.Small" />
                                <MudText Typo="Typo.body2">@context.Name</MudText>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="@CollectionLoc["Description"]">
                            @if (!string.IsNullOrWhiteSpace(context.Description))
                            {
                                <MudTooltip Text="@context.Description">
                                    <MudText Typo="Typo.body2" Style="opacity: 0.7;">@Truncate(context.Description, 20)</MudText>
                                </MudTooltip>
                            }
                        </MudTd>
                        <MudTd DataLabel="@CollectionLoc["YourRole"]">
                            <MudChip T="string" Size="Size.Small"
                                     Color="@AssetDisplayHelpers.GetRoleColor(context.UserRole)">
                                @CommonLoc[AssetDisplayHelpers.GetRoleKey(context.UserRole)]
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="@CommonLoc["Text_CountAssetsHeader"]" Style="text-align: right;">@context.AssetCount</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        }
        else
        {
            <!-- Collection Info Banner -->
            @if (_selectedCollection != null)
            {
                <MudPaper Class="pa-4 mb-3" Elevation="0" Outlined="true">
                    <div class="d-flex justify-space-between align-start">
                        <div style="flex: 1; min-width: 0;">
                            @if (!string.IsNullOrWhiteSpace(_selectedCollection.Description))
                            {
                                <MudText Typo="Typo.body2" Style="font-weight: 500;" Class="mb-1">@CollectionLoc["Description"]:</MudText>
                                <MudText Typo="Typo.body2" Class="mb-3" Style="opacity: 0.85;">@_selectedCollection.Description</MudText>
                            }
                            <div class="d-flex align-center gap-2 flex-wrap">
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">@CollectionLoc["YourRole"]:</MudText>
                                <MudTooltip Text="@GetRoleDescription(_selectedCollection.UserRole)">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@AssetDisplayHelpers.GetRoleColor(_selectedCollection.UserRole)">
                                        @CommonLoc[AssetDisplayHelpers.GetRoleKey(_selectedCollection.UserRole)]
                                    </MudChip>
                                </MudTooltip>
                            </div>
                        </div>
                        <div class="d-flex gap-2 ml-3">
                            @if (RolePermissions.CanEditCollection(CurrentUserRole))
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Size="Size.Small"
                                           Color="Color.Default"
                                           StartIcon="@Icons.Material.Filled.Edit"
                                           OnClick="@(() => EditCollectionAsync(_selectedCollection))">
                                    @CollectionLoc["EditCollection"]
                                </MudButton>
                            }
                            @if (RolePermissions.CanDelete(CurrentUserRole))
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Delete"
                                           OnClick="@(() => DeleteCollectionAsync(_selectedCollection))">
                                    @CollectionLoc["DeleteCollection"]
                                </MudButton>
                            }
                        </div>
                    </div>
                </MudPaper>
            }

            <!-- Upload Area (Contributors and above can upload) -->
            @if (CanUpload)
            {
                <AssetUpload CollectionId="@_selectedCollectionId" 
                             OnUploadComplete="@OnUploadComplete" />
            }

            <!-- Search and Filter -->
            <MudPaper Class="pa-3 my-3" Elevation="0" Outlined="true">
                <MudGrid>
                        <MudItem xs="12" sm="6" md="4">
                            <MudTextField @bind-Value="_searchQuery"
                                          Placeholder="@AssetLoc["SearchPlaceholder"]"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          Immediate="true"
                                          DebounceInterval="500"
                                          OnDebounceIntervalElapsed="SearchAsync" />
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudSelect @bind-Value="_filterType"
                                       Label="@CommonLoc["Label_Type"]"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense">
                                <MudSelectItem Value="@((string?)null)">@CommonLoc["Filter_AllTypes"]</MudSelectItem>
                                <MudSelectItem Value="@(Constants.AssetTypeFilters.Image)">@CommonLoc["Filter_Images"]</MudSelectItem>
                                <MudSelectItem Value="@(Constants.AssetTypeFilters.Video)">@CommonLoc["Filter_Videos"]</MudSelectItem>
                                <MudSelectItem Value="@(Constants.AssetTypeFilters.Document)">@CommonLoc["Filter_Documents"]</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="2">
                            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Class="mt-1">
                                <MudIconButton Icon="@Icons.Material.Filled.GridView" 
                                               Color="@(_viewMode == Constants.ViewModes.Grid ? Color.Primary : Color.Default)"
                                               OnClick="@(() => SetAssetViewModeAsync(Constants.ViewModes.Grid))" />
                                <MudIconButton Icon="@Icons.Material.Filled.ViewList"
                                               Color="@(_viewMode == Constants.ViewModes.List ? Color.Primary : Color.Default)"
                                               OnClick="@(() => SetAssetViewModeAsync(Constants.ViewModes.List))" />
                    </MudButtonGroup>
                </MudItem>
            </MudGrid>
            </MudPaper>

            <!-- Asset Grid -->
            <AssetGrid @ref="_assetGrid"
                           CollectionId="@_selectedCollectionId"
                           SearchQuery="@_searchQuery"
                           FilterType="@_filterType"
                           ViewMode="@_viewMode"
                           UserRole="@(_selectedCollection?.UserRole ?? RoleHierarchy.Roles.Viewer)"
                           SelectionMode="@_assetSelectionMode"
                           SelectedAssetIds="@_selectedAssetIds"
                           SelectedAssetIdsChanged="@OnAssetSelectionChanged"
                           OnAssetsChanged="@OnAssetsChanged" />
        }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "collection")]
    public Guid? CollectionQueryParam { get; set; }

    private AssetGrid? _assetGrid;

    private Guid? _selectedCollectionId;
    private CollectionResponseDto? _selectedCollection;
    private List<BreadcrumbItem> _breadcrumbs = new();

    private string _searchQuery = "";
    private string? _filterType;
    private string _viewMode = Constants.ViewModes.Grid;

    private const string ViewModeStorageKeyCollections = "viewMode_collections";
    private const string ViewModeStorageKeyAssets = "viewMode_collectionAssets";

    // Collection browser state
    private List<CollectionResponseDto>? _allCollections;
    private bool _allCollectionsLoading = true;
    private string _collectionSearchString = "";
    private string _collectionViewMode = Constants.ViewModes.Grid;

    // Bulk selection state (admin only)
    private bool _selectionMode;
    private HashSet<Guid> _selectedCollectionIds = new();

    // Asset bulk selection state
    private bool _assetSelectionMode;
    private HashSet<Guid> _selectedAssetIds = new();

    private bool CanDelete => RolePermissions.CanDelete(CurrentUserRole);

    private IEnumerable<CollectionResponseDto> FilteredCollections =>
        (_allCollections ?? Enumerable.Empty<CollectionResponseDto>())
        .Where(c => string.IsNullOrWhiteSpace(_collectionSearchString)
            || c.Name.Contains(_collectionSearchString, StringComparison.OrdinalIgnoreCase)
            || (c.Description?.Contains(_collectionSearchString, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(c => c.Name, new NaturalSortComparer());
    
    // Role-based UI visibility using centralized permissions
    private string CurrentUserRole => _selectedCollection?.UserRole ?? RoleHierarchy.Roles.Viewer;
    private bool CanUpload => RolePermissions.CanUpload(CurrentUserRole);
    private bool CanShare => RolePermissions.CanShare(CurrentUserRole);
    private bool CanManageAccess => RolePermissions.CanManageAccess(CurrentUserRole);

    // Track navigation to refresh when returning to this page
    private string? _lastKnownUri;

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs = new() { new(CommonLoc["Nav_Collections"].Value, "/collections") };
        _lastKnownUri = Nav.Uri;
        Nav.LocationChanged += OnLocationChanged;

        var loadCollections = LoadAllCollections();

        if (CollectionQueryParam.HasValue)
        {
            await Task.WhenAll(loadCollections, OnCollectionSelected(CollectionQueryParam.Value));
        }
        else
        {
            await loadCollections;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var storedCollectionView = await LocalStorage.GetAsync(ViewModeStorageKeyCollections);
            var storedAssetView = await LocalStorage.GetAsync(ViewModeStorageKeyAssets);
            var changed = false;

            if (!string.IsNullOrEmpty(storedCollectionView))
            {
                _collectionViewMode = storedCollectionView;
                changed = true;
            }
            if (!string.IsNullOrEmpty(storedAssetView))
            {
                _viewMode = storedAssetView;
                changed = true;
            }

            if (changed) StateHasChanged();
        }
    }

    private async Task SetCollectionViewModeAsync(string mode)
    {
        _collectionViewMode = mode;
        await LocalStorage.SetAsync(ViewModeStorageKeyCollections, mode);
    }

    private async Task SetAssetViewModeAsync(string mode)
    {
        _viewMode = mode;
        await LocalStorage.SetAsync(ViewModeStorageKeyAssets, mode);
    }

    private async Task LoadAllCollections()
    {
        try
        {
            _allCollectionsLoading = true;
            _allCollections = await Api.GetCollectionsAsync();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collections");
        }
        finally
        {
            _allCollectionsLoading = false;
        }
    }

    private async Task OnCollectionSelected(Guid? collectionId)
    {
        _selectedCollectionId = collectionId;

        if (collectionId.HasValue)
        {
            try
            {
                _selectedCollection = await Api.GetCollectionAsync(collectionId.Value);
                UpdateBreadcrumbs();
            }
            catch (Exception ex)
            {
                Feedback.HandleError(ex, "load collection");
            }
        }
        else
        {
            _selectedCollection = null;
            _breadcrumbs = new() { new(CommonLoc["Nav_Collections"].Value, "/collections") };
        }
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new() { new(CommonLoc["Nav_Collections"].Value, "/collections") };
        if (_selectedCollection != null)
        {
            _breadcrumbs.Add(new(_selectedCollection.Name, $"/collections?collection={_selectedCollection.Id}"));
        }
    }

    private async Task DeselectCollection()
    {
        await OnCollectionSelected(null);
        Nav.NavigateTo("/collections", replace: true);
    }

    private async Task OnBreadcrumbClick(BreadcrumbItem item)
    {
        if (item.Href == "/collections")
        {
            await DeselectCollection();
        }
    }

    private async Task CreateCollectionAsync()
    {
        var dialog = await DialogService.ShowAsync<CreateCollectionDialog>(AssetLoc["CreateCollection"]);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadAllCollections();
            Feedback.ShowSuccess(AssetLoc["CollectionCreatedSuccess"].Value);
        }
    }

    private async Task EditCollectionAsync(CollectionResponseDto collection)
    {
        var parameters = new DialogParameters<EditCollectionDialog>
        {
            { x => x.CollectionId, collection.Id },
            { x => x.InitialName, collection.Name },
            { x => x.InitialDescription, collection.Description }
        };

        var dialog = await DialogService.ShowAsync<EditCollectionDialog>(CollectionLoc["EditCollection"], parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadAllCollections();

            // Refresh the selected collection details if we edited the current one
            if (_selectedCollectionId == collection.Id)
            {
                await OnCollectionSelected(collection.Id);
            }

            Feedback.ShowSuccess(CollectionLoc["UpdatedSuccess"].Value);
        }
    }

    private async Task DeleteCollectionAsync(CollectionResponseDto collection)
    {
        var assetWarning = collection.AssetCount > 0
            ? string.Format(CollectionLoc["AssetCountWarning"], collection.AssetCount)
            : "";
        var message = string.Format(CollectionLoc["ConfirmDeleteCollection"], collection.Name, assetWarning);

        var confirmed = await DialogService.ShowMessageBox(
            CollectionLoc["DeleteCollection"],
            message,
            yesText: CommonLoc["Btn_Delete"],
            cancelText: CommonLoc["Btn_Cancel"]);

        if (confirmed == true)
        {
            try
            {
                await Api.DeleteCollectionAsync(collection.Id);

                // If we deleted the currently selected collection, go back to grid
                if (_selectedCollectionId == collection.Id)
                {
                    await DeselectCollection();
                }

                await LoadAllCollections();
                Feedback.ShowSuccess(CollectionLoc["DeletedSuccess"].Value);
            }
            catch (Exception ex)
            {
                Feedback.HandleError(ex, "delete collection");
            }
        }
    }

    private async Task ShareCollectionAsync()
    {
        if (!_selectedCollectionId.HasValue) return;

        var contentName = _selectedCollection?.Name ?? CommonLoc["Text_ThisCollection"].Value;

        var createParams = new DialogParameters<CreateShareDialog>
        {
            { x => x.ScopeId, _selectedCollectionId.Value },
            { x => x.ScopeType, Constants.ScopeTypes.Collection },
            { x => x.ContentName, contentName }
        };

        var createResult = await DialogService.ShowAsync<CreateShareDialog>(AssetLoc["CreateShareLink"], createParams);
        var result = await createResult.Result;

        if (result != null && !result.Canceled && result.Data is ShareResponseDto share)
        {
            var successParams = new DialogParameters<ShareLinkDialog>
            {
                { x => x.ShareUrl, share.ShareUrl },
                { x => x.Password, share.Password ?? "" },
                { x => x.ExpiresAt, share.ExpiresAt }
            };

            await DialogService.ShowAsync<ShareLinkDialog>(AssetLoc["ShareLinkCreated"], successParams);
        }
    }

    private async Task ManageAccessAsync()
    {
        if (!_selectedCollectionId.HasValue || _selectedCollection == null) return;

        var parameters = new DialogParameters<ManageAccessDialog>
        {
            { x => x.CollectionId, _selectedCollectionId.Value },
            { x => x.CollectionName, _selectedCollection.Name },
            { x => x.CurrentUserRole, _selectedCollection.UserRole ?? RoleHierarchy.Roles.Viewer }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        await DialogService.ShowAsync<ManageAccessDialog>(AssetLoc["ManageAccess"], parameters, options);
    }

    private async Task RefreshAsync()
    {
        if (_assetGrid != null)
        {
            await _assetGrid.RefreshAsync();
        }
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // Check if we navigated away and back to this page
        var wasOnAssets = _lastKnownUri?.Contains("/collections") == true || _lastKnownUri?.Contains("/assets") == true;
        var isOnAssets = e.Location.Contains("/collections") || e.Location.Contains("/assets");
        var leftAndReturned = !wasOnAssets && isOnAssets;

        _lastKnownUri = e.Location;

        // Refresh the asset grid when returning to this page
        if (leftAndReturned && _assetGrid != null && _selectedCollectionId.HasValue)
        {
            await InvokeAsync(async () =>
            {
                await _assetGrid.RefreshAsync();
                StateHasChanged();
            });
        }
    }

    private bool _isDownloading;
    private string _downloadStatusText = "";
    private DotNetObjectReference<Assets>? _dotNetRef;
    private IJSObjectReference? _jsModule;

    private async Task DownloadAllAsync()
    {
        if (!_selectedCollectionId.HasValue || _isDownloading) return;

        _isDownloading = true;
        _downloadStatusText = CommonLoc["Msg_PreparingDownload"].Value;
        StateHasChanged();

        try
        {
            var url = $"/api/v1/collections/{_selectedCollectionId.Value}/download-all";
            _dotNetRef?.Dispose();
            _dotNetRef = DotNetObjectReference.Create(this);

            _jsModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AssetHub.Ui/js/helpers.js");
            var resultJson = await _jsModule.InvokeAsync<string>("enqueueAndPollZipDownload", url, null, _dotNetRef);

            var result = System.Text.Json.JsonSerializer.Deserialize<ZipDownloadResult>(resultJson,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (result?.Success != true)
            {
                Feedback.ShowError(result?.Error ?? CommonLoc["Msg_DownloadFailed"].Value);
            }
        }
        catch (Exception)
        {
            Feedback.ShowError(CommonLoc["Msg_DownloadFailed"].Value);
        }
        finally
        {
            _isDownloading = false;
            _downloadStatusText = "";
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void UpdateZipProgress(string status, string fileName)
    {
        _downloadStatusText = status switch
        {
            Constants.ZipProgressStatus.Pending => CommonLoc["Msg_DownloadQueued"].Value,
            Constants.ZipProgressStatus.Building => CommonLoc["Msg_BuildingZip"].Value,
            _ => CommonLoc["Msg_PreparingDownload"].Value
        };
        InvokeAsync(StateHasChanged);
    }

    private record ZipDownloadResult(bool Success, string? Error);

    private async Task OnUploadComplete()
    {
        await RefreshAsync();
    }

    private async Task OnAssetsChanged()
    {
        // Refresh collection list to update asset counts
        await LoadAllCollections();
    }

    private string GetRoleDescription(string? role) => role?.ToLowerInvariant() switch
    {
        RoleHierarchy.Roles.Viewer => CollectionLoc["RoleDesc_Viewer"],
        RoleHierarchy.Roles.Contributor => CollectionLoc["RoleDesc_Contributor"],
        RoleHierarchy.Roles.Manager => CollectionLoc["RoleDesc_Manager"],
        RoleHierarchy.Roles.Admin => CollectionLoc["RoleDesc_Admin"],
        _ => ""
    };

    // ── Bulk Selection (admin only) ──────────────────────────────

    private void ToggleCollectionSelection(Guid id, bool selected)
    {
        if (selected)
            _selectedCollectionIds.Add(id);
        else
            _selectedCollectionIds.Remove(id);
    }

    private void ClearSelection() => _selectedCollectionIds.Clear();

    private void EnterSelectionMode() => _selectionMode = true;

    private void ExitSelectionMode()
    {
        _selectionMode = false;
        _selectedCollectionIds.Clear();
    }

    private string GetCollectionCardClass(Guid id) =>
        _selectedCollectionIds.Contains(id)
            ? "cursor-pointer collection-card mud-border-primary"
            : "cursor-pointer collection-card";

    private async Task OnCollectionCardClick(CollectionResponseDto collection)
    {
        if (_selectionMode)
        {
            ToggleCollectionSelection(collection.Id, !_selectedCollectionIds.Contains(collection.Id));
            return;
        }
        await OnCollectionSelected(collection.Id);
    }

    private async Task OnCollectionRowClick(TableRowClickEventArgs<CollectionResponseDto> args)
    {
        await OnCollectionCardClick(args.Item!);
    }

    private static string Truncate(string value, int maxLength) =>
        value.Length > maxLength ? value[..maxLength] + "…" : value;

    private async Task OpenBulkActionsAsync()
    {
        var selected = (_allCollections ?? new())
            .Where(c => _selectedCollectionIds.Contains(c.Id))
            .ToList();

        if (selected.Count == 0) return;

        var parameters = new DialogParameters<BulkCollectionActionsDialog>
        {
            { x => x.SelectedCollections, selected }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<BulkCollectionActionsDialog>(
            CollectionLoc["BulkActions"], parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            _selectionMode = false;
            _selectedCollectionIds.Clear();
            await LoadAllCollections();
        }
    }

    // ── Asset Bulk Selection ─────────────────────────────────────

    private void EnterAssetSelectionMode()
    {
        _assetSelectionMode = true;
        _selectedAssetIds.Clear();
    }

    private void ExitAssetSelectionMode()
    {
        _assetSelectionMode = false;
        _selectedAssetIds.Clear();
    }

    private Task OnAssetSelectionChanged(HashSet<Guid> ids)
    {
        _selectedAssetIds = ids;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OpenBulkAssetActionsAsync()
    {
        if (_selectedAssetIds.Count == 0 || _assetGrid == null) return;

        var selectedAssets = _assetGrid.GetSelectedAssets();
        if (selectedAssets.Count == 0) return;

        var parameters = new DialogParameters<BulkAssetActionsDialog>
        {
            { x => x.SelectedAssets, selectedAssets },
            { x => x.CollectionId, _selectedCollectionId }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<BulkAssetActionsDialog>(
            AssetLoc["BulkAssetActions"], parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            _assetSelectionMode = false;
            _selectedAssetIds.Clear();
            await _assetGrid.RefreshAsync();
            await OnAssetsChanged();
        }
    }

    private async Task SearchAsync()
    {
        // Debounced search handler — triggers AssetGrid reload with current _searchQuery
        await RefreshAsync();
    }

    public async ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= OnLocationChanged;
        _dotNetRef?.Dispose();
        if (_jsModule is not null)
        {
            try { await _jsModule.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
    }
}
