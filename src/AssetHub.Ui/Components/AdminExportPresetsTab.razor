@using MudBlazor
@using AssetHub.Application.Dtos
@using AssetHub.Ui.Resources
@using AssetHub.Ui.Services

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AdminResource> AdminLoc

@if (_loading && _presets == null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_presets == null || !_presets.Any())
{
    <EmptyState Title="@AdminLoc["ExportPresets_NoPresetsYet"]"
                Description="@AdminLoc["ExportPresets_NoPresetsDesc"]"
                Icon="@Icons.Material.Filled.Tune"
                ActionText="@AdminLoc["ExportPresets_CreatePreset"]"
                ActionIcon="@Icons.Material.Filled.Add"
                OnAction="OpenCreateDialog" />
}
else
{
    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @AdminLoc["ExportPresets_Desc"]
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateDialog">
                @AdminLoc["ExportPresets_CreatePreset"]
            </MudButton>
        </MudStack>

        <MudTable Items="@_presets" Hover="true" Dense="true" Striped="true" Loading="@_loading"
                  FixedHeader="true">
            <HeaderContent>
                <MudTh>@AdminLoc["ExportPresets_Header_Name"]</MudTh>
                <MudTh>@AdminLoc["ExportPresets_Header_Dimensions"]</MudTh>
                <MudTh>@AdminLoc["ExportPresets_Header_FitMode"]</MudTh>
                <MudTh>@AdminLoc["ExportPresets_Header_Format"]</MudTh>
                <MudTh>@AdminLoc["ExportPresets_Header_Quality"]</MudTh>
                <MudTh>@AdminLoc["ExportPresets_Header_Created"]</MudTh>
                <MudTh Style="width: 120px;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@AdminLoc["ExportPresets_Header_Name"]">
                    <MudText Typo="Typo.body2" Class="font-semibold">@context.Name</MudText>
                </MudTd>
                <MudTd DataLabel="@AdminLoc["ExportPresets_Header_Dimensions"]">
                    @FormatDimensions(context)
                </MudTd>
                <MudTd DataLabel="@AdminLoc["ExportPresets_Header_FitMode"]">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@GetLocalizedFitMode(context.FitMode)</MudChip>
                </MudTd>
                <MudTd DataLabel="@AdminLoc["ExportPresets_Header_Format"]">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">@context.Format.ToUpperInvariant()</MudChip>
                </MudTd>
                <MudTd DataLabel="@AdminLoc["ExportPresets_Header_Quality"]">
                    @context.Quality%
                </MudTd>
                <MudTd DataLabel="@AdminLoc["ExportPresets_Header_Created"]">
                    <MudTooltip Text="@context.CreatedAt.ToLocalTime().ToString("F")">
                        <MudText Typo="Typo.body2">@context.CreatedAt.ToLocalTime().ToString("d")</MudText>
                    </MudTooltip>
                </MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="1">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       aria-label="@AdminLoc["ExportPresets_EditPreset"]"
                                       OnClick="@(() => OpenEditDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       aria-label="@AdminLoc["ExportPresets_DeletePreset"]"
                                       OnClick="@(() => DeletePresetAsync(context))" />
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudStack>
}

@code {
    private List<ExportPresetDto>? _presets;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        try
        {
            _presets = await Api.GetExportPresetsAsync();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load export presets");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ExportPresetDialog>(
            AdminLoc["ExportPresets_CreatePreset"], options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadAsync();
        }
    }

    private async Task OpenEditDialog(ExportPresetDto preset)
    {
        var parameters = new DialogParameters<ExportPresetDialog>
        {
            { x => x.Preset, preset }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ExportPresetDialog>(
            AdminLoc["ExportPresets_EditPreset"], parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadAsync();
        }
    }

    private async Task DeletePresetAsync(ExportPresetDto preset)
    {
        var confirmed = await DialogService.ShowConfirmAsync(
            AdminLoc["ExportPresets_DeletePreset"],
            string.Format(AdminLoc["ExportPresets_ConfirmDelete"], preset.Name),
            CommonLoc["Btn_Delete"],
            Icons.Material.Filled.Delete,
            Color.Error,
            Color.Error);

        if (!confirmed)
            return;

        // Optimistic delete
        _presets?.Remove(preset);
        StateHasChanged();

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.DeleteExportPresetAsync(preset.Id),
            "delete export preset",
            string.Format(AdminLoc["ExportPresets_DeletedSuccess"], preset.Name));

        if (!success)
        {
            // Rollback
            _presets?.Add(preset);
            StateHasChanged();
        }
    }

    private string FormatDimensions(ExportPresetDto preset)
    {
        var w = preset.Width?.ToString() ?? AdminLoc["ExportPresets_DimensionsAny"].Value;
        var h = preset.Height?.ToString() ?? AdminLoc["ExportPresets_DimensionsAny"].Value;
        return $"{w} × {h}";
    }

    private string GetLocalizedFitMode(string fitMode) => fitMode switch
    {
        "contain" => AdminLoc["ExportPresets_FitMode_Contain"].Value,
        "cover" => AdminLoc["ExportPresets_FitMode_Cover"].Value,
        "stretch" => AdminLoc["ExportPresets_FitMode_Stretch"].Value,
        "width" => AdminLoc["ExportPresets_FitMode_Width"].Value,
        "height" => AdminLoc["ExportPresets_FitMode_Height"].Value,
        _ => fitMode
    };
}
