@using AssetHub.Application.Helpers
@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AdminResource> AdminLoc
@inject ISnackbar Snackbar
@inject LocalStorageService LocalStorage

@if (_allUsersLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_allUsers == null || !_allUsers.Any())
{
    <EmptyState Title="@AdminLoc["NoUsersFound"]"
                Description="@AdminLoc["NoUsersFoundDesc"]"
                Icon="@Icons.Material.Filled.PeopleAlt"
                ActionText="@CommonLoc["Btn_CreateUser"]"
                ActionIcon="@Icons.Material.Filled.PersonAdd"
                OnAction="OpenCreateUserDialog" />
}
else
{
    <MudTable Items="@_allUsers" Hover="true" Dense="true" Striped="true" Filter="new Func<KeycloakUserDto,bool>(UserFilter)" SortLabel="@CommonLoc["Label_SortBy"]">
        <ToolBarContent>
            <MudTextField @bind-Value="_userSearchString" Placeholder="@AdminLoc["SearchUsersPlaceholder"]"
                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                IconSize="Size.Medium" Class="mt-0" Immediate="true" DebounceInterval="500" />
            <MudSpacer />
            <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">@AdminLoc["Total"]: @_allUsers.Count</MudChip>
            <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
            <MudChip T="string" Color="@(_showWithAccess ? Color.Success : Color.Default)" Size="Size.Small" OnClick="ToggleWithAccess" Style="cursor: pointer;">@AdminLoc["WithAccess"]: @_allUsers.Count(u => !u.IsSystemAdmin && u.CollectionCount > 0)</MudChip>
            <MudChip T="string" Color="@(_showAdmins ? Color.Primary : Color.Default)" Size="Size.Small" OnClick="ToggleAdmins" Style="cursor: pointer;">@AdminLoc["Admins"]: @_allUsers.Count(u => u.IsSystemAdmin)</MudChip>
            <MudChip T="string" Color="@(_showNoAccess ? Color.Warning : Color.Default)" Size="Size.Small" OnClick="ToggleNoAccess" Style="cursor: pointer;">@AdminLoc["NoAssignedAccess"]: @_allUsers.Count(u => !u.IsSystemAdmin && u.CollectionCount == 0)</MudChip>
            <MudTooltip Text="@AdminLoc["SyncUsersTooltip"]">
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Sync"
                           OnClick="SyncDeletedUsers" Class="ml-2"
                           Disabled="@_isSyncing">
                    @if (_isSyncing)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                    }
                    @AdminLoc["Btn_SyncUsers"]
                </MudButton>
            </MudTooltip>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.PersonAdd"
                       OnClick="OpenCreateUserDialog" Class="ml-2">
                @CommonLoc["Btn_CreateUser"]
            </MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.Username)">@AdminLoc["Header_Username"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.Email ?? string.Empty)">@AdminLoc["Header_Email"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.CreatedAt ?? DateTime.MinValue)">@AdminLoc["Header_Created"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.CollectionCount)">@CommonLoc["Label_Collections"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<KeycloakUserDto, object>(x => x.HighestRole ?? string.Empty)">@AdminLoc["Header_HighestRole"]</MudTableSortLabel></MudTh>
            <MudTh>@CommonLoc["Label_Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Username</MudTd>
            <MudTd>@(context.Email ?? "-")</MudTd>
            <MudTd>
                @if (context.CreatedAt.HasValue)
                {
                    <MudTooltip Text="@context.CreatedAt.Value.ToLocalTime().ToString("F")">
                        <MudText Typo="Typo.body2">@context.CreatedAt.Value.ToLocalTime().ToString("g")</MudText>
                    </MudTooltip>
                }
                else
                {
                    <MudText Typo="Typo.body2">—</MudText>
                }
            </MudTd>
            <MudTd>
                @if (context.IsSystemAdmin)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                             Icon="@Icons.Material.Filled.AdminPanelSettings">
                        @CommonLoc["Text_AllCollections"]
                    </MudChip>
                }
                else if (context.CollectionCount > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.CollectionCount</MudChip>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Text_None"]</MudText>
                }
            </MudTd>
            <MudTd>
                @if (context.IsSystemAdmin)
                {
                    <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetRoleColor(RoleHierarchy.Roles.Admin)" Variant="Variant.Filled">
                        @CommonLoc[AssetDisplayHelpers.GetRoleKey(RoleHierarchy.Roles.Admin)]
                    </MudChip>
                }
                else if (!string.IsNullOrEmpty(context.HighestRole))
                {
                    <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetRoleColor(context.HighestRole)">
                        @CommonLoc[AssetDisplayHelpers.GetRoleKey(context.HighestRole)]
                    </MudChip>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@CommonLoc["Text_NoAccess"]</MudText>
                }
            </MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="1">
                    <MudTooltip Text="@CommonLoc["Btn_ManageAccess"]">
                        <MudIconButton Icon="@Icons.Material.Filled.ManageAccounts"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => ManageUserAccess(context))" />
                    </MudTooltip>
                    <MudTooltip Text="@AdminLoc["DeleteUser"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => DeleteUser(context))" />
                    </MudTooltip>
                </MudStack>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}

@code {
    /// <summary>
    /// Fires after any action that also changes collection ACL data (create/delete/manage access/sync),
    /// so the parent can tell the collections tab to refresh.
    /// </summary>
    [Parameter] public EventCallback OnChanged { get; set; }

    private List<KeycloakUserDto>? _allUsers;
    private bool _allUsersLoading = true;
    private string _userSearchString = "";
    private bool _isSyncing = false;
    private bool _showWithAccess = true;
    private bool _showAdmins = true;
    private bool _showNoAccess = true;

    private const string StorageKeyShowWithAccess = "adminUsers_showWithAccess";
    private const string StorageKeyShowAdmins = "adminUsers_showAdmins";
    private const string StorageKeyShowNoAccess = "adminUsers_showNoAccess";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _showWithAccess = await LocalStorage.GetBoolAsync(StorageKeyShowWithAccess, true);
            _showAdmins = await LocalStorage.GetBoolAsync(StorageKeyShowAdmins, true);
            _showNoAccess = await LocalStorage.GetBoolAsync(StorageKeyShowNoAccess, true);
            StateHasChanged();
        }
    }

    public async Task RefreshAsync()
    {
        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        try
        {
            _allUsersLoading = true;
            _allUsers = await Api.GetKeycloakUsersAsync();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load Keycloak users");
        }
        finally
        {
            _allUsersLoading = false;
        }
    }

    private bool UserFilter(KeycloakUserDto user)
    {
        // Category filter
        if (user.IsSystemAdmin && !_showAdmins) return false;
        if (!user.IsSystemAdmin && user.CollectionCount > 0 && !_showWithAccess) return false;
        if (!user.IsSystemAdmin && user.CollectionCount == 0 && !_showNoAccess) return false;

        if (string.IsNullOrWhiteSpace(_userSearchString))
            return true;

        return user.Username.Contains(_userSearchString, StringComparison.OrdinalIgnoreCase)
            || (user.Email?.Contains(_userSearchString, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private async Task ToggleWithAccess()
    {
        _showWithAccess = !_showWithAccess;
        await LocalStorage.SetBoolAsync(StorageKeyShowWithAccess, _showWithAccess);
    }

    private async Task ToggleAdmins()
    {
        _showAdmins = !_showAdmins;
        await LocalStorage.SetBoolAsync(StorageKeyShowAdmins, _showAdmins);
    }

    private async Task ToggleNoAccess()
    {
        _showNoAccess = !_showNoAccess;
        await LocalStorage.SetBoolAsync(StorageKeyShowNoAccess, _showNoAccess);
    }

    private async Task ManageUserAccess(KeycloakUserDto user)
    {
        var parameters = new DialogParameters<ManageUserAccessDialog>
        {
            { x => x.UserId, user.Id },
            { x => x.Username, user.Username },
            { x => x.Email, user.Email },
            { x => x.FirstName, user.FirstName },
            { x => x.LastName, user.LastName },
            { x => x.IsSystemAdmin, user.IsSystemAdmin }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ManageUserAccessDialog>(AdminLoc["ManageUserAccess"], parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadAsync();
            await OnChanged.InvokeAsync();
        }
    }

    private async Task OpenCreateUserDialog()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<CreateUserDialog>(AdminLoc["CreateNewUser"], options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadAsync();
            await OnChanged.InvokeAsync();
        }
    }

    private async Task DeleteUser(KeycloakUserDto user)
    {
        var confirmParams = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, AdminLoc["DeleteUser"] },
            { x => x.Message, string.Format(AdminLoc["ConfirmDeleteUser"], user.Username) },
            { x => x.TitleIcon, Icons.Material.Filled.PersonRemove },
            { x => x.IconColor, Color.Error },
            { x => x.ConfirmText, CommonLoc["Btn_Delete"] },
            { x => x.ConfirmColor, Color.Error }
        };
        var confirmDialog = await DialogService.ShowAsync<ConfirmDialog>(null, confirmParams);
        var confirmResult = await confirmDialog.Result;

        if (confirmResult == null || confirmResult.Canceled)
            return;

        var (success, _) = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.DeleteUserAsync(user.Id),
            "delete user",
            string.Format(AdminLoc["UserDeletedSuccess"], user.Username));

        if (success)
        {
            await LoadAsync();
            await OnChanged.InvokeAsync();
        }
    }

    private async Task SyncDeletedUsers()
    {
        try
        {
            _isSyncing = true;
            StateHasChanged();

            var preview = await Api.SyncDeletedUsersAsync(dryRun: true);

            if (preview.DeletedUsers == 0)
            {
                Snackbar.Add(AdminLoc["SyncNoGhostUsers"], Severity.Success);
                return;
            }

            var message = string.Format(AdminLoc["SyncConfirm"], preview.DeletedUsers, preview.AclsRemoved, preview.SharesRevoked);
            var confirmParams = new DialogParameters<ConfirmDialog>
            {
                { x => x.Title, AdminLoc["Btn_SyncUsers"] },
                { x => x.Message, message },
                { x => x.TitleIcon, Icons.Material.Filled.Sync },
                { x => x.IconColor, Color.Warning },
                { x => x.ConfirmText, CommonLoc["Btn_Confirm"] },
                { x => x.ConfirmColor, Color.Primary }
            };
            var confirmDialog = await DialogService.ShowAsync<ConfirmDialog>(null, confirmParams);
            var confirmResult = await confirmDialog.Result;

            if (confirmResult == null || confirmResult.Canceled)
                return;

            var result = await Api.SyncDeletedUsersAsync(dryRun: false);

            Snackbar.Add(string.Format(AdminLoc["SyncCompleted"], result.DeletedUsers, result.AclsRemoved, result.SharesRevoked), Severity.Success);

            await LoadAsync();
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "sync users");
        }
        finally
        {
            _isSyncing = false;
            StateHasChanged();
        }
    }
}
