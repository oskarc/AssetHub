@page "/assets/{AssetId:guid}"
@attribute [Authorize]

@using Dam.Application.Dtos
@using Dam.Ui.Components
@using Dam.Ui.Services
@using Microsoft.AspNetCore.Authorization

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService

<PageTitle>@(_asset?.Title ?? "Asset") - AssetHub</PageTitle>

@if (_isLoading)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.body1" Class="mt-4">Loading asset...</MudText>
        </MudStack>
    </MudContainer>
}
else if (_asset == null)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
        <EmptyState Title="Asset not found"
                    Description="This asset doesn't exist or you don't have permission to view it."
                    Icon="@Icons.Material.Filled.BrokenImage"
                    ActionText="Back to Assets"
                    ActionIcon="@Icons.Material.Filled.ArrowBack"
                    OnAction="@NavigateBackToAssets" />
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
        <!-- Back Button -->
        <MudButton Variant="Variant.Text" 
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@NavigateBackToAssets"
                   Class="mb-3">
            Back to Assets
        </MudButton>

        <MudGrid>
            <!-- Preview Area -->
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-4" Elevation="1">
                    @if (_asset.AssetType == "image")
                    {
                        <MudImage Src="@GetPreviewUrl()" 
                                  Alt="@_asset.Title"
                                  ObjectFit="ObjectFit.Contain"
                                  Style="width: 100%; max-height: 600px;"
                                  Class="rounded" />
                    }
                    else if (_asset.AssetType == "video")
                    {
                        <video controls style="width: 100%; max-height: 600px;">
                            <source src="@GetPreviewUrl()" type="@_asset.ContentType">
                            Your browser does not support the video tag.
                        </video>
                    }
                    else if (IsPdfPreviewable())
                    {
                        <iframe src="@GetInlinePreviewUrl()" 
                                style="width: 100%; height: 600px; border: none;" 
                                title="@_asset.Title">
                        </iframe>
                    }
                    else
                    {
                        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
                            <MudIcon Icon="@GetAssetIcon()" Size="Size.Large" Color="Color.Primary" />
                            <MudText Typo="Typo.h6">@_asset.Title</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                Preview not available for this file type
                            </MudText>
                            <MudButton Variant="Variant.Outlined" 
                                       StartIcon="@Icons.Material.Filled.Download"
                                       Href="@GetDownloadUrl()"
                                       Target="_blank"
                                       Class="mt-2">
                                Download to View
                            </MudButton>
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>

            <!-- Details Panel -->
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Elevation="1">
                    <!-- Title and Status -->
                    <MudStack Spacing="3">
                        <MudStack>
                            <MudText Typo="Typo.h5">@_asset.Title</MudText>
                            <MudStack Row="true" Spacing="1">
                                <MudChip T="string" Size="Size.Small" Color="@GetAssetTypeColor()">
                                    @_asset.AssetType.ToUpperInvariant()
                                </MudChip>
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor()">
                                    @_asset.Status.ToUpperInvariant()
                                </MudChip>
                            </MudStack>
                        </MudStack>

                        <MudDivider />

                        <!-- Collection Membership (Multi-Collection) -->
                        <MudStack>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.subtitle2">Collections</MudText>
                                @if (CanManageCollections())
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="OpenAddToCollectionDialogAsync"
                                                   Title="Add to Collection" />
                                }
                            </MudStack>
                            
                            @if (_assetCollections.Any())
                            {
                                <MudStack Spacing="1">
                                    @foreach (var collection in _assetCollections)
                                    {
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudChip T="string" 
                                                     Size="Size.Small" 
                                                     Color="@(collection.IsPrimary ? Color.Primary : Color.Secondary)"
                                                     Icon="@Icons.Material.Filled.Folder"
                                                     OnClick="@(() => Nav.NavigateTo($"/assets?collection={collection.Id}"))"
                                                     Style="cursor: pointer;">
                                                @collection.Name
                                                @if (collection.IsPrimary)
                                                {
                                                    <MudText Typo="Typo.caption" Class="ml-1" Style="opacity: 0.7;">(primary)</MudText>
                                                }
                                            </MudChip>
                                            @if (!collection.IsPrimary && CanManageCollections())
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                               Size="Size.Small"
                                                               Color="Color.Error"
                                                               OnClick="@(() => RemoveFromCollectionAsync(collection))"
                                                               Title="Remove from collection" />
                                            }
                                        </MudStack>
                                    }
                                </MudStack>
                            }
                            else
                            {
                                <MudChip T="string" 
                                         Size="Size.Small" 
                                         Color="Color.Secondary"
                                         Icon="@Icons.Material.Filled.Folder"
                                         OnClick="@(() => Nav.NavigateTo($"/assets?collection={_asset.CollectionId}"))"
                                         Style="cursor: pointer;">
                                    @(_asset.CollectionName ?? "Unknown Collection")
                                </MudChip>
                            }
                        </MudStack>

                        <!-- Description -->
                        @if (!string.IsNullOrEmpty(_asset.Description))
                        {
                            <MudStack>
                                <MudText Typo="Typo.subtitle2">Description</MudText>
                                <MudText Typo="Typo.body2">@_asset.Description</MudText>
                            </MudStack>
                        }

                        <!-- File Info -->
                        <MudStack>
                            <MudText Typo="Typo.subtitle2">File Information</MudText>
                            <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                <tbody>
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">Size</MudText></td>
                                        <td><MudText Typo="Typo.body2">@FormatFileSize(_asset.SizeBytes)</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">Type</MudText></td>
                                        <td><MudText Typo="Typo.body2">@_asset.ContentType</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">Created</MudText></td>
                                        <td><MudText Typo="Typo.body2">@_asset.CreatedAt.ToLocalTime().ToString("g")</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Secondary">Updated</MudText></td>
                                        <td><MudText Typo="Typo.body2">@_asset.UpdatedAt.ToLocalTime().ToString("g")</MudText></td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(_asset.Sha256))
                                    {
                                        <tr>
                                            <td><MudText Typo="Typo.body2" Color="Color.Secondary">SHA256</MudText></td>
                                            <td>
                                                <MudTooltip Text="@_asset.Sha256">
                                                    <MudText Typo="Typo.body2" Style="max-width: 200px; overflow: hidden; text-overflow: ellipsis;">
                                                        @_asset.Sha256[..16]...
                                                    </MudText>
                                                </MudTooltip>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </MudStack>

                        <!-- Tags -->
                        @if (_asset.Tags.Any())
                        {
                            <MudStack>
                                <MudText Typo="Typo.subtitle2">Tags</MudText>
                                <MudChipSet T="string" ReadOnly="true">
                                    @foreach (var tag in _asset.Tags)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@tag</MudChip>
                                    }
                                </MudChipSet>
                            </MudStack>
                        }

                        <!-- Advanced Metadata (Expandable) -->
                        <MudDivider />
                        <MudStack>
                            <MudExpansionPanels Elevation="0" Style="margin: -16px; padding: 0;">
                                <MudExpansionPanel MaxHeight="400"
                                                   Style="background: transparent; padding: 0;"
                                                   Class="pa-0 ma-0">
                                    <TitleContent>
                                        <MudText Typo="Typo.subtitle2" Style="margin-left: -8px;">Advanced MetaData</MudText>
                                    </TitleContent>
                                    <ChildContent>
                                        @if (_asset.MetadataJson.Any())
                                        {
                                            <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                                                <tbody>
                                                    @foreach (var kvp in _asset.MetadataJson.OrderBy(k => k.Key))
                                                    {
                                                        <tr>
                                                            <td><MudText Typo="Typo.body2" Color="Color.Secondary">@FormatMetadataKey(kvp.Key)</MudText></td>
                                                            <td><MudText Typo="Typo.body2">@kvp.Value?.ToString()</MudText></td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </MudSimpleTable>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                No metadata available. Upload a new image with EXIF data to see metadata here.
                                            </MudText>
                                        }
                                    </ChildContent>
                                </MudExpansionPanel>
                            </MudExpansionPanels>
                        </MudStack>

                        <MudDivider />

                        <!-- Actions -->
                        <MudStack Spacing="2">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Download"
                                       FullWidth="true"
                                       Href="@GetDownloadUrl()"
                                       Target="_blank">
                                Download Original
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.Share"
                                       FullWidth="true"
                                       OnClick="ShareAssetAsync">
                                Share
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       FullWidth="true"
                                       OnClick="EditAssetAsync">
                                Edit Details
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       FullWidth="true"
                                       OnClick="DeleteAssetAsync">
                                Delete
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
}

@code {
    [Parameter]
    public Guid AssetId { get; set; }

    private AssetResponseDto? _asset;
    private List<AssetCollectionDto> _assetCollections = new();
    private bool _isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAssetAsync();
    }

    private async Task LoadAssetAsync()
    {
        try
        {
            _isLoading = true;
            _asset = await Api.GetAssetAsync(AssetId);
            await LoadAssetCollectionsAsync();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load asset");
            _asset = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadAssetCollectionsAsync()
    {
        try
        {
            _assetCollections = await Api.GetAssetCollectionsAsync(AssetId);
        }
        catch
        {
            // Silently fail - collections will show fallback to primary collection
            _assetCollections = new();
        }
    }

    private bool CanManageCollections()
    {
        // Contributors and above can manage collection membership
        if (_asset == null) return false;
        var role = _asset.UserRole?.ToLowerInvariant() ?? "viewer";
        return role is "contributor" or "manager" or "admin";
    }

    private async Task OpenAddToCollectionDialogAsync()
    {
        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Small, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var parameters = new DialogParameters<AddToCollectionDialog>
        {
            { x => x.AssetId, AssetId },
            { x => x.ExistingCollectionIds, _assetCollections.Select(c => c.Id).ToList() }
        };

        var dialog = await DialogService.ShowAsync<AddToCollectionDialog>("Add to Collection", parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled)
        {
            await LoadAssetCollectionsAsync();
            StateHasChanged();
            Feedback.ShowSuccess("Asset added to collection");
        }
    }

    private async Task RemoveFromCollectionAsync(AssetCollectionDto collection)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Remove from Collection",
            $"Remove this asset from '{collection.Name}'?",
            yesText: "Remove",
            cancelText: "Cancel");

        if (confirm != true) return;

        try
        {
            await Api.RemoveAssetFromCollectionAsync(AssetId, collection.Id);
            await LoadAssetCollectionsAsync();
            StateHasChanged();
            Feedback.ShowSuccess($"Removed from {collection.Name}");
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "remove from collection");
        }
    }

    private string GetPreviewUrl()
    {
        if (_asset == null) return "";

        // Use medium rendition for images, poster for videos
        if (_asset.AssetType == "image" && !string.IsNullOrEmpty(_asset.MediumObjectKey))
        {
            return $"/api/assets/{_asset.Id}/medium";
        }
        else if (_asset.AssetType == "video" && !string.IsNullOrEmpty(_asset.PosterObjectKey))
        {
            return $"/api/assets/{_asset.Id}/poster";
        }

        // Fallback to original
        return $"/api/assets/{_asset.Id}/download";
    }

    private string GetDownloadUrl()
    {
        return $"/api/assets/{AssetId}/download";
    }

    private string GetInlinePreviewUrl()
    {
        return $"/api/assets/{AssetId}/preview";
    }

    private bool IsPdfPreviewable()
    {
        return IsPdfContentType(_asset?.ContentType);
    }

    private static bool IsPdfContentType(string? contentType)
    {
        return string.Equals(contentType, "application/pdf", StringComparison.OrdinalIgnoreCase);
    }

    private string GetAssetIcon()
    {
        return _asset?.AssetType switch
        {
            "image" => Icons.Material.Filled.Image,
            "video" => Icons.Material.Filled.VideoFile,
            "document" => Icons.Material.Filled.Description,
            _ => Icons.Material.Filled.InsertDriveFile
        };
    }

    private Color GetAssetTypeColor()
    {
        return _asset?.AssetType switch
        {
            "image" => Color.Success,
            "video" => Color.Info,
            "document" => Color.Warning,
            _ => Color.Default
        };
    }

    private Color GetStatusColor()
    {
        return _asset?.Status switch
        {
            "ready" => Color.Success,
            "processing" => Color.Info,
            "failed" => Color.Error,
            _ => Color.Default
        };
    }

    private async Task ShareAssetAsync()
    {
        if (_asset == null) return;

        var createParams = new DialogParameters<CreateShareDialog>
        {
            { x => x.ScopeId, _asset.Id },
            { x => x.ScopeType, "asset" },
            { x => x.ContentName, _asset.Title }
        };

        var createResult = await DialogService.ShowAsync<CreateShareDialog>("Create Share Link", createParams);
        var result = await createResult.Result;

        if (result != null && !result.Canceled && result.Data is ShareResponse share)
        {
            var successParams = new DialogParameters<ShareLinkDialog>
            {
                { x => x.ShareUrl, share.ShareUrl },
                { x => x.Password, share.Password ?? "" },
                { x => x.ExpiresAt, share.ExpiresAt }
            };

            await DialogService.ShowAsync<ShareLinkDialog>("Share Link Created", successParams);
        }
    }

    private async Task EditAssetAsync()
    {
        if (_asset == null) return;

        var parameters = new DialogParameters<EditAssetDialog>
        {
            { x => x.Asset, _asset }
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Small, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<EditAssetDialog>("Edit Asset", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is AssetResponseDto updatedAsset)
        {
            _asset = updatedAsset;
            Feedback.ShowSuccess("Asset updated successfully");
            StateHasChanged();
        }
    }

    private async Task DeleteAssetAsync()
    {
        if (_asset == null) return;

        var result = await DialogService.ShowMessageBox(
            "Delete Asset",
            $"Are you sure you want to delete '{_asset.Title}'? This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            var collectionId = _asset.CollectionId;
            var success = await Feedback.ExecuteWithFeedbackAsync(
                () => Api.DeleteAssetAsync(_asset.Id),
                "delete asset",
                "Asset deleted successfully");
            
            if (success)
            {
                Nav.NavigateTo($"/assets?collection={collectionId}");
            }
        }
    }

    private void NavigateBackToAssets()
    {
        if (_asset != null)
        {
            Nav.NavigateTo($"/assets?collection={_asset.CollectionId}");
        }
        else
        {
            Nav.NavigateTo("/assets");
        }
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private string FormatMetadataKey(string key)
    {
        // Convert camelCase to Title Case with spaces
        var result = System.Text.RegularExpressions.Regex.Replace(key, "([a-z])([A-Z])", "$1 $2");
        return char.ToUpper(result[0]) + result[1..];
    }
}
