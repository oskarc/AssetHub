@using MudBlazor
@using AssetHub.Application
@using AssetHub.Application.Dtos
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<SharesResource> ShareLoc
@inject IStringLocalizer<AdminResource> AdminLoc
@inject NavigationManager Navigation
@inject AssetHubApiClient Api
@inject IDialogService DialogService
@inject IUserFeedbackService Feedback
@inject IClipboardService Clipboard

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Link" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@ShareLoc["ShareDetails"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @ShareLoc["ShareDetailsDesc"]
            </MudText>

            @if (Share.ScopeType == Constants.ScopeTypes.Asset && Share.CollectionNames.Count > 0)
            {
                <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">@AdminLoc["Label_MemberOfCollections"]</MudText>
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        @foreach (var name in Share.CollectionNames)
                        {
                            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Folder" Variant="Variant.Outlined">@name</MudChip>
                        }
                    </MudStack>
                </MudPaper>
            }

            <!-- Share Link Section -->
            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" Class="mr-1" />
                    @ShareLoc["ShareUrl"]
                </MudText>
                @if (_isLoading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (!string.IsNullOrEmpty(ShareUrl))
                {
                    <MudTextField @bind-Value="ShareUrl"
                                  Label="@ShareLoc["ShareUrl"]"
                                  ReadOnly="true"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                                  OnAdornmentClick="CopyUrl" />
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        @ShareLoc["ShareUrlNotAvailable"]
                    </MudAlert>
                }
            </MudPaper>

            <!-- Password Section -->
            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Class="mr-1" />
                    @CommonLoc["Label_Password"]
                </MudText>
                @if (!string.IsNullOrEmpty(_displayPassword))
                {
                    <MudTextField T="string" Value="@_displayPassword"
                                  Label="@ShareLoc["SharePassword"]"
                                  ReadOnly="true"
                                  Variant="Variant.Outlined"
                                  InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="TogglePasswordVisibility" />
                    <MudButton Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.ContentCopy"
                               OnClick="CopyPassword" Class="mt-1">
                        @CommonLoc["Btn_CopyPassword"]
                    </MudButton>
                }
                else if (Share.HasPassword)
                {
                    <MudTextField T="string" Value="@_passwordPlaceholder"
                                  Label="@ShareLoc["SharePassword"]"
                                  ReadOnly="true"
                                  Variant="Variant.Outlined"
                                  HelperText="@ShareLoc["PasswordSetButHidden"]" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@ShareLoc["NoPasswordSet"]</MudText>
                }
                <MudButton Variant="Variant.Text" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Key"
                           OnClick="OpenSetPassword" Class="mt-1">
                    @ShareLoc["SetOrChangePassword"]
                </MudButton>
            </MudPaper>

            <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                @ShareLoc["ShareInfoCopyHint"]
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@CommonLoc["Btn_Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.ContentCopy"
                   OnClick="CopyAll"
                   Disabled="@(string.IsNullOrEmpty(ShareUrl))">
            @CommonLoc["Btn_CopyAll"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public AdminShareDto Share { get; set; } = default!;
    [Parameter]
    public string ShareUrl { get; set; } = string.Empty;
    [Parameter]
    public string SharePassword { get; set; } = string.Empty;

    private bool _isLoading = true;
    private bool _showPassword = false;
    private const string _passwordPlaceholder = "********";
    private string _displayPassword = string.Empty;

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    protected override async Task OnInitializedAsync()
    {
        // Initialize local display password from parameter
        _displayPassword = SharePassword;

        try
        {
            var token = await Api.GetShareTokenAsync(Share.Id);
            if (!string.IsNullOrEmpty(token))
            {
                ShareUrl = $"{Navigation.BaseUri.TrimEnd('/')}/{Constants.Routes.Share}/{Uri.EscapeDataString(token)}";
            }

            // Also fetch the password if the share has one
            if (Share.HasPassword && string.IsNullOrEmpty(_displayPassword))
            {
                var password = await Api.GetSharePasswordAsync(Share.Id);
                if (!string.IsNullOrEmpty(password))
                {
                    _displayPassword = password;
                }
            }
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "retrieve share details");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task CopyUrl()
    {
        if (string.IsNullOrEmpty(ShareUrl)) return;
        if (await Clipboard.CopyTextAsync(ShareUrl))
        {
            Feedback.ShowSuccess(CommonLoc["Success_LinkCopied"].Value);
        }
        else
        {
            Feedback.ShowWarning(CommonLoc["Warning_CopyFailed"].Value);
        }
    }

    private async Task CopyPassword()
    {
        if (string.IsNullOrEmpty(_displayPassword)) return;
        if (await Clipboard.CopyTextAsync(_displayPassword))
        {
            Feedback.ShowSuccess(CommonLoc["Success_PasswordCopied"].Value);
        }
        else
        {
            Feedback.ShowWarning(CommonLoc["Warning_CopyFailed"].Value);
        }
    }

    private async Task CopyAll()
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(ShareUrl)) parts.Add(ShareUrl);
        if (!string.IsNullOrEmpty(_displayPassword)) parts.Add(_displayPassword);
        if (await Clipboard.CopyTextAsync(string.Join("\n", parts)))
        {
            Feedback.ShowSuccess(CommonLoc["Success_LinkAndPasswordCopied"].Value);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            Feedback.ShowWarning(CommonLoc["Warning_CopyFailed"].Value);
        }
    }

    private async Task OpenSetPassword()
    {
        var parameters = new DialogParameters<SharePasswordDialog>
        {
            { x => x.Share, Share },
            { x => x.InitialPassword, _displayPassword }
        };

        var dialog = await DialogService.ShowAsync<SharePasswordDialog>(AdminLoc["EditSharePassword"], parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is string pwd && !string.IsNullOrEmpty(pwd))
        {
            _displayPassword = pwd;
            Share = Share with { HasPassword = true };
            StateHasChanged();
        }
    }
}
