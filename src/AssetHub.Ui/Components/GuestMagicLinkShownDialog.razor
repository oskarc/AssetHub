@using AssetHub.Ui.Resources
@using AssetHub.Ui.Services
@using MudBlazor
@using Microsoft.JSInterop

@inject IJSRuntime JS
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<GuestsResource> Loc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.Link" Color="Color.Primary" />
            <MudText Typo="Typo.h6" id="guest-magic-link-title">@Loc["MagicLink_Title"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 480px;">
            <MudAlert Severity="Severity.Info" Dense="true">
                @Loc["MagicLink_Desc"]
            </MudAlert>
            <MudPaper Elevation="0" Outlined="true" Class="pa-3" Style="background: var(--mud-palette-background-grey);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.body2"
                             Style="font-family: 'Courier New', monospace; word-break: break-all; flex: 1;">
                        @MagicLinkUrl
                    </MudText>
                    <MudIconButton Size="Size.Small"
                                   Icon="@Icons.Material.Outlined.ContentCopy"
                                   OnClick="CopyAsync"
                                   aria-label="@Loc["MagicLink_CopyAck"]" />
                </MudStack>
            </MudPaper>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">
            @Loc["MagicLink_Close"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter, EditorRequired] public string MagicLinkUrl { get; set; } = string.Empty;

    private async Task CopyAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", MagicLinkUrl);
            Feedback.ShowSuccess(Loc["MagicLink_CopyAck"].Value);
        }
        catch
        {
            // clipboard.writeText is silently blocked in some browser/iframe
            // contexts; the URL is still visible in the dialog.
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
