@using AssetHub.Application.Helpers

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<CollectionsResource> CollLoc

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="dialog-title">
            <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@CollLoc["ManageAccess"]</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="dialog-min-width">
            <MudText Typo="Typo.body2" Class="dialog-intro">
                @CollLoc["ManageAccessDesc"]
            </MudText>

            <!-- Collection Info Header -->
            <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1"><strong>@CollectionName</strong></MudText>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@CollLoc["YourRole"]:</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetRoleColor(CurrentUserRole)">
                                @CommonLoc[AssetDisplayHelpers.GetRoleKey(CurrentUserRole)]
                            </MudChip>
                        </MudStack>
                    </MudStack>
                </MudStack>
            </MudPaper>

            @* Parent panel — admin-only, only when this collection actually has a parent.
               Reparenting itself is API-only in v1; the GUI surface here is the inheritance
               toggle + the snapshot-copy button (T5-NEST-01). *@
            @if (_isAdmin && _parentId is not null)
            {
                <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                    <div class="dialog-section-title">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Primary" />
                            <span>@CollLoc["Parent_Header"]: @(_parentName ?? "…")</span>
                        </MudStack>
                    </div>
                    <MudStack Spacing="2">
                        <MudSwitch T="bool"
                                   Value="_inheritParentAcl"
                                   ValueChanged="OnToggleInheritAsync"
                                   Color="Color.Primary"
                                   Label="@CollLoc["Parent_Inherit_Toggle"]"
                                   Disabled="_isInheritToggling" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @CollLoc["Parent_Inherit_HelperText"]
                        </MudText>
                        <MudDivider />
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.ContentCopy"
                                       OnClick="CopyParentAclAsync"
                                       Disabled="_isCopyingAcl">
                                @CollLoc["Parent_CopyAcl_Button"]
                            </MudButton>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @CollLoc["Parent_CopyAcl_HelperText"]
                            </MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }

            <!-- Add User Section -->
            <MudPaper Class="pa-3 dialog-section" Elevation="0" Outlined="true">
                <div class="dialog-section-title">
                    @CollLoc["AddUserAccess"]
                </div>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                    <MudAutocomplete T="UserSearchResultDto"
                                     @bind-Value="_selectedUser"
                                     SearchFunc="SearchUsersAsync"
                                     ToStringFunc="@(u => u?.Username ?? "")"
                                     Label="@CollLoc["SearchUser"]"
                                     Variant="Variant.Outlined"
                                     AutoFocus="true"
                                     Dense="true"
                                     ResetValueOnEmptyText="true"
                                     DebounceInterval="300"
                                     MinCharacters="0"
                                     MaxItems="20"
                                     Class="dialog-flex-fill">
                        <ItemTemplate Context="user">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2">@user.Username</MudText>
                                @if (!string.IsNullOrEmpty(user.Email))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@user.Email</MudText>
                                }
                            </MudStack>
                        </ItemTemplate>
                    </MudAutocomplete>
                    <MudSelect T="string"
                               @bind-Value="_selectedRole"
                               Label="@CommonLoc["Label_Role"]"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Class="dialog-role-select-wide">
                        <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Viewer">@CommonLoc["Role_Viewer"]</MudSelectItem>
                        <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Contributor">@CommonLoc["Role_Contributor"]</MudSelectItem>
                        @if (RoleHierarchy.GetLevel(CurrentUserRole) >= RoleHierarchy.GetLevel(RoleHierarchy.Roles.Manager))
                        {
                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Manager">@CommonLoc["Role_Manager"]</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               OnClick="GrantAccessAsync"
                               Disabled="@(_selectedUser == null || _isGranting)">
                        @CommonLoc["Btn_Add"]
                    </MudButton>
                </MudStack>
            </MudPaper>

            <!-- Current Access List -->
            <MudText Typo="Typo.subtitle2" Class="mt-2">
                @CollLoc["CurrentAccess"] (@_aclEntries.Count)
            </MudText>

            @if (_isLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else if (_aclEntries.Count == 0)
            {
                <EmptyState Title="@CollLoc["NoAccessEntries"]"
                            Description="@CollLoc["NoAccessEntriesDesc"]"
                            Icon="@Icons.Material.Filled.LockOpen"
                            Class="py-4" />
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true" Striped="true" Elevation="0"
                                Class="table-outlined">
                    <thead>
                        <tr>
                            <th>@CollLoc["User"]</th>
                            <th>@CommonLoc["Label_Role"]</th>
                            <th class="dialog-actions-col">@CommonLoc["Label_Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in _aclEntries.OrderBy(e => e.PrincipalName ?? e.PrincipalId, new NaturalSortComparer()))
                        {
                            <tr>
                                <td>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2">@(entry.PrincipalName ?? entry.PrincipalId)</MudText>
                                        @if (!string.IsNullOrEmpty(entry.PrincipalEmail))
                                        {
                                            <MudText Typo="Typo.caption" Class="text-secondary">@entry.PrincipalEmail</MudText>
                                        }
                                    </MudStack>
                                </td>
                                <td>
                                    @if (_editingEntryId == entry.Id)
                                    {
                                        <MudSelect T="string"
                                                   @bind-Value="_editingRole"
                                                   Variant="Variant.Outlined"
                                                   Dense="true"
                                                   Margin="Margin.Dense"
                                                   Class="dialog-role-select">
                                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Viewer">@CommonLoc["Role_Viewer"]</MudSelectItem>
                                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Contributor">@CommonLoc["Role_Contributor"]</MudSelectItem>
                                            @if (RoleHierarchy.GetLevel(CurrentUserRole) >= RoleHierarchy.GetLevel(RoleHierarchy.Roles.Manager))
                                            {
                                                <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Manager">@CommonLoc["Role_Manager"]</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@AssetDisplayHelpers.GetRoleColor(entry.Role)"
                                                 Variant="Variant.Outlined">
                                            @CommonLoc[AssetDisplayHelpers.GetRoleKey(entry.Role)]
                                        </MudChip>
                                    }
                                </td>
                                <td>
                                    @if (_editingEntryId == entry.Id)
                                    {
                                        <MudStack Row="true" Spacing="1">
                                            <MudTooltip Text="@CommonLoc["Btn_Save"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Save"
                                                               Size="Size.Small"
                                                               Color="Color.Success"
                                                               OnClick="SaveRoleEditAsync" />
                                            </MudTooltip>
                                            <MudTooltip Text="@CommonLoc["Btn_Cancel"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                                               Size="Size.Small"
                                                               Color="Color.Default"
                                                               OnClick="CancelRoleEdit" />
                                            </MudTooltip>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudStack Row="true" Spacing="1">
                                            @if (CanEditEntry(entry))
                                            {
                                                <MudTooltip Text="@CollLoc["ChangeRole"]">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                                   Size="Size.Small"
                                                                   Color="Color.Primary"
                                                                   OnClick="@(() => StartRoleEdit(entry))"
                                                                   Disabled="@(_revokingIds.Count > 0)" />
                                                </MudTooltip>
                                                <MudTooltip Text="@CollLoc["RevokeAccess"]">
                                                    <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                                                   Size="Size.Small"
                                                                   Color="Color.Error"
                                                                   OnClick="@(() => RevokeAccessAsync(entry))"
                                                                   Disabled="@(_revokingIds.Contains(entry.Id))" />
                                                </MudTooltip>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Class="text-secondary">
                                                    @CollLoc["InsufficientLevel"]
                                                </MudText>
                                            }
                                        </MudStack>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">@CommonLoc["Btn_Close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    [Parameter] public Guid CollectionId { get; set; }
    [Parameter] public string CollectionName { get; set; } = "";
    [Parameter] public string CurrentUserRole { get; set; } = "";

    private List<CollectionAclResponseDto> _aclEntries = new();
    private bool _isLoading = true;
    private bool _isGranting;

    // Add user
    private UserSearchResultDto? _selectedUser;
    private string _selectedRole = RoleHierarchy.Roles.Viewer;

    // Edit role
    private Guid? _editingEntryId;
    private string _editingRole = "";
    private string _editingPrincipalId = "";

    // Revoke tracking
    private readonly HashSet<Guid> _revokingIds = new();

    // Nested collections (T5-NEST-01) — populated when this collection has a parent.
    private bool _isAdmin;
    private Guid? _parentId;
    private string? _parentName;
    private bool _inheritParentAcl;
    private bool _isInheritToggling;
    private bool _isCopyingAcl;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is not null)
        {
            var state = await AuthStateTask;
            _isAdmin = state.User.IsInRole("admin");
        }

        await LoadCollectionMetaAsync();
        await LoadAclsAsync();
    }

    private async Task LoadCollectionMetaAsync()
    {
        try
        {
            var collection = await Api.GetCollectionAsync(CollectionId);
            if (collection is null) return;
            _parentId = collection.ParentCollectionId;
            _inheritParentAcl = collection.InheritParentAcl;
            if (_parentId is { } pid)
            {
                var parent = await Api.GetCollectionAsync(pid);
                _parentName = parent?.Name;
            }
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collection metadata");
        }
    }

    private async Task OnToggleInheritAsync(bool newValue)
    {
        if (_isInheritToggling) return;
        _isInheritToggling = true;
        StateHasChanged();

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.SetCollectionInheritParentAclAsync(CollectionId, newValue),
            "toggle inheritance",
            newValue ? CollLoc["Parent_Inherit_Enabled"] : CollLoc["Parent_Inherit_Disabled"]);

        if (success)
        {
            _inheritParentAcl = newValue;
            await LoadAclsAsync();
        }

        _isInheritToggling = false;
        StateHasChanged();
    }

    private async Task CopyParentAclAsync()
    {
        if (_parentId is null || _isCopyingAcl) return;

        var confirmed = await DialogService.ShowConfirmAsync(
            CollLoc["Parent_CopyAcl_Button"],
            string.Format(CollLoc["Parent_CopyAcl_Confirm"], _parentName ?? CollLoc["Parent_Header"]),
            CollLoc["Parent_CopyAcl_Button"],
            Icons.Material.Filled.ContentCopy,
            Color.Info,
            Color.Primary);
        if (!confirmed) return;

        _isCopyingAcl = true;
        StateHasChanged();

        try
        {
            var added = await Api.CopyCollectionAclFromParentAsync(CollectionId);
            if (added > 0)
            {
                Feedback.ShowSuccess(string.Format(CollLoc["Parent_CopyAcl_Success"], added));
                await LoadAclsAsync();
            }
            else
            {
                Feedback.ShowInfo(CollLoc["Parent_CopyAcl_NoneToAdd"]);
            }
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "copy parent ACL");
        }
        finally
        {
            _isCopyingAcl = false;
            StateHasChanged();
        }
    }

    private async Task LoadAclsAsync()
    {
        _isLoading = true;
        try
        {
            _aclEntries = await Api.GetCollectionAclsAsync(CollectionId);
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load access list");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<IEnumerable<UserSearchResultDto>> SearchUsersAsync(string? value, CancellationToken ct)
    {
        try
        {
            return await Api.SearchUsersForAclAsync(CollectionId, value ?? string.Empty, ct);
        }
        catch
        {
            return Enumerable.Empty<UserSearchResultDto>();
        }
    }

    private async Task GrantAccessAsync()
    {
        if (_selectedUser == null) return;

        _isGranting = true;
        StateHasChanged();

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.SetCollectionAccessAsync(CollectionId, Constants.PrincipalTypes.User, _selectedUser.Id, _selectedRole),
            "grant access",
            string.Format(CollLoc["AccessGrantedSuccess"], _selectedUser.Username, _selectedRole));

        if (success)
        {
            _selectedUser = null;
            _selectedRole = RoleHierarchy.Roles.Viewer;
            await LoadAclsAsync();
        }

        _isGranting = false;
        StateHasChanged();
    }

    private bool CanEditEntry(CollectionAclResponseDto entry)
    {
        // System admins have implicit access — cannot edit/revoke
        if (entry.IsSystemAdmin) return false;
        // Can only edit/revoke entries with roles at or below the current user's level
        return RoleHierarchy.HasSufficientLevel(CurrentUserRole, entry.Role);
    }

    private void StartRoleEdit(CollectionAclResponseDto entry)
    {
        _editingEntryId = entry.Id;
        _editingRole = entry.Role;
        _editingPrincipalId = entry.PrincipalId;
    }

    private async Task SaveRoleEditAsync()
    {
        if (_editingEntryId == null) return;

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.SetCollectionAccessAsync(CollectionId, Constants.PrincipalTypes.User, _editingPrincipalId, _editingRole),
            "update role",
            CollLoc["RoleUpdatedSuccess"]);

        if (success)
        {
            _editingEntryId = null;
            _editingRole = "";
            _editingPrincipalId = "";
            await LoadAclsAsync();
        }
    }

    private void CancelRoleEdit()
    {
        _editingEntryId = null;
        _editingRole = "";
        _editingPrincipalId = "";
    }

    private async Task RevokeAccessAsync(CollectionAclResponseDto entry)
    {
        var confirmed = await DialogService.ShowConfirmAsync(
            CommonLoc["Confirm_Revoke"],
            string.Format(CollLoc["ConfirmRevokeAccess"], entry.PrincipalName ?? entry.PrincipalId),
            CommonLoc["Btn_Revoke"],
            Icons.Material.Filled.PersonRemove,
            Color.Warning,
            Color.Error);

        if (!confirmed)
            return;

        _revokingIds.Add(entry.Id);
        StateHasChanged();

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.RevokeCollectionAccessAsync(CollectionId, entry.PrincipalType, entry.PrincipalId),
            "revoke access",
            string.Format(CollLoc["AccessRevokedSuccess"], entry.PrincipalName ?? entry.PrincipalId));

        if (success)
            await LoadAclsAsync();

        _revokingIds.Remove(entry.Id);
        StateHasChanged();
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
