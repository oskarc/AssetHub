{
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  },
  "Keycloak": {
    "RequireHttpsMetadata": false,
    "TimeoutSeconds": 30
  },
  "MinIO": {
    "UseSSL": false,
    "PublicUseSSL": false
  },
  "Email": {
    "SmtpHost": "mailpit",
    "SmtpPort": 1025,
    "FromAddress": "noreply@assethub.local",
    "FromName": "AssetHub (Dev)",
    "Enabled": true
  },
  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "http://aspire-dashboard:18889",
    "SamplingRatio": 1.0
  },
  "ClamAV": {
    "Enabled": false
  },
  "Database": {
    "AutoMigrate": true
  },
  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false"
  }
}
