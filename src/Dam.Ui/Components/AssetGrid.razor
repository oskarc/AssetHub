@using Dam.Application.Dtos
@using Dam.Ui.Services

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AssetsResource> AssetLoc

@if (_isLoading)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">Loading assets...</MudText>
    </MudStack>
}
else if (_assets.Count == 0)
{
    <EmptyState Title="@AssetLoc["NoAssetsYet"]"
                Description="@AssetLoc["NoAssetsGridHint"]"
                Icon="@Icons.Material.Filled.PhotoLibrary" />
}
else
{
    @if (ViewMode == "grid")
    {
    <MudGrid Spacing="3">
        @foreach (var asset in _assets)
        {
            <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                <MudCard Class="asset-card" Elevation="2">
                    <div @onclick="() => ViewAsset(asset.Id)" class="clickable">
                        <MudCardMedia Image="@AssetDisplayHelpers.GetThumbnailUrl(asset.Id, asset.ThumbObjectKey, asset.AssetType)" 
                                      Height="160" 
                                      Class="asset-thumbnail" />
                        <MudCardContent Class="pa-2">
                            <MudText Typo="Typo.body2" Class="text-truncate">
                                @asset.Title
                            </MudText>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudChip T="string" 
                                         Size="Size.Small" 
                                         Color="@AssetDisplayHelpers.GetAssetTypeColor(asset.AssetType)"
                                         Variant="Variant.Outlined">
                                    @asset.AssetType
                                </MudChip>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @AssetDisplayHelpers.FormatFileSize(asset.SizeBytes)
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </div>
                    <MudCardActions Class="pa-2 pt-0">
                        @if (CanShare)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Share" 
                                           Size="Size.Small" 
                                           OnClick="@(async () => await ShareAsset(asset))" />
                        }
                        <MudSpacer />
                        @if (CanDelete)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                           Size="Size.Small" 
                                           Color="Color.Error"
                                           OnClick="@(async () => await DeleteAsset(asset))" />
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
    }
    else
    {
        <MudTable Items="@_assets" Hover="true" Dense="true" Elevation="2" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh></MudTh>
                <MudTh>@AssetLoc["Column_Title"]</MudTh>
                <MudTh>@CommonLoc["Label_Type"]</MudTh>
                <MudTh>@AssetLoc["Column_Size"]</MudTh>
                <MudTh>@AssetLoc["Column_Created"]</MudTh>
                <MudTh Class="col-text-right">@AssetLoc["Column_Actions"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="" Class="col-icon">
                    <MudAvatar Rounded="true" Size="Size.Medium" Class="clickable" @onclick="() => ViewAsset(context.Id)">
                        <MudImage Src="@AssetDisplayHelpers.GetThumbnailUrl(context.Id, context.ThumbObjectKey, context.AssetType)" 
                                  Alt="@context.Title"
                                  ObjectFit="ObjectFit.Cover"
                                  Width="40" Height="40" />
                    </MudAvatar>
                </MudTd>
                <MudTd DataLabel="@AssetLoc["Column_Title"]">
                    <MudLink OnClick="@(() => ViewAsset(context.Id))" Underline="Underline.Hover">
                        @context.Title
                    </MudLink>
                </MudTd>
                <MudTd DataLabel="@CommonLoc["Label_Type"]">
                    <MudChip T="string" Size="Size.Small"
                             Color="@AssetDisplayHelpers.GetAssetTypeColor(context.AssetType)"
                             Variant="Variant.Outlined">
                        @context.AssetType
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="@AssetLoc["Column_Size"]">
                    @AssetDisplayHelpers.FormatFileSize(context.SizeBytes)
                </MudTd>
                <MudTd DataLabel="@AssetLoc["Column_Created"]">
                    @context.CreatedAt.ToString("yyyy-MM-dd")
                </MudTd>
                <MudTd DataLabel="@AssetLoc["Column_Actions"]" Class="col-text-right">
                    @if (CanShare)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Share"
                                       Size="Size.Small"
                                       OnClick="@(async () => await ShareAsset(context))" />
                    }
                    @if (CanDelete)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(async () => await DeleteAsset(context))" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    @if (_total > _assets.Count)
    {
        <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
            <MudButton Variant="Variant.Outlined" OnClick="LoadMoreAsync">
                @CommonLoc["Btn_LoadMore"] (@(_total - _assets.Count) remaining)
            </MudButton>
        </MudStack>
    }
}

@code {
    [Parameter]
    public Guid? CollectionId { get; set; }

    [Parameter]
    public string? SearchQuery { get; set; }

    [Parameter]
    public string? FilterType { get; set; }

    [Parameter]
    public string SortBy { get; set; } = "created_desc";

    /// <summary>
    /// Display mode: "grid" for card view, "list" for table view.
    /// </summary>
    [Parameter]
    public string ViewMode { get; set; } = "grid";
    
    /// <summary>
    /// The user's role in the current collection. Used to show/hide action buttons.
    /// Valid values: "viewer", "contributor", "manager", "admin"
    /// </summary>
    [Parameter]
    public string UserRole { get; set; } = "viewer";

    [Parameter]
    public EventCallback<AssetResponseDto> OnAssetSelected { get; set; }

    [Parameter]
    public EventCallback OnAssetsChanged { get; set; }
    
    // Role-based UI visibility using centralized permissions
    private bool CanShare => RolePermissions.CanShare(UserRole);
    private bool CanDelete => RolePermissions.CanDelete(UserRole);

    private List<AssetResponseDto> _assets = new();
    private int _total = 0;
    private int _skip = 0;
    private const int _take = 24;
    private bool _isLoading = true;
    private Guid? _loadedCollectionId;
    private string? _loadedFilterType;
    private string _loadedSortBy = "";
    private string _loadedSearchQuery = "";

    protected override async Task OnParametersSetAsync()
    {
        if (CollectionId.HasValue)
        {
            var collectionChanged = _loadedCollectionId != CollectionId.Value;
            var filterChanged = _loadedFilterType != FilterType
                             || _loadedSortBy != SortBy
                             || _loadedSearchQuery != (SearchQuery ?? "");

            if (collectionChanged || filterChanged)
            {
                _loadedCollectionId = CollectionId.Value;
                _loadedFilterType = FilterType;
                _loadedSortBy = SortBy;
                _loadedSearchQuery = SearchQuery ?? "";
                _skip = 0;
                _assets.Clear();
                await LoadAssetsAsync();
            }
        }
        else
        {
            _loadedCollectionId = null;
            _assets.Clear();
            _total = 0;
            _isLoading = false;
        }
    }

    private async Task LoadAssetsAsync()
    {
        if (!CollectionId.HasValue) return;

        try
        {
            _isLoading = true;
            var response = await Api.GetAssetsAsync(
                CollectionId.Value,
                SearchQuery,
                FilterType,
                SortBy,
                _skip,
                _take);
            _assets.AddRange(response.Items);
            _total = response.Total;
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load assets");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMoreAsync()
    {
        _skip = _assets.Count;
        await LoadAssetsAsync();
    }

    public async Task RefreshAsync()
    {
        _skip = 0;
        _assets.Clear();
        await LoadAssetsAsync();
    }

    private void ViewAsset(Guid id)
    {
        if (CollectionId.HasValue)
        {
            Nav.NavigateTo($"/assets/{id}?returnUrl=/collections%3Fcollection%3D{CollectionId.Value}");
        }
        else
        {
            Nav.NavigateTo($"/assets/{id}");
        }
    }

    private async Task ShareAsset(AssetResponseDto asset)
    {
        var createParams = new DialogParameters<CreateShareDialog>
        {
            { x => x.ScopeId, asset.Id },
            { x => x.ScopeType, "asset" },
            { x => x.ContentName, asset.Title }
        };

        var createResult = await DialogService.ShowAsync<CreateShareDialog>(AssetLoc["CreateShareLink"], createParams);
        var result = await createResult.Result;

        if (result != null && !result.Canceled && result.Data is ShareResponseDto share)
        {
            var successParams = new DialogParameters<ShareLinkDialog>
            {
                { x => x.ShareUrl, share.ShareUrl },
                { x => x.Password, share.Password ?? "" },
                { x => x.ExpiresAt, share.ExpiresAt }
            };

            await DialogService.ShowAsync<ShareLinkDialog>(AssetLoc["ShareLinkCreated"], successParams);
            await OnAssetsChanged.InvokeAsync();
        }
    }

    private async Task DeleteAsset(AssetResponseDto asset)
    {
        var parameters = new DialogParameters<DeleteAssetDialog>
        {
            { x => x.AssetId, asset.Id },
            { x => x.AssetTitle, asset.Title },
            { x => x.FromCollectionId, CollectionId }
        };

        var dialog = await DialogService.ShowAsync<DeleteAssetDialog>(null, parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is string action)
        {
            bool success;
            if (action == DeleteAssetDialog.ActionRemove && CollectionId.HasValue)
            {
                success = await Feedback.ExecuteWithFeedbackAsync(
                    () => Api.DeleteAssetAsync(asset.Id, CollectionId),
                    "remove asset from collection",
                    AssetLoc["AssetRemovedSuccess"]);
            }
            else
            {
                success = await Feedback.ExecuteWithFeedbackAsync(
                    () => Api.DeleteAssetAsync(asset.Id),
                    "delete asset",
                    AssetLoc["AssetDeletedSuccess"]);
            }

            if (success)
            {
                _assets.Remove(asset);
                _total--;
                await OnAssetsChanged.InvokeAsync();
            }
        }
    }
}
