@inject IStringLocalizer<CollectionsResource> CollectionLoc
@inject IStringLocalizer<CommonResource> CommonLoc

<MudPaper Class="pa-4 mb-3" Elevation="0" Outlined="true">
    <div class="d-flex justify-space-between align-start">
        <div class="flex-1-min-0">
            @if (!string.IsNullOrWhiteSpace(Collection.Description))
            {
                <MudText Typo="Typo.subtitle2" Class="mb-1">@CollectionLoc["Description"]:</MudText>
                <MudText Typo="Typo.body2" Class="mb-3" Color="Color.Secondary">@Collection.Description</MudText>
            }
            <div class="d-flex align-center gap-2 flex-wrap">
                <MudText Typo="Typo.subtitle2">@CollectionLoc["YourRole"]:</MudText>
                <MudTooltip Text="@GetRoleDescription(Collection.UserRole)">
                    <MudChip T="string" Size="Size.Small"
                             Color="@AssetDisplayHelpers.GetRoleColor(Collection.UserRole)">
                        @CommonLoc[AssetDisplayHelpers.GetRoleKey(Collection.UserRole)]
                    </MudChip>
                </MudTooltip>
            </div>
        </div>
        <div class="d-flex gap-2 ml-3">
            @if (RolePermissions.CanEditCollection(CurrentUserRole))
            {
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Edit"
                           OnClick="@(() => OnEdit.InvokeAsync(Collection))">
                    @CollectionLoc["EditCollection"]
                </MudButton>
            }
            @if (RolePermissions.CanDelete(CurrentUserRole))
            {
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete"
                           OnClick="@(() => OnDelete.InvokeAsync(Collection))">
                    @CollectionLoc["DeleteCollection"]
                </MudButton>
            }
        </div>
    </div>
</MudPaper>

@code {
    [Parameter, EditorRequired] public CollectionResponseDto Collection { get; set; } = default!;
    [Parameter, EditorRequired] public string CurrentUserRole { get; set; } = "";
    [Parameter] public EventCallback<CollectionResponseDto> OnEdit { get; set; }
    [Parameter] public EventCallback<CollectionResponseDto> OnDelete { get; set; }

    private string GetRoleDescription(string? role) => role?.ToLowerInvariant() switch
    {
        RoleHierarchy.Roles.Viewer => CollectionLoc["RoleDesc_Viewer"],
        RoleHierarchy.Roles.Contributor => CollectionLoc["RoleDesc_Contributor"],
        RoleHierarchy.Roles.Manager => CollectionLoc["RoleDesc_Manager"],
        RoleHierarchy.Roles.Admin => CollectionLoc["RoleDesc_Admin"],
        _ => ""
    };
}
