@using AssetHub.Ui.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.JSInterop

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IDialogService DialogService

@implements IAsyncDisposable

<div class="@_uploadAreaClass"
     @ondragenter="OnDragEnter"
     @ondragenter:preventDefault
     @ondragleave="OnDragLeave"
     @ondragover:preventDefault
     @ondrop="OnDrop"
     @ondrop:preventDefault>

    <InputFile @ref="_inputFile"
               id="fileInput"
               OnChange="OnFilesSelected"
               hidden
               multiple
               accept="image/*,video/*,audio/*,.pdf,.zip,.docx,.xlsx,.pptx,.doc,.xls,.ppt,.txt,.csv,.json,.xml,.svg,.woff,.woff2,.ttf,.otf,.glb,.gltf" />

    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-4">
        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" 
                 Size="Size.Large" 
                 Color="Color.Primary" />
        <MudText Typo="Typo.body1">
            @CommonLoc["Text_DragDropFiles"]
        </MudText>
        <MudButton HtmlTag="label"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.AttachFile"
                   for="fileInput"
                   Disabled="@((RequireCollection && !CollectionId.HasValue) || _isUploading)">
            @CommonLoc["Btn_BrowseFiles"]
        </MudButton>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            @CommonLoc["Text_SupportedFormats"]
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            @string.Format(CommonLoc["Text_MaxFilesHint"].Value, Constants.Limits.MaxFilesPerUpload)
        </MudText>
    </MudStack>
</div>

@if (_showReport)
{
    var succeeded = _uploads.Count(u => u.Status == UploadStatus.Completed);
    var failed = _uploads.Count(u => u.Status == UploadStatus.Failed);
    var total = succeeded + failed;
    var allSuccess = failed == 0;

    <MudPaper Class="pa-3 mt-3" Elevation="0" Outlined="true">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
            <MudText Typo="Typo.subtitle2">@CommonLoc["Text_UploadReport"]</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small"
                           OnClick="DismissReport"
                           aria-label="@CommonLoc["Btn_Close"]" />
        </MudStack>

        <MudStack Row="true" Spacing="4" Class="mb-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" Color="Color.Default" />
                <MudText Typo="Typo.body2">@string.Format(CommonLoc["Text_ReportTotal"].Value, total)</MudText>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                <MudText Typo="Typo.body2" Color="Color.Success">@string.Format(CommonLoc["Text_ReportSucceeded"].Value, succeeded)</MudText>
            </MudStack>
            @if (failed > 0)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Small" Color="Color.Error" />
                    <MudText Typo="Typo.body2" Color="Color.Error">@string.Format(CommonLoc["Text_ReportFailed"].Value, failed)</MudText>
                </MudStack>
            }
        </MudStack>

        <MudDivider Class="mb-2" />

        <MudStack Spacing="1">
            @foreach (var upload in _uploads)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    @if (upload.Status == UploadStatus.Completed)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    }
                    else
                    {
                        <MudTooltip Text="@upload.ErrorMessage">
                            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                        </MudTooltip>
                    }
                    <MudIcon Icon="@AssetDisplayHelpers.GetContentTypeIcon(upload.ContentType)"
                             Size="Size.Small"
                             Color="Color.Default" />
                    <MudText Typo="Typo.body2" Class="flex-grow-1">
                        @upload.FileName
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @AssetDisplayHelpers.FormatFileSize(upload.Size)
                    </MudText>
                    @if (upload.Status == UploadStatus.Failed)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Error">
                            @upload.ErrorMessage
                        </MudText>
                    }
                </MudStack>
            }
        </MudStack>
    </MudPaper>
}
else if (_uploads.Any())
{
    <MudPaper Class="pa-3 mt-3" Elevation="0" Outlined="true">
        <MudText Typo="Typo.subtitle2" Class="mb-2">@CommonLoc["Text_Uploads"]</MudText>
        <MudStack Spacing="2">
            @foreach (var upload in _uploads)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@AssetDisplayHelpers.GetContentTypeIcon(upload.ContentType)"
                             Size="Size.Small"
                             Color="@GetStatusColor(upload.Status)" />
                    <MudText Typo="Typo.body2" Class="flex-grow-1">
                        @upload.FileName
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @AssetDisplayHelpers.FormatFileSize(upload.Size)
                    </MudText>
                    @if (upload.Status == UploadStatus.Uploading)
                    {
                        <MudProgressLinear Value="@upload.ProgressPercent"
                                           Min="0" Max="100"
                                           Color="Color.Primary"
                                           Class="upload-progress" />
                        <MudText Typo="Typo.caption">@upload.ProgressPercent%</MudText>
                    }
                    else if (upload.Status == UploadStatus.Scanning)
                    {
                        <MudProgressLinear Indeterminate="true"
                                           Color="Color.Warning"
                                           Class="upload-progress" />
                        <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" Color="Color.Warning" />
                        <MudText Typo="Typo.caption" Color="Color.Warning">@CommonLoc["Text_ScanningForThreats"]</MudText>
                    }
                    else if (upload.Status == UploadStatus.Processing)
                    {
                        <MudProgressLinear Indeterminate="true"
                                           Color="Color.Info"
                                           Class="upload-progress" />
                        <MudText Typo="Typo.caption" Color="Color.Info">@CommonLoc["Text_Processing"]</MudText>
                    }
                    else if (upload.Status == UploadStatus.Completed)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    }
                    else if (upload.Status == UploadStatus.Failed)
                    {
                        <MudTooltip Text="@upload.ErrorMessage">
                            <MudIconButton Icon="@Icons.Material.Filled.Error"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           aria-label="@string.Format(CommonLoc["Aria_ShowUploadError"].Value, upload.FileName)"
                                           OnClick="ShowUploadErrorsDialog" />
                        </MudTooltip>
                    }
                    else if (upload.Status == UploadStatus.Queued)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@CommonLoc["Text_Queued"]</MudChip>
                    }
                </MudStack>
            }
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter]
    public Guid? CollectionId { get; set; }

    /// <summary>
    /// When true (default), the browse button is disabled if no CollectionId is set.
    /// Set to false to allow uploads without a target collection (e.g., admin uploads).
    /// </summary>
    [Parameter]
    public bool RequireCollection { get; set; } = true;

    [Parameter]
    public EventCallback OnUploadComplete { get; set; }

    private InputFile? _inputFile;
    private IJSObjectReference? _jsModule;
    private List<UploadItem> _uploads = new();
    private bool _isUploading = false;
    private int _activeProcessingCount = 0;
    private bool _isDragOver = false;
    private bool _showReport = false;
    private IDisposable? _locationChangingRegistration;
    private bool _navigationConfirmed;
    private CancellationTokenSource _cts = new();

    private int _dragCounter = 0;
    private string _uploadAreaClass => $"pa-4 upload-area {(_isDragOver ? "drag-over" : "")}";

    private void OnDragEnter()
    {
        _dragCounter++;
        _isDragOver = true;
    }

    private void OnDragLeave()
    {
        _dragCounter--;
        if (_dragCounter <= 0)
        {
            _dragCounter = 0;
            _isDragOver = false;
        }
    }

    private void OnDrop()
    {
        _dragCounter = 0;
        _isDragOver = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AssetHub.Ui/js/fileUpload.js");
            _locationChangingRegistration = Nav.RegisterLocationChangingHandler(OnLocationChanging);
        }
    }

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        if (_jsModule == null || _inputFile?.Element == null)
        {
            Feedback.ShowError(CommonLoc["Error_UploadModuleNotInit"].Value);
            return;
        }

        _isUploading = true;
        _showReport = false;
        _uploads.Clear();
        await EnableBeforeUnloadAsync();
        var files = e.GetMultipleFiles(Constants.Limits.MaxFilesPerUpload);

        // Get file metadata from JS (no file data sent over SignalR)
        var fileMetadata = await _jsModule.InvokeAsync<FileMetadata[]>(
            "getFileMetadata", _inputFile.Element);

        // --- Client-side validation: reject disallowed types and oversized files early ---
        long maxSizeBytes = (long)Constants.Limits.DefaultMaxUploadSizeMb * 1024 * 1024;
        var validFiles = new List<(IBrowserFile File, FileMetadata? Meta, int Index)>();
        int rejectedCount = 0;

        for (var i = 0; i < files.Count; i++)
        {
            var file = files[i];
            var metadata = i < fileMetadata.Length ? fileMetadata[i] : null;
            var contentType = metadata?.Type ?? file.ContentType;
            var fileSize = metadata?.Size ?? file.Size;

            if (!Constants.AllowedUploadTypes.IsAllowed(contentType))
            {
                Feedback.ShowError(string.Format(CommonLoc["Error_FileTypeNotAllowed"].Value, file.Name));
                rejectedCount++;
                continue;
            }

            if (fileSize > maxSizeBytes)
            {
                Feedback.ShowError(string.Format(CommonLoc["Error_FileTooLarge"].Value,
                    file.Name, Constants.Limits.DefaultMaxUploadSizeMb));
                rejectedCount++;
                continue;
            }

            validFiles.Add((file, metadata, i));
        }

        if (rejectedCount > 0 && validFiles.Count > 0)
        {
            Feedback.ShowWarning(string.Format(CommonLoc["Warning_FilesRejected"].Value, rejectedCount));
        }

        if (validFiles.Count == 0)
        {
            _isUploading = false;
            await DisableBeforeUnloadAsync();
            StateHasChanged();
            return;
        }

        // Pre-populate all uploads with Queued status so user sees them immediately
        var uploadItems = new List<UploadItem>();
        foreach (var (file, metadata, fileIndex) in validFiles)
        {
            var upload = new UploadItem
            {
                FileName = file.Name,
                Size = metadata?.Size ?? file.Size,
                ContentType = metadata?.Type ?? file.ContentType,
                Status = UploadStatus.Queued,
                FileIndex = fileIndex
            };
            uploadItems.Add(upload);
            _uploads.Add(upload);
        }
        StateHasChanged();

        // Process each file sequentially
        for (var i = 0; i < validFiles.Count; i++)
        {
            if (_cts.IsCancellationRequested) break;

            var file = validFiles[i].File;
            var upload = uploadItems[i];
            upload.Status = UploadStatus.Uploading;
            StateHasChanged();

            try
            {
                // Step 1: Init upload — get presigned PUT URL from API
                var initResult = await Api.InitUploadAsync(
                    CollectionId,
                    file.Name,
                    upload.ContentType,
                    upload.Size,
                    Path.GetFileNameWithoutExtension(file.Name));

                upload.AssetId = initResult.AssetId;

                // Step 2: Upload directly to MinIO via JS interop (bypasses SignalR)
                var callbackHelper = new UploadCallbackHelper(upload, () => InvokeAsync(StateHasChanged));
                var dotNetRef = DotNetObjectReference.Create(callbackHelper);

                bool success;
                try
                {
                    success = await _jsModule.InvokeAsync<bool>(
                        "uploadFile",
                        initResult.UploadUrl,
                        _inputFile.Element,
                        upload.FileIndex,
                        dotNetRef);
                }
                finally
                {
                    dotNetRef.Dispose();
                }

                if (!success)
                {
                    upload.Status = UploadStatus.Failed;
                    upload.ErrorMessage ??= string.Format(CommonLoc["Error_UploadFailed"].Value, file.Name);
                    StateHasChanged();
                    continue;
                }

                // Step 3: Verify upload — validates file and runs malware scan
                upload.Status = UploadStatus.Scanning;
                StateHasChanged();

                var scanStart = DateTime.UtcNow;
                var confirmResult = await Api.ConfirmUploadAsync(initResult.AssetId);
                upload.AssetId = initResult.AssetId;
                upload.Message = confirmResult.Message;

                // Ensure the scanning indicator stays visible long enough for users
                // to see that each file was scanned (at least 1.5s)
                var scanElapsed = DateTime.UtcNow - scanStart;
                if (scanElapsed < TimeSpan.FromMilliseconds(1500))
                    await Task.Delay(TimeSpan.FromMilliseconds(1500) - scanElapsed);

                // Start independent background poll for this file
                upload.Status = UploadStatus.Processing;
                if (upload.AssetId.HasValue)
                {
                    Interlocked.Increment(ref _activeProcessingCount);
                    _ = PollSingleAssetCompletion(upload);
                }
            }
            catch (ApiException apiEx) when (apiEx.ErrorCode == "DUPLICATE_ASSET")
            {
                upload.Status = UploadStatus.Failed;
                upload.ErrorMessage = ClassifyUploadError(apiEx.Message, upload);
                upload.ErrorCategory = UploadErrorsDialog.ErrorCategory.Duplicate;
                upload.DuplicateAssetId = apiEx.Details?.GetValueOrDefault("existingAssetId") is string existingId
                    && Guid.TryParse(existingId, out var parsed) ? parsed : null;
                upload.DuplicateTitle = apiEx.Details?.GetValueOrDefault("existingTitle");
            }
            catch (Exception ex)
            {
                upload.Status = UploadStatus.Failed;
                upload.ErrorMessage = ClassifyUploadError(ex.Message, upload);
            }

            StateHasChanged();
        }

        _isUploading = false;

        // Trigger initial refresh to show assets (with processing status)
        if (!_cts.IsCancellationRequested)
            await OnUploadComplete.InvokeAsync();

        // If nothing entered processing, handle completion immediately
        if (_activeProcessingCount == 0)
            await HandleAllUploadsFinished();
    }

    /// <summary>
    /// Polls a single asset until its server-side processing completes.
    /// Each file is tracked independently — completed files show a checkmark
    /// and clean up without waiting for other files.
    /// </summary>
    private async Task PollSingleAssetCompletion(UploadItem upload)
    {
        const int maxAttempts = 40;
        const int pollIntervalMs = 3000;

        try
        {
            for (int attempt = 0; attempt < maxAttempts; attempt++)
            {
                await Task.Delay(pollIntervalMs, _cts.Token);

                try
                {
                    var asset = await Api.GetAssetAsync(upload.AssetId!.Value, CancellationToken.None);

                    if (asset is null)
                    {
                        upload.Status = UploadStatus.Failed;
                        upload.ErrorMessage = CommonLoc["Error_AssetProcessingDeleted"].Value;
                        await InvokeAsync(StateHasChanged);
                        return;
                    }

                    if (asset.Status == Constants.AssetStatus.Failed)
                    {
                        upload.Status = UploadStatus.Failed;
                        upload.ErrorMessage = CommonLoc["Error_AssetProcessingFailed"].Value;
                        await InvokeAsync(StateHasChanged);
                        return;
                    }

                    if (asset.Status != Constants.AssetStatus.Processing)
                    {
                        // Asset is ready — mark completed and refresh grid
                        upload.Status = UploadStatus.Completed;
                        await InvokeAsync(StateHasChanged);
                        await OnUploadComplete.InvokeAsync();

                        // Preload thumbnail so it appears without a flicker
                        if (_jsModule != null)
                        {
                            try
                            {
                                await _jsModule.InvokeVoidAsync("preloadImages",
                                    (object)new[] { $"/api/v1/assets/{upload.AssetId}/thumb" }, 10000);
                            }
                            catch { /* component may be disposed */ }
                        }

                        return;
                    }
                }
                catch (OperationCanceledException) { return; }
                catch { /* polling error — retry next attempt */ }
            }

            // Timeout
            if (!_cts.IsCancellationRequested)
            {
                upload.Status = UploadStatus.Failed;
                upload.ErrorMessage = CommonLoc["Error_AssetProcessingTimeout"].Value;
                await InvokeAsync(StateHasChanged);
            }
        }
        finally
        {
            // When the last processing file finishes, handle batch completion
            // (disable navigation guard, show error dialog if needed)
            if (Interlocked.Decrement(ref _activeProcessingCount) == 0 && !_isUploading)
                await HandleAllUploadsFinished();
        }
    }

    /// <summary>
    /// Called when the last file finishes processing (success or failure).
    /// Disables the navigation guard and shows the error dialog if any files failed.
    /// </summary>
    private async Task HandleAllUploadsFinished()
    {
        if (_cts.IsCancellationRequested) return;

        await DisableBeforeUnloadAsync();

        _showReport = true;
        await InvokeAsync(StateHasChanged);
    }

    private void DismissReport()
    {
        _showReport = false;
        _uploads.Clear();
        StateHasChanged();
    }

    private async Task ShowUploadErrorsDialog()
    {
        var failedFiles = _uploads
            .Where(u => u.Status == UploadStatus.Failed)
            .Select(u => new UploadErrorsDialog.FailedFileInfo
            {
                FileName = u.FileName,
                Size = u.Size,
                ContentType = u.ContentType,
                ErrorMessage = u.ErrorMessage,
                Category = u.ErrorCategory,
                DuplicateAssetId = u.DuplicateAssetId,
                DuplicateTitle = u.DuplicateTitle
            })
            .ToList();

        if (failedFiles.Count == 0) return;

        var parameters = new DialogParameters<UploadErrorsDialog>
        {
            { x => x.FailedFiles, failedFiles }
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<UploadErrorsDialog>(
            CommonLoc["Title_UploadErrors"].Value,
            parameters,
            options);
        await dialog.Result;

        // After user closes dialog, clear failed uploads
        _uploads.RemoveAll(u => u.Status == UploadStatus.Failed);
        StateHasChanged();
    }

    private Color GetStatusColor(UploadStatus status)
    {
        return status switch
        {
            UploadStatus.Uploading => Color.Primary,
            UploadStatus.Scanning => Color.Warning,
            UploadStatus.Processing => Color.Info,
            UploadStatus.Completed => Color.Success,
            UploadStatus.Failed => Color.Error,
            UploadStatus.Queued => Color.Default,
            _ => Color.Default
        };
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
        _locationChangingRegistration?.Dispose();
        await DisableBeforeUnloadAsync();
        try
        {
            if (_jsModule != null)
                await _jsModule.DisposeAsync();
        }
        catch (JSDisconnectedException) { }
    }

    private bool HasActiveUploads => _uploads.Any(u =>
        u.Status is UploadStatus.Queued or UploadStatus.Uploading
            or UploadStatus.Scanning or UploadStatus.Processing);

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!HasActiveUploads || _navigationConfirmed) return;

        // Prevent navigation while showing the dialog
        context.PreventNavigation();

        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, CommonLoc["Title_LeavePageConfirm"].Value },
            { x => x.Message, CommonLoc["Text_UploadInProgress"].Value },
            { x => x.TitleIcon, Icons.Material.Filled.Warning },
            { x => x.IconColor, Color.Warning },
            { x => x.ConfirmText, CommonLoc["Btn_LeavePage"].Value },
            { x => x.ConfirmColor, Color.Error }
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(
            CommonLoc["Title_LeavePageConfirm"].Value,
            parameters,
            options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            // User confirmed — cancel background work and skip the guard on re-entrant NavigateTo
            _navigationConfirmed = true;
            await _cts.CancelAsync();
            Nav.NavigateTo(context.TargetLocation);
        }
    }

    private async Task EnableBeforeUnloadAsync()
    {
        if (_jsModule != null)
        {
            try { await _jsModule.InvokeVoidAsync("enableBeforeUnload"); }
            catch { /* component may be disposed */ }
        }
    }

    private async Task DisableBeforeUnloadAsync()
    {
        if (_jsModule != null)
        {
            try { await _jsModule.InvokeVoidAsync("disableBeforeUnload"); }
            catch { /* component may be disposed */ }
        }
    }

    /// <summary>
    /// Maps API error messages to user-friendly, localized descriptions
    /// and sets the error category on the upload item for visual differentiation.
    /// </summary>
    private string ClassifyUploadError(string errorMessage, UploadItem? upload = null)
    {
        if (string.IsNullOrEmpty(errorMessage))
            return CommonLoc["Error_UploadGeneric"].Value;

        if (errorMessage.Contains("malware detected", StringComparison.OrdinalIgnoreCase))
        {
            if (upload != null) upload.ErrorCategory = UploadErrorsDialog.ErrorCategory.Malware;
            return CommonLoc["Error_MalwareDetected"].Value;
        }

        if (errorMessage.Contains("scanning failed", StringComparison.OrdinalIgnoreCase) ||
            errorMessage.Contains("scanner unavailable", StringComparison.OrdinalIgnoreCase))
        {
            if (upload != null) upload.ErrorCategory = UploadErrorsDialog.ErrorCategory.ScannerUnavailable;
            return CommonLoc["Error_ScannerUnavailable"].Value;
        }

        if (errorMessage.Contains("content does not match", StringComparison.OrdinalIgnoreCase))
            return CommonLoc["Error_ContentTypeMismatch"].Value;

        if (errorMessage.Contains("identical content already exists", StringComparison.OrdinalIgnoreCase))
        {
            if (upload != null) upload.ErrorCategory = UploadErrorsDialog.ErrorCategory.Duplicate;
            return CommonLoc["Error_DuplicateAsset"].Value;
        }

        return errorMessage;
    }

    private class UploadItem
    {
        public string FileName { get; set; } = "";
        public long Size { get; set; }
        public string ContentType { get; set; } = "";
        public UploadStatus Status { get; set; }
        public int ProgressPercent { get; set; }
        public int FileIndex { get; set; }
        public Guid? AssetId { get; set; }
        public string? Message { get; set; }
        public string? ErrorMessage { get; set; }
        public UploadErrorsDialog.ErrorCategory ErrorCategory { get; set; }
        public Guid? DuplicateAssetId { get; set; }
        public string? DuplicateTitle { get; set; }
    }

    private enum UploadStatus
    {
        Queued,
        Uploading,
        Scanning,
        Processing,
        Completed,
        Failed
    }

    /// <summary>
    /// JS interop callback helper — receives progress/completion events from the JS upload module.
    /// </summary>
    private class UploadCallbackHelper(UploadItem upload, Func<Task> stateChanged)
    {
        [JSInvokable]
        public async Task OnUploadProgress(int percent, long loaded, long total)
        {
            upload.ProgressPercent = percent;
            await stateChanged();
        }

        [JSInvokable]
        public async Task OnUploadComplete()
        {
            upload.ProgressPercent = 100;
            await stateChanged();
        }

        [JSInvokable]
        public async Task OnUploadError(string error)
        {
            upload.ErrorMessage = error;
            upload.Status = UploadStatus.Failed;
            await stateChanged();
        }
    }

    /// <summary>
    /// File metadata returned by JS interop — avoids reading file content over SignalR.
    /// </summary>
    private class FileMetadata
    {
        public string Name { get; set; } = "";
        public long Size { get; set; }
        public string Type { get; set; } = "";
    }
}
