@using AssetHub.Ui.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.JSInterop

@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IDialogService DialogService

@implements IAsyncDisposable

<div class="@_uploadAreaClass"
     @ondragenter="OnDragEnter"
     @ondragenter:preventDefault
     @ondragleave="OnDragLeave"
     @ondragover:preventDefault
     @ondrop="OnDrop"
     @ondrop:preventDefault>

    <InputFile @ref="_inputFile"
               id="fileInput"
               OnChange="OnFilesSelected"
               hidden
               multiple
               accept="image/*,video/*,audio/*,.pdf,.zip,.docx,.xlsx,.pptx,.doc,.xls,.ppt,.txt,.csv,.json,.xml,.svg,.woff,.woff2,.ttf,.otf,.glb,.gltf" />

    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-4">
        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" 
                 Size="Size.Large" 
                 Color="Color.Primary" />
        <MudText Typo="Typo.body1">
            @CommonLoc["Text_DragDropFiles"]
        </MudText>
        <MudButton HtmlTag="label"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.AttachFile"
                   for="fileInput"
                   Disabled="@((RequireCollection && !CollectionId.HasValue) || _isUploading)">
            @CommonLoc["Btn_BrowseFiles"]
        </MudButton>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            @CommonLoc["Text_SupportedFormats"]
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            @string.Format(CommonLoc["Text_MaxFilesHint"].Value, Constants.Limits.MaxFilesPerUpload)
        </MudText>
    </MudStack>
</div>

@if (_uploads.Any())
{
    <MudPaper Class="pa-3 mt-3" Elevation="0" Outlined="true">
        <MudText Typo="Typo.subtitle2" Class="mb-2">@CommonLoc["Text_Uploads"]</MudText>
        <MudStack Spacing="2">
            @foreach (var upload in _uploads)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@AssetDisplayHelpers.GetContentTypeIcon(upload.ContentType)" 
                             Size="Size.Small" 
                             Color="@GetStatusColor(upload.Status)" />
                    <MudText Typo="Typo.body2" Class="flex-grow-1 text-truncate upload-chip-max">
                        @upload.FileName
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @AssetDisplayHelpers.FormatFileSize(upload.Size)
                    </MudText>
                    @if (upload.Status == UploadStatus.Uploading)
                    {
                        <MudProgressLinear Value="@upload.ProgressPercent" 
                                           Min="0" Max="100" 
                                           Color="Color.Primary"
                                           Class="upload-progress" />
                        <MudText Typo="Typo.caption">@upload.ProgressPercent%</MudText>
                    }
                    else if (upload.Status == UploadStatus.Verifying)
                    {
                        <MudProgressLinear Indeterminate="true"
                                           Color="Color.Warning"
                                           Class="upload-progress" />
                        <MudText Typo="Typo.caption" Color="Color.Warning">@CommonLoc["Text_Verifying"]</MudText>
                    }
                    else if (upload.Status == UploadStatus.Processing)
                    {
                        <MudProgressLinear Indeterminate="true"
                                           Color="Color.Info"
                                           Class="upload-progress" />
                        <MudText Typo="Typo.caption" Color="Color.Info">@CommonLoc["Text_Processing"]</MudText>
                    }
                    else if (upload.Status == UploadStatus.Completed)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    }
                    else if (upload.Status == UploadStatus.Failed)
                    {
                        <MudTooltip Text="@upload.ErrorMessage">
                            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                        </MudTooltip>
                    }
                    else if (upload.Status == UploadStatus.Queued)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@CommonLoc["Text_Queued"]</MudChip>
                    }
                </MudStack>
            }
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter]
    public Guid? CollectionId { get; set; }

    /// <summary>
    /// When true (default), the browse button is disabled if no CollectionId is set.
    /// Set to false to allow uploads without a target collection (e.g., admin uploads).
    /// </summary>
    [Parameter]
    public bool RequireCollection { get; set; } = true;

    [Parameter]
    public EventCallback OnUploadComplete { get; set; }

    private InputFile? _inputFile;
    private IJSObjectReference? _jsModule;
    private List<UploadItem> _uploads = new();
    private bool _isUploading = false;
    private bool _isDragOver = false;
    private IDisposable? _locationChangingRegistration;
    private bool _navigationConfirmed;
    private CancellationTokenSource _cts = new();

    private int _dragCounter = 0;
    private string _uploadAreaClass => $"pa-4 upload-area {(_isDragOver ? "drag-over" : "")}";

    private void OnDragEnter()
    {
        _dragCounter++;
        _isDragOver = true;
    }

    private void OnDragLeave()
    {
        _dragCounter--;
        if (_dragCounter <= 0)
        {
            _dragCounter = 0;
            _isDragOver = false;
        }
    }

    private void OnDrop()
    {
        _dragCounter = 0;
        _isDragOver = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AssetHub.Ui/js/fileUpload.js");
            _locationChangingRegistration = Nav.RegisterLocationChangingHandler(OnLocationChanging);
        }
    }

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        if (_jsModule == null || _inputFile?.Element == null)
        {
            Feedback.ShowError(CommonLoc["Error_UploadModuleNotInit"].Value);
            return;
        }

        _isUploading = true;
        await EnableBeforeUnloadAsync();
        var files = e.GetMultipleFiles(Constants.Limits.MaxFilesPerUpload);

        // Get file metadata from JS (no file data sent over SignalR)
        var fileMetadata = await _jsModule.InvokeAsync<FileMetadata[]>(
            "getFileMetadata", _inputFile.Element);

        // --- Client-side validation: reject disallowed types and oversized files early ---
        long maxSizeBytes = (long)Constants.Limits.DefaultMaxUploadSizeMb * 1024 * 1024;
        var validFiles = new List<(IBrowserFile File, FileMetadata? Meta, int Index)>();
        int rejectedCount = 0;

        for (var i = 0; i < files.Count; i++)
        {
            var file = files[i];
            var metadata = i < fileMetadata.Length ? fileMetadata[i] : null;
            var contentType = metadata?.Type ?? file.ContentType;
            var fileSize = metadata?.Size ?? file.Size;

            if (!Constants.AllowedUploadTypes.IsAllowed(contentType))
            {
                Feedback.ShowError(string.Format(CommonLoc["Error_FileTypeNotAllowed"].Value, file.Name));
                rejectedCount++;
                continue;
            }

            if (fileSize > maxSizeBytes)
            {
                Feedback.ShowError(string.Format(CommonLoc["Error_FileTooLarge"].Value,
                    file.Name, Constants.Limits.DefaultMaxUploadSizeMb));
                rejectedCount++;
                continue;
            }

            validFiles.Add((file, metadata, i));
        }

        if (rejectedCount > 0 && validFiles.Count > 0)
        {
            Feedback.ShowWarning(string.Format(CommonLoc["Warning_FilesRejected"].Value, rejectedCount));
        }

        if (validFiles.Count == 0)
        {
            _isUploading = false;
            await DisableBeforeUnloadAsync();
            StateHasChanged();
            return;
        }

        // Pre-populate all uploads with Queued status so user sees them immediately
        var uploadItems = new List<UploadItem>();
        foreach (var (file, metadata, fileIndex) in validFiles)
        {
            var upload = new UploadItem
            {
                FileName = file.Name,
                Size = metadata?.Size ?? file.Size,
                ContentType = metadata?.Type ?? file.ContentType,
                Status = UploadStatus.Queued,
                FileIndex = fileIndex
            };
            uploadItems.Add(upload);
            _uploads.Add(upload);
        }
        StateHasChanged();

        // Process each file sequentially
        for (var i = 0; i < validFiles.Count; i++)
        {
            if (_cts.IsCancellationRequested) break;

            var file = validFiles[i].File;
            var upload = uploadItems[i];
            upload.Status = UploadStatus.Uploading;
            StateHasChanged();

            try
            {
                // Step 1: Init upload — get presigned PUT URL from API
                var initResult = await Api.InitUploadAsync(
                    CollectionId,
                    file.Name,
                    upload.ContentType,
                    upload.Size,
                    Path.GetFileNameWithoutExtension(file.Name));

                upload.AssetId = initResult.AssetId;

                // Step 2: Upload directly to MinIO via JS interop (bypasses SignalR)
                var callbackHelper = new UploadCallbackHelper(upload, () => InvokeAsync(StateHasChanged));
                var dotNetRef = DotNetObjectReference.Create(callbackHelper);

                bool success;
                try
                {
                    success = await _jsModule.InvokeAsync<bool>(
                        "uploadFile",
                        initResult.UploadUrl,
                        _inputFile.Element,
                        upload.FileIndex,
                        dotNetRef);
                }
                finally
                {
                    dotNetRef.Dispose();
                }

                if (!success)
                {
                    upload.Status = UploadStatus.Failed;
                    upload.ErrorMessage ??= string.Format(CommonLoc["Error_UploadFailed"].Value, file.Name);
                    if (!_navigationConfirmed)
                        Feedback.ShowError(string.Format(CommonLoc["Error_UploadFailed"].Value, file.Name));
                    StateHasChanged();
                    continue;
                }

                // Step 3: Verify upload — validates file and runs malware scan
                upload.Status = UploadStatus.Verifying;
                StateHasChanged();

                var confirmResult = await Api.ConfirmUploadAsync(initResult.AssetId);
                upload.AssetId = initResult.AssetId;
                upload.Message = confirmResult.Message;

                // Stay in Processing state — polling will mark Completed when ready
                upload.Status = UploadStatus.Processing;
            }
            catch (Exception ex)
            {
                upload.Status = UploadStatus.Failed;
                upload.ErrorMessage = ex.Message;
                if (!_navigationConfirmed)
                    Feedback.ShowError(string.Format(CommonLoc["Error_UploadFailed"].Value, file.Name));
            }

            StateHasChanged();
        }

        _isUploading = false;
        
        // Collect asset IDs still being processed server-side
        var processingAssetIds = _uploads
            .Where(u => u.Status == UploadStatus.Processing && u.AssetId.HasValue)
            .Select(u => u.AssetId!.Value)
            .ToList();

        // Trigger initial refresh to show assets (with processing status)
        if (!_cts.IsCancellationRequested)
            await OnUploadComplete.InvokeAsync();

        // Poll for processing completion in background, then refresh again
        if (processingAssetIds.Any())
        {
            _ = PollForProcessingCompletion(processingAssetIds);
        }
        else
        {
            // All uploads either failed or had no processing — clean up now
            await DisableBeforeUnloadAsync();
            await Task.Delay(3000);
            _uploads.RemoveAll(u => u.Status is UploadStatus.Completed or UploadStatus.Failed);
            StateHasChanged();
        }
    }

    /// <summary>
    /// Polls the API until all uploaded assets have finished processing (Ready or Failed),
    /// then triggers a refresh so thumbnails appear without manual page reload.
    /// </summary>
    private async Task PollForProcessingCompletion(List<Guid> assetIds)
    {
        const int maxAttempts = 40; // Max 120 seconds of polling (40 * 3s)
        const int pollIntervalMs = 3000;

        for (int attempt = 0; attempt < maxAttempts; attempt++)
        {
            await Task.Delay(pollIntervalMs, _cts.Token);

            try
            {
                var allReady = true;
                foreach (var assetId in assetIds)
                {
                    var upload = _uploads.FirstOrDefault(u => u.AssetId == assetId);
                    if (upload is null || upload.Status is UploadStatus.Completed or UploadStatus.Failed)
                        continue;

                    var asset = await Api.GetAssetAsync(assetId, CancellationToken.None);

                    if (asset is null)
                    {
                        // Asset was deleted (e.g., malware detected during scan)
                        upload.Status = UploadStatus.Failed;
                        upload.ErrorMessage = CommonLoc["Error_AssetProcessingDeleted"].Value;
                        await InvokeAsync(StateHasChanged);
                    }
                    else if (asset.Status == Constants.AssetStatus.Failed)
                    {
                        upload.Status = UploadStatus.Failed;
                        upload.ErrorMessage = CommonLoc["Error_AssetProcessingFailed"].Value;
                        await InvokeAsync(StateHasChanged);
                    }
                    else if (asset.Status == Constants.AssetStatus.Processing)
                    {
                        allReady = false;
                    }
                }

                if (allReady)
                {
                    await FinishProcessing(assetIds);
                    return;
                }
            }
            catch (OperationCanceledException)
            {
                return; // Component disposed or user navigated away
            }
            catch
            {
                // Ignore polling errors — worst case user refreshes manually
            }
        }

        // Timeout — mark remaining processing uploads as failed with a clear message
        if (!_cts.IsCancellationRequested)
        {
            foreach (var upload in _uploads.Where(u => u.Status == UploadStatus.Processing))
            {
                upload.Status = UploadStatus.Failed;
                upload.ErrorMessage = CommonLoc["Error_AssetProcessingTimeout"].Value;
            }
            await FinishProcessing(assetIds);
        }
    }

    /// <summary>
    /// Refreshes the asset grid, preloads thumbnail images for successful uploads,
    /// then marks remaining processing uploads as completed.
    /// </summary>
    private async Task FinishProcessing(List<Guid> assetIds)
    {
        if (_cts.IsCancellationRequested) return;

        // Uploads fully complete — remove browser navigation guard
        await DisableBeforeUnloadAsync();

        // Notify user of any failures
        var failedCount = _uploads.Count(u => u.AssetId.HasValue && assetIds.Contains(u.AssetId.Value) && u.Status == UploadStatus.Failed);
        if (failedCount > 0)
        {
            Feedback.ShowError(string.Format(CommonLoc["Error_ProcessingFailedCount"].Value, failedCount));
        }

        // Refresh grid so assets appear (still showing Processing indicator for successful ones)
        await OnUploadComplete.InvokeAsync();

        // Preload thumbnails only for assets that weren't marked as failed
        var successIds = assetIds
            .Where(id => _uploads.Any(u => u.AssetId == id && u.Status == UploadStatus.Processing))
            .ToArray();

        if (_jsModule != null && successIds.Length > 0)
        {
            var thumbUrls = successIds.Select(id => $"/api/v1/assets/{id}/thumb").ToArray();
            try
            {
                await _jsModule.InvokeVoidAsync("preloadImages", (object)thumbUrls, 10000);
            }
            catch
            {
                // JS interop may fail if component is disposed — safe to ignore
            }
        }

        // Mark remaining processing uploads as completed (failed ones keep their status)
        foreach (var upload in _uploads.Where(u => u.Status == UploadStatus.Processing))
        {
            upload.Status = UploadStatus.Completed;
        }
        await InvokeAsync(StateHasChanged);

        // Clean up after a short delay
        await Task.Delay(3000);
        _uploads.RemoveAll(u => u.Status is UploadStatus.Completed or UploadStatus.Failed);
        await InvokeAsync(StateHasChanged);
    }

    private Color GetStatusColor(UploadStatus status)
    {
        return status switch
        {
            UploadStatus.Uploading => Color.Primary,
            UploadStatus.Verifying => Color.Warning,
            UploadStatus.Processing => Color.Info,
            UploadStatus.Completed => Color.Success,
            UploadStatus.Failed => Color.Error,
            UploadStatus.Queued => Color.Default,
            _ => Color.Default
        };
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
        _locationChangingRegistration?.Dispose();
        await DisableBeforeUnloadAsync();
        if (_jsModule != null)
        {
            await _jsModule.DisposeAsync();
        }
    }

    private bool HasActiveUploads => _uploads.Any(u =>
        u.Status is UploadStatus.Queued or UploadStatus.Uploading
            or UploadStatus.Verifying or UploadStatus.Processing);

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!HasActiveUploads || _navigationConfirmed) return;

        // Prevent navigation while showing the dialog
        context.PreventNavigation();

        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, CommonLoc["Title_LeavePageConfirm"].Value },
            { x => x.Message, CommonLoc["Text_UploadInProgress"].Value },
            { x => x.TitleIcon, Icons.Material.Filled.Warning },
            { x => x.IconColor, Color.Warning },
            { x => x.ConfirmText, CommonLoc["Btn_LeavePage"].Value },
            { x => x.ConfirmColor, Color.Error }
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(
            CommonLoc["Title_LeavePageConfirm"].Value,
            parameters,
            options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            // User confirmed — cancel background work and skip the guard on re-entrant NavigateTo
            _navigationConfirmed = true;
            await _cts.CancelAsync();
            Nav.NavigateTo(context.TargetLocation);
        }
    }

    private async Task EnableBeforeUnloadAsync()
    {
        if (_jsModule != null)
        {
            try { await _jsModule.InvokeVoidAsync("enableBeforeUnload"); }
            catch { /* component may be disposed */ }
        }
    }

    private async Task DisableBeforeUnloadAsync()
    {
        if (_jsModule != null)
        {
            try { await _jsModule.InvokeVoidAsync("disableBeforeUnload"); }
            catch { /* component may be disposed */ }
        }
    }

    private class UploadItem
    {
        public string FileName { get; set; } = "";
        public long Size { get; set; }
        public string ContentType { get; set; } = "";
        public UploadStatus Status { get; set; }
        public int ProgressPercent { get; set; }
        public int FileIndex { get; set; }
        public Guid? AssetId { get; set; }
        public string? Message { get; set; }
        public string? ErrorMessage { get; set; }
    }

    private enum UploadStatus
    {
        Queued,
        Uploading,
        Verifying,
        Processing,
        Completed,
        Failed
    }

    /// <summary>
    /// JS interop callback helper — receives progress/completion events from the JS upload module.
    /// </summary>
    private class UploadCallbackHelper(UploadItem upload, Func<Task> stateChanged)
    {
        [JSInvokable]
        public async Task OnUploadProgress(int percent, long loaded, long total)
        {
            upload.ProgressPercent = percent;
            await stateChanged();
        }

        [JSInvokable]
        public async Task OnUploadComplete()
        {
            upload.ProgressPercent = 100;
            await stateChanged();
        }

        [JSInvokable]
        public async Task OnUploadError(string error)
        {
            upload.ErrorMessage = error;
            upload.Status = UploadStatus.Failed;
            await stateChanged();
        }
    }

    /// <summary>
    /// File metadata returned by JS interop — avoids reading file content over SignalR.
    /// </summary>
    private class FileMetadata
    {
        public string Name { get; set; } = "";
        public long Size { get; set; }
        public string Type { get; set; } = "";
    }
}
