  <data name="Btn_Refresh" xml:space="preserve"><value>Uppdatera</value></data>

  <data name="Empty_Title" xml:space="preserve"><value>Inga gästinbjudningar ännu</value></data>
  <data name="Empty_Desc" xml:space="preserve"><value>Bjud in externa granskare via e-post; de loggar in via en magisk länk utan att behöva ett fullständigt konto.</value></data>

  <data name="Header_Email" xml:space="preserve"><value>E-post</value></data>
