{
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Hangfire": "Warning"
      }
    }
  },
  "Keycloak": {
    "RequireHttpsMetadata": true,
    "TimeoutSeconds": 30
  },
  "MinIO": {
    "UseSSL": true
  },
  "Email": {
    "FromName": "AssetHub (Staging)",
    "Enabled": true
  },
  "ClamAV": {
    "Enabled": true
  },
  "Database": {
    "AutoMigrate": false
  },
  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "http://jaeger:4317",
    "SamplingRatio": 0.5,
    "RecordExceptions": true,
    "StripQueryStrings": true
  },
  "Redis": {
    "ConnectionString": "redis:6379,abortConnect=false"
  }
}
