@page "/collections"
@page "/assets"
@attribute [Authorize]
@implements IAsyncDisposable

@using AssetHub.Application.Dtos
@using AssetHub.Application.Helpers
@using AssetHub.Ui.Components
@using AssetHub.Ui.Services
@using Microsoft.AspNetCore.Authorization

@inject AssetHubApiClient Api
@inject NavigationManager Nav
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AssetsResource> AssetLoc
@inject IStringLocalizer<CollectionsResource> CollectionLoc
@inject LocalStorageService LocalStorage

<PageTitle>@AssetLoc["PageTitle"] - @CommonLoc["AppName"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
    <!-- Header with breadcrumb and actions -->
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <MudBreadcrumbs Items="_breadcrumbs" Class="pa-0">
            <ItemTemplate Context="item">
                <MudLink OnClick="@(() => OnBreadcrumbClick(item))" Color="Color.Primary" Class="cursor-pointer">@item.Text</MudLink>
            </ItemTemplate>
        </MudBreadcrumbs>

        @if (_selectedCollectionId.HasValue)
        {
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                @if (_assetSelectionMode)
                {
                    @if (_selectedAssetIds.Count > 0)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Checklist"
                                   OnClick="OpenBulkAssetActionsAsync">
                            @string.Format(AssetLoc["BulkAssetActionsBtn"], _selectedAssetIds.Count)
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               StartIcon="@(_allGridAssetsSelected ? Icons.Material.Filled.Deselect : Icons.Material.Filled.SelectAll)"
                               OnClick="ToggleSelectAllGridAssets">
                        @(_allGridAssetsSelected ? CommonLoc["Btn_DeselectAll"] : CommonLoc["Btn_SelectAll"])
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="ExitAssetSelectionMode">
                        @AssetLoc["CancelAssetSelection"]
                    </MudButton>
                }
                else
                {
                    @if (CanDelete)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CheckBox"
                                   OnClick="EnterAssetSelectionMode">
                            @AssetLoc["SelectManyAssets"]
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Download"
                               OnClick="DownloadAllAsync"
                               Disabled="_isDownloading">
                        @if (_isDownloading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            @_downloadStatusText
                        }
                        else
                        {
                            @CommonLoc["Btn_DownloadAll"]
                        }
                    </MudButton>
                    @if (CanShare)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Share"
                                   OnClick="ShareCollectionAsync">
                            @AssetLoc["ShareCollection"]
                        </MudButton>
                    }
                    @if (CanManageAccess)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Security"
                                   OnClick="ManageAccessAsync">
                            @AssetLoc["ManageAccess"]
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="RefreshAsync">
                        @CommonLoc["Btn_Refresh"]
                    </MudButton>
                }
            </MudStack>
        }
        else
        {
            <MudStack Row="true" Spacing="2">
                @if (_selectionMode)
                {
                    @if (_selectedCollectionIds.Count > 0)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Checklist"
                                   OnClick="OpenBulkActionsAsync">
                            @string.Format(CollectionLoc["BulkActionsBtn"], _selectedCollectionIds.Count)
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               StartIcon="@(_allCollectionsSelected ? Icons.Material.Filled.Deselect : Icons.Material.Filled.SelectAll)"
                               OnClick="ToggleSelectAllCollections">
                        @(_allCollectionsSelected ? CommonLoc["Btn_DeselectAll"] : CommonLoc["Btn_SelectAll"])
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="ExitSelectionMode">
                        @CollectionLoc["CancelSelection"]
                    </MudButton>
                }
                else
                {
                    <AuthorizeView Policy="RequireAdmin" Context="selectManyCtx">
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CheckBox"
                                   OnClick="EnterSelectionMode">
                            @CollectionLoc["SelectMany"]
                        </MudButton>
                    </AuthorizeView>
                }
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.CreateNewFolder"
                           OnClick="CreateCollectionAsync">
                    @AssetLoc["CreateCollection"]
                </MudButton>
            </MudStack>
        }
    </MudStack>

    @if (!_selectedCollectionId.HasValue)
    {
        <CollectionBrowser AllCollections="_allCollections"
                           Loading="_allCollectionsLoading"
                           SearchString="@_collectionSearchString"
                           SearchStringChanged="@(v => _collectionSearchString = v)"
                           ViewMode="@_collectionViewMode"
                           ViewModeChanged="SetCollectionViewModeAsync"
                           SelectionMode="_selectionMode"
                           SelectedCollectionIds="_selectedCollectionIds"
                           OnCollectionSelected="OnCollectionSelected" />
    }
    else
    {
        @if (_selectedCollection != null)
        {
            <CollectionHeader Collection="_selectedCollection"
                              CurrentUserRole="@CurrentUserRole"
                              OnEdit="EditCollectionAsync"
                              OnDelete="DeleteCollectionAsync" />
        }

        @if (CanUpload)
        {
            <AssetUpload CollectionId="@_selectedCollectionId"
                         OnUploadComplete="@OnUploadComplete" />
        }

        <AssetToolbar SearchQuery="@_searchQuery"
                      SearchQueryChanged="@(v => _searchQuery = v)"
                      FilterType="@_filterType"
                      FilterTypeChanged="@(v => _filterType = v)"
                      ViewMode="@_viewMode"
                      ViewModeChanged="SetAssetViewModeAsync"
                      OnSearch="SearchAsync" />

        <AssetGrid @ref="_assetGrid"
                   CollectionId="@_selectedCollectionId"
                   SearchQuery="@_searchQuery"
                   FilterType="@_filterType"
                   ViewMode="@_viewMode"
                   UserRole="@(_selectedCollection?.UserRole ?? RoleHierarchy.Roles.Viewer)"
                   SelectionMode="@_assetSelectionMode"
                   SelectedAssetIds="@_selectedAssetIds"
                   SelectedAssetIdsChanged="@OnAssetSelectionChanged"
                   OnAssetsChanged="@OnAssetsChanged" />
    }
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "collection")]
    public Guid? CollectionQueryParam { get; set; }

    private AssetGrid? _assetGrid;

    private Guid? _selectedCollectionId;
    private CollectionResponseDto? _selectedCollection;
    private List<BreadcrumbItem> _breadcrumbs = new();

    private string _searchQuery = "";
    private string? _filterType;
    private string _viewMode = Constants.ViewModes.Grid;

    private const string ViewModeStorageKeyCollections = "viewMode_collections";
    private const string ViewModeStorageKeyAssets = "viewMode_collectionAssets";

    // Collection browser state
    private List<CollectionResponseDto>? _allCollections;
    [System.Diagnostics.CodeAnalysis.SuppressMessage("Major Code Smell", "S4487:Unread \"private\" fields should be removed", Justification = "Read by Razor markup binding (Loading=\"_allCollectionsLoading\").")]
    private bool _allCollectionsLoading = true;
    private string _collectionSearchString = "";
    private string _collectionViewMode = Constants.ViewModes.Grid;

    // Bulk selection state (admin only)
    private bool _selectionMode;
    private HashSet<Guid> _selectedCollectionIds = new();

    // Asset bulk selection state
    private bool _assetSelectionMode;
    private HashSet<Guid> _selectedAssetIds = new();

    private bool CanDelete => RolePermissions.CanDelete(CurrentUserRole);

    private bool _allCollectionsSelected =>
        _allCollections?.Count > 0 && _selectedCollectionIds.Count == _allCollections.Count;

    // Role-based UI visibility using centralized permissions
    private string CurrentUserRole => _selectedCollection?.UserRole ?? RoleHierarchy.Roles.Viewer;
    private bool CanUpload => RolePermissions.CanUpload(CurrentUserRole);
    private bool CanShare => RolePermissions.CanShare(CurrentUserRole);
    private bool CanManageAccess => RolePermissions.CanManageAccess(CurrentUserRole);

    // Track navigation to refresh when returning to this page
    private string? _lastKnownUri;

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs = new() { new(CommonLoc["Nav_Collections"].Value, "/collections") };
        _lastKnownUri = Nav.Uri;
        Nav.LocationChanged += OnLocationChanged;

        var loadCollections = LoadAllCollections();

        if (CollectionQueryParam.HasValue)
        {
            await Task.WhenAll(loadCollections, OnCollectionSelected(CollectionQueryParam.Value));
        }
        else
        {
            await loadCollections;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var storedCollectionView = await LocalStorage.GetAsync(ViewModeStorageKeyCollections);
            var storedAssetView = await LocalStorage.GetAsync(ViewModeStorageKeyAssets);
            var changed = false;

            if (!string.IsNullOrEmpty(storedCollectionView))
            {
                _collectionViewMode = storedCollectionView;
                changed = true;
            }
            if (!string.IsNullOrEmpty(storedAssetView))
            {
                _viewMode = storedAssetView;
                changed = true;
            }

            if (changed) StateHasChanged();
        }
    }

    private async Task SetCollectionViewModeAsync(string mode)
    {
        _collectionViewMode = mode;
        await LocalStorage.SetAsync(ViewModeStorageKeyCollections, mode);
    }

    private async Task SetAssetViewModeAsync(string mode)
    {
        _viewMode = mode;
        await LocalStorage.SetAsync(ViewModeStorageKeyAssets, mode);
    }

    private async Task LoadAllCollections()
    {
        try
        {
            _allCollectionsLoading = true;
            _allCollections = await Api.GetCollectionsAsync();
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collections");
        }
        finally
        {
            _allCollectionsLoading = false;
        }
    }

    private async Task OnCollectionSelected(Guid? collectionId)
    {
        _selectedCollectionId = collectionId;

        if (collectionId.HasValue)
        {
            try
            {
                _selectedCollection = await Api.GetCollectionAsync(collectionId.Value);
                UpdateBreadcrumbs();
            }
            catch (Exception ex)
            {
                Feedback.HandleError(ex, "load collection");
            }
        }
        else
        {
            _selectedCollection = null;
            _breadcrumbs = new() { new(CommonLoc["Nav_Collections"].Value, "/collections") };
        }
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new() { new(CommonLoc["Nav_Collections"].Value, "/collections") };
        if (_selectedCollection != null)
        {
            _breadcrumbs.Add(new(_selectedCollection.Name, $"/collections?collection={_selectedCollection.Id}"));
        }
    }

    private async Task DeselectCollection()
    {
        await OnCollectionSelected(null);
        Nav.NavigateTo("/collections", replace: true);
    }

    private async Task OnBreadcrumbClick(BreadcrumbItem item)
    {
        if (item.Href == "/collections")
        {
            await DeselectCollection();
        }
    }

    private async Task CreateCollectionAsync()
    {
        var dialog = await DialogService.ShowAsync<CreateCollectionDialog>(AssetLoc["CreateCollection"]);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is CollectionResponseDto created)
        {
            _allCollections ??= new();
            _allCollections.Add(created);
            StateHasChanged();
            _ = LoadAllCollections(); // Background refresh for consistency
            Feedback.ShowSuccess(AssetLoc["CollectionCreatedSuccess"].Value);
        }
    }

    private async Task EditCollectionAsync(CollectionResponseDto collection)
    {
        var parameters = new DialogParameters<EditCollectionDialog>
        {
            { x => x.CollectionId, collection.Id },
            { x => x.InitialName, collection.Name },
            { x => x.InitialDescription, collection.Description },
            { x => x.CurrentParentId, collection.ParentCollectionId }
        };

        var dialog = await DialogService.ShowAsync<EditCollectionDialog>(CollectionLoc["EditCollection"], parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            // Refresh the selected collection details immediately if we edited the current one
            if (_selectedCollectionId == collection.Id)
            {
                await OnCollectionSelected(collection.Id);
            }

            Feedback.ShowSuccess(CollectionLoc["UpdatedSuccess"].Value);
            _ = LoadAllCollections(); // Background refresh for consistency
        }
    }

    private async Task DeleteCollectionAsync(CollectionResponseDto collection)
    {
        // Fetch deletion context to warn about orphaned assets
        CollectionDeletionContextDto? context = null;
        try
        {
            context = await Api.GetCollectionDeletionContextAsync(collection.Id);
        }
        catch
        {
            // Fall back to basic asset count if context fetch fails
        }

        var totalAssets = context?.TotalAssetCount ?? collection.AssetCount;
        var orphanedCount = context?.OrphanedAssetCount ?? 0;

        var messageParts = new List<string>();
        messageParts.Add(string.Format(CollectionLoc["ConfirmDeleteCollection"], collection.Name, ""));

        if (totalAssets > 0)
        {
            messageParts.Add(string.Format(CollectionLoc["AssetCountWarning"], totalAssets));
        }
        if (orphanedCount > 0)
        {
            messageParts.Add(string.Format(CollectionLoc["OrphanedAssetWarning"], orphanedCount));
        }

        var message = string.Join(" ", messageParts);

        var confirmed = await DialogService.ShowConfirmAsync(
            CollectionLoc["DeleteCollection"],
            message,
            CommonLoc["Btn_Delete"],
            Icons.Material.Filled.DeleteForever,
            Color.Error,
            Color.Error);

        if (confirmed)
        {
            try
            {
                await Api.DeleteCollectionAsync(collection.Id);

                // If we deleted the currently selected collection, go back to grid
                if (_selectedCollectionId == collection.Id)
                {
                    await DeselectCollection();
                }

                _allCollections?.RemoveAll(c => c.Id == collection.Id);
                StateHasChanged();
                _ = LoadAllCollections(); // Background refresh for consistency
                Feedback.ShowSuccess(CollectionLoc["DeletedSuccess"].Value);
            }
            catch (Exception ex)
            {
                Feedback.HandleError(ex, "delete collection");
            }
        }
    }

    private async Task ShareCollectionAsync()
    {
        if (!_selectedCollectionId.HasValue) return;

        var contentName = _selectedCollection?.Name ?? CommonLoc["Text_ThisCollection"].Value;

        await DialogService.ShowShareFlowAsync(
            _selectedCollectionId.Value,
            Constants.ScopeTypes.Collection,
            contentName,
            AssetLoc["CreateShareLink"],
            AssetLoc["ShareLinkCreated"]);
    }

    private async Task ManageAccessAsync()
    {
        if (!_selectedCollectionId.HasValue || _selectedCollection == null) return;

        var parameters = new DialogParameters<ManageAccessDialog>
        {
            { x => x.CollectionId, _selectedCollectionId.Value },
            { x => x.CollectionName, _selectedCollection.Name },
            { x => x.CurrentUserRole, _selectedCollection.UserRole ?? RoleHierarchy.Roles.Viewer }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        await DialogService.ShowAsync<ManageAccessDialog>(AssetLoc["ManageAccess"], parameters, options);
    }

    private async Task RefreshAsync()
    {
        if (_assetGrid != null)
        {
            await _assetGrid.RefreshAsync();
        }
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // Check if we navigated away and back to this page
        var wasOnAssets = _lastKnownUri?.Contains("/collections") == true || _lastKnownUri?.Contains("/assets") == true;
        var isOnAssets = e.Location.Contains("/collections") || e.Location.Contains("/assets");
        var leftAndReturned = !wasOnAssets && isOnAssets;

        _lastKnownUri = e.Location;

        // Refresh the asset grid when returning to this page
        if (leftAndReturned && _assetGrid != null && _selectedCollectionId.HasValue)
        {
            await InvokeAsync(async () =>
            {
                await _assetGrid.RefreshAsync();
                StateHasChanged();
            });
        }
    }

    // ── Download ─────────────────────────────────────────────────

    private bool _isDownloading;
    private string _downloadStatusText = "";
    private DotNetObjectReference<Assets>? _dotNetRef;
    private IJSObjectReference? _jsModule;

    private async Task DownloadAllAsync()
    {
        if (!_selectedCollectionId.HasValue || _isDownloading) return;

        _isDownloading = true;
        _downloadStatusText = CommonLoc["Msg_PreparingDownload"].Value;
        StateHasChanged();

        try
        {
            var url = $"/api/v1/collections/{_selectedCollectionId.Value}/download-all";
            _dotNetRef?.Dispose();
            _dotNetRef = DotNetObjectReference.Create(this);

            _jsModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/AssetHub.Ui/js/helpers.js");
            var resultJson = await _jsModule.InvokeAsync<string>("enqueueAndPollZipDownload", url, null, _dotNetRef);

            var result = System.Text.Json.JsonSerializer.Deserialize<ZipDownloadResult>(resultJson,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (result?.Success != true)
            {
                Feedback.ShowError(result?.Error ?? CommonLoc["Msg_DownloadFailed"].Value);
            }
        }
        catch (Exception)
        {
            Feedback.ShowError(CommonLoc["Msg_DownloadFailed"].Value);
        }
        finally
        {
            _isDownloading = false;
            _downloadStatusText = "";
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void UpdateZipProgress(string status, string fileName)
    {
        _downloadStatusText = status switch
        {
            Constants.ZipProgressStatus.Pending => CommonLoc["Msg_DownloadQueued"].Value,
            Constants.ZipProgressStatus.Building => CommonLoc["Msg_BuildingZip"].Value,
            _ => CommonLoc["Msg_PreparingDownload"].Value
        };
        InvokeAsync(StateHasChanged);
    }

    private sealed record ZipDownloadResult(bool Success, string? Error);

    // ── Callbacks ────────────────────────────────────────────────

    private async Task OnUploadComplete()
    {
        await RefreshAsync();
    }

    private async Task OnAssetsChanged()
    {
        await LoadAllCollections();
    }

    private async Task SearchAsync()
    {
        await RefreshAsync();
    }

    // ── Bulk Collection Selection (admin only) ───────────────────

    private void EnterSelectionMode() => _selectionMode = true;

    private void ExitSelectionMode()
    {
        _selectionMode = false;
        _selectedCollectionIds.Clear();
    }

    private void ToggleSelectAllCollections()
    {
        if (_allCollectionsSelected)
            _selectedCollectionIds.Clear();
        else if (_allCollections != null)
            _selectedCollectionIds = new HashSet<Guid>(_allCollections.Select(c => c.Id));
    }

    private async Task OpenBulkActionsAsync()
    {
        var selected = (_allCollections ?? new())
            .Where(c => _selectedCollectionIds.Contains(c.Id))
            .ToList();

        if (selected.Count == 0) return;

        var parameters = new DialogParameters<BulkCollectionActionsDialog>
        {
            { x => x.SelectedCollections, selected }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<BulkCollectionActionsDialog>(
            CollectionLoc["BulkActions"], parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            _selectionMode = false;
            _selectedCollectionIds.Clear();
            await LoadAllCollections();
        }
    }

    // ── Asset Bulk Selection ─────────────────────────────────────

    private bool _allGridAssetsSelected => _assetGrid != null
        && _assetGrid.GetAllAssetIds() is var ids && ids.Count > 0
        && ids.All(id => _selectedAssetIds.Contains(id));

    private void EnterAssetSelectionMode()
    {
        _assetSelectionMode = true;
        _selectedAssetIds.Clear();
    }

    private void ExitAssetSelectionMode()
    {
        _assetSelectionMode = false;
        _selectedAssetIds.Clear();
    }

    private async Task ToggleSelectAllGridAssets()
    {
        if (_assetGrid == null) return;
        var allIds = _assetGrid.GetAllAssetIds();
        if (_allGridAssetsSelected)
            _selectedAssetIds.Clear();
        else
            _selectedAssetIds = new HashSet<Guid>(allIds);
        await OnAssetSelectionChanged(_selectedAssetIds);
    }

    private Task OnAssetSelectionChanged(HashSet<Guid> ids)
    {
        _selectedAssetIds = ids;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OpenBulkAssetActionsAsync()
    {
        if (_selectedAssetIds.Count == 0 || _assetGrid == null) return;

        var selectedAssets = _assetGrid.GetSelectedAssets();
        if (selectedAssets.Count == 0) return;

        var parameters = new DialogParameters<BulkAssetActionsDialog>
        {
            { x => x.SelectedAssets, selectedAssets },
            { x => x.CollectionId, _selectedCollectionId }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<BulkAssetActionsDialog>(
            AssetLoc["BulkAssetActions"], parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            _assetSelectionMode = false;
            _selectedAssetIds.Clear();
            await _assetGrid.RefreshAsync();
            await OnAssetsChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= OnLocationChanged;
        _dotNetRef?.Dispose();
        if (_jsModule is not null)
        {
            try { await _jsModule.DisposeAsync(); }
            catch (JSDisconnectedException) { /* circuit gone — JS module is unreachable */ }
        }
    }
}
