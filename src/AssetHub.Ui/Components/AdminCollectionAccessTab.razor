@using AssetHub.Application.Helpers
@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject IDialogService DialogService
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AdminResource> AdminLoc

@if (_collectionsLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_collections == null || !_collections.Any())
{
    <EmptyState Title="@AdminLoc["NoCollectionsYet"]"
                Description="@AdminLoc["NoCollectionsDesc"]"
                Icon="@Icons.Material.Filled.Folder" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="5">
            <MudPaper Elevation="2" Class="pa-4 admin-collection-tree">
                <MudText Typo="Typo.subtitle1" Class="mb-2">@CommonLoc["Label_Collections"]</MudText>
                @foreach (var collection in _collections.OrderBy(c => c.Name, new NaturalSortComparer()))
                {
                    @RenderCollectionItem(collection)
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="7">
            <MudPaper Elevation="2" Class="pa-4">
                @if (_selectedCollection == null)
                {
                    <EmptyState Title="@AdminLoc["SelectACollection"]"
                                Description="@AdminLoc["SelectACollectionDesc"]"
                                Icon="@Icons.Material.Filled.FolderShared" />
                }
                else
                {
                    <MudText Typo="Typo.subtitle1" Class="mb-2">
                        @AdminLoc["AccessFor"] <strong>@_selectedCollection.Name</strong>
                    </MudText>

                    @* Brand assignment — null means inherit (use the default brand
                       when one is configured). Server-side AssignToCollectionAsync
                       upserts; UnassignFromCollectionAsync clears the FK. *@
                    <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Palette" Size="Size.Small" Color="Color.Default" />
                            <MudText Typo="Typo.body2" Style="min-width: 80px;">
                                @AdminLoc["Brand_Label"]
                            </MudText>
                            <MudSelect T="Guid?"
                                       Value="_selectedCollection.BrandId"
                                       ValueChanged="@OnBrandChangedAsync"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Dense="true"
                                       Class="dialog-flex-fill"
                                       Disabled="@(_brandsLoading || _changingBrand)">
                                <MudSelectItem T="Guid?" Value="@((Guid?)null)">
                                    @AdminLoc["Brand_None"]
                                </MudSelectItem>
                                @foreach (var b in _brands)
                                {
                                    <MudSelectItem T="Guid?" Value="@((Guid?)b.Id)">
                                        @b.Name@(b.IsDefault ? $" ({AdminLoc["Brand_Default_Suffix"].Value})" : "")
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudStack>
                    </MudPaper>

                    @* Add user form *@
                    <MudGrid Class="mb-4">
                        <MudItem xs="12" sm="5">
                            <MudAutocomplete T="UserSearchResultDto"
                                             @bind-Value="_newAclUser"
                                             SearchFunc="SearchUsersForAcl"
                                             ToStringFunc="@(u => u?.Username ?? "")"
                                             Label="@AdminLoc["SearchUsersPlaceholder"]"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             ResetValueOnEmptyText="true"
                                             DebounceInterval="200"
                                             MinCharacters="0"
                                             MaxItems="20">
                                <ItemTemplate Context="user">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2">@user.Username</MudText>
                                        @if (!string.IsNullOrEmpty(user.Email))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@user.Email</MudText>
                                        }
                                    </MudStack>
                                </ItemTemplate>
                            </MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudSelect @bind-Value="_newAclRole" Label="@CommonLoc["Label_Role"]"
                                Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@RoleHierarchy.Roles.Viewer">@CommonLoc["Role_Viewer"]</MudSelectItem>
                                <MudSelectItem Value="@RoleHierarchy.Roles.Contributor">@CommonLoc["Role_Contributor"]</MudSelectItem>
                                <MudSelectItem Value="@RoleHierarchy.Roles.Manager">@CommonLoc["Role_Manager"]</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                OnClick="AddCollectionAccess" Disabled="@(_newAclUser == null)"
                                FullWidth="true" Class="mt-1">
                                @CommonLoc["Btn_Add"]
                            </MudButton>
                        </MudItem>
                    </MudGrid>

                    @* Current ACLs *@
                    @if (!_selectedCollection.Acls.Any())
                    {
                        <EmptyState Title="@AdminLoc["NoUsersHaveAccess"]"
                                    Description="@AdminLoc["NoUsersHaveAccessDesc"]"
                                    Icon="@Icons.Material.Filled.PersonAdd" />
                    }
                    else
                    {
                        <MudTable Items="@_selectedCollection.Acls" Dense="true" Hover="true" Striped="true" Elevation="0">
                            <HeaderContent>
                                <MudTh><MudTableSortLabel SortBy="@((CollectionAclResponseDto acl) => acl.PrincipalName ?? "")">@CommonLoc["Label_User"]</MudTableSortLabel></MudTh>
                                <MudTh><MudTableSortLabel SortBy="@((CollectionAclResponseDto acl) => acl.Role)">@CommonLoc["Label_Role"]</MudTableSortLabel></MudTh>
                                <MudTh>@CommonLoc["Label_Actions"]</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="acl">
                                <MudTd DataLabel="@CommonLoc["Label_User"]">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2">@acl.PrincipalName</MudText>
                                        @if (!string.IsNullOrEmpty(acl.PrincipalEmail))
                                        {
                                            <MudText Typo="Typo.caption" Class="text-secondary">@acl.PrincipalEmail</MudText>
                                        }
                                    </MudStack>
                                </MudTd>
                                <MudTd DataLabel="@CommonLoc["Label_Role"]">
                                    @if (_editingAclId == acl.Id)
                                    {
                                        <MudSelect T="string" @bind-Value="_editingRole"
                                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   Dense="true" Class="dialog-role-select">
                                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Viewer">@CommonLoc["Role_Viewer"]</MudSelectItem>
                                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Contributor">@CommonLoc["Role_Contributor"]</MudSelectItem>
                                            <MudSelectItem T="string" Value="@RoleHierarchy.Roles.Manager">@CommonLoc["Role_Manager"]</MudSelectItem>
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="@AssetDisplayHelpers.GetRoleColor(acl.Role)">
                                            @CommonLoc[AssetDisplayHelpers.GetRoleKey(acl.Role)]
                                        </MudChip>
                                    }
                                </MudTd>
                                <MudTd DataLabel="@CommonLoc["Label_Actions"]">
                                    @if (acl.IsSystemAdmin)
                                    {
                                        <MudTooltip Text="@AdminLoc["AdminImplicitAccess"]">
                                            <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings"
                                                     Size="Size.Small" Color="Color.Default" />
                                        </MudTooltip>
                                    }
                                    else if (_editingAclId == acl.Id)
                                    {
                                        <MudStack Row="true" Spacing="1">
                                            <MudTooltip Text="@CommonLoc["Btn_Save"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Success"
                                                    Size="Size.Small" OnClick="@(() => SaveRoleEditAsync(acl))" />
                                            </MudTooltip>
                                            <MudTooltip Text="@CommonLoc["Btn_Cancel"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Default"
                                                    Size="Size.Small" OnClick="CancelRoleEdit" />
                                            </MudTooltip>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudStack Row="true" Spacing="1">
                                            <MudTooltip Text="@CommonLoc["Btn_Edit"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                                    Size="Size.Small" OnClick="@(() => StartRoleEdit(acl))" />
                                            </MudTooltip>
                                            <MudTooltip Text="@CommonLoc["Btn_Remove"]">
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                    Size="Size.Small" OnClick="@(() => RemoveCollectionAccess(acl))" />
                                            </MudTooltip>
                                        </MudStack>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private List<CollectionAccessDto>? _collections;
    private bool _collectionsLoading = true;
    private CollectionAccessDto? _selectedCollection;
    private UserSearchResultDto? _newAclUser;
    private string _newAclRole = RoleHierarchy.Roles.Viewer;

    // Inline role-edit state. Mirrors the pattern in ManageAccessDialog +
    // ManageUserAccessDialog so admins don't have to remove + re-add a user
    // just to bump them from viewer to contributor.
    private Guid? _editingAclId;
    private string _editingRole = "";

    // Brand assignment state. The dropdown is per-collection (only meaningful
    // for the right-pane selection); the brand list itself is org-wide and
    // loaded once. _changingBrand prevents double-submission while the API
    // round-trip is in flight.
    private List<BrandResponseDto> _brands = new();
    private bool _brandsLoading = true;
    private bool _changingBrand;

    protected override async Task OnInitializedAsync()
    {
        await LoadCollectionsAsync();
        await LoadBrandsAsync();
    }

    private async Task LoadBrandsAsync()
    {
        try
        {
            _brandsLoading = true;
            _brands = await Api.GetBrandsAsync();
        }
        catch (Exception ex)
        {
            // Brand failures shouldn't break the rest of the tab — the admin
            // can still manage ACLs.
            Feedback.HandleError(ex, "load brands");
        }
        finally
        {
            _brandsLoading = false;
        }
    }

    private async Task OnBrandChangedAsync(Guid? newBrandId)
    {
        if (_selectedCollection is null || _changingBrand) return;
        if (_selectedCollection.BrandId == newBrandId) return; // no-op

        _changingBrand = true;
        try
        {
            if (newBrandId is { } brandId)
                await Api.AssignBrandToCollectionAsync(brandId, _selectedCollection.Id);
            else
                await Api.UnassignBrandFromCollectionAsync(_selectedCollection.Id);

            Feedback.ShowSuccess(AdminLoc["Brand_Updated_Success"].Value);
            await LoadCollectionsAsync();
            _selectedCollection = CollectionTreeHelper.FindById(_collections, _selectedCollection.Id);
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "assign brand to collection");
        }
        finally
        {
            _changingBrand = false;
            StateHasChanged();
        }
    }

    public async Task RefreshAsync()
    {
        await LoadCollectionsAsync();
        StateHasChanged();
    }

    private async Task LoadCollectionsAsync()
    {
        try
        {
            _collectionsLoading = true;
            var selectedId = _selectedCollection?.Id;
            _collections = await Api.GetCollectionAccessAsync();

            if (selectedId.HasValue)
                _selectedCollection = CollectionTreeHelper.FindById(_collections, selectedId.Value);
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load collections");
        }
        finally
        {
            _collectionsLoading = false;
        }
    }

    private RenderFragment RenderCollectionItem(CollectionAccessDto collection) => __builder =>
    {
        var isSelected = _selectedCollection?.Id == collection.Id;

        <MudButton Variant="@(isSelected ? Variant.Filled : Variant.Text)"
            Color="@(isSelected ? Color.Primary : Color.Default)"
            OnClick="@(() => SelectCollection(collection))"
            FullWidth="true"
            Class="justify-start mb-1 admin-tree-item">
            <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Class="mr-2" />
            @collection.Name
            <MudSpacer />
            <MudChip T="string" Size="Size.Small" Color="Color.Default">@collection.Acls.Count</MudChip>
        </MudButton>
    };

    private void SelectCollection(CollectionAccessDto collection)
    {
        _selectedCollection = collection;
        _newAclUser = null;
        _newAclRole = RoleHierarchy.Roles.Viewer;
    }

    private async Task<IEnumerable<UserSearchResultDto>> SearchUsersForAcl(string? value, CancellationToken ct)
    {
        if (_selectedCollection == null)
            return Enumerable.Empty<UserSearchResultDto>();

        try
        {
            return await Api.SearchUsersForAclAsync(_selectedCollection.Id, value ?? string.Empty, ct);
        }
        catch
        {
            return Enumerable.Empty<UserSearchResultDto>();
        }
    }

    private async Task AddCollectionAccess()
    {
        if (_selectedCollection == null || _newAclUser == null)
            return;

        var userId = _newAclUser.Id;
        var username = _newAclUser.Username;

        try
        {
            await Api.AddCollectionAclAsync(_selectedCollection.Id, Constants.PrincipalTypes.User, userId, _newAclRole);
            Feedback.ShowSuccess(string.Format(CommonLoc["Success_AccessGranted"], username));
            _newAclUser = null;
            await LoadCollectionsAsync();
            _selectedCollection = CollectionTreeHelper.FindById(_collections, _selectedCollection.Id);
        }
        catch (Exception ex)
        {
            if (ex.Message.Contains("not found", StringComparison.OrdinalIgnoreCase))
                Feedback.ShowWarning(string.Format(CommonLoc["Warning_UserNotFound"], username));
            else
                Feedback.HandleError(ex, "add access");
        }
    }

    private void StartRoleEdit(CollectionAclResponseDto acl)
    {
        _editingAclId = acl.Id;
        _editingRole = acl.Role;
    }

    private void CancelRoleEdit()
    {
        _editingAclId = null;
        _editingRole = "";
    }

    private async Task SaveRoleEditAsync(CollectionAclResponseDto acl)
    {
        if (_selectedCollection == null || _editingAclId != acl.Id) return;

        // AdminSetAccessAsync is upsert — same call as Add. The server replaces
        // the role atomically; no need to remove + re-add.
        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.AddCollectionAclAsync(_selectedCollection.Id, acl.PrincipalType, acl.PrincipalId, _editingRole),
            "update role",
            string.Format(AdminLoc["RoleUpdatedSuccess"], acl.PrincipalName ?? acl.PrincipalId));

        if (success)
        {
            _editingAclId = null;
            _editingRole = "";
            await LoadCollectionsAsync();
            _selectedCollection = CollectionTreeHelper.FindById(_collections, _selectedCollection.Id);
        }
    }

    private async Task RemoveCollectionAccess(CollectionAclResponseDto acl)
    {
        if (_selectedCollection == null)
            return;

        var confirmed = await DialogService.ShowConfirmAsync(
            CommonLoc["Confirm_RemoveAccess"],
            string.Format(AdminLoc["ConfirmRemoveAccess"], acl.PrincipalName ?? acl.PrincipalId, _selectedCollection.Name),
            CommonLoc["Btn_Remove"],
            Icons.Material.Filled.RemoveCircle,
            Color.Warning,
            Color.Error);

        if (!confirmed)
            return;

        var success = await Feedback.ExecuteWithFeedbackAsync(
            () => Api.RemoveCollectionAclAsync(_selectedCollection.Id, acl.PrincipalId, acl.PrincipalType),
            "remove access",
            string.Format(CommonLoc["Success_AccessRemoved"], acl.PrincipalName ?? acl.PrincipalId));

        if (success)
        {
            await LoadCollectionsAsync();
            _selectedCollection = CollectionTreeHelper.FindById(_collections, _selectedCollection.Id);
        }
    }
}
