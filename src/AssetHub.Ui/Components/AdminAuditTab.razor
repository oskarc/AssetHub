@using AssetHub.Application
@inject AssetHubApiClient Api
@inject IUserFeedbackService Feedback
@inject LocalStorageService LocalStorage
@inject IStringLocalizer<CommonResource> CommonLoc
@inject IStringLocalizer<AdminResource> AdminLoc

@if (_auditLoading && _auditEvents == null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_auditEvents == null || (!_auditEvents.Any() && !_hasMore))
{
    <EmptyState Title="@AdminLoc["NoAuditEventsYet"]"
                Description="@AdminLoc["NoAuditEventsDesc"]"
                Icon="@Icons.Material.Filled.History" />
}
else
{
    <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-3 rounded">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">@AdminLoc["Header_TargetType"]</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    <MudChip T="string" Color="@(_showCollections ? Color.Tertiary : Color.Default)" Size="Size.Small" OnClick="ToggleCollections" Style="cursor: pointer;">@CommonLoc["ScopeType_Collection"]: @_auditEvents.Count(e => string.Equals(e.TargetType, Constants.ScopeTypes.Collection, StringComparison.OrdinalIgnoreCase))</MudChip>
                    <MudChip T="string" Color="@(_showAssets ? Color.Info : Color.Default)" Size="Size.Small" OnClick="ToggleAssets" Style="cursor: pointer;">@CommonLoc["ScopeType_Asset"]: @_auditEvents.Count(e => string.Equals(e.TargetType, Constants.ScopeTypes.Asset, StringComparison.OrdinalIgnoreCase))</MudChip>
                    <MudChip T="string" Color="@(_showShares ? Color.Primary : Color.Default)" Size="Size.Small" OnClick="ToggleShares" Style="cursor: pointer;">@CommonLoc["ScopeType_Share"]: @_auditEvents.Count(e => string.Equals(e.TargetType, Constants.ScopeTypes.Share, StringComparison.OrdinalIgnoreCase))</MudChip>
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">@AdminLoc["Header_EventType"]</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    <MudChip T="string" Color="@(_showCreate ? Color.Success : Color.Default)" Size="Size.Small" OnClick="ToggleCreate" Style="cursor: pointer;">@AdminLoc["AuditAction_Create"]: @_auditEvents.Count(e => GetActionCategory(e.EventType) == "create")</MudChip>
                    <MudChip T="string" Color="@(_showUpdate ? Color.Warning : Color.Default)" Size="Size.Small" OnClick="ToggleUpdate" Style="cursor: pointer;">@AdminLoc["AuditAction_Update"]: @_auditEvents.Count(e => GetActionCategory(e.EventType) == "update")</MudChip>
                    <MudChip T="string" Color="@(_showDelete ? Color.Error : Color.Default)" Size="Size.Small" OnClick="ToggleDelete" Style="cursor: pointer;">@AdminLoc["AuditAction_Delete"]: @_auditEvents.Count(e => GetActionCategory(e.EventType) == "delete")</MudChip>
                    <MudChip T="string" Color="@(_showDownload ? Color.Info : Color.Default)" Size="Size.Small" OnClick="ToggleDownload" Style="cursor: pointer;">@AdminLoc["AuditAction_Download"]: @_auditEvents.Count(e => GetActionCategory(e.EventType) == "download")</MudChip>
                    <MudChip T="string" Color="@(_showAccessGranted ? Color.Secondary : Color.Default)" Size="Size.Small" OnClick="ToggleAccessGranted" Style="cursor: pointer;">@AdminLoc["AuditAction_AccessGranted"]: @_auditEvents.Count(e => GetActionCategory(e.EventType) == "access")</MudChip>
                    <MudChip T="string" Color="@(_showSecurity ? Color.Error : Color.Default)" Size="Size.Small" OnClick="ToggleSecurity" Style="cursor: pointer;">@AdminLoc["AuditAction_Security"]: @_auditEvents.Count(e => GetActionCategory(e.EventType) == "security")</MudChip>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable Items="@_auditEvents" Hover="true" Dense="true" Striped="true"
              Filter="new Func<AuditEventDto, bool>(AuditFilter)" SortLabel="@CommonLoc["Label_SortBy"]"
              FixedHeader="true" Height="550px" Loading="@_auditLoading">
        <NoRecordsContent>
            <EmptyState Title="@AdminLoc["NoMatchingAuditEvents"]"
                        Description="@AdminLoc["NoMatchingAuditEventsDesc"]"
                        Icon="@Icons.Material.Filled.SearchOff" />
        </NoRecordsContent>
        <ToolBarContent>
            <MudTextField @bind-Value="_searchString" Placeholder="@AdminLoc["SearchAuditPlaceholder"]"
                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                IconSize="Size.Medium" Class="mt-0" Immediate="true" DebounceInterval="500" />
            <MudSpacer />
            <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">@AdminLoc["Total"]: @_totalCount</MudChip>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="new Func<AuditEventDto, object>(x => x.CreatedAt)">@AdminLoc["Header_Timestamp"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AuditEventDto, object>(x => x.EventType)">@AdminLoc["Header_EventType"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="@(new Func<AuditEventDto, object>(x => x.ActorUserName ?? string.Empty))">@AdminLoc["Header_Actor"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AuditEventDto, object>(x => x.TargetType)">@AdminLoc["Header_TargetType"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AuditEventDto, object>(x => x.TargetName ?? string.Empty)">@AdminLoc["Header_TargetName"]</MudTableSortLabel></MudTh>
            <MudTh>@AdminLoc["Header_Details"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@AdminLoc["Header_Timestamp"]">
                <MudTooltip Text="@context.CreatedAt.ToLocalTime().ToString("F")">
                    <MudText Typo="Typo.body2">@context.CreatedAt.ToLocalTime().ToString("g")</MudText>
                </MudTooltip>
            </MudTd>
            <MudTd DataLabel="@AdminLoc["Header_EventType"]">
                <MudTooltip Text="@context.EventType">
                    <MudChip T="string" Size="Size.Small" Color="@GetEventColor(context.EventType)" Variant="Variant.Outlined">
                        @GetLocalizedEventType(context.EventType)
                    </MudChip>
                </MudTooltip>
            </MudTd>
            <MudTd DataLabel="@AdminLoc["Header_Actor"]">@(context.ActorUserName ?? context.ActorUserId ?? "—")</MudTd>
            <MudTd DataLabel="@AdminLoc["Header_TargetType"]">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@GetLocalizedTargetType(context.TargetType)</MudChip>
            </MudTd>
            <MudTd DataLabel="@AdminLoc["Header_TargetName"]">
                @if (!string.IsNullOrEmpty(context.TargetName))
                {
                    <MudTooltip Text="@context.TargetId?.ToString()">
                        <MudText Typo="Typo.body2" Class="text-truncate-180">
                            @context.TargetName
                        </MudText>
                    </MudTooltip>
                }
                else if (context.TargetId.HasValue)
                {
                    <MudTooltip Text="@context.TargetId.Value.ToString()">
                        <MudText Typo="Typo.body2" Class="text-truncate-120" Color="Color.Secondary">
                            @(context.TargetId.Value.ToString()[..8])...
                        </MudText>
                    </MudTooltip>
                }
                else
                {
                    <MudText Typo="Typo.body2">—</MudText>
                }
            </MudTd>
            <MudTd DataLabel="@AdminLoc["Header_Details"]">
                @if (context.Details != null && context.Details.Any())
                {
                    <MudTooltip>
                        <ChildContent>
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Info" />
                        </ChildContent>
                        <TooltipContent>
                            <div style="max-width: 400px;">
                                @foreach (var kvp in context.Details)
                                {
                                    <div style="padding: 2px 0;">
                                        <span style="opacity: 0.7;">@GetLocalizedDetailKey(kvp.Key):</span>
                                        <span style="margin-left: 4px;">@FormatDetailValue(kvp.Key, kvp.Value)</span>
                                    </div>
                                }
                            </div>
                        </TooltipContent>
                    </MudTooltip>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>

    @* Cursor-based pagination controls *@
    <MudPaper Elevation="0" Class="d-flex justify-center align-center pa-3 gap-3">
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @CommonLoc["Showing"] @_auditEvents.Count @CommonLoc["OfTotal"] @_totalCount
        </MudText>
        @if (_hasMore)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                OnClick="LoadMoreAsync" Disabled="@_auditLoading">
                @if (_auditLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @AdminLoc["LoadMore"]
            </MudButton>
        }
    </MudPaper>
}

@code {
    private List<AuditEventDto>? _auditEvents;
    private bool _auditLoading = true;
    private string _searchString = "";
    private DateTime? _nextCursor;
    private bool _hasMore;
    private int _totalCount;

    private bool _showCollections = true;
    private bool _showAssets = true;
    private bool _showShares = true;
    private bool _showCreate = true;
    private bool _showUpdate = true;
    private bool _showDelete = true;
    private bool _showDownload = true;
    private bool _showAccessGranted = true;
    private bool _showSecurity = true;

    private const string StorageKeyShowCollections = "auditLog_showCollections";
    private const string StorageKeyShowAssets = "auditLog_showAssets";
    private const string StorageKeyShowShares = "auditLog_showShares";
    private const string StorageKeyShowCreate = "auditLog_showCreate";
    private const string StorageKeyShowUpdate = "auditLog_showUpdate";
    private const string StorageKeyShowDelete = "auditLog_showDelete";
    private const string StorageKeyShowDownload = "auditLog_showDownload";
    private const string StorageKeyShowAccessGranted = "auditLog_showAccessGranted";
    private const string StorageKeyShowSecurity = "auditLog_showSecurity";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(reset: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _showCollections = await LocalStorage.GetBoolAsync(StorageKeyShowCollections, true);
            _showAssets = await LocalStorage.GetBoolAsync(StorageKeyShowAssets, true);
            _showShares = await LocalStorage.GetBoolAsync(StorageKeyShowShares, true);
            _showCreate = await LocalStorage.GetBoolAsync(StorageKeyShowCreate, true);
            _showUpdate = await LocalStorage.GetBoolAsync(StorageKeyShowUpdate, true);
            _showDelete = await LocalStorage.GetBoolAsync(StorageKeyShowDelete, true);
            _showDownload = await LocalStorage.GetBoolAsync(StorageKeyShowDownload, true);
            _showAccessGranted = await LocalStorage.GetBoolAsync(StorageKeyShowAccessGranted, true);
            _showSecurity = await LocalStorage.GetBoolAsync(StorageKeyShowSecurity, true);
            StateHasChanged();
        }
    }

    private async Task LoadAsync(bool reset = false)
    {
        try
        {
            _auditLoading = true;

            if (reset)
            {
                _auditEvents = null;
                _nextCursor = null;
            }

            var response = await Api.GetAuditEventsPaginatedAsync(
                pageSize: 50,
                cursor: _nextCursor);

            if (reset || _auditEvents == null)
            {
                _auditEvents = response.Items;
            }
            else
            {
                _auditEvents.AddRange(response.Items);
            }

            _nextCursor = response.NextCursor;
            _hasMore = response.HasMore;
            _totalCount = response.TotalCount;
        }
        catch (Exception ex)
        {
            Feedback.HandleError(ex, "load audit events");
        }
        finally
        {
            _auditLoading = false;
        }
    }

    private async Task LoadMoreAsync()
    {
        await LoadAsync(reset: false);
    }

    private bool AuditFilter(AuditEventDto evt)
    {
        // Target type filter
        var targetType = evt.TargetType.ToLowerInvariant();
        if (targetType == Constants.ScopeTypes.Collection && !_showCollections) return false;
        if (targetType == Constants.ScopeTypes.Asset && !_showAssets) return false;
        if (targetType == Constants.ScopeTypes.Share && !_showShares) return false;

        // Action type filter
        var action = GetActionCategory(evt.EventType);
        if (action == "create" && !_showCreate) return false;
        if (action == "update" && !_showUpdate) return false;
        if (action == "delete" && !_showDelete) return false;
        if (action == "download" && !_showDownload) return false;
        if (action == "access" && !_showAccessGranted) return false;
        if (action == "security" && !_showSecurity) return false;

        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        var localizedEventType = GetLocalizedEventType(evt.EventType);
        return evt.EventType.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || localizedEventType.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || evt.TargetType.Contains(_searchString, StringComparison.OrdinalIgnoreCase)
            || (evt.TargetName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            || (evt.ActorUserName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            || (evt.ActorUserId?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private static string GetActionCategory(string eventType)
    {
        var et = eventType.ToLowerInvariant();
        if (et.Contains("malware") || et.Contains("password_failed") || et.Contains("processing_failed")) return "security";
        if (et.Contains("download")) return "download";
        if (et.Contains("acl.set") || et.Contains("access_granted") || et.Contains("access_set")) return "access";
        if (et.Contains("created") || et.Contains("upload")) return "create";
        if (et.Contains("updated")) return "update";
        if (et.Contains("deleted") || et.Contains("removed") || et.Contains("revoked") || et.Contains("cleanup")) return "delete";
        return "other";
    }

    private async Task ToggleCollections()
    {
        _showCollections = !_showCollections;
        await LocalStorage.SetBoolAsync(StorageKeyShowCollections, _showCollections);
    }

    private async Task ToggleAssets()
    {
        _showAssets = !_showAssets;
        await LocalStorage.SetBoolAsync(StorageKeyShowAssets, _showAssets);
    }

    private async Task ToggleShares()
    {
        _showShares = !_showShares;
        await LocalStorage.SetBoolAsync(StorageKeyShowShares, _showShares);
    }

    private async Task ToggleCreate()
    {
        _showCreate = !_showCreate;
        await LocalStorage.SetBoolAsync(StorageKeyShowCreate, _showCreate);
    }

    private async Task ToggleUpdate()
    {
        _showUpdate = !_showUpdate;
        await LocalStorage.SetBoolAsync(StorageKeyShowUpdate, _showUpdate);
    }

    private async Task ToggleDelete()
    {
        _showDelete = !_showDelete;
        await LocalStorage.SetBoolAsync(StorageKeyShowDelete, _showDelete);
    }

    private async Task ToggleDownload()
    {
        _showDownload = !_showDownload;
        await LocalStorage.SetBoolAsync(StorageKeyShowDownload, _showDownload);
    }

    private async Task ToggleAccessGranted()
    {
        _showAccessGranted = !_showAccessGranted;
        await LocalStorage.SetBoolAsync(StorageKeyShowAccessGranted, _showAccessGranted);
    }

    private async Task ToggleSecurity()
    {
        _showSecurity = !_showSecurity;
        await LocalStorage.SetBoolAsync(StorageKeyShowSecurity, _showSecurity);
    }

    private static Color GetEventColor(string eventType) =>
        AssetDisplayHelpers.GetAuditEventColor(eventType);

    private string GetLocalizedEventType(string eventType)
    {
        var key = $"Event_{eventType}";
        var localized = AdminLoc[key];
        return localized.ResourceNotFound ? eventType : localized.Value;
    }

    private string GetLocalizedTargetType(string targetType) =>
        AssetDisplayHelpers.GetLocalizedScopeType(targetType, CommonLoc);

    private string GetLocalizedDetailKey(string key)
    {
        var locKey = $"Detail_{key}";
        var localized = AdminLoc[locKey];
        return localized.ResourceNotFound ? FormatCamelCase(key) : localized.Value;
    }

    private string FormatDetailValue(string key, object value)
    {
        var str = value?.ToString() ?? "";
        if (str is "True" or "true") return CommonLoc["Text_Yes"].Value;
        if (str is "False" or "false") return CommonLoc["Text_No"].Value;
        return str;
    }

    private static string FormatCamelCase(string input)
    {
        if (string.IsNullOrEmpty(input)) return input;
        var result = new System.Text.StringBuilder();
        result.Append(char.ToUpper(input[0]));
        for (var i = 1; i < input.Length; i++)
        {
            if (char.IsUpper(input[i]))
                result.Append(' ');
            result.Append(input[i]);
        }
        return result.ToString();
    }
}
