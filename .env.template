# ============================================================================
# AssetHub — Production Environment Variables
# ============================================================================
# Copy this file to .env and fill in all REPLACE_ME values before starting.
#
#   cp .env.template .env
#   $EDITOR .env
#   docker compose -f docker-compose.prod.yml up -d
#
# IMPORTANT: Never commit the .env file to version control.
# ============================================================================

# --- General -----------------------------------------------------------------

# Timezone for all containers (affects log timestamps, scheduled jobs)
TZ=Europe/Stockholm

# Public URL where users access the application (no trailing slash).
# Used for share links, OIDC redirect URIs, CORS, and presigned URL generation.
APP_BASE_URL=https://assethub.example.com

# Hostname for AllowedHosts validation (defense-in-depth against host header attacks).
# Should match your domain without protocol/port (e.g., "assethub.example.com").
APP_HOSTNAME=assethub.example.com

# --- PostgreSQL --------------------------------------------------------------

# The app database name. Keycloak uses a separate 'keycloak' database on the
# same PostgreSQL instance (created automatically by docker/init-keycloak-db.sh).
POSTGRES_DB=assethub
POSTGRES_USER=assethub
POSTGRES_PASSWORD=REPLACE_ME

# --- Keycloak ----------------------------------------------------------------

# Master realm admin account (used only for initial setup, can be rotated later).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=REPLACE_ME

# Keycloak database credentials (separate from app database for isolation).
# The keycloak user is created automatically by init-keycloak-db.sh.
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=REPLACE_ME

# Public hostname where Keycloak is reachable by browsers.
# Tokens will contain this issuer URL; it MUST match what the app validates.
KEYCLOAK_HOSTNAME=keycloak.example.com

# OIDC client credentials (created during Keycloak setup — see DEPLOYMENT.md).
KEYCLOAK_CLIENT_ID=assethub-app
KEYCLOAK_CLIENT_SECRET=REPLACE_ME

# Keycloak admin API credentials — service account or admin user that can
# manage users in the "media" realm (used by the Create User feature).
# Option A (recommended): Use client_credentials grant with a service account client
KEYCLOAK_ADMIN_CLIENT_ID=assethub-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=REPLACE_ME
# Option B (fallback): Use password grant with an admin user (requires ADMIN_CLIENT_SECRET to be empty)
KEYCLOAK_ADMIN_API_USERNAME=svc-assethub
KEYCLOAK_ADMIN_API_PASSWORD=REPLACE_ME

# Passwords for users created during realm import (media-realm.json).
# Set these before first Keycloak startup; they configure the default users.
KEYCLOAK_TESTUSER_PASSWORD=REPLACE_ME
KEYCLOAK_ADMIN_USER_PASSWORD=REPLACE_ME

# --- MinIO (S3-compatible object storage) ------------------------------------

MINIO_ROOT_USER=REPLACE_ME
MINIO_ROOT_PASSWORD=REPLACE_ME

# Application-level access key (create via MinIO Console or mc admin).
MINIO_ACCESS_KEY=REPLACE_ME
MINIO_SECRET_KEY=REPLACE_ME
MINIO_BUCKET_NAME=assethub

# Public URL for presigned download URLs that browsers use directly.
# If MinIO is behind your reverse proxy, set this to its public hostname.
# If not exposed publicly, leave blank — the app will proxy downloads instead.
MINIO_PUBLIC_URL=
MINIO_PUBLIC_USE_SSL=true

# --- Email (optional — enables share-link email notifications) ---------------

EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=REPLACE_ME
EMAIL_SMTP_PASSWORD=REPLACE_ME
EMAIL_USE_SSL=true
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=AssetHub

# --- Application Tuning (optional — sensible defaults provided) --------------

# Max file upload size in megabytes (presigned path bypasses this; applies to
# the fallback IFormFile path only).
APP_MAX_UPLOAD_SIZE_MB=500

# Default page size for paginated API responses.
APP_DEFAULT_PAGE_SIZE=50

# --- Image / Video Processing (optional) ------------------------------------

# Thumbnail dimensions (px). Aspect ratio is preserved; image fits within box.
IMAGE_THUMBNAIL_WIDTH=200
IMAGE_THUMBNAIL_HEIGHT=200

# Medium rendition dimensions (px).
IMAGE_MEDIUM_WIDTH=800
IMAGE_MEDIUM_HEIGHT=800

# JPEG quality for generated renditions (1-100).
IMAGE_JPEG_QUALITY=85

# Poster frame: seconds into video to capture, width, and quality.
VIDEO_POSTER_FRAME_SECONDS=5
VIDEO_POSTER_WIDTH=800
VIDEO_POSTER_QUALITY=5

# --- ClamAV (Malware Scanning) -----------------------------------------------

# Enable/disable malware scanning on file uploads.
# When enabled, requires the clamav container to be running.
CLAMAV_ENABLED=true
